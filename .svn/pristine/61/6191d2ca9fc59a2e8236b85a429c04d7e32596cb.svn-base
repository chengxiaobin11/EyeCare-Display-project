 293          void SysSourceHandler(void)
 294          {
 295   1          SysSourceCableDetection();
 296   1      
 297   1      #if(_URGENT_EVENT_CHECK_MODE == _ON)
 298   1          if((ScalerSyncCheckUrgentEvent() == _TRUE) &&
 299   1             (GET_POWER_STATUS() == _POWER_STATUS_NORMAL))
 300   1          {
 301   2      #if(_DP_LINK_INTERVAL_CHECK_SUPPORT == _ON)
                      if(ScalerSyncGetUrgentDpRxLinkLossInfo() == _FALSE)
                      {
                          return;
                      }
              #endif
 307   2          }
 308   1      #endif
 309   1      
 310   1          if((GET_MODE_STATE() != _MODE_STATUS_POWER_OFF) &&
 311   1             (GET_MODE_STATE() != _MODE_STATUS_INITIAL) &&
 312   1             (UserInterfaceGetForcePSStatus() == _FALSE) &&
 313   1             (UserInterfaceSourceBypassDetection() == _SOURCE_DETECTION_NORMAL))
 314   1          {
 315   2              if(GET_SOURCE_JUDGE(g_ucSearchIndex) == _FALSE)
 316   2              {
 317   3                  if(GET_SOURCE_DETECTING() == _FALSE)
 318   3                  {
 319   4                      SysSourceSwitchPort();
 320   4                  }
 321   3      
 322   3                  if(GET_SOURCE_SEARCH_PORT_INITIAL() == _TRUE)
 323   3                  {
 324   4                      SysSourceScanPortInitial(g_ucSearchIndex);
 325   4      
 326   4                      CLR_SOURCE_SEARCH_PORT_INITIAL();
 327   4                  }
 328   3      
 329   3                  if(GET_SOURCE_SEARCH_TIME_INITIAL() == _TRUE)
 330   3                  {
 331   4                      SysSourceSearchTimeInitial(g_ucSearchIndex);
 332   4      
 333   4                      CLR_SOURCE_SEARCH_TIME_INITIAL();
 334   4                  }
 335   3      
 336   3                  // Port Detection
 337   3                  SysSourceDetectPort(g_ucSearchIndex);
 338   3      
 339   3                  // Decide if this port is about to be chosen
 340   3                  SysSourceJudge();
 341   3              }
 342   2      
 343   2      #if(_SOURCE_BACKGROUND_DETECT_SUPPORT == _ON)
                      else if(SysSourceBgJudgeDoDetect() == _TRUE)
                      {
                          if(GET_SOURCE_DETECTING() == _FALSE)
                          {
                              SysSourceBgSwitchPort();
                          }
              
                          if(GET_SOURCE_SEARCH_PORT_INITIAL() == _TRUE)
                          {
                              SysSourceScanPortInitial(g_ucBgDetectIndex);
              
C51 COMPILER V9.01   SYSSOURCE                                                             05/24/2025 15:50:57 PAGE 7   

                              CLR_SOURCE_SEARCH_PORT_INITIAL();
                          }
              
                          if(GET_SOURCE_SEARCH_TIME_INITIAL() == _TRUE)
                          {
                              SysSourceSearchTimeInitial(g_ucBgDetectIndex);
              
                              CLR_SOURCE_SEARCH_TIME_INITIAL();
                          }
                          // Change color array index to bg detect to prevent overwritting of sys color
                          ScalerColorSwitchColorInfoArray(_COLOR_INFO_BG_DETECT);
              
                          // Port Detect
                          SysSourceDetectPort(g_ucBgDetectIndex);
              
                          // Change Back after finishing bg detect
                          ScalerColorSwitchColorInfoArray(_COLOR_INFO_SYSTEM);
              
                          // Decide if this port is about to be chosen
                          SysSourceBgJudge();
                      }
                      else if(SysSourceBgJudgeDoStableCheck() == _TRUE)
                      {
                          if(SysSourceBgStableCheck() == _FALSE)
                          {
                              DebugMessageSystem("Background Source Unstable!!", GET_SOURCE_TYPE(g_ucBgDetectIndex));
              
                              SysSourceBgInfoReset();
                          }
                      }
              #endif
 386   2          }
 387   1      
 388   1          CLR_MODE_STATE_CHANGE_SOURCE();
 389   1      }
