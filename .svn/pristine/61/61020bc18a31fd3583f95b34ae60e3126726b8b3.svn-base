             -rt)
              {
                  EnumTypeCPinAssignmentESupportStatus enumPinAssignmentESupportStatus = _TYPE_C_PIN_ASSIGNMENT_E_SUPPOR
             -T_ON;
              
                  switch(ucInputPort)
                  {
              #if(_D0_DP_TYPE_C_CONNECTOR_SUPPORT == _ON)
                      case _D0_INPUT_PORT:
