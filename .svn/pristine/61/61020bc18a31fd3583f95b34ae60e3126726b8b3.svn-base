                          if(enumPowerRole == _TYPE_C_POWER_SRC)
                          {
                              // Default 2 EPR PDO : 28V@(PDP/28)A and 1 AVS PDO 15V~28V@(PDP/AVS Voltage)A
                              return _TYPE_C_PDO_NUM_2;
