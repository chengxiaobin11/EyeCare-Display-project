 158   4                      ScalerSetBit(P31_C1_D_DB_CTRL, ~0xFF, (_BIT7 | _BIT6));
 159   4                  }
 160   3              }
 161   2          }
 162   1          else if(GET_MEMORY_FRAME_BUFFER() == _MEMORY_1_5_FRAME_BUFFER)
 163   1          {
 164   2              // IVS/ DVS for M:N = 2:5 or 1:3 case
 165   2              ScalerSetBit(P31_C0_I_DB_CTRL, ~0x3F, 0x00);
 166   2              ScalerSetBit(P31_C1_D_DB_CTRL, ~0xFF, 0x00);
 167   2          }
 168   1          else
 169   1          {
 170   2              switch(GET_MEMORY_SELECT())
