 274          //--------------------------------------------------
 275          // Description  : Set I and D domain double buffer apply
 276          // Input Value  : DB path select, DB apply polling/ no polling/ none
 277          // Output Value : None
 278          //--------------------------------------------------
 279          void ScalerGlobalIDDomainDBApply(EnumDBApply enumDBApply)
 280          {
 281   1      #if(_FORCE_D_DOMAIN_DB_APPLY == _ON)
                  if(ScalerGlobalForceDDomainDBRecovery(enumDBApply, _TRUE) == _TRUE)
                  {
                      return;
                  }
              #endif
 287   1      
 288   1          // Check IMD Doube Buffer Enable
 289   1          if(ScalerGlobalGetDBStatus() == _ENABLE)
 290   1          {
 291   2              if(enumDBApply != _DB_APPLY_NONE)
 292   2              {
 293   3                  // Check I/D domain status
 294   3                  if((ScalerGetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, _BIT0) == 0x00) ||
C51 COMPILER V9.60.0.0   RL6432_SERIES_GLOBAL                                              08/27/2025 11:01:32 PAGE 6   

 295   3                     (GET_DPLL_POWER_STATUS() == _FALSE) ||
 296   3                     (ScalerGetBit(P0_10_M1_VGIP_CTRL, _BIT0) == 0x00))
 297   3                  {
 298   4                      // Disable Double Buffer
 299   4                      ScalerSetBit(P31_C0_I_DB_CTRL, ~_BIT7, 0x00);
 300   4                      return;
 301   4                  }
 302   3      
 303   3      #if(_FREESYNC_SUPPORT == _ON)
 304   3                  if((GET_FREESYNC_ENABLED() == _TRUE) && ((GET_MEMORY_SELECT() == _FRAME_SYNC_LINE_BUFFER) || (
             -GET_MEMORY_SELECT() == _FRAME_SYNC_MEMORY)))
 305   3                  {
 306   4                      if(ScalerGetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, _BIT5) == 0x00)
 307   4                      {
 308   5                          // IDEN stop/ DDEN stop
 309   5                          ScalerSetBit(P31_C0_I_DB_CTRL, ~0x3F, (_BIT5 | _BIT4));
 310   5                          ScalerSetBit(P31_C1_D_DB_CTRL, ~0xFF, 0x00);
 311   5                      }
 312   4                      else
 313   4                      {
 314   5                          // IVS/ DDEN stop
 315   5                          ScalerSetBit(P31_C0_I_DB_CTRL, ~0x3F, (_BIT4));
 316   5                          ScalerSetBit(P31_C1_D_DB_CTRL, ~0xFF, 0x00);
 317   5                      }
 318   4                  }
 319   3      #endif
 320   3      
 321   3                  // Set IMD apply bit
 322   3                  ScalerSetBit(P31_C0_I_DB_CTRL, ~_BIT6, _BIT6);
 323   3      
 324   3                  if(enumDBApply == _DB_APPLY_POLLING)
 325   3                  {
 326   4                      // Wait IMD double buffer
 327   4                      if(ScalerTimerPollingFlagProc(_DOUBLE_BUFFER_WAIT_TIME, P31_C0_I_DB_CTRL, _BIT6, 0) == _FA
             -LSE)
 328   4                      {
 329   5                          // Disable Double Buffer
 330   5                          ScalerSetBit(P31_C0_I_DB_CTRL, ~_BIT7, 0x00);
 331   5                      }
 332   4                  }
 333   3              }
 334   2          }
 335   1          else
 336   1          {
 337   2              if(enumDBApply != _DB_APPLY_NONE)
 338   2              {
 339   3                  // I-domain double buffer apply
 340   3                  ScalerVgipVgipDoubleBufferApply(enumDBApply);
 341   3      
 342   3                  // Display timing gen double buffer apply
 343   3                  ScalerMDomainDisplayTimingGenDBApply(enumDBApply);
 344   3              }
 345   2          }
 346   1      }
