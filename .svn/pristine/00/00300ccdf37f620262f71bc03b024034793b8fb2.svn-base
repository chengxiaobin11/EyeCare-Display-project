 426   3                  SET_GLOBAL_XTAL_CLK_SWITCH(_GLOBAL_XTAL_CLK_SEL_TO_EXTERNAL);
 427   3      
 428   3                  // Manual Trigger WD_Timer INT to Proc WDTimerProc_WDINT
