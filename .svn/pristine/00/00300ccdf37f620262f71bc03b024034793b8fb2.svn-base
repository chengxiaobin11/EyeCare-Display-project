 400   2              ScalerSetBit(P0_09_GA_POWER_CTRL, ~_BIT3, _BIT3);
 401   2      
 402   2      #if(_WD_TIMER_INT_SUPPORT == _ON)
 403   2              if((ucWDPreRefClk & _BIT3) == 0x00)
 404   2              {
 405   3                  // Record Global Xtal Clk Has been Switched, WD_Timer INT Ref Clk Change
 406   3                  SET_GLOBAL_XTAL_CLK_SWITCH(_GLOBAL_XTAL_CLK_SEL_TO_INTERNAL);
 407   3      
 408   3                  // Manual Trigger WD_Timer INT to Proc WDTimerProc_WDINT
 409   3                  EXIF = (EXIF & (~_BIT4)) | _BIT4;
 410   3              }
 411   2              else
 412   2              {
 413   3                  SET_GLOBAL_XTAL_CLK_SWITCH(_GLOBAL_XTAL_CLK_SEL_UNCHANGE);
 414   3              }
 415   2      #endif
 416   2          }
C51 COMPILER V9.60.0.0   RL6432_SERIES_GLOBAL                                              08/27/2025 11:01:32 PAGE 8   

 417   1          else if(enumClkSel == _EXT_XTAL_CLK)
