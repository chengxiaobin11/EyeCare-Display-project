 204   4                          ScalerSetBit(P31_C1_D_DB_CTRL, ~0xFF, 0x00);
 205   4                      }
 206   3      
 207   3                      break;
 208   3              }
 209   2          }
 210   1      #else
              
              #if(_FREESYNC_SUPPORT == _ON)
