  66          //--------------------------------------------------
  67          // Description  : Enable/Disable double buffer
  68          // Input Value  : bEn --> _ENABLE or _DISABLE
  69          // Output Value : None
  70          //--------------------------------------------------
  71          void ScalerGlobalDoubleBufferEnable(bit bEn)
  72          {
  73   1          if(GET_MEMORY_FRAME_BUFFER() == _MEMORY_1_5_FRAME_BUFFER)
  74   1          {
  75   2              // IMD Double Buffer Disable
  76   2              ScalerSetBit(P31_C0_I_DB_CTRL, ~(_BIT7 | _BIT6), 0x00);
  77   2      
  78   2              // I Domain Double Buffer Disable
  79   2              ScalerSetBit(P31_A0_I_DB_CTRL0, ~(_BIT7 | _BIT3), 0x00);
  80   2      
  81   2              // D Domain Double Buffer Disable
  82   2              ScalerSetBit(P31_B0_D_DB_CTRL0, ~(_BIT7 | _BIT6), 0x00);
  83   2      
  84   2              ScalerVgipDoubleBufferEnable(bEn);
  85   2              ScalerMDomainDisplayTimingGenDBEnable(bEn);
  86   2          }
  87   1          else
  88   1          {
  89   2              ScalerVgipDoubleBufferEnable(_DISABLE);
  90   2              ScalerMDomainDisplayTimingGenDBEnable(_DISABLE);
  91   2      
  92   2              if(bEn == _ENABLE)
  93   2              {
  94   3                  // IMD Double Buffer Enable
  95   3                  ScalerSetBit(P31_C0_I_DB_CTRL, ~(_BIT7 | _BIT6), _BIT7);
  96   3      
  97   3                  // I Domain Double Buffer Disable
  98   3                  ScalerSetBit(P31_A0_I_DB_CTRL0, ~(_BIT7 | _BIT3), 0x00);
  99   3      
 100   3                  // D Domain Double Buffer Disable
 101   3                  ScalerSetBit(P31_B0_D_DB_CTRL0, ~(_BIT7 | _BIT6), 0x00);
 102   3              }
 103   2              else
 104   2              {
 105   3                  ScalerSetBit(P31_C0_I_DB_CTRL, ~(_BIT7 | _BIT6), 0x00);
 106   3              }
 107   2          }
 108   1      }
