 439          //--------------------------------------------------
 440          // Description  : Enabel Global Watch Dog
 441          // Input Value  : _ENABLE or _DISABLE
 442          // Output Value : None
 443          //--------------------------------------------------
 444          void ScalerGlobalWatchDog(bit bEnable)
 445          {
 446   1          if(bEnable == _ENABLE)
 447   1          {
 448   2              if(GET_MEMORY_SELECT() == _FRAME_SYNC_LINE_BUFFER)
 449   2              {
 450   3      #if(_PANEL_FREESYNC_FREE_RUN_DVTOTAL_CALCULATED_BY_VFREQ_MIN == _ON)
 451   3      #if(_FREESYNC_SUPPORT == _ON)
 452   3                  if(GET_FREESYNC_ENABLED() == _FALSE)
 453   3      #endif
 454   3      #endif
 455   3                  {
 456   4                      // Set Free Run DVTotal = WD-Triggering DVTotal + 1 to Prevent DVTotal Too Long
 457   4                      ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_0B_DISPLAY_VER_TOTAL_H, 2,
             - pData, _AUTOINC);
 458   4                      PDATA_WORD(0) += 1;
 459   4      
 460   4                      SET_FREE_RUN_DVTOTAL(PDATA_WORD(0));
 461   4      
 462   4                      ScalerGlobalDDomainDBApply(_DB_APPLY_POLLING);
 463   4                  }
 464   3              }
 465   2      
 466   2              // Set Background Color to Black
 467   2              ScalerDDomainBackgroundSetColor(0x00, 0x00, 0x00);
 468   2      
 469   2              // Clear Display Vsync Timeout Flag
 470   2              ScalerSetByte(P0_0C_WATCH_DOG_CTRL0, 0x01);
 471   2      
 472   2      #if(_DISPLAY_PREVENT_GARBAGE_METHOD == _GARBAGE_PREVENT_BY_BACKLIGHT)
              
                      // Clear Buffer Status and Input HVsync error flag
                      ScalerSetByte(P0_02_STATUS0, 0xFF);
              
                      // Internal IRQ Enable (Global)
C51 COMPILER V9.60.0.0   RL6432_SERIES_GLOBAL                                              08/27/2025 11:01:32 PAGE 9   

                      ScalerGlobalIRQControl(_ENABLE);
              
                      // Enable Input HVsync error IRQ and fifo under/overflow IRQ
                      ScalerSetBit(P0_04_IRQ_CTRL0, ~(_BIT5 | _BIT1), (_BIT5 | _BIT1));
              
                      EX0 = 1;
              #else
 485   2              // Disable WD First
 486   2              ScalerSetBit(P16_17_MEAS_HS_VS_DELTA_WD, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
 487   2              ScalerSetBit(P16_18_MEAS_HS_VS_ERROR_WD, ~(_BIT5 | _BIT4), 0x00);
 488   2              ScalerSetBit(P16_1C_M1_MEASURE_DUMMY0, ~_BIT7, 0x00);
 489   2      
 490   2              // Clear flag
 491   2              ScalerSetByte(P0_02_STATUS0, 0xFF);
 492   2              ScalerSetBit(P16_16_MEAS_HS_VS_DELTA_IRQ, ~(_BIT6 | _BIT5 | _BIT4), (_BIT6 | _BIT5 | _BIT4));
 493   2              ScalerSetByte(P16_03_MEAS_ERROR_FLG0, 0xFF);
 494   2      
 495   2              // Enable Input H/V Error WD & Enable Frame Sync WD & WD Action
 496   2              ScalerSetBit(P0_0C_WATCH_DOG_CTRL0, ~(_BIT7 | _BIT5 | _BIT3 | _BIT2 | _BIT1), (_BIT7 | _BIT5 | _BI
             -T3 | _BIT2 | _BIT1));
 497   2      
 498   2              // Enable measure overrange WD
 499   2      #if(_VGA_SUPPORT == _ON)
                      if(ScalerFmtCnvGetSourceType() != _FC_SOURCE_ADC)
              #endif
 502   2              {
 503   3                  ScalerSetBit(P16_17_MEAS_HS_VS_DELTA_WD, ~(_BIT2 | _BIT1 | _BIT0), (_BIT2 | _BIT1 | _BIT0));
 504   3              }
