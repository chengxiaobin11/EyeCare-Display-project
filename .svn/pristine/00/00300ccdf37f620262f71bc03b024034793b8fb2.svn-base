 139   3                  {
 140   4                      // Input slow & fast case
 141   4                      ScalerSetBit(P31_C0_I_DB_CTRL, ~0x3F, (_BIT2 | _BIT0));
 142   4                      ScalerSetBit(P31_C1_D_DB_CTRL, ~0xFF, (_BIT7 | _BIT6));
