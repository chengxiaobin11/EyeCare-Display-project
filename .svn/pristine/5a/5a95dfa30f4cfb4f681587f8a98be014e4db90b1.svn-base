1016   4                  }
1017   3                  else
1018   3                  {
1019   4                      ScalerTMDSHdmiSetAmdAupiScdcInfo(ucInputPort, _DISABLE);
1020   4                  }
1021   3      #endif
1022   3              }
1023   2      
1024   2              ScalerTMDSHdmiSetHpd5vPinHighFlag(ucInputPort, _ON);
1025   2          }
1026   1          else if((ScalerTMDSHdmiHpd5vPinDetect(ucInputPort) == _HDMI_5V_STATUS_LOW) && (ScalerTMDSHdmiGetHpd5vP
             -inHighFlag(ucInputPort) == _TRUE))
1027   1          {
1028   2              ScalerTMDSHdmiResetScdcInfo(ucInputPort);
1029   2      
1030   2              // 5V Low then Reset Scramble Status
1031   2              ScalerTMDSHdmiScrambleStatusReset(ucInputPort);
1032   2      
1033   2              ScalerTMDSHdmiSetScdcInfo(ucInputPort);
1034   2      
1035   2      #if(_HDMI_FREESYNC_SUPPORT == _ON)
1036   2              if(ScalerTMDSHdmiGetFreeSyncSupport(ucInputPort) == _FREESYNC_SUPPORT_ON)
1037   2              {
1038   3                  ScalerTMDSHdmiSetAmdAupiScdcInfo(ucInputPort, _ENABLE);
1039   3              }
1040   2              else
1041   2              {
1042   3                  ScalerTMDSHdmiSetAmdAupiScdcInfo(ucInputPort, _DISABLE);
1043   3              }
1044   2      #endif
1045   2      
1046   2              ScalerTMDSHdmiSetHpd5vPinHighFlag(ucInputPort, _OFF);
1047   2          }
1048   1      
1049   1          ScalerTMDSHdmiHpd5vPinCheckEvent(ucInputPort, _ENABLE);
1050   1      }
