                          ScalerSetByte(P10_32_PIN_SHARE_CTRL82___PC99, _PIN_110_AUXP0);
              
                          // Pin 111 Pinshare Config : AUX_N Mode
                          ScalerSetByte(P10_33_PIN_SHARE_CTRL83___PC99, _PIN_111_AUXN0);
