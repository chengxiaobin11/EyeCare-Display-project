  51          // Description  : Enable/Disable 3D Gamma swap
C51 COMPILER V8.12   RL6449_SERIES_COLORRGB3DGAMMASWAPENABLE                               03/11/2025 19:56:09 PAGE 2   

  52          // Input Value  : _FUNCTION_ON / _FUNCTION_OFF
  53          // Output Value : None
  54          //--------------------------------------------------
  55          void ScalerColorRGB3DGammaSwapEnable(EnumFunctionOnOFF enumOn)
  56          {
  57   1          if(enumOn == _FUNCTION_ON)
  58   1          {
  59   2              ScalerSetBit(P9_B0_RGB_3D_GAMMA_CTRL, ~_BIT5, _BIT5);
  60   2          }
  61   1          else
  62   1          {
  63   2              ScalerSetBit(P9_B0_RGB_3D_GAMMA_CTRL, ~_BIT5, 0x00);
  64   2          }
  65   1      }


