  47          //--------------------------------------------------
  48          // Description  : Set OSD Transparency
  49          // Input Value  : ucTransparency -> 0 ~ 255
  50          // Output Value :
  51          //--------------------------------------------------
C51 COMPILER V8.12   RL6449_SERIES_OSDSETTRANSPARENCY                                      03/11/2025 19:56:18 PAGE 2   

  52          void ScalerOsdSetTransparency(BYTE ucTransparency)
  53          {
  54   1          // alpha_blending_level[7:5]
  55   1          ScalerSetBit(P0_6C_OVERLAY_CTRL, ~(_BIT4 | _BIT3 | _BIT2), ((ucTransparency & 0xE0) >> 3));
  56   1      
  57   1          // alpha_blending_level[4:0]
  58   1          ScalerSetBit(P0_8F_OVERLAY_CTRL1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), ((ucTransparency & 0x1F) <
             -< 3));
  59   1      }
  60          


