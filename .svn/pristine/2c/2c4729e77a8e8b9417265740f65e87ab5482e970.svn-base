                  BYTE pucSeqNumV[3] = {0};
              
                  pucRxInfo[0] = ScalerDpRx0GetDpcdInfo(0x06, 0x93, 0x30);
                  pucRxInfo[1] = ScalerDpRx0GetDpcdInfo(0x06, 0x93, 0x31);
              
                  // Compute V = HMAC-SHA256(Receiver ID List || RxInfo || seq_num_V, kd)
                  if(ScalerHdcp2VprimeCalculate(g_pucDpRx0Hdcp2dKey0, g_pucDpRx0Hdcp2dKey1, g_pucDpTxHdcp2ReceiverIdList
             -, pucRxInfo, pucSeqNumV) == _FALSE)
                  {
                      return _FALSE;
