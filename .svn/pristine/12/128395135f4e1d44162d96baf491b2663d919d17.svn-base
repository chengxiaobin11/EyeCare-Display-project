 223          // Input Value  : _ON or _OFF
 224          // Output Value : None
 225          //--------------------------------------------------
 226          void ScalerDisplayLvdsPadPower(bit bOn)
 227          {
 228   1      #if(_LVDS_SETTING_CONTROL_BY_USER == _ENABLE)
                  // Weakly/ Strongly Pull Down Controlled By User
                  ScalerSetBit(P15_26_LVDS_PORTA_CTRL6, ~(_BIT7 | _BIT6), ((_LVDS_PORTA_WEAK_PULL_DOWN_USER_CTRL << 7) |
             - (_LVDS_PORTA_STRONG_PULL_DOWN_USER_CTRL << 6)));
