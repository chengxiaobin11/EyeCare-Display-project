              //--------------------------------------------------
              // Description  : LVDS PinShare Setting
              // Input Value  : _LVDS_TYPE or _HIZ_TYPE
              // Output Value : None
C51 COMPILER V9.60.0.0   RL6432_SERIES_DISPLAY                                             09/09/2025 14:04:39 PAGE 31  

              //--------------------------------------------------
              void ScalerDisplayLvdsPinshareSetting(EnumLvdsPinshareType enumLvdsPinshareType)
              {
                  if(enumLvdsPinshareType == _LVDS_TYPE)
                  {
              #if((_LVDS_PORT_SEL == _LVDS_1_PORT_A) || (_LVDS_PORT_SEL == _LVDS_2_PORT_AB) || (_LVDS_PORT_SEL == _LVDS_
             -4_PORT_ABCD))
                      if(_PANEL_DISP_BIT_MODE == _PANEL_DISP_30_BIT)
                      {
                          // TXA4P TXA4N Pinshare
                          ScalerSetByte(P10_4F_PIN_SHARE_CTRLB7, 0x04);
                          ScalerSetByte(P10_50_PIN_SHARE_CTRLC0, 0x04);
                      }
                      // TXA0P TXA0N~ TXA3P TXA3N Pinshare
                      ScalerSetByte(P10_51_PIN_SHARE_CTRLC1, 0x04);
                      ScalerSetByte(P10_52_PIN_SHARE_CTRLC2, 0x04);
                      ScalerSetByte(P10_53_PIN_SHARE_CTRLC3, 0x04);
                      ScalerSetByte(P10_54_PIN_SHARE_CTRLC4, 0x04);
                      ScalerSetByte(P10_55_PIN_SHARE_CTRLC5, 0x04);
                      ScalerSetByte(P10_56_PIN_SHARE_CTRLC6, 0x04);
                      ScalerSetByte(P10_57_PIN_SHARE_CTRLC7, 0x04);
                      ScalerSetByte(P10_58_PIN_SHARE_CTRLD0, 0x04);
                      ScalerSetByte(P10_59_PIN_SHARE_CTRLD1, 0x04);
                      ScalerSetByte(P10_5A_PIN_SHARE_CTRLD2, 0x04);
              #endif
              
              #if((_LVDS_PORT_SEL == _LVDS_1_PORT_B) || (_LVDS_PORT_SEL == _LVDS_2_PORT_AB) || (_LVDS_PORT_SEL == _LVDS_
             -4_PORT_ABCD))
                      if(_PANEL_DISP_BIT_MODE == _PANEL_DISP_30_BIT)
                      {
                          // TXB4P TXB4N Pinshare
                          ScalerSetByte(P10_45_PIN_SHARE_CTRLA5, 0x04);
                          ScalerSetByte(P10_46_PIN_SHARE_CTRLA6, 0x04);
                      }
                      // TXB0P TXB0N~ TXB3P TXB3N Pinshare
                      ScalerSetByte(P10_47_PIN_SHARE_CTRLA7, 0x04);
                      ScalerSetByte(P10_48_PIN_SHARE_CTRLB0, 0x04);
                      ScalerSetByte(P10_49_PIN_SHARE_CTRLB1, 0x04);
                      ScalerSetByte(P10_4A_PIN_SHARE_CTRLB2, 0x04);
                      ScalerSetByte(P10_4B_PIN_SHARE_CTRLB3, 0x04);
                      ScalerSetByte(P10_4C_PIN_SHARE_CTRLB4, 0x04);
                      ScalerSetByte(P10_4D_PIN_SHARE_CTRLB5, 0x04);
                      ScalerSetByte(P10_4E_PIN_SHARE_CTRLB6, 0x04);
              #endif
                  }
                  else if(enumLvdsPinshareType == _GPIO_TYPE)
                  {
              #if((_LVDS_PORT_SEL == _LVDS_1_PORT_B) || (_LVDS_PORT_SEL == _LVDS_2_PORT_AB) || (_LVDS_PORT_SEL == _LVDS_
             -4_PORT_ABCD))
              
                      // For 24 bit Panel need use B port LVDS GPIO
                      if(_PANEL_DISP_BIT_MODE == _PANEL_DISP_30_BIT)
                      {
                          ScalerSetBit(P10_45_PIN_SHARE_CTRLA5, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                          ScalerSetBit(P10_46_PIN_SHARE_CTRLA6, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      }
                      // Use Push Pull Replace Weakly/Strong Pull Down because need use LVDS GPIO
                      ScalerSetBit(P10_47_PIN_SHARE_CTRLA7, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_48_PIN_SHARE_CTRLB0, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_49_PIN_SHARE_CTRLB1, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_4A_PIN_SHARE_CTRLB2, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_4B_PIN_SHARE_CTRLB3, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
C51 COMPILER V9.60.0.0   RL6432_SERIES_DISPLAY                                             09/09/2025 14:04:39 PAGE 32  

                      ScalerSetBit(P10_4C_PIN_SHARE_CTRLB4, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_4D_PIN_SHARE_CTRLB5, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_4E_PIN_SHARE_CTRLB6, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
              #endif
              
              #if((_LVDS_PORT_SEL == _LVDS_1_PORT_A) || (_LVDS_PORT_SEL == _LVDS_2_PORT_AB) || (_LVDS_PORT_SEL == _LVDS_
             -4_PORT_ABCD))
              
                      // For 24 bit Panel need use A port LVDS GPIO
                      if(_PANEL_DISP_BIT_MODE == _PANEL_DISP_30_BIT)
                      {
                          ScalerSetBit(P10_4F_PIN_SHARE_CTRLB7, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                          ScalerSetBit(P10_50_PIN_SHARE_CTRLC0, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      }
              
                      // Use Push Pull Replace Weakly/Strong Pull Down because need use LVDS GPIO
                      ScalerSetBit(P10_51_PIN_SHARE_CTRLC1, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_52_PIN_SHARE_CTRLC2, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_53_PIN_SHARE_CTRLC3, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_54_PIN_SHARE_CTRLC4, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_55_PIN_SHARE_CTRLC5, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_56_PIN_SHARE_CTRLC6, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_57_PIN_SHARE_CTRLC7, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_58_PIN_SHARE_CTRLD0, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_59_PIN_SHARE_CTRLD1, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
                      ScalerSetBit(P10_5A_PIN_SHARE_CTRLD2, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
              #endif
                  }
              }
              #endif
1767          
1768          #elif(_PANEL_STYLE == _PANEL_DPTX)
              //--------------------------------------------------
              // Description  : LVDS Pad Power Control --> eDP Panel
              // Input Value  : _ON or _OFF
              // Output Value : None
              //--------------------------------------------------
              void ScalerDisplayUseLvdsPadPower(bit bOn)
              {
                  // Disable Weakly / Strongly Pull Down
                  ScalerSetBit(P15_26_LVDS_PORTA_CTRL6, ~(_BIT7 | _BIT6), 0x00);
                  ScalerSetBit(P15_36_LVDS_PORTB_CTRL6, ~(_BIT7 | _BIT6), 0x00);
              
                  if(bOn == _ON)
                  {
                      // Power Up Port AB LVDS Block
                      ScalerSetBit(P15_00_LVDS_COMMON_AB_CTRL0, ~(_BIT6 | _BIT5), (_BIT6 | _BIT5));
                  }
                  else
                  {
                      // Power Down Port AB LVDS Block
                      ScalerSetBit(P15_00_LVDS_COMMON_AB_CTRL0, ~(_BIT6 | _BIT5), 0x00);
                  }
              }
              #endif // End of #if(_PANEL_STYLE == _PANEL_LVDS)
