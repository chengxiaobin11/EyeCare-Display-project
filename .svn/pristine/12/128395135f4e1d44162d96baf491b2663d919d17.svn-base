             - (_LVDS_PORTB_STRONG_PULL_DOWN_USER_CTRL << 6)));
                  ScalerSetBit(P55_26_LVDS_PORTA_CTRL6, ~(_BIT7 | _BIT6), ((_LVDS_PORTC_WEAK_PULL_DOWN_USER_CTRL << 7) |
             - (_LVDS_PORTC_STRONG_PULL_DOWN_USER_CTRL << 6)));
                  ScalerSetBit(P55_36_LVDS_PORTB_CTRL6, ~(_BIT7 | _BIT6), ((_LVDS_PORTD_WEAK_PULL_DOWN_USER_CTRL << 7) |
             - (_LVDS_PORTD_STRONG_PULL_DOWN_USER_CTRL << 6)));
              #endif
 235   1      
 236   1          if(bOn == _ON)
 237   1          {
 238   2              // Set LVDS Configuration: Hiz
 239   2              ScalerDisplayLvdsPower(_OFF);
 240   2      
 241   2              // Power Up Port AB LVDS Block
 242   2              ScalerSetBit(P15_00_LVDS_COMMON_AB_CTRL0, ~(_BIT6 | _BIT5), (_BIT6 | _BIT5));
 243   2      
 244   2      #if((_LVDS_PORT_SEL == _LVDS_1_PORT_C) || (_LVDS_PORT_SEL == _LVDS_2_PORT_CD) || (_LVDS_PORT_SEL == _LVDS_
             -4_PORT_ABCD))
 245   2              // Power Up Port C LVDS Block
 246   2              ScalerSetBit(P55_00_LVDS_COMMON_AB_CTRL0, ~(_BIT5), (_BIT5));
 247   2      #endif
 248   2      
 249   2      #if((_LVDS_PORT_SEL == _LVDS_1_PORT_D) || (_LVDS_PORT_SEL == _LVDS_2_PORT_CD) || (_LVDS_PORT_SEL == _LVDS_
             -4_PORT_ABCD))
 250   2              // Power Up Port D LVDS Block
 251   2              ScalerSetBit(P55_00_LVDS_COMMON_AB_CTRL0, ~(_BIT6), (_BIT6));
 252   2      #endif
 253   2          }
 254   1          else
 255   1          {
 256   2              // Power Down Port ABCD LVDS Block
 257   2              ScalerSetBit(P15_00_LVDS_COMMON_AB_CTRL0, ~(_BIT6 | _BIT5), 0x00);
 258   2              ScalerSetBit(P55_00_LVDS_COMMON_AB_CTRL0, ~(_BIT6 | _BIT5), 0x00);
 259   2          }
 260   1      }
