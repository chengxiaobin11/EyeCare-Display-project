C51 COMPILER V8.12   SCALERCOMMONDEBUGTIMERCURSORMS                                        03/11/2025 19:55:37 PAGE 2   

  52          //--------------------------------------------------
  53          WORD ScalerDebugGetTimerCursorMSDifference(EnumDebugTimeCursor enumIndex)
  54          {
  55   1          // Check if cursor is used
  56   1          if(((g_ucTimerCursorUsedMS >> enumIndex) & _BIT0) == _DISABLE)
  57   1          {
  58   2              return 0xFFFF;
  59   2          }
  60   1          else
  61   1          {
  62   2              // Calculate counter difference
  63   2              if(g_pstTimerCursorMS[enumIndex].usCounter_Start <= g_pstTimerCursorMS[enumIndex].usCounter_End)
  64   2              {
  65   3                  return g_pstTimerCursorMS[enumIndex].usCounter_End - g_pstTimerCursorMS[enumIndex].usCounter_S
             -tart;
  66   3              }
  67   2              else
  68   2              {
  69   3                  return 0xFFFF - g_pstTimerCursorMS[enumIndex].usCounter_Start + g_pstTimerCursorMS[enumIndex].
             -usCounter_End;
  70   3              }
  71   2          }
  72   1      }
