C51 COMPILER V8.12   RL6449_SERIES_COLORLDSRGBADJUST                                       03/11/2025 19:56:16 PAGE 2   

  52          
  53          //--------------------------------------------------
  54          // Description  : Adjust SRGB function for effective immd
  55          // Input Value  : SRGB Matrix
  56          //                SRGB Precision
  57          // Output Value : _TRUE/_FALSE
  58          //--------------------------------------------------
  59          bit ScalerColorLDSRGBAdjust(BYTE *pucSRGBArray, EnumSrgbPrecision enumPrecision)
  60          {
  61   1          // Clear Waiting flag
  62   1          ScalerSetBit(P0_62_SRGB_CTRL, ~_BIT7, 0x00);
  63   1          ScalerSetBit(P0_62_SRGB_CTRL, ~_BIT6, _BIT6); // Reset Port
  64   1      
  65   1          if(ScalerTimerPollingFlagProc(2, P0_62_SRGB_CTRL, _BIT6, 0) == _FALSE) // pollling till Reset port add
             -ress finished
  66   1          {
  67   2              return _FALSE;
  68   2          }
  69   1      
  70   1          ScalerSetBit(P0_62_SRGB_CTRL, ~(_BIT5 | _BIT4 | _BIT3), 0x00); // Write sequence
  71   1      
  72   1          ScalerBurstWrite(pucSRGBArray, _SRGB_TABLE_SIZE, GET_CURRENT_BANK_NUMBER(), P0_63_SRGB_ACCESS_PORT_SET
             -A, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_XRAM);
  73   1      
  74   1          ScalerSetBit(P0_68_GAMMA_BIST_DITHER_SETA, ~(_BIT6 | _BIT5), (enumPrecision << 5)); // Precision
  75   1      
  76   1          ScalerSetBit(P0_62_SRGB_CTRL, ~_BIT7, _BIT7);   // no apply none, always effective on dvs
  77   1      
  78   1          return _TRUE;
  79   1      }
  80          
  81          
  82          


