  61          // Description  : MCU Initial Settings
  62          //
  63          // MCU initial function, must be called at first
  64          // Since code banking can not work correctly before this function is called,
  65          // this function should stay in bank0.
  66          //
  67          // Input Value  : None
  68          // Output Value : None
  69          //--------------------------------------------------
  70          void ScalerMcuInitial(void)
  71          {
  72   1          // Clear Watchdog & Set CNT1 to Max
  73   1          MCU_FFEA_WATCHDOG_TIMER |= _BIT6 | _BIT2 | _BIT1 | _BIT0;
