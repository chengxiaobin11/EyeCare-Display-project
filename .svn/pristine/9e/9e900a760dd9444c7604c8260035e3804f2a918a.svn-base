 411          BYTE ScalerDpRx1LinkRateDetect(void)
 412          {
 413   1          BYTE ucDpLinkRate = 0;
 414   1          BYTE ucDpLinkRateDecide = _DP_LINK_NONE;
 415   1      
 416   1          do
C51 COMPILER V9.01   SCALERCOMMONDPRX1                                                     05/24/2025 15:51:31 PAGE 8   

 417   1          {
 418   2              if(ucDpLinkRate == 0)
 419   2              {
 420   3                  if(_HW_DP_D1_MAX_LINK_RATE_SUPPORT > ScalerDpRx1GetDpcdInfo(0x00, 0x00, 0x01))
 421   3                  {
 422   4                      ucDpLinkRate = _HW_DP_D1_MAX_LINK_RATE_SUPPORT;
 423   4                  }
 424   3                  else
 425   3                  {
 426   4                      ucDpLinkRate = ScalerDpRx1GetDpcdInfo(0x00, 0x00, 0x01);
 427   4                  }
 428   3              }
 429   2              else if(ucDpLinkRate == _DP_LINK_HBR3)
 430   2              {
 431   3                  ucDpLinkRate = _DP_LINK_HBR2;
 432   3              }
 433   2              else if(ucDpLinkRate == _DP_LINK_HBR2)
 434   2              {
 435   3                  ucDpLinkRate = _DP_LINK_HBR;
 436   3              }
 437   2              else if(ucDpLinkRate == _DP_LINK_HBR)
 438   2              {
 439   3                  ucDpLinkRate = _DP_LINK_RBR;
 440   3              }
 441   2      
 442   2              if(ScalerDpRx1LinkRateCheck(ucDpLinkRate) == _TRUE)
 443   2              {
 444   3                  ucDpLinkRateDecide = ucDpLinkRate;
 445   3      
 446   3                  break;
 447   3              }
 448   2          }
 449   1          while(ucDpLinkRate != _DP_LINK_RBR);
 450   1      
 451   1          return ucDpLinkRateDecide;
 452   1      }
