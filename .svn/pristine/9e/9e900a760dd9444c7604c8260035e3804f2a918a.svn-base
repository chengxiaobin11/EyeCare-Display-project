 519          //--------------------------------------------------
 520          // Description : DP Signal Detection Measure
 521          // Input Value  : DP Lane Select, Measure target, Measure Period
 522          // Output Value : Measure Counter
 523          //--------------------------------------------------
 524          WORD ScalerDpRx1SignalDetectMeasureCount(BYTE ucDpLaneSel, EnumDpMeasureTarget enumDpMeasureTarget, EnumDp
             -MeasurePeriod enumDpMeasurePeriod)
 525          {
 526   1          WORD usDpMeasureCount = 0;
 527   1      
 528   1          // [1:0] freqdet_lane_sel
 529   1          ScalerSetBit(PB0_51_DP_SIG_DET_1, ~(_BIT1 | _BIT0), (ucDpLaneSel & (_BIT1 | _BIT0)));
 530   1      
 531   1          // [5] ln_ck_sel
 532   1          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT5, enumDpMeasureTarget);
 533   1      
 534   1          switch(enumDpMeasurePeriod)
 535   1          {
 536   2              case _DP_MEASURE_PERIOD_1000_CYCLE:
 537   2      
 538   2      #if(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_1)
C51 COMPILER V9.01   SCALERCOMMONDPRX1                                                     05/24/2025 15:51:31 PAGE 10  

 539   2                  // [4:0] DP_XTAL_CYCLE = 5'b00011
 540   2                  ScalerSetBit(PB0_50_DP_SIG_DET_0, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT1 | _BIT0));
 541   2      #elif(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_2)
                          // [0] DP_XTAL_CYCLE = 1'b0
                          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT0, 0x00);
              #endif
 545   2                  break;
 546   2      
 547   2              case _DP_MEASURE_PERIOD_2000_CYCLE:
 548   2              default:
 549   2      
 550   2      #if(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_1)
 551   2                  // [4:0] DP_XTAL_CYCLE = 5'b00100
 552   2                  ScalerSetBit(PB0_50_DP_SIG_DET_0, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT2);
 553   2      #elif(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_2)
                          // [0] DP_XTAL_CYCLE = 1'b1
                          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT0, _BIT0);
              #endif
 557   2                  break;
 558   2          }
 559   1      
 560   1          // [6] LANE_COUNT_CLEAR = 0 -> Keep the LANE_COUNT value
 561   1          ScalerSetBit(PB0_52_DP_SIG_DET_2, ~_BIT6, 0x00);
 562   1      
 563   1          // [7] DP_SIG_DET_EN = 1'b1 -> Enable Signal Detection
 564   1          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT7, 0x00);
 565   1          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT7, _BIT7);
 566   1      
 567   1          // Delay Time us [5,150] Polling for Measure Done
 568   1          for(pData[0] = 0; pData[0] <= 30; pData[0]++)
 569   1          {
 570   2              DELAY_5US();
 571   2      
 572   2              if(ScalerGetBit(PB0_50_DP_SIG_DET_0, _BIT6) == _BIT6)
 573   2              {
 574   3                  usDpMeasureCount = ((((WORD)ScalerGetByte(PB0_53_DP_SIG_DET_3)) << 8) | ScalerGetByte(PB0_54_D
             -P_SIG_DET_4));
 575   3      
 576   3                  break;
 577   3              }
 578   2          }
 579   1      
 580   1          // [7] DP_SIG_DET_EN = 0 -> Disable Signal Detection
 581   1          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT7, 0x00);
 582   1      
 583   1          return usDpMeasureCount;
 584   1      }
