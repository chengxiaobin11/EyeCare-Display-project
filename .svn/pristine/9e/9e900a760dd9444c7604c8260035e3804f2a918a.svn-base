                  // =========== Continue Measure Two Frame Start ===========
                  // Start to Measure Vertical BS to BS Counter by GDI Clock
                  ScalerSetBit(PA_58_MN_MEAS_CTRL, ~_BIT7, 0x00);
                  ScalerSetBit(PA_58_MN_MEAS_CTRL, ~_BIT7, _BIT7);
              
