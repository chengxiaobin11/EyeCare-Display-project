//==================================================
// Message OSD Common
//==================================================
void OsdNothingKey(void)
{
	DebugMessageOsd("1.OsdNothingKey",GET_KEYMESSAGE());

#if _OSD_PowerSaving_Fun

	if(g_usPowerSavingCount<_OSD_TIME_AUTO_DOWN_COUNT && GET_KEYMESSAGE()!=_NONE_KEY_MESSAGE)
	{
		ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_AUTO_POWER_Saving); 
		SET_AUTO_SLEEP_STATUS(_SleepPowerSaving_OFF);
		OsdDispDisableOsd();
	}

#endif

	if(GET_KEYREPEATENABLE())
	{
		;//CLR_KEYREPEATENABLE();
	}
	else
	{
		switch (GET_KEYMESSAGE())
		{
			case _MENU_KEY_MESSAGE: 
			case _EXIT_KEY_MESSAGE:
			case _RIGHT_KEY_MESSAGE:
			case _LEFT_KEY_MESSAGE:
			case _UP_KEY_MESSAGE:
			case _DOWN_KEY_MESSAGE:
				OsdDispDisableOsd();
				break;
			
			default:
				break;
		
		}

	}
	


}



//==================================================
// Message OSD Common
//==================================================
void OsdNothingKey1(void)
{
	DebugMessageOsd("1.OsdNothingKey1",GET_KEYMESSAGE());
	
	if(GET_OSD_MESSAGE()==_OSD_DISP_LOGO_BOOTUP_STATUS_MSG || GET_OSD_MESSAGE()==_OSD_DISP_POWER_LOCK_STATUS_MSG \
		)
		SET_OSD_MESSAGE(_OSD_DISP_NULL_MSG);
	else
	{

		switch (GET_KEYMESSAGE())
		{
			case _MENU_KEY_MESSAGE: 
			case _EXIT_KEY_MESSAGE:
			case _RIGHT_KEY_MESSAGE:
			case _LEFT_KEY_MESSAGE:
			case _UP_KEY_MESSAGE:
			case _DOWN_KEY_MESSAGE:
				OsdDispDisableOsd();
				break;
			
			default:
				break;
		
		}

	}


}



void MENU_FUN_RESOLUTION_NOTICE(void)
{
    switch(GET_KEYMESSAGE())
    {
#if(_DEF_KEY_ROCKER)
			case _RIGHT_KEY_MESSAGE:
#else
			case _MENU_KEY_MESSAGE: 
			case _EXIT_KEY_MESSAGE:
#endif
			SET_OSD_RESOLUTION_STATUS(_OFF);
			RTDNVRamSaveOSDData();
            OsdDispDisableOsd();
            break;

#if(_DEF_KEY_ROCKER)
			case _LEFT_KEY_MESSAGE:
#else
			case _RIGHT_KEY_MESSAGE:
			case _LEFT_KEY_MESSAGE:
#endif

			OsdDispDisableOsd();
            break;

        default:
            break;
    }
}


#if(_DEF_NAVIGATION_OSD_ENABLE)
void MenuNavigat(void)
{

#if(_DEF_KEY_ROCKER)

    switch(GET_KEYMESSAGE())
    {
    	case _MIDDLE_KEY_MESSAGE:
			OsdDispDisableOsd();
			break;
			
		case _LEFT_KEY_MESSAGE:
			OsdDispHotKeySourceMenu(_OSD_HOTKEY_INPUT);
			break;
		
		case _RIGHT_KEY_MESSAGE:
			if(!OSD_ITEM_MASK_GET(_OSD_HOTKEY_CONBRI))
				OsdDispHotKeySourceMenu(_OSD_HOTKEY_CONBRI);
			break;
			
		case _UP_KEY_MESSAGE:
			if(!OSD_ITEM_MASK_GET(_OSD_HOTKEY_VIEWMODE))
				OsdDispHotKeySourceMenu(_OSD_HOTKEY_VIEWMODE);
			break;

		case _DOWN_KEY_MESSAGE:
			OsdDispMainMenu();
			break;

		default:
			break;
	}

#elif(_DEF_JS_KEY_ICON_5_KEY_MODE)

	switch(GET_KEYMESSAGE())
	{
		case _EXIT_KEY_MESSAGE:
			OsdDispDisableOsd();
			break;
		
		case _RIGHT_KEY_MESSAGE:
			OsdDispHotKeySourceMenu(_OSD_HOTKEY_INPUT);
			break;
			
		case _LEFT_KEY_MESSAGE:
			if(!OSD_ITEM_MASK_GET(_OSD_HOTKEY_VIEWMODE))
				OsdDispHotKeySourceMenu(_OSD_HOTKEY_VIEWMODE);
			break;

		case _MENU_KEY_MESSAGE:
			OsdDispMainMenu();
			break;

		default:
			break;
	}

#endif
	
}
#endif

