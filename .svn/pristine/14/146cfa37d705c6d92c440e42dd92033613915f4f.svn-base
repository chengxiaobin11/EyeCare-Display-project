		return 1;
	return 0;
}


//--------------------------------------------------
// Description  : OSD Handler, executed in the main loop
// Input Value  : None
// Output Value : None
//--------------------------------------------------
void UserOsdHandler(void)
{
    RTDOsdSystemFlowProc();
    RTDOsdEventMsgProc();
}

//--------------------------------------------------
// Description  : OSD system flow
// Input Value  : None
// Output Value : None
//--------------------------------------------------
void RTDOsdSystemFlowProc(void)
{
    switch(SysModeGetModeState())
    {
        case _MODE_STATUS_POWER_OFF:

            if(SysModeGetModeStateChange() == _TRUE)
            {
                SET_FORCE_POW_SAV_STATUS(_FALSE);
            }

            break;

        case _MODE_STATUS_INITIAL:

            if(SysModeGetModeStateChange() == _TRUE)
            {
#if(_FREESYNC_OD_MEASURE == _ON)
                UserAdjustFREESYNCODMeasure();
#endif

#if(_DCR_SUPPORT ==_ON)
				if(GET_OSD_DCR_STATUS() !=_DCR_Level_0)
				{
					CDcrReset();
					UserAdjustBacklight(GET_OSD_BACKLIGHT());
				}
#endif

//#if(_PROJECT_ID !=_ID_ZQ_2513E05_PANDA_LC215DTBA_8BIT_FHD75_VA2271_H_20241223)  //2025.2.11  tx
				if(GET_FACTORY_FORCE_LOGO_OFF() && !GET_FACTORY_MODE())
//#endif		
				{
					OsdDispShowLogo();
					UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);

#if(_AUDIO_TTS_SUPPORT_TYPE == _AUDIO_TTS_EMBEDDED_TYPE)
					ScalerTimerActiveTimerEvent(SEC(2), _USER_TIMER_EVENT_AUDIO_TTS_SHOW_LOGO);
#else
					ScalerTimerActiveTimerEvent(SEC(3), _USER_TIMER_EVENT_OSD_DISABLE_OSD_LOGO);
#endif // End of #if(_AUDIO_TTS_SUPPORT_TYPE == _AUDIO_TTS_EMBEDDED_TYPE)
				}


				ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_DISABLE); 			
				ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_BUININ_MSG);

            }

            break;

        case _MODE_STATUS_SEARCH:

            if(SysModeGetModeStateChange() == _TRUE)
            {
#if(_FREEZE_SUPPORT == _ON)
                if(GET_OSD_FREEZE_STATUS() == _ON)
                {
                    SET_OSD_FREEZE_STATUS(_OFF);
                }
#endif

#if(_DCR_SUPPORT ==_ON)
				if(GET_OSD_DCR_STATUS() !=_DCR_Level_0)
				{
					CDcrReset();
	
					if(GET_OSD_LOGO_ON() == _FALSE)
					{
						UserAdjustBacklight(GET_OSD_BACKLIGHT());
					}
				}
#endif


                if(SysPowerGetPowerStatus() == _POWER_STATUS_NORMAL)
                {  
					#if(_PROJECT_ID==_ID_ZQ_2513E05_PANDA_LC215DTBA_8BIT_FHD75_VA2271_H_20241223)||(_PROJECT_ID==_ID_ZQ_2513E05_BOE_HV320FHB_F4A_8BIT_FHD75_VA2271_H_20250301)
                	if(GET_FACTORY_MODE())
				 		UserInterfaceKeyPadLedControl(_LED_POWER_SAVING);
				 	else
				 	#endif 	
                    	UserInterfaceKeyPadLedControl(_LED_POWER_SEARCH);
                }
            }

#if(_OVERSCAN_SUPPORT == _ON)
			g_bOverScanFlag = _FALSE;
#endif

            break;

        case _MODE_STATUS_DISPLAY_SETTING:

            break;

        case _MODE_STATUS_ACTIVE:

            if(SysModeGetModeStateChange() == _TRUE)
            {
                if(SysPowerGetPowerStatus() == _POWER_STATUS_NORMAL)
                {
              		#if(_PROJECT_ID==_ID_ZQ_2513E05_PANDA_LC215DTBA_8BIT_FHD75_VA2271_H_20241223)||(_PROJECT_ID==_ID_ZQ_2513E05_BOE_HV320FHB_F4A_8BIT_FHD75_VA2271_H_20250301)
                	if(GET_FACTORY_MODE())
				 		UserInterfaceKeyPadLedControl(_LED_POWER_SAVING);
				 	else
			  		#endif	 	
                   		UserInterfaceKeyPadLedControl(_LED_POWER_ACTIVE);
					 DebugMessageOsd("My_led",20);

#if(_AUDIO_TTS_SUPPORT_TYPE == _AUDIO_TTS_EMBEDDED_TYPE)
                    UserAdjustAudioTtsPlayEvent(_AUDIO_TTS_EVENT_POWER_ON);
#endif // End of #if(_AUDIO_TTS_SUPPORT_TYPE == _AUDIO_TTS_EMBEDDED_TYPE)
                }

#if(_MPRT_SUPPORT == _ON)
				UserAdjustMPRTFuntion(GET_OSD_MPRT()); 		
#endif
#if(_PROJECT_ID==_ID_ZQ_2513E05_PANDA_LC215DTBA_8BIT_FHD75_VA2271_H_20241223)||(_PROJECT_ID==_ID_ZQ_2513E05_BOE_HV320FHB_F4A_8BIT_FHD75_VA2271_H_20250301)
			if(GET_OSD_LANGUAGE_HK_STATUS() == _ON)//����ѡ��δ����л��ֱ��ʲ�������ݼ�ѡ������
			{
				Language_District_flang=0;
				SET_OSD_ACTIVE_STATE_MESSAGE(_TRUE);
			}
#endif
				
            }
			
#if(_DEF_NO_CHECK_LANGUAGE_DISTRICT_MODE_SWTICH)
          if(ddcci_reset==0)
			OsdDisplayActiveStateCheck();	//ѭ�����
#endif


#if(_DCR_SUPPORT == _ON)
#if(_HDR10_SUPPORT == _ON)
			if(UserCommonHDRGetHDR10Status() == _HDR10_ON) //|| (GET_OSD_MPRT_STATUS() != _OFF))
			{	
				if(GET_OSD_DCR_STATUS() != _OFF)
				{
					SET_OSD_DCR_STATUS(_OFF);
					ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_DCR_SLOW_ADJUST); // yongle 20130710
					RTDNVRamSaveSceneModeData(GET_OSD_VIEWMODE_TYPE());
				}
			}
			else
#endif
			{
				if(GET_OSD_DCR_STATUS() != _OFF)
				{
					
					//UserAdjustDCR();
					ScalerTimerActiveTimerEvent(SEC(0.01), _USER_TIMER_EVENT_DCR_SLOW_ADJUST);
				}
			}
#endif


            break;

        case _MODE_STATUS_NOSUPPORT:

            if(SysModeGetModeStateChange() == _TRUE)
            {
                if(SysPowerGetPowerStatus() == _POWER_STATUS_NORMAL)
                {   
   
                    SET_OSD_EVENT_MESSAGE(_OSDEVENT_SHOW_NOSUPPORT_MSG);
                    UserInterfaceKeyPadLedControl(_LED_POWER_NOSUPPORT);
                }
            }

            break;

        case _MODE_STATUS_NOSIGNAL:

			if((GET_OSD_HOTKEY_BURNIN() == _ON)&& (GET_FACTORY_MODE() == _ON))
			{
				SET_FACTORY_BURNIN(_ON);
				SET_OSD_HOTKEY_BURNIN(_OFF);
				TPVNVRamSaveFactoryDate();

			}
			
 			 if(SysModeGetModeStateChange() == _TRUE)
            {


			
    			if((GET_FACTORY_BURNIN() == _ON)&&(GET_FACTORY_MODE() == _ON))
    			{

					#if _DEFAULT_OSD_STYLE == _TRG_OSD_STYLE

					#else
						SysSourceSetScanType(_SOURCE_SWITCH_AUTO_IN_GROUP);
					#endif
					ScalerTimerActiveTimerEvent(SEC(2), _USER_TIMER_EVENT_BUININ_MSG);

					#if (_BURNIN_MSG_MENU_SUPPORT==_ON)
						RTDBurnInMenu();
					#endif

					UserAdjustContrast(100);
					UserAdjustBacklight(100);
					UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
                    // while(1);
				}
                else if((GET_FACTORY_BURNIN() == _OFF) && (GET_FACTORY_MODE() == _ON)&&(SysModeGetModeState() != _MODE_STATUS_ACTIVE && ScalerTimerSearchActiveTimerEvent(_USER_TIMER_EVENT_OSD_SHOW_NO_SIGNAL)))
                {
			 		//ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_SHOW_POWER_SAVING);
                   // UserCommonInterfacePanelPowerAction(_PANEL_OFF);
                   
#if _DEFAULT_OSD_STYLE == _TRG_OSD_STYLE


#if(_DEF_NO_SIGNAL_SHOW_SOURCE_MENU)

				{
						SET_OSD_POWER_SAVING_SHOW_SOURCE(_FALSE);
						SET_OSD_EVENT_MESSAGE(_OSDEVENT_SHOW_CHANGE_SOURCE_MENU_MSG);
				}
#endif
									
								
				
#endif
                }
				else
				{
					ScalerTimerActiveTimerEvent(SEC(2), _USER_TIMER_EVENT_OSD_SHOW_NO_SIGNAL);	//�������źŵ���  
				}
            }

            break;

        case _MODE_STATUS_POWER_SAVING:

            if(SysSourceGetCableDetect(SysSourceGetInputPort()) == _FALSE)
            {
                SET_FORCE_POW_SAV_STATUS(_FALSE);
            }

            if(SysPowerGetPowerStatus() == _POWER_STATUS_NORMAL)
            {
                if(GET_OSD_POWER_SAVING_SHOW_SOURCE() == _TRUE)
                {
#if(_DEF_NO_SIGNAL_SHOW_SOURCE_MENU)
                    SET_OSD_POWER_SAVING_SHOW_SOURCE(_FALSE);
                    SET_OSD_EVENT_MESSAGE(_OSDEVENT_SHOW_CHANGE_SOURCE_MENU_MSG);
#endif
                }
                else if(GET_OSD_WAKE_UP_SWITCH_DDCCI_PORT() == _TRUE)
                {
                    SET_OSD_WAKE_UP_SWITCH_DDCCI_PORT(_FALSE);

                    SET_OSD_EVENT_MESSAGE(_OSDEVENT_WAKE_UP_SWITCH_DDCCI_PORT_MSG);
                }
#if(_DP_SUPPORT == _ON)
                else if(GET_OSD_POWER_SAVING_SHOW_DP_OPTION() == _TRUE)
                {
                    SET_OSD_POWER_SAVING_SHOW_DP_OPTION(_FALSE);
                    SET_OSD_EVENT_MESSAGE(_OSDEVENT_DP_VERSIOM_MSG);
                }
#endif
#if(_DP_DEBUG_MSG == _ON)
                else if(GET_OSD_POWER_SAVING_SHOW_DP_INFO() == _TRUE)
                {
                    SET_OSD_POWER_SAVING_SHOW_DP_INFO(_FALSE);

                    OsdDispOsdMessage(_OSD_DISP_INPUT_SIGNAL_MSG);
                    UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
                }
#endif
            }

            break;

        case _MODE_STATUS_FACTORY:

            break;

        default:

            break;
    }

#if(_DP_EMBEDDED_SWITCH_SUPPORT_TYPE == _DP_EMBEDDED_SWITCH_2_DP)
    // Check embedded DP switch status
    UserCommonAdjustEmbeddedDpSwitch();
#endif

    if(GET_KEYMESSAGE() < _KEY_AMOUNT)
    {
        // hot key
        if((SysModeGetModeState() == _MODE_STATUS_ACTIVE) ||
           (SysModeGetModeState() == _MODE_STATUS_NOSUPPORT) ||
           (SysModeGetModeState() == _MODE_STATUS_NOSIGNAL) ||
           (SysModeGetModeState() == _MODE_STATUS_POWER_SAVING))
        {

            if((GET_OSD_STATE() != _MENU_NONE) &&
                ((GET_KEYMESSAGE() == _LEFT_KEY_MESSAGE) || (GET_KEYMESSAGE() == _RIGHT_KEY_MESSAGE) || (GET_KEYMESSAGE() == _UP_KEY_MESSAGE) || (GET_KEYMESSAGE() == _DOWN_KEY_MESSAGE)))
            {
                SET_KEYREPEATENABLE();
            }
        }

        if(GET_OSD_IN_FACTORY_MENU_STATUS() == _TRUE)
        {
            RTDFactoryMenuOperation();
            ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_DISABLE);
        }
        else
        {
#if(_FREEZE_SUPPORT == _ON)
#if(_URGENT_EVENT_CHECK_MODE == _ON)
            if(ScalerTimerSearchActiveTimerEvent(_USER_TIMER_EVENT_OSD_DISABLE_FREEZE_MSG) == _TRUE)
            {
                return;
            }
#else
            if(GET_FREEZE_DISABLE_MSG_STATE() == _ON)
            {
                return;
            }
#endif
#endif
            // back up previous OSD State
            SET_OSD_STATE_PREVIOUS(GET_OSD_STATE());

#if(_FREEZE_SUPPORT == _ON)
            if(GET_OSD_FREEZE_STATUS() == _ON) // Confirm whether disable the freeze status
            {
                if(OsdFuncCheckFreezeDisable() == _TRUE)
                {
                    return;
                }
            }
#endif

			if(OsdDisplayCheckkeyValid() == _TRUE)
			{
				if(GET_OSD_LOCK_STATUS())
				{
					if(GET_OSD_MESSAGE()==_OSD_DISP_LOCKING_STATUS_MSG  \
						|| GET_OSD_MESSAGE()==_OSD_DISP_POWER_LOCK_STATUS_MSG \
						|| GET_OSD_MESSAGE()==_OSD_DISP_POWER_LOCKING_STATUS_MSG)
					{
						SET_OSD_MESSAGE(_OSD_DISP_NULL_MSG);
						OsdDispDisableOsd();
					}
					#if _PROJECT_ID == _ID_ZQ_2557E02_SG2701B08_4_FHD200_MKF27F240L_20250515
						else if(SysModeGetModeState() == _MODE_STATUS_ACTIVE && (GET_OSD_STATE() != _MENU_NONE))
	                    	return;
					#else
						else if(SysModeGetModeState() == _MODE_STATUS_ACTIVE && ScalerOsdGetOsdEnable() == _ENABLE)
	                    	return;
					#endif
					else
						SET_OSD_EVENT_MESSAGE(_OSDEVENT_SHOW_OSD_LOCK_MSG);
				}
				else
				{
					(*OperationTable[GET_OSD_STATE()])();
				
				}

			}
			
			if(GET_OSD_STATE() == _OSD_MSG_INPUT_SOURCE)
			{
				OsdDispDisableOsd();
			}
			else if(GET_OSD_STATE() == _OSD_MSG_NOTHING1)
			{
				return;
			}


			OsdFuncShowSourceMenuCheck();

            if(GET_OSD_IN_FACTORY_MENU_STATUS() == _FALSE)
            {
                if(SysModeGetModeState() == _MODE_STATUS_ACTIVE)
                {
                
					if(OsdDisplayCheckkeyValid() == _TRUE)
					{
						if(OsdDisplayTimeOut(GET_OSD_TIME_OUT()) < _OSD_TIMEOUT_MIN)
						{
							ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_DISABLE);
						}
						else
						{
							DebugMessageOsd("OSD_DISABLE",1);
							ScalerTimerReactiveTimerEvent(SEC(OsdDisplayTimeOut(GET_OSD_TIME_OUT())), _USER_TIMER_EVENT_OSD_DISABLE);
						}

					}

                }
            }





        }
    }
}

//--------------------------------------------------
// Description  : OSD event message processing function
// Input Value  : None
// Output Value : None
//--------------------------------------------------
void RTDOsdEventMsgProc(void)
{
    switch(GET_OSD_EVENT_MESSAGE())
    {
        case _OSDEVENT_SHOW_NOSIGNAL_MSG:
			

			if(GET_FACTORY_BURNIN() != _ON)
			{
            	OsdDispOsdMessage(_OSD_DISP_NOSIGNAL_MSG);
            	UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
				OsdFuncEnableOsd();
			}
            ScalerTimerActiveTimerEvent(SEC(3), _USER_TIMER_EVENT_GO_TO_POWER_SAVING);
            //ScalerTimerActiveTimerEvent(SEC(3), _USER_TIMER_EVENT_OSD_SHOW_POWER_SAVING);
            break;

        case _OSDEVENT_SHOW_NOCABLE_MSG:
            OsdDispOsdMessage(_OSD_DISP_NOCABLE_MSG);
            UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
            ScalerTimerActiveTimerEvent(SEC(3), _USER_TIMER_EVENT_GO_TO_POWER_SAVING);
            //ScalerTimerActiveTimerEvent(SEC(3), _USER_TIMER_EVENT_OSD_SHOW_POWER_SAVING);
            break;

        case _OSDEVENT_SHOW_NOSUPPORT_MSG:

            ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_SHOW_NO_CABLE);
            ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_SHOW_NO_SIGNAL);

            OsdDispOsdMessage(_OSD_DISP_NOSUPPORT_MSG);
			
            UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
            ScalerTimerActiveTimerEvent(SEC(3), _USER_TIMER_EVENT_GO_TO_POWER_SAVING);
            //ScalerTimerReactiveTimerEvent(SEC(3), _USER_TIMER_EVENT_OSD_SHOW_POWER_SAVING);
            break;

        case _OSDEVENT_SHOW_FAIL_SAFE_MODE_MSG:
            OsdDispOsdMessage(_OSD_DISP_FAIL_SAFE_MODE_MSG);
            break;

        case _OSDEVENT_SLEEP_TIME_ADJ_MSG:
            OsdDispOsdMessage(_OSD_DISP_SLEEP_MSG_ADJ);
            break;

#if(_DEF_NO_SIGNAL_SHOW_SOURCE_MENU)
        case _OSDEVENT_SHOW_CHANGE_SOURCE_MENU_MSG:
            ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_GO_TO_POWER_SAVING);
            ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_SHOW_NO_CABLE);
            ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_SHOW_NO_SIGNAL);
            OsdFuncSetOsdItemFlag();
            g_usBackupValue = GET_OSD_INPUT_PORT_OSD_ITEM();
			
			OsdDispHotKeySourceMenu(_OSD_HOTKEY_INPUT); // �ź�ѡ��    // OsdDispHotKeySourceMenu();

            ScalerTimerReactiveTimerEvent(SEC(5), _USER_TIMER_EVENT_OSD_SHOW_NO_SIGNAL);
            //ScalerTimerReactiveTimerEvent(SEC(3), _USER_TIMER_EVENT_OSD_SHOW_POWER_SAVING);
            UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
			if(GET_POWER_INDICATOR() == _OFF)
				;
			else
				UserInterfaceKeyPadLedControl(_LED_POWER_ACTIVE);
            break;
#endif

        case _OSDEVENT_WAKE_UP_SWITCH_DDCCI_PORT_MSG:

            ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_GO_TO_POWER_SAVING);
            ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_SHOW_NO_CABLE);
            ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_SHOW_NO_SIGNAL);
            //SET_OSD_STATE(_MENU_HOTKEY_DDCCI);
            ScalerTimerActiveTimerEvent(SEC(3), _USER_TIMER_EVENT_GO_TO_POWER_SAVING);
            //ScalerTimerReactiveTimerEvent(SEC(3), _USER_TIMER_EVENT_OSD_SHOW_POWER_SAVING);
            UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);

            break;

        case _OSDEVENT_SHOW_POWER_SAVING_EVENT_MSG:
            OsdDispDisableOsd();
            OsdDispOsdMessage(_OSD_DISP_POWER_SAVING_MSG);
            UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
            ScalerTimerActiveTimerEvent(SEC(2), _USER_TIMER_EVENT_GO_TO_POWER_SAVING);
#if(_MPRT_SUPPORT == _ON)
			UserAdjustMPRTFuntion(_OFF);
#endif

#if(_AUDIO_TTS_SUPPORT_TYPE == _AUDIO_TTS_EMBEDDED_TYPE)
            UserAdjustAudioTtsPlayEvent(_AUDIO_TTS_EVENT_POWER_SAVING);
#endif // End of #if(_AUDIO_TTS_SUPPORT_TYPE == _AUDIO_TTS_EMBEDDED_TYPE)

            break;

        case _OSDEVENT_GO_TO_POWER_SAVING_EVENT_MSG:
			
            OsdDispDisableOsd();

 #if _OSD_Sleep_PowenOff_Fun
			if(GET_AUTO_POWEROFF_STATUS())
			{	
				g_usPowerOffCount = 3; // 3���Ӻ�ػ�
				ScalerTimerActiveTimerEvent(SEC(60), _USER_TIMER_EVENT_AUTO_POWER_DOWN); 
			}
#endif

            SysPowerSetTargetPowerStatus(_POWER_STATUS_SAVING);
            break;

#if(_VGA_SUPPORT == _ON)
        case _OSDEVENT_DO_AUTO_CONFIG_MSG:
#if(_FREEZE_SUPPORT == _ON)
            ScalerTimerWaitForActiveTimerEvent(_USER_TIMER_EVENT_OSD_DISABLE_FREEZE_MSG);
#endif
            OsdDispAutoConfigProc();
            break;
#endif

#if(_A0_INPUT_PORT_TYPE != _A0_NO_PORT)
        case _OSDEVENT_DO_AUTO_COLOR_MSG:
        	if(SysSourceGetSourceType() == _SOURCE_VGA)
            {
                //if(GET_OSD_HOTKEY_DETECT() == _FALSE)
                {
                    OsdDisplayAutoBalanceProc();
                    //SET_OSD_HOTKEY_DETECT(_TRUE);
                }
#if(_INSTANT_TIMER_EVENT_0 == _ON)
				ScalerTimer0SetTimerCount(_OFF); // this timer always counter
#endif
            }
        	break;
#endif


        case _OSDEVENT_ACTIVE_DO_ONE_TIME_MSG:

#if(_FREEZE_SUPPORT == _ON)
            ScalerTimerWaitForActiveTimerEvent(_USER_TIMER_EVENT_OSD_DISABLE_FREEZE_MSG);
#endif

#if(_VGA_SUPPORT == _ON)
            if(SysSourceGetSourceType() == _SOURCE_VGA)
            {
                if(UserInterfaceGetFirstAutoConfigStatus() == _TRUE)
                {
                    OsdDispAutoConfigProc();
                }
            }
#endif



            if((GET_OSD_STATE() == _MENU_NONE) 
#if(_FRONT_SIGHT_FUNCTION == _ON)
				|| (GET_OSD_STATE() == _OSD_HOTKEY_FRONT_SIGHT)
#endif
#if(_GSYNC_TEST== _ON)
				|| (GET_OSD_STATE() == _OSD_HOTKEY_VFREQ)
#endif
				)
            {
				if(GET_POWER_INDICATOR() == _OFF)
					UserInterfaceKeyPadLedControl(_LED_POWER_OFF);

                Input_Old_State=Input_New_State;
                Input_New_State=SysSourceGetInputPort();
				if(Input_Old_State!=Input_New_State)
				{
                	OsdDispOsdMessage(_OSD_DISP_INPUT_SIGNAL_MSG);
				}
#if(_FRONT_SIGHT_FUNCTION == _ON)
				else if(GET_OSD_FRONT_SIGHT())
				{
					OsdDispFrontSight();
				}
#endif
				
				if(GET_OSD_STATE() != _OSD_HOTKEY_FRONT_SIGHT  
					#if(_GSYNC_TEST== _ON)
					&& (GET_OSD_STATE() != _OSD_HOTKEY_VFREQ)
					#endif
					)
                	ScalerTimerActiveTimerEvent(SEC(3), _USER_TIMER_EVENT_OSD_DISABLE);


#if _OSD_Timing_Notice
				if((GET_INPUT_TIMING_HWIDTH()!=_PANEL_DH_WIDTH ||GET_INPUT_TIMING_VHEIGHT()!=_PANEL_DV_HEIGHT)&&GET_OSD_RESOLUTION_STATUS() && !GET_FACTORY_MODE())
				{
					g_usShowTimingNotice=1;
					ScalerTimerActiveTimerEvent(SEC(30), _USER_TIMER_EVENT_OSD_SHOW_Timing_Notice);
				}
				else
				{
					g_usShowTimingNotice=0;
					ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_SHOW_Timing_Notice);
				}
#endif

            }

#if _OSD_Sleep_PowenOff_Fun
			ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_AUTO_POWER_DOWN); 
#endif

#if _OSD_PowerSaving_Fun
			if(GET_AUTO_SLEEP_STATUS() == _SleepPowerSaving_30)
			{
				g_usPowerSavingCount = 30*_OSD_TIME_AUTO_DOWN;
				ScalerTimerActiveTimerEvent(SEC(1), _USER_TIMER_EVENT_AUTO_POWER_Saving); 
		
			}
			else if(GET_AUTO_SLEEP_STATUS() == _SleepPowerSaving_45)
			{
				g_usPowerSavingCount = 45*_OSD_TIME_AUTO_DOWN;
				ScalerTimerActiveTimerEvent(SEC(1), _USER_TIMER_EVENT_AUTO_POWER_Saving); 
		
			}
			else if(GET_AUTO_SLEEP_STATUS() == _SleepPowerSaving_60)
			{
				g_usPowerSavingCount = 60*_OSD_TIME_AUTO_DOWN;
				ScalerTimerActiveTimerEvent(SEC(1), _USER_TIMER_EVENT_AUTO_POWER_Saving); 
		
			}
			else if(GET_AUTO_SLEEP_STATUS() == _SleepPowerSaving_120)
			{
				g_usPowerSavingCount = 120*_OSD_TIME_AUTO_DOWN;
				ScalerTimerActiveTimerEvent(SEC(1), _USER_TIMER_EVENT_AUTO_POWER_Saving); 
		
			}
			else if(GET_AUTO_SLEEP_STATUS() == _SleepPowerSaving_OFF)
			{
				ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_AUTO_POWER_Saving); 
		
			}
#endif

		    SET_OSD_HOTKEY_BURNIN(_OFF);
		    TPVNVRamSaveFactoryDate();

			
            break;

        case _OSDEVENT_SAVE_NVRAM_SYSTEMDATA_MSG:
            UserCommonNVRamSaveSystemData();
            break;

#if(_VGA_SUPPORT == _ON)
        case _OSDEVENT_SAVE_NVRAM_MODEUSERDATA_MSG:
            UserCommonNVRamSaveModeUserData();
            break;
#endif
        case _OSDEVENT_SAVE_NVRAM_OSDUSERDATA_MSG:
            RTDNVRamSaveOSDData();
            break;

#if(_VGA_SUPPORT == _ON)
        case _OSDEVENT_SAVE_NVRAM_ADCDATA_MSG:
            if(ScalerColorGetColorSpaceRGB(UserCommonInterfaceGetColorFormat()) == _TRUE)
            {
                UserCommonNVRamSaveADCSetting(_COLOR_SPACE_RGB);
            }
            else
            {
                UserCommonNVRamSaveADCSetting(_COLOR_SPACE_YPBPR);
            }
            break;
#endif

        case _OSDEVENT_SAVE_NVRAM_COLORPROC_MSG:
            RTDNVRamSaveColorSetting(GET_COLOR_TEMP_TYPE());
            break;

        case _OSDEVENT_SAVE_NVRAM_BRICON_MSG:
            RTDNVRamSaveSceneModeData(GET_OSD_GAME_MODE());
            RTDNVRamSaveBriCon(SysSourceGetSourceType());
            break;

        case _OSDEVENT_SAVE_NVRAM_OSDSIXCOLORDATA_MSG:
            //RTDNVRamSaveSixColorData();
            break;
		case _OSDEVENT_BUININ_MSG:
			
	        if((SysModeGetModeState() == _MODE_STATUS_NOSIGNAL) && GET_FACTORY_BURNIN())
	        {
				FactoryBurnInEvent();			
	    	}
			else
			{
			
// #if (_BURNIN_MSG_MENU_SUPPORT==_ON)
				OsdDispDisableOsd();
// #endif
				ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_BUININ_MSG);
			}
			break;
			
		case _OSDEVENT_SHOW_OSD_LOCK_MSG:
            OsdDispOsdMessage(_OSD_DISP_LOCK_STATUS_MSG);
			//UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
			//UserInterfaceKeyPadLedControl(_LED_POWER_ACTIVE);
			
#if(_DEF_JS_KEY_ICON_5_KEY_MODE)
#if(_INSTANT_TIMER_EVENT_0 == _ON)
			ScalerTimer0SetTimerCount(_TIMER_OFF);
#endif
#else
			ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_OSD_SHOW_OSD_LOCKING_STATUS_MSG);
#endif
            ScalerTimerActiveTimerEvent(SEC(3), _USER_TIMER_EVENT_OSD_DISABLE);
			break;

		case _OSDEVENT_SHOW_POWER_LOCK_MSG:
			OsdDispOsdMessage(_OSD_DISP_POWER_LOCK_STATUS_MSG);
#if(_INSTANT_TIMER_EVENT_0 == _ON)
			ScalerTimer0SetTimerCount(_TIMER_OFF);
#endif
            ScalerTimerActiveTimerEvent(SEC(3), _USER_TIMER_EVENT_OSD_DISABLE);
			break;
			
		case _OSDEVENT_LOGOBOOTUP_MSG:
			OsdDispOsdMessage(_OSD_DISP_LOGO_BOOTUP_STATUS_MSG);
			break;
			
		case _OSDEVENT_SHOW_AUTO_POWER_OFF_MSG:
			OsdDispOsdMessage(_OSD_DISP_AUTO_POWER_OFF_MSG);
			break;

			
#if(_DEF_VGA_TIMING_KEY_2_4)
        case _OSDEVENT_SWITCHMODE_MSG:
#if(_A0_INPUT_PORT_TYPE != _A0_NO_PORT)
			OsdDispModeSwitch(); 
#endif
        	break;

#endif




        default:
            break;
    }

    SET_OSD_EVENT_MESSAGE(_OSDEVENT_NONE_MSG);
}


void MenuNone(void)
{

#if(_DEF_NAVIGATION_OSD_ENABLE)


#if(_DEF_NO_SIGNAL_SHOW_SOURCE_MENU)
		if(SysModeGetModeState() != _MODE_STATUS_ACTIVE)
		{
			if(SysSourceGetScanType() != (_SOURCE_SWITCH_AUTO_IN_GROUP))
			{
				SET_OSD_POWER_SAVING_SHOW_SOURCE(_ON); // �ź�ѡ��
	
				if((SysPowerGetPowerStatus() == _POWER_STATUS_SAVING))
				{
					SysPowerSetTargetPowerStatus(_POWER_STATUS_NORMAL);
				}
				
				return;
			}
		}
#endif


    switch(GET_KEYMESSAGE())
    {
    	case _MIDDLE_KEY_MESSAGE:
		case _LEFT_KEY_MESSAGE:
		case _UP_KEY_MESSAGE:
		case _EXIT_KEY_MESSAGE:   //�������ѡ����м�ֵ��Ϊ"3"?????	
			if((SysModeGetModeState() != _MODE_STATUS_ACTIVE)||(SysModeGetModeState() == _MODE_STATUS_NOSIGNAL))
			{
				if(SysModeGetModeState() == _MODE_STATUS_POWER_SAVING && GET_KEYMESSAGE() != _MIDDLE_KEY_MESSAGE)
				{
					if(GetOsdValue(_MENU_FUN_SEARCH) == _FALSE)
					{
						SET_OSD_POWER_SAVING_SHOW_SOURCE(_TRUE);

						if(SysPowerGetPowerStatus() == _POWER_STATUS_SAVING)
						{
						    SysPowerSetTargetPowerStatus(_POWER_STATUS_NORMAL);
						}
					}
				}
				return;
			}
				
			if(GET_FACTORY_MODE() == _ON)
			{
				RTDFactoryMainMenu();
				return;
			}

#if(ENABLE_LANGUAGE_SELECT_OSD)			
			if(GET_OSD_LANGUAGE_HK_STATUS() != _OFF)
			{
                OsdDispHotKeySourceMenu(_OSD_HOTKEY_LANGUAGE_SELECT);
			}
			else
#endif

#if(_DEF_District_swtich_Message == _ON)
			if(GET_OSD_DISTRICT_SWTICH_STATE() != _OFF) //������ԣ�����ѡ�񣬽���˵�
			{
				OsdDispHotKeySourceMenu(_OSD_HOTKEY_DISTRICT_SELECT);
			}
			else 
#endif

#if(_POWER_CONSUMPTION_HINT_SUPPORT == _ON)
			if(GET_OSD_PC_HINT_STATUS() != _OFF)
			{
				OsdDisplayPowerConsumptionHint();
			}
			else
#endif

			{	
#if(_DEF_NAVIGATION_OSD_ENABLE)
				OsdDisplayUserKeyPage();
#endif
			}
			break;

		case _RIGHT_KEY_MESSAGE:
			
			if((SysModeGetModeState() == _MODE_STATUS_ACTIVE)&&(SysModeGetModeState() != _MODE_STATUS_NOSIGNAL))
			{
				if(GET_FACTORY_MODE() == _ON)
				{
					RTDFactoryMainMenu();
				
					return;
				}
#if ENABLE_LANGUAGE_SELECT_OSD
				if(GET_OSD_LANGUAGE_HK_STATUS() != _OFF)
				{
	                OsdDispHotKeySourceMenu(_OSD_HOTKEY_LANGUAGE_SELECT);
				}
				else
#endif

#if(_DEF_District_swtich_Message == _ON)
				if(GET_OSD_DISTRICT_SWTICH_STATE() != _OFF) //������ԣ�����ѡ�񣬽���˵�
				{
					OsdDispHotKeySourceMenu(_OSD_HOTKEY_DISTRICT_SELECT);
				}
				else
#endif

#if(_POWER_CONSUMPTION_HINT_SUPPORT == _ON)
				if(GET_OSD_PC_HINT_STATUS() != _OFF)
				{
					OsdDisplayPowerConsumptionHint();
				}
				else
#endif
				{	
					if(0);
#if(_DEF_NAVIGATION_OSD_ENABLE)
					else
						OsdDisplayUserKeyPage();
#endif
				}
			}
			else if(SysModeGetModeState() == _MODE_STATUS_POWER_SAVING)
            {
            	if(GetOsdValue(_MENU_FUN_SEARCH) == _FALSE)
        		{
		            SET_OSD_POWER_SAVING_SHOW_SOURCE(_TRUE);

		            if(SysPowerGetPowerStatus() == _POWER_STATUS_SAVING)
		            {
		                SysPowerSetTargetPowerStatus(_POWER_STATUS_NORMAL);
		            }
        		}
            }
			break;

		case _DOWN_KEY_MESSAGE:
			if((SysModeGetModeState() != _MODE_STATUS_ACTIVE)||(SysModeGetModeState() == _MODE_STATUS_NOSIGNAL))
			{
				if(SysModeGetModeState() == _MODE_STATUS_POWER_SAVING && GET_KEYMESSAGE() != _MIDDLE_KEY_MESSAGE)
				{
						if(GetOsdValue(_MENU_FUN_SEARCH) == _FALSE)
						{
							SET_OSD_POWER_SAVING_SHOW_SOURCE(_TRUE);

							if(SysPowerGetPowerStatus() == _POWER_STATUS_SAVING)
							{
							    SysPowerSetTargetPowerStatus(_POWER_STATUS_NORMAL);
							}
						}
				}
				return;
			}
				
			if(GET_FACTORY_MODE() == _ON)
			{
				RTDFactoryMainMenu();
			
				return;
			}

#if(_DEFAULT_OSD_STYLE == _TRG_OSD_STYLE)
				OsdDisplayUserKeyPage();
#else

			#if(_FRONT_SIGHT_FUNCTION == _ON)
				OsdDispFrontSight();
			#endif

#endif
			break;

		default:
			break;
    }

/*********************************else***********************************/ 
#else


//RTDOsdSystemFlowProc
#if(_DEF_NO_SIGNAL_SHOW_SOURCE_MENU)
	if(SysModeGetModeState() != _MODE_STATUS_ACTIVE)
	{
		if(SysSourceGetScanType() != (_SOURCE_SWITCH_AUTO_IN_GROUP))
		{
			SET_OSD_POWER_SAVING_SHOW_SOURCE(_ON); // �ź�ѡ��

			if((SysPowerGetPowerStatus() == _POWER_STATUS_SAVING))
			{
				SysPowerSetTargetPowerStatus(_POWER_STATUS_NORMAL);
			}
            
			return;
		}
	}
#endif

    switch(GET_KEYMESSAGE())
    {
        case _MENU_KEY_MESSAGE:
            if(SysModeGetModeState() == _MODE_STATUS_ACTIVE)
            {
				if(GET_FACTORY_MODE() == _ON)
				{
					RTDFactoryMainMenu();
					return;
				}

				if(0);
#if(ENABLE_LANGUAGE_SELECT_OSD)			
				else if(GET_OSD_LANGUAGE_HK_STATUS() == _ON)
				{
					OsdDispHotKeySourceMenu(_OSD_HOTKEY_LANGUAGE_SELECT); // ����ѡ��
				}
#endif
#if(_DEF_District_swtich_Message == _ON)
				else if(GET_OSD_DISTRICT_SWTICH_STATE() == _ON)
				{
					OsdDispHotKeySourceMenu(_OSD_HOTKEY_DISTRICT_SELECT); // ����ѡ��
				}
#endif
#if(_POWER_CONSUMPTION_HINT_SUPPORT == _ON)
				else if(GET_OSD_PC_HINT_STATUS() == _ON) //�ܺ�����
				{
					OsdDisplayPowerConsumptionHint();
				}
				else
#else
				else
#endif

				{
				     //OsdDispOsdMessage(_OSD_DISP_Timing_Notice); 
					OsdDispMainMenu();
				}	




            }
            break;

        case _RIGHT_KEY_MESSAGE:
			
            if(SysModeGetModeState() == _MODE_STATUS_ACTIVE)
            {
				CLR_KEYREPEATENABLE();
				if(GET_FACTORY_MODE() == _ON)
				{
					RTDFactoryMainMenu();
					return;
				}
				
				if(0);
#if(ENABLE_LANGUAGE_SELECT_OSD)			
				else if(GET_OSD_LANGUAGE_HK_STATUS() == _ON)
				{
					OsdDispHotKeySourceMenu(_OSD_HOTKEY_LANGUAGE_SELECT); // ����ѡ��
				}
#endif
#if(_DEF_District_swtich_Message == _ON)
				else if(GET_OSD_DISTRICT_SWTICH_STATE() == _ON)
				{
					OsdDispHotKeySourceMenu(_OSD_HOTKEY_DISTRICT_SELECT); // ����ѡ��
				}
#endif
#if(_POWER_CONSUMPTION_HINT_SUPPORT == _ON)
				else if(GET_OSD_PC_HINT_STATUS() == _ON) //�ܺ�����
				{
					OsdDisplayPowerConsumptionHint();
				}
				else
#else
				else
#endif

				{
					OsdDispMainMenu();
				}

			}


            break;

        case _LEFT_KEY_MESSAGE:

			if(SysModeGetModeState() == _MODE_STATUS_ACTIVE)
            {
				CLR_KEYREPEATENABLE();
				if(GET_FACTORY_MODE() == _ON)
				{
					RTDFactoryMainMenu();
					return;
				}

				if(0);
#if(ENABLE_LANGUAGE_SELECT_OSD)			
				else if(GET_OSD_LANGUAGE_HK_STATUS() == _ON)
				{
					OsdDispHotKeySourceMenu(_OSD_HOTKEY_LANGUAGE_SELECT); // ����ѡ��
				}
#endif
#if(_DEF_District_swtich_Message == _ON)
				else if(GET_OSD_DISTRICT_SWTICH_STATE() == _ON)
				{
					OsdDispHotKeySourceMenu(_OSD_HOTKEY_DISTRICT_SELECT); // ����ѡ��
				}
#endif
#if(_POWER_CONSUMPTION_HINT_SUPPORT == _ON)
				else if(GET_OSD_PC_HINT_STATUS() == _ON) //�ܺ�����
				{
					OsdDisplayPowerConsumptionHint();
				}
				else
#else
				else
#endif
				{
#if(_5KEY_MENU_STYLE)	  //2025.2.14 tx			
				if(SysSourceGetSourceType() == _SOURCE_VGA&&GET_OSD_HOTKEY_LEFT()==_OSD_HOTKEY_VOLUME)
				   {
					SET_OSD_HOTKEY_LEFT(_OSD_HOTKEY_CONBRI);
				   }
				else
				  {
					if(GET_OSD_DCR_STATUS()!=0&&GET_OSD_HOTKEY_LEFT()==_OSD_HOTKEY_CONBRI)
					 SET_OSD_HOTKEY_LEFT(_OSD_HOTKEY_INPUT);
				   }
#endif	

					OsdDispHotKeySourceMenu(GET_OSD_HOTKEY_LEFT());
				}	

			}


			

            break;

        case _EXIT_KEY_MESSAGE:

			if(SysModeGetModeState() == _MODE_STATUS_ACTIVE)
            {
				CLR_KEYREPEATENABLE();
				if(GET_FACTORY_MODE() == _ON)
				{
					RTDFactoryMainMenu();
					return;
				}

				if(0);
#if(ENABLE_LANGUAGE_SELECT_OSD)			
				else if(GET_OSD_LANGUAGE_HK_STATUS() == _ON)
				{
					OsdDispHotKeySourceMenu(_OSD_HOTKEY_LANGUAGE_SELECT); // ����ѡ��
				}
#endif
#if(_DEF_District_swtich_Message == _ON)
				else if(GET_OSD_DISTRICT_SWTICH_STATE() == _ON)
				{
					OsdDispHotKeySourceMenu(_OSD_HOTKEY_DISTRICT_SELECT); // ����ѡ��
				}
#endif
#if(_POWER_CONSUMPTION_HINT_SUPPORT == _ON)
				else if(GET_OSD_PC_HINT_STATUS() == _ON) //�ܺ�����
				{
					OsdDisplayPowerConsumptionHint();
				}
				else
#else
				else
#endif
				{
					OsdDispMainMenu();
				}

			}

			
            break;

        default:
            break;
    }


	
#endif
}











void MenuInput(void)
{
    switch(GET_KEYMESSAGE())
    {
        case _MENU_KEY_MESSAGE:
        	
			OSDSubMenuMove();
            break;

        case _RIGHT_KEY_MESSAGE:
#if(_DEF_NO_SIGNAL_SHOW_SOURCE_MENU)
			if(SysModeGetModeState() != _MODE_STATUS_ACTIVE)
			{
				break;
			}
#endif

#if(_MENU_AUDIO_SUPPORT && _DEFAULT_OSD_STYLE!=_SUMA_OSD_STYLE)
           if(SysSourceGetSourceType() == _SOURCE_VGA)  //2025.2.11 tx
            UpdateOSDMainInterface(_MENU_VIEWMODE);
		   else
			UpdateOSDMainInterface(_MENU_AUDIO);
#else
			UpdateOSDMainInterface(_MENU_VIEWMODE);
#endif
            break;
        case _LEFT_KEY_MESSAGE:
			
			UpdateOSDMainInterface(_MENU_SETUP);
            break;

        case _EXIT_KEY_MESSAGE:
#if(_5KEY_MENU_STYLE)  //2025.2.13  tx wan
		    ScalerTimerDelayXms(_KEY_DELAYED_TIME); 
#endif			
			OsdDispDisableOsd();
            break;

#if(_DEF_KEY_ROCKER)
		case _UP_KEY_MESSAGE:
			UpdateOSDMainInterface(_MENU_SETUP);
			OSD_SubMenuCur = InforMation_index;
			OSDSubMenuMove();
			break;
#endif

        default:
            break;
    }
}

