void MENU_FUN_COMMON(void)
{
	DebugMessageOsd("My_COMMON",GET_OSD_STATE());
    switch(GET_KEYMESSAGE())
    {
        case _MENU_KEY_MESSAGE: 
        case _EXIT_KEY_MESSAGE:

            OSDSubMenuMove();
            break;

        case _RIGHT_KEY_MESSAGE:
        case _LEFT_KEY_MESSAGE:
		case _UP_KEY_MESSAGE:
		case _DOWN_KEY_MESSAGE:
			OsdInterfaceAdjust();
            SpecialFuncAdj();		
			if((GET_OSD_VOLUME_MUTE() == _ON)&&(GET_OSD_VOLUME() !=0)&&(GET_OSD_STATE() == _MENU_FUN_VOLUME ))
			{
				SET_OSD_VOLUME_MUTE(_OFF);
				#if(_DEF_MAIN_MENU_MUTE_ICON_SUPPORT == _ON)
				OsdDisplayVolumeAdjustUpdateIcon();
				#endif
			}
            break;

        default:
            break;
    }
}



BYTE InputSourceConvert(BYTE ucInputPort)
{

	
	if(0);
	
#if(_A0_INPUT_PORT_TYPE != _A0_NO_PORT)
	else if(ucInputPort==_OSD_INPUT_A0)
		ucInputPort = _A0_INPUT_PORT;
#endif

#if(_D0_INPUT_PORT_TYPE != _D0_NO_PORT)
	else if(ucInputPort==_OSD_INPUT_D0)
		ucInputPort = _D0_INPUT_PORT;
#endif

#if(_D1_INPUT_PORT_TYPE != _D1_NO_PORT)
	else if(ucInputPort==_OSD_INPUT_D1)
		ucInputPort = _D1_INPUT_PORT;
#endif

#if(_D2_INPUT_PORT_TYPE != _D2_NO_PORT)
	else if(ucInputPort==_OSD_INPUT_D2)
		ucInputPort = _D2_INPUT_PORT;
#endif

#if(_D3_INPUT_PORT_TYPE != _D3_NO_PORT)
	else if(ucInputPort==_OSD_INPUT_D3)
		ucInputPort = _D3_INPUT_PORT;
#endif

#if(_D4_INPUT_PORT_TYPE != _D4_NO_PORT)
	else if(ucInputPort==_OSD_INPUT_D4)
		ucInputPort = _D4_INPUT_PORT;
#endif

	return ucInputPort;
}





void HotKeyFUNAdjust(void)
{

	//WORD usValue;

    switch (OSD_HOT_KEY_PAGE)
    {
    
#if(ENABLE_LANGUAGE_SELECT_OSD)			
        case _OSD_HOTKEY_LANGUAGE_SELECT:
            if (GET_OSD_LANGUAGE_HK_STATUS() == _ON)
            {  
            	if(GET_KEYMESSAGE()==_MENU_KEY_MESSAGE)
                	SET_OSD_LANGUAGE(OsdHotLanguageSelect[OSD_SubMenuCur]);
				
                SET_OSD_LANGUAGE_HK_STATUS(_OFF); // �������ѡ����л�������ѡ��
     #if(_5KEY_MENU_STYLE)  //2025.2.13  tx wan
		       ScalerTimerDelayXms(_KEY_DELAYED_TIME); 
     #endif	
                //OsdFuncDisableOsd();
                
				#if _GSYNC_TEST
					ucDsiableShowVFreqFlag = 0;
				#endif
	 			OsdDispDisableOsd();
                
				
	#if(_DEF_NO_CHECK_LANGUAGE_DISTRICT_MODE_SWTICH)
                OsdDispDrawHotKeyWindow(_OSD_HOTKEY_DISTRICT_SELECT);
	#else
				SET_OSD_STATE(_MENU_NONE);
				SET_OSD_DISTRICT_SWTICH_STATE(_ON);
				
	#endif
				RTDNVRamSaveOSDData();

            }
            break;
#endif

#if(_DEF_District_swtich_Message == _ON)

        case _OSD_HOTKEY_DISTRICT_SELECT:
            if (GET_OSD_DISTRICT_SWTICH_STATE() == _ON && GET_KEYMESSAGE()==_MENU_KEY_MESSAGE)
            {
#if(_DEF_ZhongDong)
                if(OSD_SubMenuCur == _DEF_REGION_AMERICAS  || OSD_SubMenuCur == _DEF_REGION_EUROPE || OSD_SubMenuCur == _DEF_REGION_MIDDLE_EAST) // ŷ�� Ĭ������
#else
				if(OSD_SubMenuCur == _DEF_REGION_AMERICAS  || OSD_SubMenuCur == _DEF_REGION_EUROPE) // ŷ�� Ĭ������
#endif
                {
					SET_OSD_DISTRICT(OSD_SubMenuCur);
                    if(GET_OSD_BACKLIGHT() != _DEF_REGION_BACKLIGHT)
                    {
                     #if(_5KEY_MENU_STYLE)  //2025.2.13 tx
                        SET_OSD_BACKLIGHT(70);
					 #else
                        SET_OSD_BACKLIGHT(_DEF_REGION_BACKLIGHT);
					 #endif
                        //PCB_BACKLIGHT_PWM(_BACKLIGHT_MAX - GET_OSD_BACKLIGHT());
                       // RTDNVRamRestoreBacklight();
						RTDNVRamSaveSceneModeData(GET_OSD_GAME_MODE()); //��������
                    }
                }

                else
                {
                	SET_OSD_DISTRICT(OSD_SubMenuCur);
                    if (GET_OSD_BACKLIGHT() != 100)
                    {
                        SET_OSD_BACKLIGHT(100); 
                        //PCB_BACKLIGHT_PWM(_BACKLIGHT_MAX - GET_OSD_BACKLIGHT());
                        //RTDNVRamRestoreBacklight();
						RTDNVRamSaveSceneModeData(GET_OSD_GAME_MODE()); //��������
                    }
                }
				UserAdjustBacklight(GET_OSD_BACKLIGHT());
   #if(_5KEY_MENU_STYLE)  //2025.2.13	tx wan
				 ScalerTimerDelayXms(_KEY_DELAYED_TIME); 
   #endif 
                OsdFuncDisableOsd();
                SET_OSD_STATE(_MENU_NONE);
                SET_OSD_DISTRICT_SWTICH_STATE(_OFF);
                RTDNVRamSaveOSDData();
            }
			else if(GET_KEYMESSAGE()==_EXIT_KEY_MESSAGE)
			{
                OsdFuncDisableOsd();
                SET_OSD_STATE(_MENU_NONE);
                SET_OSD_DISTRICT_SWTICH_STATE(_OFF);
                RTDNVRamSaveOSDData();

			}
			//DebugMessageOsd("4._OSD_HOTKEY_DISTRICT_SELECT",567);
            break;

#endif

#if(_POWER_CONSUMPTION_HINT_SUPPORT == _ON)
		case _OSD_HOTKEY_POWER_CONSUMPTION_HINT:
			if(GET_OSD_PC_HINT_STATUS() == _ON)
			{
				SET_OSD_PC_HINT_STATUS(_OFF);
				RTDNVRamSaveOSDData();
#if(_DEF_NAVIGATION_OSD_ENABLE)
				OsdDisplayUserKeyPage();
#else
				OsdDispMainMenu();
#endif
			}
			break;
#endif

        case _OSD_HOTKEY_VIEWMODE:
			
			UserAdjustViewMode();
			UpdateMaskValue();
			//OsdDispDrawHotKeyWindow(_OSD_HOTKEY_VIEWMODE);
#if 0//(_DEF_JS_KEY_ICON_5_KEY_MODE)
       #if(_PROJECT_ID==_ID_ZQ_2513E05_PANDA_LC215DTBA_8BIT_FHD75_VA2271_H_20241223)
           // OsdFontPut1BitTable(ROW(2*OsdHotPageSize[HotKeyPageIndex]+3), COL(9), tiOSD_OSDKEY_ICON_ConBri, COLOR((OSD_ITEM_MASK_GET(_OSD_HOTKEY_CONBRI) ? _CP_BLOCK : _CP_WHITE), _CP_BG));
	   #else
			OsdFontPut1BitTable(ROW(2*OsdHotPageSize[HotKeyPageIndex]+3), COL(7), tiOSD_OSDKEY_ICON_ConBri, COLOR((OSD_ITEM_MASK_GET(_OSD_HOTKEY_CONBRI) ? _CP_BLOCK : _CP_WHITE), _CP_BG));
       #endif
#endif
			//RTDFlashSaveOSDData();
            break;

        case _OSD_HOTKEY_CONBRI:
				
			//DebugMessageOsd("1.ucTypeTemp",1);

            OsdDisplaySliderAndNumber(OsdHotConbri[OSD_SubMenuCur], GetOsdValue(OsdHotConbri[OSD_SubMenuCur]), _SLIDER_HOTKEY);
            //RTDNVRamSaveOSDData();
            break;
			
#if(_MENU_AUDIO_SUPPORT)
        case _OSD_HOTKEY_VOLUME:
            OsdDisplaySliderAndNumber(_OSD_HOTKEY_VOLUME, GetOsdValue(_OSD_HOTKEY_VOLUME), _SLIDER_HOTKEY);
            SET_OSD_VOLUME_MUTE(_OFF);     
#if(_DEF_JS_KEY_ICON_5_KEY_MODE)			
            OsdDisplayUpdateVolumeMuteIcon();
#endif
            //RTDNVRamSaveOSDData();
			ScalerTimerReactiveTimerEvent(SEC(1),_USER_TIMER_EVENT_SAVE_OSD_DATE);
            break;
#endif

		case _OSD_HOTKEY_INPUT:


			if(GET_KEYMESSAGE() == _MENU_KEY_MESSAGE && GetOsdValue(_MENU_INPUT)!=OSD_SubMenuCur )
			{
			
				Input_New_State = 10; // ֻҪ���źž��㵱ǰͨ������
				SET_FORCE_POW_SAV_STATUS(_FALSE);
				SET_OSD_STATE(_MENU_NONE);

				ScalerDDomainPatternGenAdjustColor(0, 0, 0);//�ر���Ĺ������������ƻ���һЩ���߰���Ļ���
				ScalerDDomainBackgroundSetColor(0, 0, 0);
				ScalerDDomainBackgroundEnable(_ENABLE);
				
				//DebugMessageOsd("4._OSD_HOTKEY_INPUT",567);

				SysSourceSwitchInputPort(InputSourceConvert(OSD_SubMenuCur));

			
			    #if(_MPRT_SUPPORT)	
				if(GET_OSD_MPRT())
				{
					SET_OSD_MPRT(_OFF);
					UserAdjustMPRTFuntion(GET_OSD_MPRT());
				}
				#endif
				
				if((SysSourceGetScanType() == _SOURCE_SWITCH_AUTO_IN_GROUP) )
				{
					SysSourceSetScanType(_SOURCE_SWITCH_AUTO_IN_GROUP);

					if(UserCommonNVRamGetSystemData(_SOURCE_SCAN_TYPE) != SysSourceGetScanType())
					{
						UserCommonNVRamSetSystemData(_SOURCE_SCAN_TYPE, SysSourceGetScanType());
						SET_OSD_EVENT_MESSAGE(_OSDEVENT_SAVE_NVRAM_SYSTEMDATA_MSG);
					}

				}
				else //(SysSourceGetScanType() == _SOURCE_SWITCH_FIXED_PORT)
				{
					SysSourceSetScanType(_SOURCE_SWITCH_FIXED_PORT);

					if((UserCommonNVRamGetSystemData(_SEARCH_PORT) != SysSourceGetInputPort()) ||
					   (UserCommonNVRamGetSystemData(_SOURCE_SCAN_TYPE) != SysSourceGetScanType()))
					{
						UserCommonNVRamSetSystemData(_SEARCH_PORT, SysSourceGetInputPort());
						UserCommonNVRamSetSystemData(_SOURCE_SCAN_TYPE, SysSourceGetScanType());
						SET_OSD_EVENT_MESSAGE(_OSDEVENT_SAVE_NVRAM_SYSTEMDATA_MSG);

					}

				}
				SysModeSetResetTarget(_MODE_ACTION_RESET_TO_SEARCH);

			}

			break;

        default:
            break;
    }
}


