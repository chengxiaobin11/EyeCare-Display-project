 468          //--------------------------------------------------
 469          // Description  : Deal With Power Manage According To Input Pamater
 470          // Input Value  : ucSwitch    --> Power action description.
 471          // Output Value : None
 472          //--------------------------------------------------
 473          void SysPowerSwitch(EnumPowerAction enumSwitch)
 474          {
 475   1          switch(enumSwitch)
 476   1          {
 477   2              case _POWER_ACTION_NORMAL_TO_PS:
 478   2      
 479   2                  // User Power Process
 480   2                  UserInterfacePowerSwitch(enumSwitch);
 481   2      
 482   2      #if(_AUDIO_SUPPORT == _ON)
 483   2                  SysAudioPowerProc(enumSwitch);
 484   2      #endif
 485   2                  // Mode Power Saving Process
 486   2                  SysModeResetState(_MODE_ACTION_RESET_TO_POWER_SAVING);
 487   2      
 488   2      #if(_MEMORY_TYPE_CONFIG != _NO_MEMORY)
 489   2                  ScalerMemoryPowerControl(_OFF);
 490   2      #endif
 491   2      
 492   2      #if(_DP_TYPE_C_PORT_CTRL_SUPPORT == _ON)
                          SysTypeCPowerSwitch(enumSwitch);
              #endif
 495   2      
 496   2      #if(_DP_SUPPORT == _ON)
 497   2                  // DP Fake LT Protect
 498   2                  ScalerSyncDpFakeLTProtect();
 499   2      #endif
 500   2      
 501   2      #if(_HDMI_SUPPORT == _ON)
 502   2                  if((UserInterfaceGetForcePSStatus() == _TRUE) || (UserInterfaceForcePSWakeupTmdsHpdToggle() ==
             - _USER_FORCE_PS_TMDS_HPD_TOGGLE))
 503   2                  {
 504   3                      SysTMDSRxSetPsWakeupHpdToggle();
 505   3                  }
 506   2      #endif
 507   2      
 508   2      #if(_SYSTEM_LOW_POWER_GEN == _POWER_FLOW_GEN_1)
 509   2                  // Interface Power Saving Process
 510   2                  ScalerSyncPowerProc(enumSwitch);
 511   2      #endif
