 299          //--------------------------------------------------
 300          // Description  : Power Handler Process
 301          // Input Value  : None
 302          // Output Value : None
 303          //--------------------------------------------------
 304          void SysPowerHandler(void)
 305          {
 306   1          // The process will deal with all kinds of power changing by power action flag.
 307   1          switch(GET_TARGET_POWER_STATUS())
 308   1          {
 309   2              case _POWER_STATUS_NORMAL:
 310   2      
 311   2                  switch(GET_POWER_STATUS())
 312   2                  {
 313   3                      case _POWER_STATUS_OFF:
 314   3      
 315   3                          if(SysPowerCheckNormal() == _TRUE)
 316   3                          {
 317   4                              SysPowerSwitch(_POWER_ACTION_OFF_TO_NORMAL);
 318   4                          }
 319   3                          else
 320   3                          {
 321   4                              SysPowerSwitch(_POWER_ACTION_OFF_TO_FAKE_OFF);
 322   4                          }
 323   3                          break;
 324   3      
 325   3                      case _POWER_STATUS_SAVING:
 326   3      
 327   3                          SysPowerSwitch(_POWER_ACTION_PS_TO_NORMAL);
 328   3      
 329   3      #if(_AIO_MODERN_STANDBY_SUPPORT == _ON)
                                  if(UserInterfaceGetAIOModernStandbyMode() == _AIO_MODERN_STANDBY_MODE_ENABLE)
                                  {
                                      SET_AIO_MODERN_STANDBY_MODE();
                                      ScalerTimerReactiveTimerEvent(SEC(0.5), _SYSTEM_TIMER_EVENT_AIO_MODERN_STANDBY_MOD
             -E_TIMEOUT);
C51 COMPILER V9.01   SYSPOWER                                                              08/18/2025 18:00:50 PAGE 7   

                                  }
                                  else
                                  {
                                      CLR_AIO_MODERN_STANDBY_MODE();
                                      ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_AIO_MODERN_STANDBY_MODE_TIMEOUT);
                                  }
              #endif
 341   3                          break;
 342   3      
 343   3                      case _POWER_STATUS_AC_ON:
 344   3                          SysPowerSwitch(_POWER_ACTION_AC_ON_TO_NORMAL);
 345   3                          break;
 346   3      
 347   3                      case _POWER_STATUS_NORMAL:
 348   3      
 349   3                          if((GET_MODE_STATE() == _MODE_STATUS_POWER_OFF) || (GET_POWER_SWITCH_TO_FAKE_OFF() == 
             -_TRUE))
 350   3                          {
 351   4                              CLR_POWER_SWITCH_TO_FAKE_OFF();
 352   4                              ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_POWER_FAKE_OFF_TO_OFF);
 353   4                              SysPowerSwitch(_POWER_ACTION_FAKE_OFF_TO_NORMAL);
 354   4                          }
 355   3                          else if(GET_POWER_SWITCH_TO_FAKE_SAVING() == _TRUE)
 356   3                          {
 357   4                              CLR_POWER_SWITCH_TO_FAKE_SAVING();
 358   4                              SysPowerSwitch(_POWER_ACTION_FAKE_PS_TO_NORMAL);
 359   4      
 360   4      #if(_AIO_MODERN_STANDBY_SUPPORT == _ON)
                                      if(UserInterfaceGetAIOModernStandbyMode() == _AIO_MODERN_STANDBY_MODE_ENABLE)
                                      {
                                          SET_AIO_MODERN_STANDBY_MODE();
                                          ScalerTimerReactiveTimerEvent(SEC(0.5), _SYSTEM_TIMER_EVENT_AIO_MODERN_STANDBY
             -_MODE_TIMEOUT);
                                      }
                                      else
                                      {
                                          CLR_AIO_MODERN_STANDBY_MODE();
                                          ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_AIO_MODERN_STANDBY_MODE_TIMEOU
             -T);
                                      }
              #endif
 372   4                          }
 373   3      
 374   3                          break;
 375   3      
 376   3                      default:
 377   3                          break;
 378   3                  }
 379   2      
 380   2                  SET_POWER_STATUS(_POWER_STATUS_NORMAL);
 381   2      
 382   2                  break;
 383   2      
 384   2              case _POWER_STATUS_OFF:
 385   2      
 386   2                  CLR_POWER_SWITCH_TO_FAKE_SAVING();
 387   2      
 388   2                  // Clear Mode change flag
 389   2                  CLR_MODE_STATE_CHANGE_MODE();
 390   2      
 391   2                  switch(GET_POWER_STATUS())
 392   2                  {
C51 COMPILER V9.01   SYSPOWER                                                              08/18/2025 18:00:50 PAGE 8   

 393   3                      case _POWER_STATUS_SAVING:
 394   3                          SysPowerSwitch(_POWER_ACTION_PS_TO_OFF);
 395   3                          SET_POWER_STATUS(_POWER_STATUS_OFF);
 396   3                          break;
 397   3      
 398   3                      case _POWER_STATUS_AC_ON:
 399   3                          SysPowerSwitch(_POWER_ACTION_AC_ON_TO_OFF);
 400   3                          SET_POWER_STATUS(_POWER_STATUS_OFF);
 401   3                          break;
 402   3      
 403   3                      case _POWER_STATUS_NORMAL:
