  48          // Description  : Adjust Contrast
  49          // Input Value  : EnumBriConCoefType, Coefficient
  50          //                12 bit input, old 8 bit contrast input value must left shift 4 bit
  51          //                0 (00h) ~ 1(800h) ~  2(FFFh)
C51 COMPILER V8.12   RL6449_SERIES_COLORCONTRASTADJUST                                     03/11/2025 19:56:02 PAGE 2   

  52          // Output Value : void
  53          //--------------------------------------------------
  54          void ScalerColorContrastAdjust(EnumBriConCoefType enumBriConCoefType, WORD *pusData)
  55          {
  56   1          switch(enumBriConCoefType)
  57   1          {
  58   2              case _CONTRAST_COEF_A:
  59   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_03_CTS_RED_COE_SETA_H, (pusData[0] & 0
             -x0FF0) >> 4);
  60   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_04_CTS_GRN_COE_SETA_H, (pusData[1] & 0
             -x0FF0) >> 4);
  61   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_05_CTS_BLU_COE_SETA_H, (pusData[2] & 0
             -x0FF0) >> 4);
  62   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_21_CTS_COE_SETA_RG_L, ((pusData[0] & 0
             -x000F) << 4) | ((pusData[1] & 0x000F)));
  63   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_22_CTS_COE_SETA_B_L, (pusData[2] & 0x0
             -00F) << 4);
  64   2                  break;
  65   2      
  66   2              case _CONTRAST_COEF_B:
  67   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_09_CTS_RED_COE_SETB_H, (pusData[0] & 0
             -x0FF0) >> 4);
  68   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_0A_CTS_GRN_COE_SETB_H, (pusData[1] & 0
             -x0FF0) >> 4);
  69   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_0B_CTS_BLU_COE_SETB_H, (pusData[2] & 0
             -x0FF0) >> 4);
  70   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_24_CTS_COE_SETB_RG_L, ((pusData[0] & 0
             -x000F) << 4) | ((pusData[1] & 0x000F)));
  71   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_25_CTS_COE_SETB_B_L, (pusData[2] & 0x0
             -00F) << 4);
  72   2                  break;
  73   2      
  74   2              default:
  75   2                  break;
  76   2          }
  77   1      }


