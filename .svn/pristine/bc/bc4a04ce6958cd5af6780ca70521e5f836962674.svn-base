                  }
              #endif
              #if(_RTK_ADVANCED_MOTION_BLUR_REDUCTION_SUPPORT == _ON)
                  if(GET_MBR_BACKLIGHT_MODE() == _BACKLIGHT_MODE_STROBE_RTK_ADV_MBR)
                  {
                      ScalerMbrRtkAdvMbrCtrl(_PCB_MBR_TCON_PIN, ucBacklightDuty, ucBacklightPos, bLightCtrl);
                  }
              #endif
              }
