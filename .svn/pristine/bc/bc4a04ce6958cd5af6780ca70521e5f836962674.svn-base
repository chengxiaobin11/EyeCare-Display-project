                      case _AUDIO_GEN_FREQ_3000HZ:
              
                          return _AUDIO_FREQ_192K;
              
                          break;
              
                      default:
              
                          return _AUDIO_FREQ_64K;
                          break;
                  }
              #else
                  return _AUDIO_FREQ_64K;
              #endif
              }
              
