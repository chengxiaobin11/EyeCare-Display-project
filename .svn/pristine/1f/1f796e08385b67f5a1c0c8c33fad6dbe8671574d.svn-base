2921          // Description  : Measure Clk
2922          // Input Value  : Clk Source to be measured
2923          // Output Value : Measured Clk Count
2924          //--------------------------------------------------
2925          WORD ScalerTMDSRx3MeasureClk(BYTE ucMeasureClk)
2926          {
2927   1          BYTE ucDelayCount = 0;
2928   1      
2929   1      #if(_D3_INPUT_PORT_TYPE == _D3_MHL_PORT)
                  if(GET_D3_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
C51 COMPILER V9.01   RL6449_SERIES_TMDSRX3                                                 05/24/2025 15:52:10 PAGE 50  

                      // Enable Rx_EN (Lane0,3)
                      ScalerSetBit(P7C_1A_CMU_00, ~(_BIT7 | _BIT4), (_BIT7 | _BIT4));
                  }
                  else
              #endif
2937   1          {
2938   2              // Enable Rx_EN (Lane3)
2939   2              ScalerSetBit(P7C_1A_CMU_00, ~_BIT7, _BIT7);
2940   2          }
2941   1      
2942   1          // Disable Measure for Reset Measure Window
2943   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2944   1          ScalerSetBit(P72_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), 0x00);
2945   1      
2946   1          // Select reference clk to Xtal Clk and measure clk
2947   1          ScalerSetBit(P72_AD_TMDS_CPS, ~(_BIT6 | _BIT5 | _BIT4), ((ucMeasureClk << 5) | _BIT4));
2948   1      
2949   1          // Start Measure
2950   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2951   1          ScalerSetBit(P72_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), _BIT3);
2952   1      
2953   1          // Delay at least 40us at Xtal = 27MHz
2954   1          for(ucDelayCount = 0; ucDelayCount <= 8; ucDelayCount++)
2955   1          {
2956   2              DELAY_5US();
2957   2      
2958   2              ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2959   2              if(ScalerGetBit(P72_CA_HDMI_DP, _BIT3) == 0x00)
2960   2              {
2961   3                  break;
2962   3              }
2963   2          }
2964   1      
2965   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2966   1          pData[0] = ScalerGetByte(P72_CA_HDMI_DP);
2967   1      
2968   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_29_PORT_PAGE72_HDMI_NTX1024TR1);
2969   1          pData[1] = ScalerGetByte(P72_CA_HDMI_DP);
2970   1      
2971   1          return ((WORD)(pData[0] & 0x07) << 8) | pData[1];
2972   1      }
