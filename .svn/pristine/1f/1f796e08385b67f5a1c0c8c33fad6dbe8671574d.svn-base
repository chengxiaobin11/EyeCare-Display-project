4724   1      #if(_D3_INPUT_PORT_TYPE == _D3_MHL_PORT)
                  if((GET_HDMI_HOTPLUG_TOGGLE() == _TRUE) && (GET_D3_CABLE_STATUS() == _TRUE) && (GET_D3_TMDS_MODE() == 
