4221          //--------------------------------------------------
4222          // Description  : DFE Adaptation in Normal Signal
4223          // Input Value  : None
4224          // Output Value : True --> DFE Normal
4225          //                False --> DFE Abnormal
4226          //--------------------------------------------------
4227          bit ScalerTMDSRx3CheckDataDFE(void)
4228          {
4229   1          BYTE ucTemp = 0;
4230   1          BYTE ucCnt = 0;
4231   1      
4232   1          // DFE Check only under HDMI Mode.
4233   1          // MHL has only 1 data Lane --> Skip DFE Check Process and Function return True!
4234   1          if(ScalerGetBit(P7C_17_BANDGAP_03, _BIT1) != _BIT1)
4235   1          {
4236   2              for(pData[0] = 0; pData[0] <= 2; pData[0]++)
4237   2              {
4238   3                  // Sel lane
4239   3                  ScalerSetBit(P7C_F2_COEF_3, ~(_BIT7 | _BIT6), pData[0] << 6);
4240   3      
4241   3                  // Read VTH
