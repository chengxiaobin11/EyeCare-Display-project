             - _BIT4)) == 0x00))
3557   1          {
3558   2              // Clear AVMute Flag
3559   2              ScalerSetBit(P72_CB_HDMI_SR, ~_BIT7, _BIT7);
3560   2      
3561   2              // Disable AVMute Watch Dog
3562   2              ScalerSetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_31_PORT_PAGE72_HDMI_WDCR0, ~_BIT7, 0x00);
3563   2      
3564   2              // Enable Video/Audio Output
3565   2              ScalerSetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_30_PORT_PAGE72_HDMI_AVMCR, ~(_BIT6 | _BIT5 | _BIT3
             -), (_BIT6 | _BIT5 | _BIT3));
3566   2      
3567   2              // Enable RGB Output
3568   2              ScalerSetBit(P72_A6_TMDS_OUTCTL, ~(_BIT6 | _BIT5 | _BIT4), (_BIT6 | _BIT5 | _BIT4));
3569   2      
3570   2              // Enable AVMute Watch Dog
3571   2              ScalerSetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_31_PORT_PAGE72_HDMI_WDCR0, ~_BIT7, _BIT7);
3572   2          }
3573   1      }
