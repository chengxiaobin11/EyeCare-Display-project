4744   2      
4745   2              ScalerTMDSHdmiHpd5vPinCheckEvent(_D3_INPUT_PORT, _ENABLE);
4746   2      #endif
4747   2      
4748   2      #if(_DELL_HDMI_HPD_DDC_STYLE_SUPPORT == _ON)
                      if(g_ucTmdsD3DdcramNackStatus == _FALSE)
                      {
                          // DDCRAM Force Nack off
                          ScalerSyncSetDdcForceNack(_D3_INPUT_PORT, _OFF);
                      }
              
