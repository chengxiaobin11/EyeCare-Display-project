4198   2      
4199   2              return _FALSE;
4200   2          }
4201   1      #if(_TMDS_HDCP_2_2_SUPPORT == _ON)
4202   1          else if((ScalerGetBit(P72_C0_HDCP_CR, _BIT0) == 0x00) && (ScalerGetBit(P2E_26_HDCP_I2C_CTRL_0, _BIT7) 
