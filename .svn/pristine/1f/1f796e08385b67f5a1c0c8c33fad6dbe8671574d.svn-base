4727   1      
4728   1      #if((_D12_INPUT_PORT_TYPE == _D12_HDMI_PORT) && (_D12_INPUT_PORT_SWITCH_FROM == _SWITCH_FROM_D3))
                  if((GET_HDMI_HOTPLUG_TOGGLE() == _TRUE) &&
                     (((GET_D3_CABLE_STATUS() == _TRUE) && (PCB_GET_HDMI_SW_SELECT() == _SW_SEL_HDMI3)) ||
                      ((GET_D12_CABLE_STATUS() == _TRUE) && (PCB_GET_HDMI_SW_SELECT() == _SW_SEL_HDMI3_1))))
              #else
4733   1          if((GET_HDMI_HOTPLUG_TOGGLE() == _TRUE) && (GET_D3_CABLE_STATUS() == _TRUE))
4734   1      #endif
4735   1      
4736   1      #endif
4737   1          {
C51 COMPILER V9.01   RL6449_SERIES_TMDSRX3                                                 05/24/2025 15:52:10 PAGE 80  

4738   2              // Restore Slave Address
