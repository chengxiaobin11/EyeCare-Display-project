4762   3                  ScalerSetBit(P7C_18_IMPEDANCE_00, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), g_ucTMDSRx3Z0Status);
4763   3              }
4764   2          }
4765   1      }
