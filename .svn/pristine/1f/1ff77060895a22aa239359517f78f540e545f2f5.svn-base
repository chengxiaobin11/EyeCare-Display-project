 232          
 233          void ScalerMcuDdcciSendData(BYTE *pucWriteArray)
 234          {
 235   1          WORD usTimeOutCnt = _DDCCI_TIMEOUT_LIMIT;
 236   1          BYTE ucDdcciCount = 0;
 237   1      
 238   1      
 239   1          if((MCU_FF27_IIC_STATUS & _BIT0) == _BIT0)
 240   1          {
 241   2              g_bSrcReadDdcciAlready = _TRUE;
 242   2      
 243   2              // Clear Flag
 244   2              MCU_FF27_IIC_STATUS &= ~_BIT0;
 245   2          }
 246   1      
 247   1          // Enable mcu write
 248   1          MCU_FF2A_IIC_IRQ_CONTROL2 |= (_BIT6 | _BIT5);
 249   1      
 250   1      #if(_SMBUS_BLOCK_READ_WRITE_COMMAND_SUPPORT == _ON)
                  if(GET_SMBUS_BLOCK_RW_STATUS() == _TRUE)
                  {
                      MCU_FF26_IIC_DATA_OUT = g_stSmbusBlockRWCmd.ucDataLen;
                  }
              #endif
 256   1      
 257   1          while(ucDdcciCount < ((pucWriteArray[_DDCCI_LENGTH] & 0x7F) + 3))
 258   1          {
 259   2              // Load data to DDC-CI buffer until buffer full
 260   2              if((MCU_FF29_IIC_STATUS2 & _BIT2) == 0)
 261   2              {
 262   3                  MCU_FF26_IIC_DATA_OUT = pucWriteArray[ucDdcciCount++];
 263   3      
 264   3                  usTimeOutCnt = _DDCCI_TIMEOUT_LIMIT;
 265   3              }
 266   2              else
 267   2              {
 268   3                  ScalerTimerDelayXms(2);
 269   3      
 270   3                  usTimeOutCnt--;
 271   3              }
 272   2      
 273   2              if(usTimeOutCnt == 0)
 274   2              {
 275   3                  break;
 276   3              }
 277   2          }
 278   1      
 279   1          // Disable mcu write
 280   1          MCU_FF2A_IIC_IRQ_CONTROL2 &= ~_BIT5;
 281   1      }
 282          
