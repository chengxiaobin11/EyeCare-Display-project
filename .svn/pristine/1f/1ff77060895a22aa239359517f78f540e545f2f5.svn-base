 207          // Description  : Cache Control
 208          // Input Value  : bControl
 209          // Output Value : None
 210          //--------------------------------------------------
 211          void ScalerMcuCacheControl(bit bControl)
 212          {
 213   1          if(bControl == _ENABLE)
 214   1          {
 215   2              // Enable Cache
 216   2              MCU_FDA0_CACHE_FUNCTION |= _BIT0;
 217   2          }
 218   1          else
 219   1          {
 220   2              // Disable Cache
 221   2              MCU_FDA0_CACHE_FUNCTION &= ~_BIT0;
 222   2          }
 223   1      }
