3358   2                 }
3359   1      #endif
3360   1      
3361   1      
3362   1      #if(_BACKLIGHT_DEFAULT == 100)
3363   1              return (WORD)((DWORD)(_BACKLIGHT_MAX_PWM - _BACKLIGHT_MIN_PWM) * usBacklight / 100 + _BACKLIGHT_MIN_PWM);
3364   1      
3365   1      #else
                      if(usBacklight<=_BACKLIGHT_DEFAULT)
                              return ((_BACKLIGHT_PWM_CENTER-_BACKLIGHT_MIN_PWM)*usBacklight/_BACKLIGHT_DEFAULT+_BACKLIGHT_MIN_PWM);
                      else
                              return ((_BACKLIGHT_MAX_PWM-_BACKLIGHT_PWM_CENTER)*(usBacklight-_BACKLIGHT_DEFAULT)/(100-_BACKLIGHT_DEFA
             -ULT)+_BACKLIGHT_PWM_CENTER);
              #endif
3371   1      
3372   1      }
