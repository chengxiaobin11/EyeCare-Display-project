1775          //--------------------------------------------------
1776          // Description  : TPV Factory Command Tx command
1777          // Input Value  : None
1778          // Output Value : checksum
1779          //--------------------------------------------------
C51 COMPILER V9.60.0.0   TPVFACTORYCOMMAND                                                 08/27/2025 11:02:23 PAGE 31  

1780          void TPVFCReplyCommand(BYTE ucResult, BYTE ucLength)
1781          {
1782   1          WORD usCRC = 0;
1783   1          BYTE i = 0;
1784   1      
1785   1          for(i = 0; i < ucLength; i++ )
1786   1          {
1787   2              usCRC = TPVFCCrc16(g_pucDdcciRxBuf[_FC_BYTE4 + i], usCRC);
1788   2          }
1789   1      
1790   1          g_pucDdcciTxBuf[_DDCCI_SOURCE] = _DDCCI_DEST_ADDRESS;
1791   1          g_pucDdcciTxBuf[_DDCCI_LENGTH] = _DDCCI_CONTROL_STATUS_FLAG | 0x03;
1792   1          g_pucDdcciTxBuf[_DDCCI_COMMAND] = ucResult;
1793   1          g_pucDdcciTxBuf[3] = (BYTE)((usCRC&0xff00)>>8);
1794   1          g_pucDdcciTxBuf[4] = (BYTE)(usCRC&0x00ff);
