1747          // Description  : TPV Factory Command CRC calculation for HDCP
1748          // Input Value  : None
1749          // Output Value : None
1750          //--------------------------------------------------
1751          
1752          
1753          //--------------------------------------------------
1754          // Description  : TPV Factory Command CRC calculation
1755          // Input Value  : None
1756          // Output Value : CRC
1757          //--------------------------------------------------
1758          WORD TPVFCCrc16(BYTE nData, WORD nCRC)
1759          {
1760   1          BYTE nMask;
1761   1          bit fFeedback;
1762   1          for (nMask= 0x80; nMask; nMask >>= 1)
1763   1          {
1764   2              fFeedback= (bit)(((nCRC & 0x8000) ? 1 : 0) ^ ((nMask & nData) ? 1 : 0));
1765   2              nCRC <<= 1;
1766   2              if (fFeedback)
1767   2              {
1768   3                  nCRC ^= 0x1021;
1769   3              }
1770   2          }
1771   1      
1772   1          return nCRC;
1773   1      }
