  47          //--------------------------------------------------
  48          // Description  : Load Panel Uniformity LUT
  49          // Input Value  : LUT, Bank number, EnumUniformityModeSelect
C51 COMPILER V8.12   RL6449_SERIES_COLORPANELUNIFORMITYLDTARGE                             03/11/2025 19:56:08 PAGE 2   

  50          // Output Value : None
  51          //--------------------------------------------------
  52          void ScalerColorPanelUniformityLDTargetLUTAdjust(BYTE *pucUNILUT, WORD usUNIGainStartAddr, WORD usUNILUTSi
             -ze)
  53          {
  54   1          // Enable uniformity access
  55   1          ScalerSetBit(P34_00_UN_GLOBAL_CTRL, ~_BIT2, _BIT2);
  56   1      
  57   1          // Set Gain table Start Addr
  58   1          ScalerSetByte(P34_06_UN_GAIN_LUT_ADDR_PORT_MSB, HIBYTE(usUNIGainStartAddr) & 0x3F);
  59   1          ScalerSetByte(P34_07_UN_GAIN_LUT_ADDR_PORT_LSB, LOBYTE(usUNIGainStartAddr));
  60   1      
  61   1          // Load uniformity gain LUT from Xram
  62   1          ScalerBurstWrite(pucUNILUT, usUNILUTSize, GET_CURRENT_BANK_NUMBER(), P34_08_UN_GAIN_LUT_ACCESS_PORT, _
             -BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_XRAM);
  63   1      
  64   1          // Disable uniformity access
  65   1          ScalerSetBit(P34_00_UN_GLOBAL_CTRL, ~_BIT2, 0x00);
  66   1      }
  67          


