C51 COMPILER V8.12   RL6449_SERIES_COLORIAPSGAINENABLE                                     03/11/2025 19:56:05 PAGE 2   

  52          void ScalerColorIAPSGainEnable(EnumFunctionOnOFF enumOn)
  53          {
  54   1          if(enumOn == _FUNCTION_ON)
  55   1          {
  56   2              // Enable Soft Clamp and Iaps Gain
  57   2              ScalerSetBit(P7_E0_IAPS_GAIN_CTRL_M1, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
  58   2      
  59   2              // Enable Double Buffer
  60   2              ScalerSetBit(P7_E4_IAPS_GAIN_DB_CTRL_M1, ~(_BIT0), _BIT0);
  61   2          }
  62   1          else
  63   1          {
  64   2              ScalerSetBit(P7_E0_IAPS_GAIN_CTRL_M1, ~(_BIT0), 0x00);
  65   2          }
  66   1      }


