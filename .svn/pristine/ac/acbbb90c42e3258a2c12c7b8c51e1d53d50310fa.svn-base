  40          void ScalerColorOutputGammaChannelCtrl(BYTE ucColorChannel, WORD usOffset, bit bLocation);
  41          
  42          //****************************************************************************
  43          // FUNCTION DEFINITIONS
  44          //****************************************************************************
  45          //--------------------------------------------------
  46          // Description  : Switch Gamma Channel
  47          // Input Value  : ucColorChannel: 0- Red, 1- Green, 2- Blue;
  48          //                ucOffset: Offset
  49          //                bLocation: 0-Write to SDRAM, 1- Write to LATCH
  50          // Output Value : None
  51          //--------------------------------------------------
C51 COMPILER V8.12   RL6449_SERIES_COLOROUTPUTGAMMACHANNELCTRL                             03/11/2025 19:56:07 PAGE 2   

  52          void ScalerColorOutputGammaChannelCtrl(BYTE ucColorChannel, WORD usOffset, bit bLocation)
  53          {
  54   1          // Select Channel
  55   1          ScalerSetBit(P0_67_GAMMA_CTRL_SETA, ~(_BIT7 | _BIT5 | _BIT4 | _BIT2), ((ucColorChannel << 4) | ((BYTE)
             -bLocation << 2)));
  56   1      
  57   1          // Specify address
  58   1          ScalerSetBit(P0_67_GAMMA_CTRL_SETA, ~_BIT3, _BIT3);
  59   1          ScalerSetByte(P0_66_GAMMA_PORT_SETA, HIBYTE(usOffset));
  60   1          ScalerSetByte(P0_66_GAMMA_PORT_SETA, LOBYTE(usOffset));
  61   1          ScalerSetBit(P0_67_GAMMA_CTRL_SETA, ~(_BIT7 | _BIT3), _BIT7);
  62   1      }
  63          


