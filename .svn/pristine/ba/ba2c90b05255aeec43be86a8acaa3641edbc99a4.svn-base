  41          void ScalerOsdWindowGradientStep(bit bEnable, EnumOsdWindowsType enumOsdWindowsType, BYTE ucStep);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Set window gradient step extension
  49          // Input Value  : bEnable    -> _ENABLE or _DISABLE
  50          //                enumOsdWindowsType -> _OSD_WINDOW_0, _OSD_WINDOW_5, _OSD_WINDOW_6, _OSD_WINDOW_7, _OSD_W
             -INDOW_8, _OSD_WINDOW_9
C51 COMPILER V8.12   OSDWINDOWGRADIENTSTEP                                                 03/11/2025 19:56:00 PAGE 2   

  51          //                ucStep           -> extended gradient step (0 ~ 255)
  52          // Output Value :
  53          //--------------------------------------------------
  54          void ScalerOsdWindowGradientStep(bit bEnable, EnumOsdWindowsType enumOsdWindowsType, BYTE ucStep)
  55          {
  56   1          WORD usTempWindowNumber = 0;
  57   1          BYTE ucTemp = 0;
  58   1      
  59   1          // Set Extended Gradient Step
  60   1          usTempWindowNumber = 0x176 + (enumOsdWindowsType * 7);
  61   1          ScalerOsdFrameControlByte(usTempWindowNumber, _OSD_BYTE1, ucStep);
  62   1      
  63   1          // Set Window Gradient Step Extension Enable/Disable
  64   1          usTempWindowNumber++;
  65   1          ucTemp = ScalerOsdFrameControlByteGet(usTempWindowNumber, _OSD_BYTE0);
  66   1          ucTemp = ((ucTemp & ~_BIT4) | ((BYTE)bEnable << 4));
  67   1          ScalerOsdFrameControlByte(usTempWindowNumber, _OSD_BYTE0, ucTemp);
  68   1      }
  69          
  70          
  71          /*
  72          //--------------------------------------------------
  73          // example
  74          //--------------------------------------------------
  75              SET_OSD_WINDOW_GRADIENT_ENABLE_R(_ENABLE);
  76              SET_OSD_WINDOW_GRADIENT_ENABLE(_ENABLE);
