1551          //--------------------------------------------------
1552          // Description  : Get the free page number of flash
1553          // Input Value  : None
1554          // Output Value : Free page index
1555          //--------------------------------------------------
1556          BYTE RTDFlashGetFreePage(void)
1557          {
1558   1          BYTE ucPageID = _START_OF_PAGEID;
1559   1          BYTE ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1560   1      
1561   1          // If the _END_PAGE page has the biggest move count, suppose first page is free page
1562   1          if(g_ulFlashMoveCount > 0)
1563   1          {
1564   2              if(g_ucFlashLastPage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1565   2              {
1566   3                  ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1567   3              }
1568   2              else
1569   2              {
1570   3                  ucFreePage = g_ucFlashLastPage + 1;
1571   3              }
1572   2          }
1573   1      
1574   1          // Check the supposed free page is actual free page which has not been used ever
1575   1          do
1576   1          {
1577   2              if(ucFreePage == g_pucFlashPageArr[ucPageID])
1578   2              {
1579   3                  if(ucFreePage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1580   3                  {
1581   4                      ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1582   4                  }
1583   3                  else
1584   3                  {
C51 COMPILER V9.60.0.0   RTD2014NVRAMOSD                                                   08/21/2025 10:45:43 PAGE 27  

1585   4                      ucFreePage += 1;
1586   4                  }
1587   3      
1588   3                  ucPageID = _START_OF_PAGEID;
1589   3              }
1590   2              else
1591   2              {
1592   3                  ucPageID++;
1593   3              }
1594   2          }
1595   1          while(ucPageID <= _END_OF_PAGEID);
1596   1      
1597   1          return ucFreePage;
1598   1      }
