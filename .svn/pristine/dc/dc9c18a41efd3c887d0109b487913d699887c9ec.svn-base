1600          //--------------------------------------------------
1601          // Description  : Check the page is vaild or not
1602          // Input Value  : ucPage: The page to be check, must between 0 and (_END_PAGE - _START_PAGE)
1603          // Output Value : _TRUE means the page is valid, _FLASE is invalid
1604          //--------------------------------------------------
1605          bit RTDFlashIsPageInfoValid(BYTE ucPage)
1606          {
1607   1          WORD usPageInfoAddr = ucPage * _FLASH_PAGE_SIZE;
1608   1          BYTE ucPageInfoChecksum = 0;
1609   1          BYTE pucPageInfo[5] = {0};
1610   1          BYTE pucPageInfoTemp[4] = {0};
1611   1      
1612   1          UserCommonFlashRead(_SYSTEM_EEPROM_EMULATION_FLASH_BANK, usPageInfoAddr + _PAGEINFO_CHECKSUM_ADDR, 5, 
             -pucPageInfo);
1613   1          pucPageInfoTemp[0] = pucPageInfo[1];
1614   1          pucPageInfoTemp[1] = pucPageInfo[2];
1615   1          pucPageInfoTemp[2] = pucPageInfo[3];
1616   1          pucPageInfoTemp[3] = pucPageInfo[4];
1617   1          ucPageInfoChecksum = UserCommonFlashCalculateCheckSumData(pucPageInfoTemp, 4);
1618   1          ucPageInfoChecksum = (ucPageInfoChecksum & 0x7F);
1619   1      
1620   1          if(ucPageInfoChecksum == pucPageInfo[0])
1621   1          {
1622   2              return _TRUE;
1623   2          }
1624   1      
1625   1          return _FALSE;
1626   1      }
