1628          //--------------------------------------------------
1629          // Description  : Initial data page
1630          // Input Value  : None
1631          // Output Value : None
1632          //--------------------------------------------------
1633          void RTDFlashInitialDataPage(BYTE ucPageID)
1634          {
1635   1          WORD usAddr = _SYSTEM_EEPROM_EMULATION_START_PAGE * _FLASH_PAGE_SIZE;
1636   1          BYTE ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1637   1         // BYTE ucVersionCode = 0;
1638   1         // BYTE ucChecksum = 0;
1639   1      
1640   1          ucFreePage = RTDFlashGetFreePage();
1641   1          // Initial page index
1642   1          g_pucFlashPageArr[ucPageID] = ucFreePage;
1643   1          // Initial address
1644   1          g_pusFlashAddrArr[ucPageID] = 0;
1645   1          // Initial move count
C51 COMPILER V9.60.0.0   RTD2014NVRAMOSD                                                   08/21/2025 10:45:43 PAGE 28  

1646   1          if(g_ulFlashMoveCount == 0xFFFFFF)
1647   1          {
1648   2              g_ulFlashMoveCount = 0x01;
1649   2          }
1650   1          else
1651   1          {
1652   2              g_ulFlashMoveCount++;
1653   2          }
1654   1      
1655   1          g_ucFlashLastPage = ucFreePage;
1656   1      
1657   1          usAddr = g_pucFlashPageArr[ucPageID] * _FLASH_PAGE_SIZE;
1658   1          UserCommonFlashErasePage(_SYSTEM_EEPROM_EMULATION_FLASH_BANK, g_pucFlashPageArr[ucPageID]);
1659   1      
1660   1          {
1661   2              BYTE pucBuffer[5] = {0};
1662   2      
1663   2              pucBuffer[0] = ucPageID;
1664   2              pucBuffer[1] = (BYTE)(g_ulFlashMoveCount >> 16);
1665   2              pucBuffer[2] = (BYTE)(g_ulFlashMoveCount >> 8);
