              void UserAdjustGetColorTransferUserModeTableAddress(EnumPCMType enumPCMType, EnumColortemptureDef enumOSDC
             -olorTempIndex, WORD *pusTable)
              {
                  BYTE ucI = 0;
                  EnumColorimetryTransfer enumColorimetryTransfer = _COLORIMETRY_TRANSFER_DEFUALT_CCT;
                  if(enumPCMType == _PCM_SRGB)
                  {
                      switch(enumOSDColorTempIndex)
                      {
                          case _CT_9300:
