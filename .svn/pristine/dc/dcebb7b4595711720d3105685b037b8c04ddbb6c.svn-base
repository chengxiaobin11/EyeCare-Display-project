                  for(ucI = 0; ucI < _COLORIMETRY_TRANSFER_MATRIX_SIZE; ucI++)
                  {
                      pusTable[ucI] = *(tPCM_COLORTRANSFER_MATRIX + (enumColorimetryTransfer * _COLORIMETRY_TRANSFER_MAT
             -RIX_SIZE) + ucI);
                  }
