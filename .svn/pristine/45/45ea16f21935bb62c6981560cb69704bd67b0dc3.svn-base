 193   2              ScalerSetBit(PB7_65_AUX_5, ~_BIT7, _BIT7);
 194   2          }
 195   1      
 196   1          // Aux Mode Set (Diff Mode or Single-ended mode) && Aux RX0 Resistance Setting
