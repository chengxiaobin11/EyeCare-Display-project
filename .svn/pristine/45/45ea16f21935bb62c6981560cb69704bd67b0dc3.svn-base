 123          //--------------------------------------------------
 124          // Description  : Initial Setting for DP Digital Aux, Analog Aux
 125          // Input Value  : None
 126          // Output Value : None
 127          //--------------------------------------------------
 128          void ScalerDpRx0AuxPowerOnInitial(void)
 129          {
 130   1          BYTE ucConnectorType = ScalerSyncDpRxGetConnectorType(_D0_INPUT_PORT);
 131   1      
 132   1          if(ucConnectorType == _DP_CONNECTOR_EMBEDDED)
 133   1          {
 134   2              // Reset Aux Phy
 135   2              ScalerSetBit(PB7_65_AUX_5, ~_BIT7, 0x00);
 136   2          }
 137   1      
 138   1          // Digital Aux Power On, DPCD REG Power On, MSG Power On.
 139   1          ScalerSetBit(PB7_C0_DPCD_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT1 | _BIT0), 0x00);
 140   1      
 141   1          // Average 8 cycles as Start Postion, Aux Clk Select to 27MHz, no Swap
 142   1          ScalerSetByte(PB7_72_AUX_DIG_PHY2, 0xC0);
 143   1      
 144   1      #if(_DP_AUX_REPLY_CLK_SEL_FROM == _DP_AUX_REPLY_SEL_IOSC)
 145   1          // Aux Clk Select Manual Mode, Aux New Mode
 146   1          ScalerSetBit(PB7_73_AUX_DIG_PHY3, ~(_BIT7 | _BIT6), _BIT6);
 147   1      #else
                  // Aux Clk Select Source, Aux New Mode
                  ScalerSetBit(PB7_73_AUX_DIG_PHY3, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
              #endif
 151   1      
 152   1          // HW Fake Link Training Disable.
 153   1          ScalerSetBit(PB7_C6_AUX_PHY_DIG2, ~_BIT4, 0x00);
 154   1      
 155   1          // Set Aux Precharge Number.
 156   1          ScalerSetBit(PB7_74_AUX_DIG_PHY4, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT0));
 157   1      
 158   1          // Aux Auto Mode, Using Default Average Number.
 159   1          ScalerSetByte(PB7_75_AUX_DIG_PHY5, 0x0D);
 160   1      
 161   1          // Aux Reply Timeout Setting
 162   1          ScalerSetByte(PB7_A2_AUX_RESERVE2, _DP_AUX_REPLY_TIMEOUT_USER_SETTING);
 163   1      
 164   1          // Enble Aux Channel.
 165   1          ScalerSetBit(PB7_D0_AUX_MODE_SET, ~(_BIT3 | _BIT2 | _BIT0), _BIT0);
 166   1      
 167   1          // Fast IIC Clock.
 168   1          ScalerSetBit(PB7_D1_DP_IIC_SET, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_DP_AUX_IIC_SCL_CLK_SETTING << 4));
 169   1      
 170   1          // Set aux mac clk use xclk
C51 COMPILER V9.60.0.0   RL6432_SERIES_DPRX0                                               09/09/2025 18:04:07 PAGE 4   

 171   1          ScalerSetBit(PB7_DA_AUX_FIFO_RST, ~(_BIT4 | _BIT3 | _BIT1 | _BIT0), _BIT3);
 172   1      
 173   1          // Not Reply when Aux Error.
 174   1          ScalerSetBit(PB7_DB_AUX_STATUS, ~(_BIT5 | _BIT4), _BIT4);
 175   1          ScalerSetBit(PB7_76_AUX_DIG_PHY6, ~(_BIT7 | _BIT6), _BIT6);
 176   1      
 177   1          // Aux Ack Timer.
 178   1          ScalerSetBit(PB7_F0_AUX_TX_TIMER, ~(_BIT5 | _BIT2), (_BIT5 | _BIT2));
 179   1      
 180   1          // I2C timeout setting
 181   1          ScalerSetByte(PB7_F1_AUX_TX_TIMER_2, _DP_AUX_I2C_REPLY_TIMEOUT_SETTING);
 182   1      
 183   1          // Disable Reply IIC Defer Before Data Ready.
 184   1          ScalerSetBit(PB7_F4_MCUIIC, ~(_BIT6 | _BIT5), 0x00);
 185   1      
 186   1          // Enable Aux Error Handler.
 187   1          ScalerSetBit(PB7_78_AUX_DIG_PHY8, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT5 | _
