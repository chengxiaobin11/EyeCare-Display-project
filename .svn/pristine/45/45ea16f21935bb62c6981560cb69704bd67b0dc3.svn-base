 206   1      
 207   1          // Set Aux D_2 = ~D_1 for Aux Single Ended Mode
 208   1          ScalerSetBit(PB7_79_AUX_DIG_PHY9, ~_BIT7, _BIT7);
 209   1      
 210   1          // Clear the Clock Divider for AUX MAC and PHY
 211   1          ScalerSetBit(PB7_73_AUX_DIG_PHY3, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 212   1          ScalerSetBit(PB7_B0_AUX_PAYLOAD_CLEAR, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 213   1      
 214   1          // Aux ps clk from IOSC
 215   1          ScalerSetBit(P0_0B_POWER_CTRL, ~(_BIT5 | _BIT4), 0x00);
 216   1      
 217   1          // Set the Clock Divider = 1 for AUX MAC and PHY
 218   1          ScalerSetBit(PB7_73_AUX_DIG_PHY3, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT0);
 219   1          ScalerSetBit(PB7_B0_AUX_PAYLOAD_CLEAR, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT0);
