                  }
                  else if(ScalerGetBit(PA_C0_MN_SCLKG_PLL_INSEL, (_BIT5 | _BIT4)) == (_BIT5 | _BIT4))
                  {
                      pData[5] = 4396 * ulpllm / 2340 / 13;
                  }
                  else
                  {
                      // For ICP default Setting
                      pData[5] = 4396 * ulpllm / 1340 / 13;
                  }
              
                  pData[5] = ((20 * pData[5]) + 25) / 50;
