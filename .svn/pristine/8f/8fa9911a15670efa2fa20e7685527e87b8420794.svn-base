 312   2              {
 313   3      #if(_HDMI_FREESYNC_SUPPORT == _ON)
 314   3                  if((ucPortType == _PORT_HDMI) || (ucPortType == _PORT_DVI))
 315   3                  {
 316   4                      return GET_HDMI_FREESYNC_ENABLED();
 317   4                  }
 318   3                  else
 319   3      #endif
 320   3                  {
 321   4      #if(_DP_FREESYNC_SUPPORT == _ON)
 322   4      #if(_DP_DRR_GET_IVF_TYPE == _DP_DRR_SPD_INFO)
 323   4                      if(ucPortType == _PORT_DP)
 324   4                      {
 325   5                          return GET_DP_FREESYNC_ENABLED();
 326   5                      }
 327   4      #endif
 328   4      #endif
 329   4                  }
 330   3              }
 331   2              else
 332   2              {
 333   3                  // Gsync
 334   3              }
 335   2          }
 336   1          else
 337   1          {
 338   2              // Version 3 or _AMD_VER_NONE
 339   2          }
 340   1      
 341   1          return _FALSE;
 342   1      }
