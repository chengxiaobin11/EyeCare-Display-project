 392          //--------------------------------------------------
 393          // Description  : EDID Analysis Check Hwidth/ Vheight/ Hblanking/ Pixel
 394          // Input Value  : Hwidth/ Vheight/ Hblanking/ Pixel
 395          // Output Value : _TRUE: Find
 396          //--------------------------------------------------
 397          bit ScalerFreeSyncEdidAnalysisCheckBoundry(const StructFreeSyncEdidInfo *pstEdidInfo, const StructFreeSync
             -EdidRefInfo *pstEdidRefInfo)
 398          {
 399   1          // Check Interlace Timing/ Hactive/ Vactive/ Hblank match & PixelRate inside the Boundary
 400   1          if((pstEdidInfo->b1Interlace == pstEdidRefInfo->b1RefInterlace) &&
 401   1             (pstEdidInfo->usHwidth == pstEdidRefInfo->usRefHwidth) &&
 402   1             (pstEdidInfo->usVheight == pstEdidRefInfo->usRefVheight) &&
 403   1             ((pstEdidInfo->usHblank <= pstEdidRefInfo->usRefHblankHBound) && (pstEdidInfo->usHblank >= pstEdidR
             -efInfo->usRefHblankLBound)) &&
 404   1             ((pstEdidInfo->usPixelClk <= pstEdidRefInfo->usPixelClkHBound) && (pstEdidInfo->usPixelClk >= pstEd
C51 COMPILER V9.60.0.0   SCALERCOMMONFREESYNC                                              09/09/2025 14:04:20 PAGE 8   

             -idRefInfo->usPixelClkLBound)))
 405   1          {
 406   2              return _TRUE;
 407   2          }
 408   1          else
 409   1          {
 410   2              return _FALSE;
 411   2          }
 412   1      }
