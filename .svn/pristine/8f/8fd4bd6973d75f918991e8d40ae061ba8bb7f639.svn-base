                  if(ucInputPort == _D0_INPUT_PORT)
                  {
                      // Enable DDC Toggle IRQ
              #if(_D0_DDC_CHANNEL_SEL == _DDC0)
                      if(((MCU_FFE4_DDC0_EDID_IRQ & _BIT3) != _BIT3) && (GET_TMDS_RX0_DDC_DETECTED() != _TRUE))
                      {
