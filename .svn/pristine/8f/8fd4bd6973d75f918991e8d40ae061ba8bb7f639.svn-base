2631   5                          ScalerSetByte(P1D_A2_L0_LIMIT_INIT, 0x06);
2632   5                          ScalerSetByte(P1D_B2_L1_LIMIT_INIT, 0x06);
2633   5                          ScalerSetByte(P1D_C2_L2_LIMIT_INIT, 0x06);
2634   5                      }
2635   4                      else
2636   4                      {
2637   5                          // change to LEQ = 5
2638   5                          ScalerSetByte(P1D_A2_L0_LIMIT_INIT, 0x05);
2639   5                          ScalerSetByte(P1D_B2_L1_LIMIT_INIT, 0x05);
2640   5                          ScalerSetByte(P1D_C2_L2_LIMIT_INIT, 0x05);
2641   5                      }
2642   4      
2643   4                      break;
2644   4                  }
2645   3              }
2646   2              // no Vsync, DE only mode keep LEQ default
2647   2              else
2648   2              {
2649   3                  break;
2650   3              }
2651   2          }
2652   1      
2653   1          // Enable Freq. Unstable IRQ
2654   1          ScalerSetBit(P2_E6_HDMI_FREQDET_CTRL, ~(_BIT6 | _BIT2 | _BIT1), _BIT1);
