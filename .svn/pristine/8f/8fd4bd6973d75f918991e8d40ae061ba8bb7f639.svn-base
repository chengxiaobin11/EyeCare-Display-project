                      if(((MCU_FFE4_DDC0_EDID_IRQ & _BIT3) != _BIT3) && (GET_TMDS_RX0_DDC_DETECTED() != _TRUE))
                      {
                          MCU_FFE4_DDC0_EDID_IRQ |= _BIT2;
                          MCU_FFE4_DDC0_EDID_IRQ |= _BIT3;
              
