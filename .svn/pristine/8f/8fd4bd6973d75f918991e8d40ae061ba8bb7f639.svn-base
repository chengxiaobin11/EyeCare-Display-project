 240          //--------------------------------------------------
 241          // Description  : Initialize TMDS Interrupt Required Settings
 242          // Input Value  : None
 243          // Output Value : None
 244          //--------------------------------------------------
 245          void ScalerTMDSInterruptInitial(BYTE ucInputPort)
 246          {
 247   1          ucInputPort = ucInputPort;
 248   1      
 249   1          if(ScalerGetBit(P2_E6_HDMI_FREQDET_CTRL, _BIT1) == 0x00)
 250   1          {
 251   2              CLR_TMDS_PHY_SET();
 252   2          }
 253   1      
 254   1          // Enable Rx_En for Clk pair Z0
 255   1          ScalerSetBit(PB_C0_CMU_03, ~_BIT7, _BIT7);
 256   1      
 257   1          // Set Reg_bypass_ok=1 for solve P/N short(480p issue)
 258   1          ScalerSetBit(PB_C1_CMU_04, ~_BIT0, _BIT0);
 259   1      
 260   1          // Choose Measure Clk to TMDS Clk
 261   1          ScalerSetBit(P2_E6_HDMI_FREQDET_CTRL, ~(_BIT7 | _BIT5 | _BIT4), 0x00);
 262   1      
 263   1          // Settings for IRQ set PHY
 264   1          // Consider using table to fill all required initial settings
 265   1          // Set pre-set threshold (225MHz * 0.01 / 26.8KHz = 0x54)
 266   1      
 267   1          // Set TMDS Offset = 1/32
 268   1          ScalerSetBit(P2_E7_HDMI_FREQDET_OFFSET, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
 269   1      
 270   1      #if(_TMDS_LOW_SPEED_PORT_SPEED_LIMIT == _OFF)
                  // Set Upper Bound
                  ScalerSetByte(P2_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
                  ScalerSetByte(P2_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
              #else
 275   1          ScalerSetByte(P2_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_FREQ_NORMAL_LOW_SPEED_UPPER_BOUND));
 276   1          ScalerSetByte(P2_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_FREQ_NORMAL_LOW_SPEED_UPPER_BOUND));
 277   1      #endif
 278   1      
 279   1          // Set Lower Bound
 280   1          ScalerSetByte(P2_EA_HDMI_FREQDET_LOWER_M, HIBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 281   1          ScalerSetByte(P2_EB_HDMI_FREQDET_LOWER_L, LOBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 282   1      
 283   1          // Disable Freq. Unstable IRQ
C51 COMPILER V8.12   RL6463_SERIES_TMDS                                                    03/10/2025 13:50:51 PAGE 6   

 284   1          ScalerSetBit(P2_E6_HDMI_FREQDET_CTRL, ~_BIT1, 0x00);
 285   1      
 286   1          // Enable Freq. Stable IRQ
 287   1          ScalerSetBit(P2_EF_HDMI_ERROR_TH, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 288   1      
 289   1          // Set Stable Time (0x3F = about 5ms)
 290   1          ScalerSetByte(P2_EC_HDMI_FREQDET_STABLE, 0x3F);
 291   1      
 292   1          // Clear IRQ Pending Flag
 293   1          ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_60_PORT_PAGE2_HDMI_INTCR, ~_BIT7, _BIT7);
 294   1      
 295   1          // Internal IRQ Enable (Global)
 296   1          ScalerGlobalIRQControl(_ENABLE);
 297   1      
 298   1          EX0 = 1;
 299   1      
 300   1          // Start Freq. Detection
 301   1          ScalerSetBit(P2_E6_HDMI_FREQDET_CTRL, ~_BIT7, _BIT7);
 302   1      }
