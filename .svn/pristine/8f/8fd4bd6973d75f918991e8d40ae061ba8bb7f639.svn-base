 366          //--------------------------------------------------
 367          // Description  : TMDS DFE Initial Setting (EXINT0 Only)
 368          // Input Value  : None
 369          // Output Value : None
 370          //--------------------------------------------------
 371          void ScalerTMDSSetDFEInitial_EXINT0(void) using 1
 372          {
 373   1          /////////////////////////
 374   1          // DFE Code Initialize //
 375   1          /////////////////////////
 376   1      
 377   1          // Initial DFE Code
 378   1          if(GET_INPUT_PIXEL_CLK() < 375)
 379   1          {
 380   2              // LE  Initial = 4
 381   2              ScalerSetByte_EXINT(P1D_A2_L0_LIMIT_INIT, 0x04);
 382   2              ScalerSetByte_EXINT(P1D_B2_L1_LIMIT_INIT, 0x04);
 383   2              ScalerSetByte_EXINT(P1D_C2_L2_LIMIT_INIT, 0x04);
 384   2          }
 385   1          else if(GET_INPUT_PIXEL_CLK() < 700)
 386   1          {
 387   2              // LE  Initial = 6
 388   2              ScalerSetByte_EXINT(P1D_A2_L0_LIMIT_INIT, 0x06);
 389   2              ScalerSetByte_EXINT(P1D_B2_L1_LIMIT_INIT, 0x06);
 390   2              ScalerSetByte_EXINT(P1D_C2_L2_LIMIT_INIT, 0x06);
 391   2          }
 392   1          else
 393   1          {
 394   2              // Change to T-switch to solve interference but input BW loss more 2dB
 395   2              if(ScalerGlobalGetIDCode_EXINT0() >= _RL6463_VER_C_ID_CODE)
 396   2              {
 397   3                  // LE Initial = 11
 398   3                  ScalerSetByte_EXINT(P1D_A2_L0_LIMIT_INIT, 0x0B);
 399   3                  ScalerSetByte_EXINT(P1D_B2_L1_LIMIT_INIT, 0x0B);
 400   3                  ScalerSetByte_EXINT(P1D_C2_L2_LIMIT_INIT, 0x0B);
 401   3              }
 402   2              else
 403   2              {
 404   3                  // LE Initial = 9
 405   3                  ScalerSetByte_EXINT(P1D_A2_L0_LIMIT_INIT, 0x09);
