 304          //--------------------------------------------------
 305          // Description  : Set Config of TMDS Mac Deonly mode
 306          // Input Value  : None
 307          // Output Value : enumInputPort, enumDeonlyConfig
 308          //--------------------------------------------------
 309          void ScalerTMDSSetDeOnlyModeConfig(EnumSourceSearchPort enumSourceSearchPort, EnumDeOnlyConfig enumDeonlyC
             -onfig)
 310          {
 311   1          enumSourceSearchPort = enumSourceSearchPort;
 312   1      
 313   1          // De only enable?
 314   1          if((enumDeonlyConfig & _DE_ONLY_DISABLE) == _DE_ONLY_DISABLE)
 315   1          {
 316   2              ScalerSetBit(P2_A7_TMDS_PWDCTL, ~_BIT7, 0x00);
 317   2          }
 318   1          else if((enumDeonlyConfig & _DE_ONLY_ENABLE) == _DE_ONLY_ENABLE)
 319   1          {
 320   2              ScalerSetBit(P2_A7_TMDS_PWDCTL, ~_BIT7, _BIT7);
 321   2          }
 322   1      
 323   1          // Set HS
 324   1          if((enumDeonlyConfig & _DE_ONLY_HS_8T) == _DE_ONLY_HS_8T)
 325   1          {
 326   2              ScalerSetBit(P2_AB_TMDS_ACC2, ~_BIT7, _BIT7);
 327   2          }
 328   1          else if((enumDeonlyConfig & _DE_ONLY_HS_72T) == _DE_ONLY_HS_72T)
 329   1          {
 330   2              ScalerSetBit(P2_AB_TMDS_ACC2, ~_BIT7, 0x00);
 331   2          }
 332   1      }
 333          
 334          //--------------------------------------------------
 335          // Description  : Get Config of TMDS Mac Deonly mode
 336          // Input Value  : None
 337          // Output Value : EnumDeOnlyConfig
 338          //--------------------------------------------------
 339          EnumDeOnlyConfig ScalerTMDSGetDeOnlyModeConfig(EnumSourceSearchPort enumSourceSearchPort)
 340          {
 341   1          EnumDeOnlyConfig enumDeConfig = _DE_NO_INDICATED;
 342   1      
 343   1          enumSourceSearchPort = enumSourceSearchPort;
 344   1      
C51 COMPILER V8.12   RL6463_SERIES_TMDS                                                    03/10/2025 13:50:51 PAGE 7   

 345   1          if(ScalerGetBit(P2_A7_TMDS_PWDCTL, _BIT7) == _BIT7)
 346   1          {
 347   2              enumDeConfig = _DE_ONLY_ENABLE;
 348   2          }
 349   1          else
 350   1          {
 351   2              enumDeConfig = _DE_ONLY_DISABLE;
 352   2          }
 353   1      
 354   1          if(ScalerGetBit(P2_AB_TMDS_ACC2, _BIT7) == _BIT7)
 355   1          {
 356   2              enumDeConfig |= _DE_ONLY_HS_8T;
 357   2          }
 358   1          else
 359   1          {
 360   2              enumDeConfig |= _DE_ONLY_HS_72T;
 361   2          }
 362   1      
 363   1          return enumDeConfig;
 364   1      }
