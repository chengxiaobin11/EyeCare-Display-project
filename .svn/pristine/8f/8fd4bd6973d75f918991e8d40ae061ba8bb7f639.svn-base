1116   1          if(abs(usClkCount - ScalerTMDSMeasureClk_EXINT0(_CLK_SOURCE_GREEN)) > (usClkCount >> 6))
1117   1          {
1118   2              return _FALSE;
1119   2          }
1120   1      
1121   1          return _TRUE;
