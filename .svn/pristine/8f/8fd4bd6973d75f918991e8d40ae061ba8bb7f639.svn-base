1170          //--------------------------------------------------
1171          // Description  : Measure Clk (EXINT0 Only)
1172          // Input Value  : Clk Source to be measured
1173          // Output Value : Measured Clk Count
1174          //--------------------------------------------------
1175          WORD ScalerTMDSMeasureClk_EXINT0(BYTE ucMeasureClk) using 1
1176          {
1177   1          BYTE ucDelayCount = 0;
1178   1          WORD usClkCount = 0;
1179   1          BYTE ucBackUp = 0;
1180   1      
1181   1          // Enable CMU_EN(Lane0,1,2) and Rx_EN(Lane0,1,2,3)
1182   1          ScalerSetByte_EXINT(PB_C0_CMU_03, 0xFF);
1183   1      
1184   1          // Disable Measure for Reset Measure Window
1185   1          ScalerSetByte_EXINT(P2_C9_HDMI_AP, _P2_CA_PT_28_PORT_PAGE2_HDMI_NTX1024TR0);
1186   1          ScalerSetBit_EXINT(P2_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), 0x00);
1187   1      
1188   1          // Select reference clk to Xtal Clk and measure clk
1189   1          ScalerSetBit_EXINT(P2_AD_TMDS_CPS, ~(_BIT6 | _BIT5 | _BIT4), ((ucMeasureClk << 5) | _BIT4));
1190   1      
C51 COMPILER V8.12   RL6463_SERIES_TMDS                                                    03/10/2025 13:50:51 PAGE 21  

1191   1          ucBackUp = (ScalerGetByte_EXINT(P2_C8_HDMI_APC) & 0x01);
1192   1      
1193   1          // Set CA Port non-auto increase
1194   1          ScalerSetBit_EXINT(P2_C8_HDMI_APC, ~_BIT0, 0x00);
1195   1      
1196   1          // Start Measure
1197   1          ScalerSetByte_EXINT(P2_C9_HDMI_AP, _P2_CA_PT_28_PORT_PAGE2_HDMI_NTX1024TR0);
1198   1          ScalerSetBit_EXINT(P2_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), _BIT3);
1199   1      
1200   1          // Delay at least 40us at Xtal = 27MHz
1201   1          for(ucDelayCount = 0; ucDelayCount <= 8; ucDelayCount++)
1202   1          {
1203   2              DELAY_5US_EXINT();
1204   2      
1205   2              if((ScalerGetBit_EXINT(P2_CA_HDMI_DP, _BIT3)) == 0x00)
1206   2              {
1207   3                  break;
1208   3              }
1209   2          }
1210   1      
1211   1          ScalerSetByte_EXINT(P2_C9_HDMI_AP, _P2_CA_PT_28_PORT_PAGE2_HDMI_NTX1024TR0);
1212   1          usClkCount = ((WORD)(ScalerGetByte_EXINT(P2_CA_HDMI_DP) & 0x07) << 8);
1213   1      
1214   1          ScalerSetByte_EXINT(P2_C9_HDMI_AP, _P2_CA_PT_29_PORT_PAGE2_HDMI_NTX1024TR1);
1215   1          usClkCount = usClkCount | ScalerGetByte_EXINT(P2_CA_HDMI_DP);
1216   1      
1217   1          ScalerSetBit_EXINT(P2_C8_HDMI_APC, ~_BIT0, ucBackUp);
1218   1      
1219   1          return usClkCount;
1220   1      }
