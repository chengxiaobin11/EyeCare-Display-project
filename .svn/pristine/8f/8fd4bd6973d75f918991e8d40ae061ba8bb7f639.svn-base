1124          //--------------------------------------------------
1125          // Description  : Measure Clk
1126          // Input Value  : Clk Source to be measured
1127          // Output Value : Measured Clk Count
1128          //--------------------------------------------------
C51 COMPILER V8.12   RL6463_SERIES_TMDS                                                    03/10/2025 13:50:51 PAGE 20  

1129          WORD ScalerTMDSMeasureClk(BYTE ucInputPort, BYTE ucMeasureClk)
1130          {
1131   1          BYTE ucDelayCount = 0;
1132   1      
1133   1          ucInputPort = ucInputPort;
1134   1      
1135   1          // Enable CMU_EN(Lane0,1,2) and Rx_EN(Lane0,1,2,3)
1136   1          ScalerSetByte(PB_C0_CMU_03, 0xFF);
1137   1      
1138   1          // Disable Measure for Reset Measure Window
1139   1          ScalerSetByte(P2_C9_HDMI_AP, _P2_CA_PT_28_PORT_PAGE2_HDMI_NTX1024TR0);
1140   1          ScalerSetBit(P2_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), 0x00);
1141   1      
1142   1          // Select reference clk to Xtal Clk and measure clk
1143   1          ScalerSetBit(P2_AD_TMDS_CPS, ~(_BIT6 | _BIT5 | _BIT4), ((ucMeasureClk << 5) | _BIT4));
1144   1      
1145   1          // Start Measure
1146   1          ScalerSetByte(P2_C9_HDMI_AP, _P2_CA_PT_28_PORT_PAGE2_HDMI_NTX1024TR0);
1147   1          ScalerSetBit(P2_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), _BIT3);
1148   1      
1149   1          // Delay at least 40us at Xtal = 27MHz
1150   1          for(ucDelayCount = 0; ucDelayCount <= 8; ucDelayCount++)
1151   1          {
1152   2              DELAY_5US();
1153   2      
1154   2              ScalerSetByte(P2_C9_HDMI_AP, _P2_CA_PT_28_PORT_PAGE2_HDMI_NTX1024TR0);
1155   2              if(ScalerGetBit(P2_CA_HDMI_DP, _BIT3) == 0x00)
1156   2              {
1157   3                  break;
1158   3              }
1159   2          }
1160   1      
1161   1          ScalerSetByte(P2_C9_HDMI_AP, _P2_CA_PT_28_PORT_PAGE2_HDMI_NTX1024TR0);
1162   1          pData[0] = ScalerGetByte(P2_CA_HDMI_DP);
1163   1      
1164   1          ScalerSetByte(P2_C9_HDMI_AP, _P2_CA_PT_29_PORT_PAGE2_HDMI_NTX1024TR1);
1165   1          pData[1] = ScalerGetByte(P2_CA_HDMI_DP);
1166   1      
1167   1          return ((WORD)(pData[0] & 0x07) << 8) | pData[1];
1168   1      }
