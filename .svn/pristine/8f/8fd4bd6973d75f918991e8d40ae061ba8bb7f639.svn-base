                  if(ScalerDebugCheckDebugPort(ucInputPort) == _FALSE)
              #endif
1466   1          {
1467   2              if((ucInputPort == _D1_INPUT_PORT) && (GET_TMDS_RX1_DDC_DETECTED() == _TRUE))
1468   2              {
