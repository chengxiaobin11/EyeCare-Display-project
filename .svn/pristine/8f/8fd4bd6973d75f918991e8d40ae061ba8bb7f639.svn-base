2607   1          // Disable Freq. Unstable IRQ to prevent DFE return to Default value
2608   1          ScalerSetBit(P2_E6_HDMI_FREQDET_CTRL, ~(_BIT6 | _BIT2 | _BIT1), 0x00);
2609   1      
2610   1          // check 12 frames, XBOX worst case is 10 frames.
2611   1          for(ucTMDSBEDCycle = 0; ucTMDSBEDCycle < 12; ucTMDSBEDCycle++)
2612   1          {
2613   2              // Clear Vsync
2614   2              ScalerSetBit(P2_A4_TMDS_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), _BIT3);
2615   2      
2616   2              // Wait Vsync
2617   2              if(ScalerTimerPollingFlagProc(50, P2_A4_TMDS_CTRL, _BIT3, _TRUE) == _TRUE)
2618   2              {
2619   3                  // Read Bit Error enable
2620   3                  ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_AF_PORT_PAGE2_HDMI_BED_FUNC_0, ~_BIT5, _BIT5);
2621   3      
2622   3                  // pop up Bit Error Counter
2623   3                  ScalerSetByte(P2_C9_HDMI_AP, _P2_CA_PT_B6_PORT_PAGE2_HDMI_BED_FUNC_7);
2624   3                  ucBEDErrorCount = ScalerGetByte(P2_CA_HDMI_DP);
