              #elif(_D0_DDC_CHANNEL_SEL == _DDC1)
                      if(((MCU_FFE5_DDC1_EDID_IRQ & _BIT3) != _BIT3) && (GET_TMDS_RX0_DDC_DETECTED() != _TRUE))
                      {
                          MCU_FFE5_DDC1_EDID_IRQ |= _BIT2;
                          MCU_FFE5_DDC1_EDID_IRQ |= _BIT3;
              
                          CLR_TMDS_RX0_DDC_DETECTED();
