                      {
                          // DDC handshake Detected
                          DebugMessageDigital("7. wuzanne test : Normal D0 DDC", 0);
              
                          CLR_TMDS_RX0_DDC_DETECTED();
              
              #if(_TMDS_TOGGLE_HPD_Z0_FOR_ACER == _ON)
                          SET_TMDS_RX0_TOGGLE_Z0();
