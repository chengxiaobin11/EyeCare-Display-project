 179   1      
 180   1          // Set HDCP Address is 0x74
 181   1          ScalerSetDataPortBit(P2_C3_HDCP_AP, _P2_C4_PT_C2_PORT_PAGE2_HDCP_SLAVE_ADD, ~(_BIT6 | _BIT5 | _BIT4 | 
             -_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x3A);
 182   1      
 183   1          // Set HDCP Feature
 184   1      #if(_HDMI_SUPPORT == _ON)
 185   1      
 186   1      #if(_TMDS_HDCP_FEATURE == _HDCP_FEATURE_1_0)
                  ScalerSetDataPortByte(P2_C3_HDCP_AP, _P2_C4_PT_40_PORT_PAGE2_BCAPS, 0x81);
              #elif(_TMDS_HDCP_FEATURE == _HDCP_FEATURE_1_1)
                  ScalerSetDataPortByte(P2_C3_HDCP_AP, _P2_C4_PT_40_PORT_PAGE2_BCAPS, 0x83);
              #else
 191   1          ScalerSetDataPortByte(P2_C3_HDCP_AP, _P2_C4_PT_40_PORT_PAGE2_BCAPS, 0x81);
 192   1      #endif
 193   1      
 194   1      #else // Else of #if(_HDMI_SUPPORT == _ON)
              
              #if(_TMDS_HDCP_FEATURE == _HDCP_FEATURE_1_0)
                  ScalerSetDataPortByte(P2_C3_HDCP_AP, _P2_C4_PT_40_PORT_PAGE2_BCAPS, 0x01);
              #elif(_TMDS_HDCP_FEATURE == _HDCP_FEATURE_1_1)
                  ScalerSetDataPortByte(P2_C3_HDCP_AP, _P2_C4_PT_40_PORT_PAGE2_BCAPS, 0x03);
              #else
                  ScalerSetDataPortByte(P2_C3_HDCP_AP, _P2_C4_PT_40_PORT_PAGE2_BCAPS, 0x01);
              #endif
              
              #endif // End of #if(_HDMI_SUPPORT == _ON)
 205   1      
 206   1          // MAC Select to HDMI
 207   1          ScalerSetBit(PB_00_HD_DP_SEL, ~_BIT0, _BIT0);
 208   1      
 209   1          // PHY Select to HDMI
 210   1          ScalerSetBit(PB_A5_DIG_05, ~_BIT7, _BIT7);
 211   1      
 212   1          // Analog Select to HDMI
 213   1          ScalerSetBit(PB_B6_BANDGAP_02, ~_BIT5, 0x00);
 214   1      
 215   1          // Termination to VDD
 216   1          ScalerSetBit(PB_BF_CMU_02, ~(_BIT5 | _BIT4), 0x00);
 217   1      
 218   1          // Disable HDMI MAC Global Power Down
 219   1          ScalerSetBit(P2_AD_TMDS_CPS, ~_BIT1, 0x00);
 220   1      
 221   1          // Enable MAC Input
 222   1          ScalerSetBit(P2_A7_TMDS_PWDCTL, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT2 | _BIT1 | _BI
             -T0));
 223   1      
C51 COMPILER V8.12   RL6463_SERIES_TMDS                                                    03/10/2025 13:50:51 PAGE 5   

 224   1          // Set MAC Signal Swap
 225   1          ScalerSetBit(P2_A7_TMDS_PWDCTL, ~(_BIT6 | _BIT5), ((ucInputPort == _D0_INPUT_PORT) ? ((_D0_TMDS_BR_SWA
             -P << 6) | (_D0_TMDS_PN_SWAP << 5)) : ((_D1_TMDS_BR_SWAP << 6) | (_D1_TMDS_PN_SWAP << 5))));
 226   1      
 227   1          // Auto switch to DVI when no signal
 228   1          ScalerSetBit(P2_AD_TMDS_CPS, ~_BIT2, _BIT2);
 229   1      
