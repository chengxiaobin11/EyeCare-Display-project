 115          // Description  : Initialize TMDS setting for search
 116          // Input Value  : Current Search Port
 117          // Output Value : None
 118          //--------------------------------------------------
 119          void ScalerTMDSInitial(BYTE ucInputPort)
 120          {
 121   1          // Disable TMDS output
 122   1          ScalerSetBit(P2_A6_TMDS_OUTCTL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), 0x00);
 123   1      
 124   1          // Set HS Width(DE only) and HDCP Reference VS
 125   1          ScalerSetBit(P2_AB_TMDS_ACC2, ~(_BIT7 | _BIT6), 0x00);
 126   1      
 127   1          // Disable C9/CA Port Auto-Inc
 128   1          ScalerSetBit(P2_C8_HDMI_APC, ~_BIT0, 0x00);
 129   1      
 130   1      #if(_HDMI_SUPPORT == _ON)
 131   1      
 132   1          ScalerTMDSHdmiWatchDog((_HDMI_AVI_INFO_VARIATION_WD | _HDMI_AV_MUTE_WD), _DISABLE);
 133   1      
 134   1          // Deep Color Mode clock and detection auto
 135   1          ScalerSetBit(P2_B8_TMDS_DPC1, ~(_BIT3 | _BIT2), _BIT2);
 136   1      
 137   1          // Enable BCH Detection
 138   1          ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_02_PORT_PAGE2_HDMI_BCHCR, ~(_BIT6 | _BIT3 | _BIT2 | _BIT
             -1), (_BIT6 | _BIT3 | _BIT2 | _BIT1));
 139   1      
 140   1          // DVI mode don't disable Audio Clk
 141   1          ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_00_PORT_PAGE2_HDMI_SCR, ~(_BIT7 | _BIT6 | _BIT5), _BIT5)
             -;
 142   1      
 143   1          // Set Video Watch Dog New Mode
 144   1          ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_32_PORT_PAGE2_HDMI_WDCR1, ~_BIT5, _BIT5);
 145   1      
 146   1          // Specify Packet Detect Type
 147   1          ScalerSetDataPortByte(P2_C9_HDMI_AP, _P2_CA_PT_43_PORT_PAGE2_HDMI_PTRSV0, _HDMI_AVI_INFO_TYPE);
 148   1          ScalerSetDataPortByte(P2_C9_HDMI_AP, _P2_CA_PT_44_PORT_PAGE2_HDMI_PTRSV1, _HDMI_GENERAL_CONTROL_TYPE);
 149   1      
 150   1      #if(_HDMI_IDENTIFY_GAME_SRC_SUPPORT == _ON)
                  memset(&g_stTmdsMacRx0SpdInfo, 0x00, sizeof(g_stTmdsMacRx0SpdInfo));
              #endif
 153   1      
 154   1      #if((_HDMI_FREESYNC_SUPPORT == _ON) || (_HDMI_IDENTIFY_GAME_SRC_SUPPORT == _ON))
 155   1          ScalerSetDataPortByte(P2_C9_HDMI_AP, _P2_CA_PT_A4_PORT_PAGE2_HDMI_PTRSV_2, _SPD_INFO_TYPE);
 156   1      #endif
 157   1      
 158   1          // Packet Variation Detect Disable
 159   1          ScalerSetDataPortByte(P2_C9_HDMI_AP, _P2_CA_PT_45_PORT_PAGE2_HDMI_PVGCR0, 0x00);
 160   1          ScalerSetDataPortByte(P2_C9_HDMI_AP, _P2_CA_PT_46_PORT_PAGE2_HDMI_PVGCR1, 0x00);
 161   1          ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_47_PORT_PAGE2_HDMI_PVGCR2, ~(_BIT3 | _BIT2 | _BIT1 | _BI
             -T0), 0x00);
 162   1          ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_A9_PORT_PAGE2_HDMI_PVSR_4, ~(_BIT7 | _BIT6 | _BIT5), 0x0
             -0);
 163   1          ScalerSetDataPortByte(P2_C9_HDMI_AP, _P2_CA_PT_AA_PORT_PAGE2_HDMI_PVGCR3, 0x00);
 164   1          ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_AB_PORT_PAGE2_HDMI_PVGCR4, ~(_BIT7 | _BIT6 | _BIT5), 0x0
             -0);
 165   1      #endif
C51 COMPILER V8.12   RL6463_SERIES_TMDS                                                    03/10/2025 13:50:51 PAGE 4   

 166   1      
 167   1          // BED enable for Data Rate >= 700
 168   1          if(GET_INPUT_PIXEL_CLK() >= 700)
 169   1          {
 170   2              // BED counter period set 1 frame
 171   2              ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_B5_PORT_PAGE2_HDMI_BED_FUNC_6, ~(_BIT7 | _BIT6), 0x0
             -0);
 172   2      
 173   2              // Enable BED Double buffer and Valid Period Type by Frame(by Vsync)
 174   2              ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_AF_PORT_PAGE2_HDMI_BED_FUNC_0, ~(_BIT3 | _BIT1 | _BI
             -T0), _BIT3);
 175   2          }
 176   1      
 177   1          // Set HDCP DDC Debounce, TMDS Function
