  62   2              ScalerSetBit(P9_A1_INPUT_GAMMA_CTRL, ~_BIT6, 0x00);
  63   2          }
  64   1          else // _FUNCTION_CLOCK_GATED
  65   1          {
  66   2              ScalerSetBit(P9_A1_INPUT_GAMMA_CTRL, ~_BIT6, 0x00);
