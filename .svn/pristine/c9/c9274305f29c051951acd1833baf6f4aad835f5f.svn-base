  51          void ScalerColorPCMInputGammaEnable(EnumFunctionOnOFF enumOn)
C51 COMPILER V8.12   RL6449_SERIES_COLORPCMINPUTGAMMAENABLE                                03/11/2025 19:56:08 PAGE 2   

  52          {
  53   1          if(enumOn == _FUNCTION_ON)
  54   1          {
  55   2              // Disable Clock Gated
  56   2              ScalerSetBit(P1_DB_DCLK_GATED_CTRL1, ~_BIT2, _BIT2);
  57   2      
