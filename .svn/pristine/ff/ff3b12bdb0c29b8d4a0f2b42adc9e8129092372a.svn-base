  21          #define _DIG_FILTER_BGAIN                   0
  22          #define _DIG_FILTER_GGAIN                   1
  23          #define _DIG_FILTER_RGAIN                   2
  24          #define _DIG_FILTER_RGB_CHANNEL             3
  25          
  26          #define _DIG_FILTER_THRESHOLD1              30
  27          #define _DIG_FILTER_OFFSET                  5
  28          #define _DIG_FILTER_DELTA                   5
  29          
