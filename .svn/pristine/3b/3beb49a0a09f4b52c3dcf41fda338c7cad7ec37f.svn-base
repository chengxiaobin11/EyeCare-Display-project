 519          //--------------------------------------------------
 520          // Description  : DP CRC Calculate
 521          // Input Value  : None
 522          // Output Value : None
 523          //--------------------------------------------------
 524          void ScalerDpRx0CrcCalculate(void)
 525          {
 526   1          if(GET_DP_RX0_CRC_CALCULATE() == _TRUE)
 527   1          {
 528   2              DebugMessageRx0("7. DP CRC Test Start", 0);
 529   2      
 530   2              if(GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR422)
 531   2              {
 532   3                  ScalerSetBit(PB5_70_DP_CRC_CTRL, ~_BIT4, _BIT4);
 533   3              }
 534   2              else
 535   2              {
 536   3                  ScalerSetBit(PB5_70_DP_CRC_CTRL, ~_BIT4, 0x00);
 537   3              }
 538   2      
 539   2              // Start CRC Calculation
 540   2              ScalerSetBit(PB5_70_DP_CRC_CTRL, ~_BIT7, _BIT7);
 541   2      
 542   2              if((ScalerTimerPollingFlagProc(_DP_MEASURE_POLLING_TIMEOUT, PB5_70_DP_CRC_CTRL, _BIT6, _TRUE) && (
             -ScalerDpRx0FifoCheck(_DP_FIFO_POLLING_CHECK))) == _TRUE)
 543   2              {
 544   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x40, ScalerGetByte(PB5_72_DP_CRC_R_L));
 545   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x41, ScalerGetByte(PB5_71_DP_CRC_R_M));
 546   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x42, ScalerGetByte(PB5_74_DP_CRC_G_L));
 547   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x43, ScalerGetByte(PB5_73_DP_CRC_G_M));
 548   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x44, ScalerGetByte(PB5_76_DP_CRC_B_L));
 549   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x45, ScalerGetByte(PB5_75_DP_CRC_B_M));
 550   3      
 551   3                  CLR_DP_RX0_CRC_CALCULATE();
 552   3      
 553   3                  // Update _TEST_CRC_COUNT
 554   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x46, 0x21);
 555   3              }
 556   2      
 557   2              // Stop CRC Calculation
 558   2              ScalerSetBit(PB5_70_DP_CRC_CTRL, ~_BIT7, 0x00);
 559   2          }
 560   1      }
