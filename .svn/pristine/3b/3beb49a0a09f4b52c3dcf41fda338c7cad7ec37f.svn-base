 878          void ScalerDpRx0DpcdGroupReset(BYTE ucDpcdAccessPortH, BYTE ucDpcdAccessPortM, BYTE ucDpcdAccessPortL, WOR
             -D usLen)
 879          {
 880   1          BYTE ucAuxModeBackUp = 0;
 881   1          BYTE ucAutoIncBackUp = 0;
