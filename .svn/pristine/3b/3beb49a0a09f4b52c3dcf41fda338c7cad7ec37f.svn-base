 898   1      
 899   1          if((ucAutoIncBackUp & _BIT0) == 0x00)
 900   1          {
 901   2              // Enable Dpcd Auto Inc
 902   2              ScalerSetBit(PB7_C0_DPCD_CTRL, ~_BIT0, _BIT0);
 903   2          }
 904   1      
 905   1          while(usLen > 0)
 906   1          {
 907   2              // Reset Dpcd
 908   2              ScalerSetByte(PB7_C4_DPCD_DATA_PORT, 0x00);
 909   2      
 910   2              usLen--;
 911   2          }
 912   1      
 913   1          if((ucAutoIncBackUp & _BIT0) == 0x00)
 914   1          {
 915   2              // Disable Dpcd Auto Inc
 916   2              ScalerSetBit(PB7_C0_DPCD_CTRL, ~_BIT0, 0x00);
 917   2          }
 918   1      
 919   1          if((ucAuxModeBackUp & _BIT1) == _BIT1)
 920   1          {
 921   2              SET_DP_RX0_AUX_AUTO_MODE();
 922   2          }
 923   1      }
