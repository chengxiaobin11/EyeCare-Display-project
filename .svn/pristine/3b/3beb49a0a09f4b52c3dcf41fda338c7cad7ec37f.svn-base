 361          void ScalerDpRx0ScrambleSetting(void)
 362          {
 363   1          BYTE ucBackUp = ScalerGetByte(PB7_D0_AUX_MODE_SET);
 364   1          bit bEnhanceChange = _FALSE;
 365   1          bit bScrambleChange = _FALSE;
 366   1      
 367   1          SET_DP_RX0_AUX_MANUAL_MODE();
 368   1      
 369   1          if((ScalerDpRx0GetDpcdBitInfo(0x00, 0x01, 0x01, _BIT7) == _BIT7) != (ScalerGetBit(PB_01_PHY_DIG_RESET_
             -CTRL, _BIT2) == _BIT2))
 370   1          {
 371   2              bEnhanceChange = _TRUE;
 372   2      
 373   2              if(ScalerDpRx0GetDpcdBitInfo(0x00, 0x01, 0x01, _BIT7) == _BIT7)
 374   2              {
 375   3                  // Enable Enhancement Control Mode --> MAC
 376   3                  ScalerSetBit(PB_01_PHY_DIG_RESET_CTRL, ~_BIT2, _BIT2);
 377   3              }
 378   2              else
 379   2              {
 380   3                  // Disable Enhancement Control Mode --> MAC
 381   3                  ScalerSetBit(PB_01_PHY_DIG_RESET_CTRL, ~_BIT2, 0x00);
 382   3              }
 383   2          }
 384   1      
 385   1          if((ScalerDpRx0GetDpcdBitInfo(0x00, 0x01, 0x02, _BIT5) == _BIT5) != (ScalerGetBit(PB_07_SCRAMBLE_CTRL,
             - _BIT5) == _BIT5))
 386   1          {
 387   2              bScrambleChange = _TRUE;
 388   2      
 389   2              if(ScalerDpRx0GetDpcdBitInfo(0x00, 0x01, 0x02, _BIT5) == _BIT5)
 390   2              {
 391   3                  // Disable Scrambling
 392   3                  ScalerSetBit(PB_07_SCRAMBLE_CTRL, ~_BIT5, _BIT5);
 393   3              }
 394   2              else
 395   2              {
 396   3                  // Enable Scrambling
 397   3                  ScalerSetBit(PB_07_SCRAMBLE_CTRL, ~_BIT5, 0x00);
 398   3              }
C51 COMPILER V9.60.0.0   SCALERDPRX0                                                       09/09/2025 18:16:22 PAGE 8   

 399   2          }
 400   1      
 401   1          if((bEnhanceChange == _TRUE) || (bScrambleChange == _TRUE))
 402   1          {
 403   2              SET_DP_RX0_AUX_AUTO_MODE();
 404   2      
 405   2              // Delay 2ms for Scramble
 406   2              ScalerTimerDelayXms(2);
 407   2      
 408   2              SET_DP_RX0_AUX_MANUAL_MODE();
