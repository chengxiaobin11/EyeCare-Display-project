1249   2              if(GET_DP_RX0_H_PORCH_ENLARGE() > (usFifoOffset / 2))
1250   2              {
1251   3                  SET_DP_RX0_H_PORCH_ENLARGE(usFifoOffset / 2);
1252   3              }
1253   2      
1254   2              usTempHtotal = usTempHtotal + GET_DP_RX0_H_PORCH_ENLARGE();
1255   2          }
1256   1          else
1257   1          {
1258   2              CLR_DP_RX0_H_PORCH_ENLARGE();
1259   2          }
1260   1      
1261   1          if((usTempHtotal % 2) != 0)
1262   1          {
1263   2              // Avoid Htotal value is odd.
1264   2              usTempHtotal += 1;
1265   2          }
1266   1      
1267   1          return usTempHtotal;
