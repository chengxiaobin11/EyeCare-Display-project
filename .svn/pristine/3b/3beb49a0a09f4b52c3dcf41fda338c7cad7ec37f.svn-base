 887   1          ucAutoIncBackUp = ScalerGetByte(PB7_C0_DPCD_CTRL);
 888   1      
 889   1          if((ucAuxModeBackUp & _BIT1) == _BIT1)
 890   1          {
 891   2              SET_DP_RX0_AUX_MANUAL_MODE();
 892   2          }
 893   1      
