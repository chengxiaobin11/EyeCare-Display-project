  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Set window extension gradient level for R/G/B channel
  49          // Input Value  : enumOsdWindowsType -> _OSD_WINDOW_0, _OSD_WINDOW_5, _OSD_WINDOW_6, _OSD_WINDOW_7, _OSD_W
             -INDOW_8, _OSD_WINDOW_9
C51 COMPILER V8.12   OSDWINDOWGRADIENTLEVEL                                                03/11/2025 19:56:00 PAGE 2   

  50          //                ucLevelR           -> window RED extension gradient level (0 ~ 255)
  51          //                ucLevelG           -> window GRN extension gradient level (0 ~ 255)
  52          //                ucLevelB           -> window BLU extension gradient level (0 ~ 255)
  53          // Output Value :
  54          //--------------------------------------------------
  55          void ScalerOsdWindowGradientLevel(EnumOsdWindowsType enumOsdWindowsType, BYTE ucLevelR, BYTE ucLevelG, BYT
             -E ucLevelB)
  56          {
  57   1          WORD usTempWindowNumber = 0;
  58   1      
  59   1          usTempWindowNumber = 0x174 + (enumOsdWindowsType * 7);
  60   1          ScalerOsdWriteAllByte((_OSD_WIN_CONTROL), usTempWindowNumber, ucLevelR, ucLevelG, ucLevelB);
  61   1      }
