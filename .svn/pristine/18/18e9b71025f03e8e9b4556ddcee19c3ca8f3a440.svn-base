  48          // Description  : DDR1 ScalerDDR1PowerMode
  49          // Input Value  : None
  50          // Output Value : None
  51          //--------------------------------------------------
  52          void ScalerDDR1PowerEnable(bit bOn)
  53          {
  54   1          if(bOn == _ON)
  55   1          {
  56   2              // Config for DDR1 mode
  57   2              ScalerSetBit(P4_00_SDDR_CTRL, ~_BIT0, 0x00);
  58   2      
  59   2              // Enable OP power
  60   2              ScalerSetBit(P4_00_SDDR_CTRL, ~_BIT1, 0x00);
  61   2      
  62   2              // DDR Vref select internal
  63   2              ScalerSetBit(P4_00_SDDR_CTRL, ~_BIT4, 0x00);
  64   2      
  65   2              // Enable DQ low different amplifier
  66   2              ScalerSetBit(P4_00_SDDR_CTRL, ~_BIT2, 0x00);
  67   2      
  68   2              // Enable DQ high different amplifier
  69   2              ScalerSetBit(P4_00_SDDR_CTRL, ~_BIT3, 0x00);
  70   2      
  71   2              // Enable Pad power on
  72   2              ScalerSetBit(P4_00_SDDR_CTRL, ~_BIT5, _BIT5);
  73   2      
  74   2              // Disable Second OP power
  75   2              ScalerSetBit(P4_10_SDDR_CTRL, ~_BIT1, _BIT1);
  76   2      
  77   2      #if(_MEMORY_SIZE_CONFIG == _4M_16BIT_DDR1_2PCS)
              
                      // Config for Second DDR1 mode
                      ScalerSetBit(P4_10_SDDR_CTRL, ~_BIT0, 0x00);
              
                      // Enable Second OP power
                      ScalerSetBit(P4_10_SDDR_CTRL, ~_BIT1, 0x00);
              
                      // DDR Second Vref select internal
                      ScalerSetBit(P4_10_SDDR_CTRL, ~_BIT4, 0x00);
              
                      // Enable Second DQ low different amplifier
                      ScalerSetBit(P4_10_SDDR_CTRL, ~_BIT2, 0x00);
              
                      // Enable Second DQ high different amplifier
                      ScalerSetBit(P4_10_SDDR_CTRL, ~_BIT3, 0x00);
              
                      // Enable Second Pad power on
                      ScalerSetBit(P4_10_SDDR_CTRL, ~_BIT5, _BIT5);
              #endif
  97   2      
  98   2              // Disable DDR1 CKE force low into Power down mode
  99   2              ScalerSetBit(P4_A6_SDR_SLEW_RATE, ~_BIT1, 0x00);
 100   2      
 101   2              // Precharge power down mode select
 102   2              ScalerSetBit(P4_B7_SDR_POWER_CTRL0, ~(_BIT5 | _BIT4), 0x00);
 103   2      
 104   2              // Delay Time us [5,x] Waiting for DDR setting
 105   2              DELAY_5US();
 106   2      
 107   2              // Inactive power down
 108   2              ScalerSetBit(P4_B7_SDR_POWER_CTRL0, ~_BIT7, 0x00);
 109   2          }
