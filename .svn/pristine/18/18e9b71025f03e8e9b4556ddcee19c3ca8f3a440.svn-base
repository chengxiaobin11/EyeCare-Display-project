 196          //--------------------------------------------------
 197          // Description  : DDR1 system initial
 198          // Input Value  : None
 199          // Output Value : None
 200          //--------------------------------------------------
 201          void ScalerDDR1MemoryType(void)
 202          {
 203   1      #if(_MEMORY_SIZE_CONFIG == _4M_16BIT_DDR1_1PC)
 204   1      
 205   1          // Set DDR1 Memory Type & Control CAS Latency = 1.5
 206   1          ScalerSetBit(P4_A5_SDR_MEM_TYPE, ~(_BIT7 | _BIT6 | _BIT5 | _BIT2 | _BIT1 | _BIT0), (_BIT6 | _BIT1));
 207   1      
 208   1          // Set DDR1 Read SRAM Length
 209   1          ScalerSetByte(P4_BD_SDR_MCU_RD_LEN, 0x02);
 210   1      
 211   1      #elif(_MEMORY_SIZE_CONFIG == _4M_16BIT_DDR1_2PCS)
              
                  // Set DDR1 Memory Type & Control CAS Latency = 1.5
                  ScalerSetBit(P4_A5_SDR_MEM_TYPE, ~(_BIT7 | _BIT6 | _BIT5 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | _BIT1));
              
                  // Set DDR1 Read SRAM Length
                  ScalerSetByte(P4_BD_SDR_MCU_RD_LEN, 0x01);
              
              #endif
 220   1      }
 221          
