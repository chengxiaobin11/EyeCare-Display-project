  50          // Description  : SRAM address value and which byte
  51          // Input Value  : ucRow. ucCol.     -> Just that !!
C51 COMPILER V8.12   OSDSRAMADDRESSCOUNT                                                   03/11/2025 19:55:58 PAGE 2   

  52          //                enumOsdWriteType  -> _OSD_BYTE0 or _OSD_BYTE1 or _OSD_BYTE2
  53          // Output Value :
  54          //--------------------------------------------------
  55          void ScalerOsdSramAddressCount(BYTE ucRow, BYTE ucCol, EnumOsdWriteType enumOsdWriteType)
  56          {
  57   1          WORD usCharCommandStartAddress = 0;
  58   1          BYTE ucColSize = 0;
  59   1          BYTE ucByte0 = 0;
  60   1          BYTE ucByte1 = 0;
  61   1          BYTE ucByte2 = 0;
  62   1      
  63   1          if(ScalerGetBit(P3A_18_FRAME_CTRL_18, _BIT3) == _BIT3) // OSD 2 Font Function
  64   1          {
  65   2              ucByte0 = ScalerGetByte(P3A_1B_FRAME_CTRL_1B);
  66   2              ucByte1 = ScalerGetByte(P3A_1C_FRAME_CTRL_1C);
  67   2              ucByte2 = ScalerGetByte(P3A_1D_FRAME_CTRL_1D);
  68   2      
  69   2              if(ucRow >= _OSD_MAP_B_ROW_OFFSET)
  70   2              {
  71   3                  ucRow -= _OSD_MAP_B_ROW_OFFSET;
  72   3                  ucColSize = GET_OSD_MAPB_COL_MAX();
  73   3                  // Font Select Base 1
  74   3                  usCharCommandStartAddress = ((ucByte0 & 0x0F) << 8) | ucByte2;
  75   3              }
  76   2              else
  77   2              {
  78   3                  ucColSize = GET_OSD_MAPA_COL_MAX();
  79   3                  // Font Select Base 0
  80   3                  usCharCommandStartAddress = ((ucByte0 & 0xF0) << 4) | ucByte1;
  81   3              }
  82   2          }
  83   1          else
  84   1          {
  85   2              ucByte0 = ScalerGetByte(P3A_0C_FRAME_CTRL_0C);
  86   2              ucByte1 = ScalerGetByte(P3A_0D_FRAME_CTRL_0D);
  87   2              ucByte2 = ScalerGetByte(P3A_0E_FRAME_CTRL_0E);
  88   2      
  89   2              ucColSize = GET_OSD_MAPA_COL_MAX();
  90   2      
  91   2              // Font Select Base Address
  92   2              usCharCommandStartAddress = ((ucByte1 & 0xF0) << 4) | ucByte0;
  93   2          }
  94   1      
  95   1          usCharCommandStartAddress = usCharCommandStartAddress + (ucRow * ucColSize) + ucCol;
  96   1      
  97   1          ScalerOsdAddrSet(_OSD_SRAM, enumOsdWriteType, usCharCommandStartAddress, _OSD_WITHOUT_DB);
  98   1      }
  99          
