 121          // Description  : Initial Setting for DP Digital Aux, Analog Aux
 122          // Input Value  : None
 123          // Output Value : None
 124          //--------------------------------------------------
 125          void ScalerDpRx1AuxPowerOnInitial(void)
 126          {
 127   1          BYTE ucConnectorType = ScalerSyncDpRxGetConnectorType(_D1_INPUT_PORT);
 128   1      
 129   1          if(ucConnectorType == _DP_CONNECTOR_EMBEDDED)
 130   1          {
 131   2              // Reset Aux Phy
 132   2              ScalerSetBit(PBA_65_AUX_5, ~_BIT7, 0x00);
 133   2          }
 134   1      
 135   1          // Digital Aux Power On, DPCD REG Power On, MSG Power On.
 136   1          ScalerSetBit(PBA_C0_DPCD_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT1 | _BIT0), 0x00);
 137   1      
 138   1          // Average 8 cycles as Start Postion, Aux Clk Select to 27MHz, no Swap
 139   1          ScalerSetByte(PBA_72_AUX_DIG_PHY2, 0xC0);
 140   1      
 141   1      #if(_DP_AUX_REPLY_CLK_SEL_FROM == _DP_AUX_REPLY_SEL_IOSC)
 142   1          // Aux Clk Select Manual Mode, Aux New Mode
 143   1          ScalerSetBit(PBA_73_AUX_DIG_PHY3, ~(_BIT7 | _BIT6), _BIT6);
 144   1      #else
                  // Aux Clk Select Source, Aux New Mode
                  ScalerSetBit(PBA_73_AUX_DIG_PHY3, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
              #endif
 148   1      
 149   1          // HW Fake Link Training Disable.
 150   1          ScalerSetBit(PBA_C6_AUX_PHY_DIG2, ~_BIT4, 0x00);
 151   1      
 152   1          // Set Aux Precharge Number.
 153   1          ScalerSetBit(PBA_74_AUX_DIG_PHY4, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT0));
 154   1      
 155   1          // Aux Auto Mode, Using Default Average Number.
 156   1          ScalerSetByte(PBA_75_AUX_DIG_PHY5, 0x0D);
 157   1      
 158   1          // Aux Reply Timeout Setting
 159   1          ScalerSetByte(PBA_A2_AUX_RESERVE2, _DP_AUX_REPLY_TIMEOUT_USER_SETTING);
 160   1      
 161   1          // Enble Aux Channel.
 162   1          ScalerSetBit(PBA_D0_AUX_MODE_SET, ~(_BIT3 | _BIT2 | _BIT0), _BIT0);
 163   1      
 164   1          // Fast IIC Clock.
 165   1          ScalerSetBit(PBA_D1_DP_IIC_SET, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_DP_AUX_IIC_SCL_CLK_SETTING << 4));
 166   1      
 167   1          // Set aux mac clk use xclk
 168   1          ScalerSetBit(PBA_DA_AUX_FIFO_RST, ~(_BIT4 | _BIT3 | _BIT1 | _BIT0), _BIT3);
 169   1      
 170   1          // Not Reply when Aux Error.
C51 COMPILER V8.12   RL6449_SERIES_DPRX1                                                   01/02/2025 16:31:35 PAGE 4   

 171   1          ScalerSetBit(PBA_DB_AUX_STATUS, ~(_BIT5 | _BIT4), _BIT4);
 172   1          ScalerSetBit(PBA_76_AUX_DIG_PHY6, ~(_BIT7 | _BIT6), _BIT6);
 173   1      
 174   1          // Aux Ack Timer.
 175   1          ScalerSetBit(PBA_F0_AUX_TX_TIMER, ~(_BIT5 | _BIT2), (_BIT5 | _BIT2));
 176   1      
 177   1          // I2C timeout setting
 178   1          ScalerSetByte(PBA_F1_AUX_TX_TIMER_2, _DP_AUX_I2C_REPLY_TIMEOUT_SETTING);
 179   1      
 180   1          // Disable Reply IIC Defer Before Data Ready.
 181   1          ScalerSetBit(PBA_F4_MCUIIC, ~(_BIT6 | _BIT5), 0x00);
 182   1      
 183   1          // Enable Aux Error Handler.
 184   1          ScalerSetBit(PBA_78_AUX_DIG_PHY8, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT5 | _
             -BIT4));
 185   1      
 186   1          if(ucConnectorType != _DP_CONNECTOR_EMBEDDED)
 187   1          {
 188   2              // Toggle Aux Auto K
 189   2              ScalerSetBit(PBA_65_AUX_5, ~_BIT7, 0x00);
 190   2              ScalerSetBit(PBA_65_AUX_5, ~_BIT7, _BIT7);
 191   2          }
 192   1      
 193   1          // Aux Mode Set (Diff Mode or Single-ended mode) && Aux RX1 Resistance Setting
 194   1          ScalerDpRx1AuxSet();
 195   1      
 196   1          // Set Aux Talk Mode ADJR
 197   1          ScalerSetByte(PBA_67_DIG_TX_03, 0x88);
 198   1      
 199   1          ScalerSetBit(PBA_60_DIG_TX_04, ~(_BIT1 | _BIT0), _BIT0);
 200   1      
 201   1          // Aux comm current select max
 202   1          ScalerSetBit(PBA_64_AUX_4, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 203   1      
 204   1          // Set Aux D_2 = ~D_1 for Aux Single Ended Mode
 205   1          ScalerSetBit(PBA_79_AUX_DIG_PHY9, ~_BIT7, _BIT7);
 206   1      
 207   1          // Clear the Clock Divider for AUX MAC and PHY
 208   1          ScalerSetBit(PBA_73_AUX_DIG_PHY3, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 209   1          ScalerSetBit(PBA_B0_AUX_PAYLOAD_CLEAR, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 210   1      
 211   1          // Aux ps clk from IOSC
 212   1          ScalerSetBit(P0_0B_POWER_CTRL, ~(_BIT5 | _BIT4), 0x00);
 213   1      
 214   1          // Set the Clock Divider = 1 for AUX MAC and PHY
 215   1          ScalerSetBit(PBA_73_AUX_DIG_PHY3, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT0);
 216   1          ScalerSetBit(PBA_B0_AUX_PAYLOAD_CLEAR, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT0);
 217   1      }
