 873          //--------------------------------------------------
 874          bit ScalerMeasureAutoFuncWaitFinish(void)
 875          {
 876   1          BYTE ucIvsCnt = 0;
 877   1      
 878   1          ucIvsCnt = (ScalerGetBit(P0_7A_AUTO_ADJ_CTRL0, _BIT1 | _BIT0) == 0x03) ? 3 : 1;
 879   1          ucIvsCnt = (ScalerGetBit(P0_7A_AUTO_ADJ_CTRL0, _BIT7) == _BIT7) ? ucIvsCnt * 2 : ucIvsCnt;
 880   1          ucIvsCnt += 2;
 881   1      
 882   1          do
 883   1          {
 884   2              if(ScalerGetBit(P0_7D_AUTO_ADJ_CTRL1, _BIT0) == 0x00)
 885   2              {
 886   3                  return _TRUE;
 887   3              }
 888   2      
 889   2              if(ScalerTimerWaitForEvent(_EVENT_IVS) == _FALSE)
 890   2              {
 891   3                  return _FALSE;
 892   3              }
 893   2          }
 894   1          while(--ucIvsCnt);
 895   1      
 896   1          return _FALSE;
 897   1      }
