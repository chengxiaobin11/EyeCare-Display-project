 496   4                                             (abs(stMeasureSyncHV.usHTotal - GET_SYNC_H_TOTAL()) > 2) ||
 497   4                                             (abs(stMeasureSyncHV.usHWidth - GET_SYNC_H_WIDTH()) > 2) ||
 498   4                                             (abs(stMeasureSyncHV.usVHeight - GET_SYNC_V_HEIGHT()) > 2));
 499   4      
 500   4                      if(GET_INPUT_TIMING_INTERLACE_FLG() == _TRUE)
 501   4                      {
 502   5                          bTimingChangeStatus |= (abs(stMeasureSyncHV.usVSPeriod - GET_SYNC_V_PERIOD()) > 3);
 503   5                      }
 504   4                      else
 505   4                      {
 506   5                          bTimingChangeStatus |= (abs(stMeasureSyncHV.usVSPeriod - GET_SYNC_V_PERIOD()) > 2);
 507   5                      }
 508   4                  }
 509   3              }
 510   2      
 511   2      #if(_DUAL_DVI_SUPPORT == _ON)
