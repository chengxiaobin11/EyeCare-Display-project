 112          // Description  : Measure Input Timing
 113          // Input Value  : ucSourceType --> Input source type
 114          // Output Value : _TURE => All Required Timing Info is done
 115          //--------------------------------------------------
 116          bit ScalerMeasureVgaInputInfo(void)
 117          {
 118   1          DWORD pulActiveRegionCount[2];
 119   1          EnumSourceSearchPort enumSourceSearchPort = _A0_INPUT_PORT;
 120   1      
 121   1          pulActiveRegionCount[0] = 0;
 122   1          pulActiveRegionCount[1] = 0;
 123   1      
 124   1          //===========================================================================================
 125   1          // 0. Initialization
 126   1          //===========================================================================================
 127   1      
 128   1          // Initial the inteface to be measured
 129   1          ScalerMeasureInterfaceInitial(_SOURCE_VGA, &enumSourceSearchPort);
 130   1      
 131   1          // Initial Measure
 132   1          ScalerMeasureInitialSetting(_SOURCE_VGA, _A0_INPUT_PORT);
 133   1      
 134   1          // Initial Interlace Check Block
 135   1          ScalerMeasureInterlaceInitial(_SOURCE_VGA, _A0_INPUT_PORT);
 136   1      
 137   1          // Enable IVS bypass
 138   1          ScalerMeasureVgaVsBypass(_ENABLE);
 139   1      
 140   1          // Initial active region count block
 141   1          ScalerMeasureSetInputRegionCount(_WHOLE_FRAME_TYPE);
 142   1      
 143   1          //===========================================================================================
 144   1          // 1. Start measure block & region count(raw VS); pop-out result
 145   1          //===========================================================================================
 146   1      
 147   1          // Wait for 3raw IVS for VGA; Pop out measure result
 148   1          if((ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS) == _FALSE) ||
 149   1             (ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS) == _FALSE) ||
 150   1             (ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS) == _FALSE) ||
 151   1             (ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS) == _FALSE) ||
 152   1             (ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS) == _FALSE) ||
 153   1             (ScalerMeasureGetOfflineMeasureResult(&g_stMeasureSyncHV, _A0_INPUT_PORT) == _FALSE) ||
 154   1             (ScalerMeasureGetStableMeasureResult(&g_stMeasureSyncHV) == _FALSE))
 155   1          {
 156   2              DebugMessageMeasure("VGA off-line measure fail", 0x00);
 157   2              return _FALSE;
 158   2          }
 159   1      
 160   1          ScalerTimerDelayXms(2);
 161   1      
 162   1          // Pop out active region count result (raw)
 163   1          if((pulActiveRegionCount[0] = ScalerMeasureGetInputRegionCountResult(_NOT_WAIT)) == 0x00)
 164   1          {
 165   2              return _FALSE;
 166   2          }
 167   1      
 168   1          // Disable IVS bypass
C51 COMPILER V8.12   SCALERMEASURE                                                         03/10/2025 13:50:25 PAGE 4   

 169   1          ScalerMeasureVgaVsBypass(_DISABLE);
 170   1      
 171   1          // Restart active region count block;
 172   1          ScalerMeasureSetInputRegionCount(_WHOLE_FRAME_TYPE);
 173   1      
 174   1          //===========================================================================================
 175   1          // 2. Check VGIP HS/VS polarity
 176   1          //===========================================================================================
 177   1      
 178   1          // Update input timing polarity (MUST BE HERE)
 179   1          ScalerMeasureUpdateInputTimingPolarity(_SOURCE_VGA, _A0_INPUT_PORT, &g_stMeasureSyncHV);
 180   1      
 181   1          // Modify VGIP sync polarity
 182   1          ScalerVgipModifyPolarity(_SOURCE_VGA);
 183   1      
 184   1          // Update input timing data from variable "g_stMeasureSyncHV"
 185   1          ScalerMeasureUpdateInputTimingData(&g_stMeasureSyncHV, &g_stActiveRegion);
 186   1      
 187   1          //===========================================================================================
 188   1          // 3. Start auto-function & check VGIP VS latch edge
 189   1          //===========================================================================================
 190   1      
 191   1          // Start auto-function measure
 192   1          ScalerVgaTopSetAuto(_NORMAL_MEASURE, _FULL_BOUNDARY, ScalerAPLLGetIHTotal());
 193   1      
 194   1          // Check IVS latch edge after 1 IVS; Add additional 1 frame if latch edge changed
 195   1          if((ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS) == _FALSE) ||
 196   1             ((ScalerVgaTopModifyVsLatchEdge(_NOT_WAIT) == _TRUE) &&
 197   1              (ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS) == _FALSE)))
 198   1          {
 199   2              return _FALSE;
 200   2          }
 201   1      
 202   1          // Wait for 1 latched IVS; Pop out auto-function result
 203   1          if((ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS) == _FALSE) ||
 204   1             (ScalerVgaTopGetAutoResult(&g_stActiveRegion, _NOT_WAIT) == _FALSE) ||
 205   1             (ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS) == _FALSE))
 206   1          {
 207   2              DebugMessageMeasure("VGA auto-function fail", 0x00);
 208   2              return _FALSE;
 209   2          }
 210   1      
 211   1          //===========================================================================================
 212   1          // 4. Detect interlace format
 213   1          //===========================================================================================
 214   1      
 215   1          // Pop out active region count result (latched) for VGA
 216   1          pulActiveRegionCount[1] = ScalerMeasureGetInputRegionCountResult(_NOT_WAIT);
 217   1      
 218   1          // Check active region count result; Return _FALSE if the difference is too large
 219   1          if(ABSDWORD(pulActiveRegionCount[0], pulActiveRegionCount[1]) > (pulActiveRegionCount[1] >> 6))
 220   1          {
 221   2              DebugMessageMeasure("VGA active count difference fail", 0x00);
 222   2              return _FALSE;
 223   2          }
 224   1      
 225   1          // Get HS period in measure clock
 226   1          PDATA_WORD(1) = (((WORD)ScalerGetBit(P30_05_MEAS_HS_PERIOD_A_M, (_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0
             -)) << 8) |
 227   1                           ((WORD)ScalerGetByte(P30_06_MEAS_HS_PERIOD_A_L)));
 228   1      
 229   1          // Calculate difference of V period
C51 COMPILER V8.12   SCALERMEASURE                                                         03/10/2025 13:50:25 PAGE 5   

 230   1          PDATA_WORD(0) = (WORD)(ABSDWORD(pulActiveRegionCount[0], pulActiveRegionCount[1]) % PDATA_WORD(1));
 231   1      
 232   1          // Check half line length; flag interlace between [0.25:0.75] * H period
 233   1          if(abs(PDATA_WORD(0) - (PDATA_WORD(1) >> 1)) < (PDATA_WORD(1) >> 2))
 234   1          {
 235   2              DebugMessageMeasure("Interlace: detect by half line", PDATA_WORD(0));
 236   2              g_stInputTimingData.b1Interlace = _TRUE;
 237   2          }
 238   1          // Check full line length; flag interlace for 0.875 line difference
 239   1          else if(PDATA_WORD(0) > (PDATA_WORD(1) - (PDATA_WORD(1) >> 3)))
 240   1          {
 241   2              DebugMessageMeasure("Interlace: detect by full line", PDATA_WORD(1));
 242   2              g_stInputTimingData.b1Interlace = _TRUE;
 243   2          }
 244   1      
 245   1          // Check active measure overflow status
 246   1          if(ScalerGetBit(P30_41_I_ACT_MEAS_ERROR_FLG, _BIT6) == _BIT6)
 247   1          {
 248   2              DebugMessageMeasure("Interlace: detect by flag", PDATA_WORD(0));
 249   2              g_stInputTimingData.b1Interlace = ScalerMeasureInterlaceCheck(_SOURCE_VGA, _A0_INPUT_PORT);
 250   2          }
 251   1      
 252   1          //===========================================================================================
 253   1          // 5. Double-check current timing
 254   1          //===========================================================================================
 255   1      
 256   1          // Double-check for timing change
 257   1          if(ScalerMeasureTimingChange(_SOURCE_VGA, _A0_INPUT_PORT) == _TRUE)
 258   1          {
 259   2              DebugMessageMeasure("VGA off-line double check fail", 0x00);
 260   2              return _FALSE;
 261   2          }
 262   1      
 263   1      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
                  if(ScalerFmtCnvGetHalfDataPathEvenOddModeStatus() == _FALSE)
                  {
                      // Final format conversion setting
                      ScalerFmtCnvFinalSetting();
                  }
              #endif
 270   1      
 271   1          // Update input timing data
 272   1          ScalerMeasureUpdateInputTimingData(&g_stMeasureSyncHV, &g_stActiveRegion);
 273   1      
 274   1          return _TRUE;
 275   1      }
