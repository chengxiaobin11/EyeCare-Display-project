                  if(ScalerFmtCnvFtoPGetStatus() == _TRUE)
                  {
                      return (DWORD)(usVHeight - 2) * usHTotal + usHWidth * 2;
                  }
              #endif
 839   1      
 840   1          return (DWORD)(usVHeight - 1) * usHTotal + usHWidth;
 841   1      }
