                          // Measure Time Clock = 16384 Xtal; VS Measure Invert Disable; Disable HS/DEN swap
                          ScalerSetBit(P16_01_MEAS_CTL0, ~(_BIT7 | _BIT6 | _BIT4 | _BIT3), (_BIT7 | _BIT6));
