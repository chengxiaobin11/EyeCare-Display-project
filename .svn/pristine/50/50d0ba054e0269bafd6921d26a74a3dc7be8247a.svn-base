                      }
                      else if(GET_INPUT_TIMING_VFREQ() > (PDATA_WORD(1) >> 2))
                      {
                          // Measure Time Clock = 8192 Xtal; VS Measure Invert Disable; Disable HS/DEN swap
                          ScalerSetBit(P16_01_MEAS_CTL0, ~(_BIT7 | _BIT6 | _BIT4 | _BIT3), _BIT7);
                      }
