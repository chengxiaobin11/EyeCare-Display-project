 296   1          pstMeasureSyncHV->usHSPeriod = ((((WORD)ScalerGetByte(P0_50_STABLE_PERIOD_H) & 0x07) << 8) | (ScalerGe
             -tByte(P0_51_STABLE_PERIOD_L))) + 1;
 297   1      
