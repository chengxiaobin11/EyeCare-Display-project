              void CAlignSendAckCmd(BYTE Status)
              {
              
                      if(Status == _SUCCESS)
                      {
                              g_pucDdcciTxBuf[0] = 0x6E;
                              g_pucDdcciTxBuf[1] = 0x82;      
                              g_pucDdcciTxBuf[2] = 0x00;      
