                      }
                      else
                      {
                              g_pucDdcciTxBuf[0] = 0x6E;
                              g_pucDdcciTxBuf[1] = 0x82;      
                              g_pucDdcciTxBuf[2] = 0x03;      
                              g_pucDdcciTxBuf[3] = 0x58;
                              g_pucDdcciTxBuf[4] =0xE7;
              
                      }
              
              
              
                  ScalerMcuDdcciSendData(g_pucDdcciTxBuf);
                      ScalerMcuDdcciReleaseScl();
              
              }
              
              
              
              
