1205          void ScalerSyncProcSetSogCompareLevel(BYTE *pucLevels)
1206          {
1207   1          // Reset SOG mid compare level in power normal
1208   1          if(ScalerGetBit(P0_C6_ADC_POWER, _BIT3) != 0x00)
1209   1          {
1210   2              g_ucSogMidLevel = _SOG_MID_COMPARE_LEVEL;
1211   2          }
1212   1      
1213   1          // Set pre-set SOG compare levels
1214   1          pucLevels[0] = 0x10;
1215   1          pucLevels[1] = g_ucSogMidLevel;
1216   1          pucLevels[2] = 0x1C;
1217   1      }
