1130          // Output Value : _TRUE or _FALSE
1131          //--------------------------------------------------
1132          EnumSogLevelSearchResult ScalerSyncProcSogCheckVs(StructMeasureSyncData *pstMeasureSyncHV)
1133          {
1134   1          BYTE ucLoopCounter = 0;
1135   1          BYTE ucTimeoutCounter = ((_WAIT_TWO_FRAME_TIME >> 2) + 1);
1136   1      
1137   1          // Enable De-composite circuit; Set to analog measure
1138   1          ScalerSetBit(P0_47_SYNC_SELECT, ~(_BIT5 | _BIT0), _BIT5);
1139   1      
1140   1          // Select DE-VS/HS
1141   1          ScalerSetBit(P0_49_SYNC_CTRL, ~(_BIT6 | _BIT5), (_BIT6 | _BIT5));
1142   1      
1143   1          // Waitting for de-composite circuit decode one frame.
1144   1          while(ucLoopCounter < ucTimeoutCounter)
1145   1          {
1146   2              ++ucLoopCounter;
1147   2              ScalerTimerDelayXms(4);
1148   2      
1149   2              // Check HS stability
1150   2              if(ScalerGetBit(P0_4E_HSYNC_TYPE_DETECTION_FLAG, _BIT7) != 0x00)
1151   2              {
1152   3                  return _SOG_LEVEL_FAIL;
1153   3              }
1154   2          }
1155   1      
1156   1          // Check maximum VS width
1157   1          if((pstMeasureSyncHV->usVSWidth = ScalerSyncProcGetDeVsyncWidth()) >= _MAX_VSYNC_HIGH_PERIOD)
1158   1          {
1159   2              return _SOG_LEVEL_INVALID;
1160   2          }
1161   1      
1162   1          return _SOG_LEVEL_VALID;
1163   1      }
