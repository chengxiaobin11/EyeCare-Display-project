1177   2                 (ScalerGetBit(P0_D7_ADC_SOG_DAC, 0x3F) <= (_SOG_MID_COMPARE_LEVEL + _SOG_MID_COMPARE_RANGE)))
1178   2              {
1179   3                  if(ScalerSyncProcTypeAutoRun() == _NO_SYNC_STATE)
1180   3                  {
1181   4                      // Change SOG middle compare level within range
1182   4                      if(g_ucSogMidLevel >= (_SOG_MID_COMPARE_LEVEL + _SOG_MID_COMPARE_RANGE))
1183   4                      {
1184   5                          g_ucSogMidLevel = (_SOG_MID_COMPARE_LEVEL - _SOG_MID_COMPARE_RANGE);
1185   5                      }
