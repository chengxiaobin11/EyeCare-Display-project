 424          //--------------------------------------------------
 425          // Description  : Sync Processor Detect H/V Sync Stable for SS/CS
 426          // Input Value  : None
 427          // Output Value : True --> HV Stable
 428          //                False --> HV Not Stable
 429          //--------------------------------------------------
 430          bit ScalerSyncProcHSSyncStableDetect(void)
 431          {
 432   1          BYTE ucCirCleCnt = 5;
 433   1          WORD usHSyncPeriod = 0;
 434   1          WORD usHSyncPulseCount = 0;
 435   1      
 436   1          do
 437   1          {
 438   2              ucCirCleCnt--;
 439   2      
 440   2              // Clear flag
 441   2              ScalerSetBit(P0_5B_HS_DETECT, ~_BIT7, _BIT7);
 442   2      
 443   2              // For SOG Power Stable, Refernce H-Freq = 15.63k, Delay time about 4 H-Sync Period, 300us include
             - margin
 444   2              DELAY_XUS(300); /* Delay time us [300, x] */
 445   2      
 446   2              if(ScalerGetBit(P0_5B_HS_DETECT, _BIT7) == _BIT7)
 447   2              {
 448   3                  continue;
 449   3              }
 450   2              else
 451   2              {
 452   3                  break;
 453   3              }
 454   2          }
 455   1          while(ucCirCleCnt > 0);
 456   1      
 457   1          if(ucCirCleCnt != 0)
 458   1          {
 459   2              return _FALSE;
 460   2          }
 461   1      
 462   1          // Enable Sync Processor Clock
 463   1          ScalerSetBit(P0_47_SYNC_SELECT, ~(_BIT7 | _BIT6 | _BIT5 | _BIT3 | _BIT2 | _BIT0), 0x00);
 464   1      
 465   1          // HS_OUT Signal Output Enable, HS Out not invert
 466   1          ScalerSetBit(P0_48_SYNC_INVERT, ~(_BIT5 | _BIT4), _BIT4);
 467   1      
 468   1          // HS_OUT by pass mode, Measure Source is ADC_HS1/ADC_VS, H Sync measure source is original hs
 469   1          ScalerSetByte(P0_49_SYNC_CTRL, 0x06);
 470   1      
 471   1          // Sync from HS Pad
 472   1          ScalerSetBit(P0_47_SYNC_SELECT, ~_BIT4, 0x00);
 473   1      
C51 COMPILER V8.12   SCALERSYNCPROC                                                        03/10/2025 13:50:28 PAGE 9   

 474   1          // Start Stable Period Measure
 475   1          ScalerSetBit(P0_4F_STABLE_MEASURE, ~_BIT0, 0x00);
 476   1          ScalerSetBit(P0_4F_STABLE_MEASURE, ~_BIT0, _BIT0);
 477   1      
 478   1          if(ScalerTimerPollingFlagProc(12, P0_4F_STABLE_MEASURE, _BIT7, _TRUE) == _FALSE)
 479   1          {
 480   2              return _FALSE;
 481   2          }
 482   1      
 483   1          // Pop up stable result
 484   1          ScalerSetBit(P0_4F_STABLE_MEASURE, ~_BIT1, _BIT1);
 485   1      
 486   1          usHSyncPeriod = ((WORD)(ScalerGetByte(P0_50_STABLE_PERIOD_H) & 0x07) << 8) | ScalerGetByte(P0_51_STABL
             -E_PERIOD_L);
 487   1          usHSyncPulseCount = ((WORD)(ScalerGetByte(P0_4A_STABLE_HIGH_PERIOD_H) & 0x07) << 8) | ScalerGetByte(P0
             -_4B_STABLE_HIGH_PERIOD_L);
 488   1      
 489   1          if(ScalerGetBit(P0_4F_STABLE_MEASURE, _BIT6) == 0x00) // HS Negative
 490   1          {
 491   2              usHSyncPulseCount = (usHSyncPeriod - usHSyncPulseCount);
 492   2          }
 493   1      
 494   1          if(((usHSyncPulseCount * 7) < usHSyncPeriod) && (usHSyncPulseCount >= _MIN_SYNC_HIGHPULSE_CNT_PS))
 495   1          {
 496   2              if(ScalerTimerPollingFlagProc(_WAIT_TWO_FRAME_TIME, P0_4E_HSYNC_TYPE_DETECTION_FLAG, _BIT4, _TRUE)
             - == _TRUE) // Saperate signal
 497   2              {
 498   3                  return _TRUE;
 499   3              }
