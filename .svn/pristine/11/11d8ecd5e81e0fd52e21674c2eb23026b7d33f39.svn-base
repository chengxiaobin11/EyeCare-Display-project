 301          //--------------------------------------------------
 302          // Description  : On Line Check VGA sync stability
 303          // Input Value  : None
 304          // Output Value : True --> VGA Sync Stable
 305          //                False --> VGA Sync Unstable
 306          //--------------------------------------------------
 307          bit ScalerSyncProcStableDetect(void)
 308          {
 309   1          ScalerSetBit(P0_47_SYNC_SELECT, ~_BIT7, 0x00);
 310   1      
 311   1          if(ScalerGetBit(P0_4E_HSYNC_TYPE_DETECTION_FLAG, (_BIT7 | _BIT6 | _BIT5 | _BIT3)) != 0x00)
 312   1          {
 313   2              return _FALSE;
 314   2          }
 315   1          else
 316   1          {
 317   2      #if(_VGA_CHROMA_PATTERN12_SUPPORT == _ON)
                      // Check porch voltage level change for chroma pattern 12
                      if(ScalerSyncProcCheckPorchChange() == _TRUE)
                      {
                          // Toggle "Clamp-to-Top" status
                          ScalerADCSetClampToTopStatus(~(ScalerADCGetClampToTopStatus()));
              
                          DebugMessageAnalog("Toggle clamp-to-top status", ScalerADCGetClampToTopStatus());
                      }
              #endif
 327   2              return _TRUE;
 328   2          }
 329   1      }
