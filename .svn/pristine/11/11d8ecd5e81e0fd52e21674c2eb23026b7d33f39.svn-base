1057          EnumSogLevelSearchResult ScalerSyncProcSogCheckHs(StructMeasureSyncData *pstMeasureSyncHV)
1058          {
1059   1          WORD usHSyncPeriod = 0;
1060   1          WORD usHSyncPulseCount = 0;
1061   1      
1062   1          // Enable Sync Processor Clock
1063   1          ScalerSetBit(P0_47_SYNC_SELECT, ~(_BIT7 | _BIT6 | _BIT5 | _BIT3 | _BIT2 | _BIT0), 0x00);
1064   1      
1065   1          // HS_OUT Signal Output Enable
