1298          //--------------------------------------------------
1299          // Description  : Recheck SOG Sync Stable Condtion avioding mistacke wake up
1300          // Input Value  : None
1301          // Output Value : True --> Sync is realy stable
1302          //                False --> Sync is fake stable before
1303          //--------------------------------------------------
1304          bit ScalerSyncProcRecheckSOGSyncStable(void)
1305          {
1306   1          bit bStatus = _TRUE;
1307   1      
1308   1          if(ScalerGetBit(P0_C6_ADC_POWER, _BIT3) == 0x00) // Check Current Mode is PS Mode
C51 COMPILER V8.12   SCALERSYNCPROC                                                        03/10/2025 13:50:28 PAGE 23  

1309   1          {
1310   2              // Clamp position unit: Single Crystal clock
1311   2              ScalerSetDataPortBit(P0_5C_SYNC_PROC_PORT_ADDR, _P0_5D_PT_06_CLAMP_CTRL2, ~_BIT7, _BIT7);
1312   2      
1313   2              // G Clamp Position default Setting, Reference Crystal, Back port lenth Min = 11.69 cnt (1920x1440
             - @59.9Hz -R 184.75M, back port = 80)
1314   2              ScalerSyncProcClampPosSetting(0x01, 0x0B);
1315   2      
1316   2              // Disable DC Restore circut & Enable SOG Clamp
1317   2              ScalerSetBit(P0_D4_ADC_SOG_CTRL, ~(_BIT5 | _BIT4), _BIT5);
1318   2      
1319   2              // Waitting for SOG floating voltage Rising to 400 V
1320   2              ScalerTimerDelayXms(3);
1321   2      
1322   2              // Recheck H-Sync Status
1323   2              if(ScalerSyncProcStableCheck() == _FALSE)
1324   2              {
1325   3                  bStatus = _FALSE;
1326   3              }
1327   2      
1328   2              // Restore G Clamp Position default Setting
1329   2              ScalerSyncProcClampPosSetting(_CLAMP_POSITION_START, _CLAMP_POSITION_END);
1330   2      
1331   2              // Restore Clamp position unit: ADC clock
1332   2              ScalerSetDataPortBit(P0_5C_SYNC_PROC_PORT_ADDR, _P0_5D_PT_06_CLAMP_CTRL2, ~_BIT7, 0x00);
1333   2      
1334   2              // Enable DC Restore circut & Disable SOG Clamp
1335   2              ScalerSetBit(P0_D4_ADC_SOG_CTRL, ~(_BIT5 | _BIT4), _BIT4);
1336   2          }
1337   1      
1338   1          return bStatus;
1339   1      }
