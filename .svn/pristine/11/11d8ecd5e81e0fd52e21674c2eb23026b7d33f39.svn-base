                      pData[0] = _FALSE;
              #endif
 233   2          }
 234   1      
 235   1          if(pData[0] == _TRUE)
 236   1          {
 237   2              if(ScalerSyncProcHSSyncStableDetect() == _TRUE)
 238   2              {
 239   3                  if(ScalerSyncProcStableCheck() == _TRUE)
 240   3                  {
 241   4                      return _TRUE;
 242   4                  }
 243   3              }
 244   2              else
 245   2              {
 246   3                  // Inverse CS_RAW signal for repeat check status
 247   3                  ScalerSetBit(P0_48_SYNC_INVERT, ~_BIT3, ((~(ScalerGetBit(P0_48_SYNC_INVERT, _BIT3))) & _BIT3))
             -;
