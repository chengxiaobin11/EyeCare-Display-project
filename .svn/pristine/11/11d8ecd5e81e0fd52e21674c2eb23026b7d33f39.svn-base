 213   1      
 214   1          pData[0] = _TRUE;
 215   1      
 216   1          if(ucInputPort == _A0_INPUT_PORT)
 217   1          {
 218   2      #if(_A0_VGA_CONNECTOR_TYPE == _VGA_CONNECTOR_YPBPR)
                      pData[0] = _FALSE;
              #endif
 221   2          }
 222   1          else if(ucInputPort == _A1_INPUT_PORT)
 223   1          {
 224   2      #if(_A1_VGA_CONNECTOR_TYPE == _VGA_CONNECTOR_YPBPR)
                      pData[0] = _FALSE;
              #endif
 227   2          }
