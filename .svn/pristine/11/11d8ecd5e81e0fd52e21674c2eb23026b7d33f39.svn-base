1079   1          {
1080   2              // Pop up stable result
1081   2              ScalerSetBit(P0_4F_STABLE_MEASURE, ~_BIT1, _BIT1);
1082   2      
1083   2              usHSyncPeriod = ((WORD)(ScalerGetByte(P0_50_STABLE_PERIOD_H) & 0x07) << 8) | ScalerGetByte(P0_51_S
             -TABLE_PERIOD_L);
1084   2              usHSyncPulseCount = ((WORD)(ScalerGetByte(P0_4A_STABLE_HIGH_PERIOD_H) & 0x07) << 8) | ScalerGetByt
             -e(P0_4B_STABLE_HIGH_PERIOD_L);
1085   2      
1086   2              // Check HS width / HS period ratio
1087   2              if(((usHSyncPulseCount * 7) >= usHSyncPeriod) ||
1088   2                 (usHSyncPulseCount < _MIN_SYNC_HIGHPULSE_CNT_PS))
1089   2              {
1090   3                  return _SOG_LEVEL_INVALID;
1091   3              }
1092   2      
1093   2              // De-bounce check for stable measure
1094   2              if((pstMeasureSyncHV->usHSPeriod != 0) || (pstMeasureSyncHV->usHSWidth != 0))
1095   2              {
1096   3                  if((abs(pstMeasureSyncHV->usHSPeriod - usHSyncPeriod) > ((pstMeasureSyncHV->usHSPeriod <= 1) ?
             - 1 : (pstMeasureSyncHV->usHSPeriod >> 1))) ||
1097   3                     (abs(pstMeasureSyncHV->usHSWidth - usHSyncPulseCount) > ((pstMeasureSyncHV->usHSWidth <= 1)
             - ? 1 : (pstMeasureSyncHV->usHSWidth >> 1))))
1098   3                  {
1099   4                      return _SOG_LEVEL_INVALID;
1100   4                  }
1101   3              }
1102   2              else
1103   2              {
1104   3                  // Store measure HS info
1105   3                  pstMeasureSyncHV->usHSPeriod = usHSyncPeriod;
1106   3                  pstMeasureSyncHV->usHSWidth = usHSyncPulseCount;
1107   3      
1108   3                  // Set VS down-counter
1109   3                  ScalerSyncProcDownCounterSetting();
1110   3              }
1111   2      
1112   2              // Rough check H-Sync Freq Range
1113   2              usHSyncPeriod = (_SYNC_PROC_CLK / usHSyncPeriod);
1114   2      
1115   2              if((_SUPPORT_HSYNC_MIN_FREQ > usHSyncPeriod) || (usHSyncPeriod > _SUPPORT_HSYNC_MAX_FREQ))
1116   2              {
