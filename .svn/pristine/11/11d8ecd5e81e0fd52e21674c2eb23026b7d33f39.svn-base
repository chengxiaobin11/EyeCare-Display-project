1066   1          ScalerSetByte(P0_48_SYNC_INVERT, 0x10);
1067   1      
1068   1          // HS_OUT by pass mode, Measure Source is ADC_HS1/ADC_VS, H Sync measure source is original hs
1069   1          ScalerSetByte(P0_49_SYNC_CTRL, 0x06);
1070   1      
1071   1          // Sync from SOG Pad
1072   1          ScalerSetBit(P0_47_SYNC_SELECT, ~_BIT4, _BIT4);
1073   1      
1074   1          // Start Stable Period Measure
1075   1          ScalerSetBit(P0_4F_STABLE_MEASURE, ~_BIT0, 0x00);
