1219          //-------------------------------------------------------------------
1220          // Description  : Check SOG Sync Status
1221          // Input Value  : None
1222          // Output Value : _TRUE: SOG Sync Checked OK  _FALSE: SOG Sync Checked Fail
1223          //-------------------------------------------------------------------
1224          bit ScalerSyncProcSogSyncCheck(void)
1225          {
1226   1          BYTE ucLevelCounter = 0x00;
1227   1          BYTE ucLevelTarget = 0x00;
1228   1          bit bResetSearch = _FALSE;
1229   1          StructMeasureSyncData stMeasureSyncHV;
1230   1          BYTE pucSOYCompareLelArr[3];
1231   1          memset(pucSOYCompareLelArr, 0, sizeof(pucSOYCompareLelArr));
1232   1          memset(&stMeasureSyncHV, 0, sizeof(StructMeasureSyncData));
1233   1      
1234   1          // Initialize SOG compare levels
1235   1          ScalerSyncProcSetSogCompareLevel(pucSOYCompareLelArr);
1236   1      
1237   1          // Search pre-set SOG compare levels
1238   1          while(ucLevelCounter < sizeof(pucSOYCompareLelArr))
1239   1          {
1240   2              // Set current SOG compare level
1241   2              ScalerSetBit(P0_D7_ADC_SOG_DAC, ~(0x3F), pucSOYCompareLelArr[ucLevelCounter]);
1242   2              ++ucLevelCounter;
1243   2      
1244   2              // Check SOG flag and HS result
1245   2              if(((pData[0] = ScalerSyncProcSogCheckFlag()) != _SOG_LEVEL_VALID) ||
1246   2                 ((pData[0] = ScalerSyncProcSogCheckHs(&stMeasureSyncHV)) != _SOG_LEVEL_VALID) ||
1247   2                 ((pData[0] = ScalerSyncProcSogCheckVs(&stMeasureSyncHV)) != _SOG_LEVEL_VALID) ||
C51 COMPILER V8.12   SCALERSYNCPROC                                                        03/10/2025 13:50:28 PAGE 22  

1248   2                 ((pData[0] = ScalerSyncProcSogCheckSyncType()) != _SOG_LEVEL_VALID))
1249   2              {
1250   3                  // Stop searching up if target level already being found, or invald result detected
1251   3                  if((ucLevelTarget != 0x00) || (pData[0] == _SOG_LEVEL_INVALID))
1252   3                  {
1253   4                      break;
1254   4                  }
1255   3      
1256   3                  continue;
1257   3              }
1258   2      
1259   2              if(ucLevelTarget != 0x00)
1260   2              {
1261   3                  // Second level found. Set average SOG compare level.
1262   3                  ucLevelTarget = (ucLevelTarget + ScalerGetBit(P0_D7_ADC_SOG_DAC, 0x3F)) / 2;
1263   3                  break;
1264   3              }
1265   2              else if((bResetSearch == _FALSE) && (ucLevelCounter != 1))
1266   2              {
1267   3                  // Reset search process to avoid the case when sync become available during searching
1268   3                  bResetSearch = _TRUE;
1269   3                  ucLevelCounter = 0;
1270   3                  ucLevelTarget = 0;
1271   3                  memset(&stMeasureSyncHV, 0x00, sizeof(StructMeasureSyncData));
1272   3      
1273   3                  continue;
1274   3              }
1275   2      
1276   2              // Store current compare level
1277   2              ucLevelTarget = ScalerGetBit(P0_D7_ADC_SOG_DAC, 0x3F);
1278   2          }
1279   1      
1280   1          if(ucLevelTarget != 0x00)
1281   1          {
1282   2              // Resume target compare level
1283   2              ScalerSetBit(P0_D7_ADC_SOG_DAC, ~(0x3F), ucLevelTarget);
1284   2      
1285   2              if(stMeasureSyncHV.usVSWidth <= 1)
1286   2              {
1287   3                  // Enable Clamp Mask and select clamp mask signal as DeVS
1288   3                  ScalerSetDataPortByte(P0_5C_SYNC_PROC_PORT_ADDR, _P0_5D_PT_05_CLAMP_CTRL1, 0xC2);
1289   3      
1290   3                  // Align the rising edge of Clamp Mask to DeVS rising edge
1291   3                  ScalerSetDataPortBit(P0_5C_SYNC_PROC_PORT_ADDR, _P0_5D_PT_04_CLAMP_CTRL0, ~(_BIT5 | _BIT4 | _B
             -IT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
1292   3              }
1293   2          }
1294   1      
1295   1          return (ucLevelTarget != 0x00);
1296   1      }
