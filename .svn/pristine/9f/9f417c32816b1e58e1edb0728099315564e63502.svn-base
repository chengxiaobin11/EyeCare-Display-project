                          SET_DP_RX_HDCP2_UPSTREAM_PORT(_HDCP_D1_PORT);
              #endif
              
                          return;
                      }
                  }
              #endif
              
              #if(_DP_HDCP_2_2_SUPPORT == _ON)
              #if(_D0_DP_EXIST == _ON)
                  if(GET_DP_RX_HDCP2_UPSTREAM_PORT() == _HDCP_D0_PORT)
