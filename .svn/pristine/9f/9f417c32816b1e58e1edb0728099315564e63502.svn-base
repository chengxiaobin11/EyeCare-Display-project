                      }
                  }
                  else
                  {
                      if(GET_COLORIMETRY() == _COLORIMETRY_EXT)
                      {
                          if(ScalerTMDSRx0HdmiGetAVIInfo(_AVI_INFO_EXTENDED_COLORIMETRY) != GET_TMDS_RX0_COLORIMETRY_EXT
             -_PREVALUE())
                          {
                              DebugMessageRx0("Ext Colorimetry Changed", 0x00);
              
