11631  00      bit ScalerSyncTMDSRx3HdmiColorInfoChanged(void)
11632  00      {
11633  01          // Check Color Space
11634  01          if(ScalerTMDSRx3HdmiGetAVIInfo(_AVI_INFO_COLOR_SPACE) != GET_COLOR_SPACE())
11635  01          {
C51 COMPILER V9.01   SCALERCOMMONSYNC                                                      05/24/2025 15:51:41 PAGE 193 

11636  02              DebugMessageRx3("Color Space Changed", 0x00);
11637  02              return _TRUE;
11638  02          }
11639  01      
11640  01          // Check Colorimetry
11641  01          if(ScalerTMDSRx3HdmiGetAVIInfo(_AVI_INFO_COLORIMETRY) != GET_TMDS_RX3_COLORIMETRY_PREVALUE())
11642  01          {
11643  02              DebugMessageRx3("Colorimetry Changed", 0x00);
11644  02      
11645  02              if(GET_DIGITAL_COLOR_INFO_CHANGE_RESET() == _FALSE)
11646  02              {
11647  03                  BYTE pucTemp[2];
11648  03      
11649  03                  pucTemp[0] = ScalerTMDSRx3HdmiGetAVIInfo(_AVI_INFO_COLORIMETRY);
11650  03      
11651  03                  pucTemp[1] = GET_TMDS_RX3_COLORIMETRY_PREVALUE();
11652  03      
11653  03                  ScalerSyncTMDSRx3HdmiColorimetrySetting();
11654  03      
11655  03                  if((GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR420) || (GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR42
             -2) || (GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR444))
11656  03                  {
11657  04                      if(!(((pucTemp[0] == _AVI_COLORIMETRY_00) && (pucTemp[1] == _AVI_COLORIMETRY_01)) || ((pu
             -cTemp[0] == _AVI_COLORIMETRY_01) && (pucTemp[1] == _AVI_COLORIMETRY_00))))
11658  04                      {
11659  05                          SET_TMDS_RX3_COLORIMETRY_CHANGED();
11660  05                      }
11661  04                  }
11662  03                  else if(GET_COLOR_SPACE() == _COLOR_SPACE_RGB)
11663  03                  {
11664  04                      if((pucTemp[0] == _AVI_COLORIMETRY_11) || (pucTemp[1] == _AVI_COLORIMETRY_11))
11665  04                      {
11666  05                          SET_TMDS_RX3_COLORIMETRY_CHANGED();
11667  05                      }
11668  04                  }
11669  03              }
11670  02              else
11671  02              {
11672  03                  return _TRUE;
11673  03              }
11674  02          }
11675  01          else
11676  01          {
11677  02              if(GET_COLORIMETRY() == _COLORIMETRY_EXT)
