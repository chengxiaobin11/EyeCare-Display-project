             -) || (GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR444))
                          {
                              if(!(((pucTemp[0] == _AVI_COLORIMETRY_00) && (pucTemp[1] == _AVI_COLORIMETRY_01)) || ((puc
             -Temp[0] == _AVI_COLORIMETRY_01) && (pucTemp[1] == _AVI_COLORIMETRY_00))))
