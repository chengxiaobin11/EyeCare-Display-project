             -BIT4 | _BIT3 | _BIT2), 0x00);
              #endif
                      }
              
                      // Disable down sampling
              #if(_D1_INPUT_PORT_TMDS_MAC_PAGE == _PAGE70)
                      ScalerSetDataPortBit(P70_C9_HDMI_AP, _P70_CA_PT_50_PORT_PAGE70_HDMI_VCR, ~(_BIT3 | _BIT2 | _BIT1 |
             - _BIT0), 0x00);
