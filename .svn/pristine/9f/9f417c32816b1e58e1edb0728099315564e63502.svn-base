             -EXT_111)) || ((pucTemp[1] == _AVI_COLORIMETRY_EXT_100) && (pucTemp[0] == _AVI_COLORIMETRY_EXT_111))))
                                      {
                                          SET_TMDS_RX0_COLORIMETRY_EXT_CHANGED();
