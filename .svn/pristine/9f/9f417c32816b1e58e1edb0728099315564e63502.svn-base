                              SET_TMDS_RX5_COLORIMETRY_PREVALUE(_AVI_COLORIMETRY_11);
              
                              SET_COLORIMETRY(_COLORIMETRY_EXT);
              
                              ScalerSyncTMDSRx5HdmiColorimetryExtSetting();
              
