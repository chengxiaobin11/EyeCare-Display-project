             -NG_STATUS() == _DP_NORMAL_TRAINING_PATTERN_END_REBUILD_PHY))
                      {
                          SET_DP_RX_HDCP_UPSTREAM_PORT(_HDCP_D0_PORT);
              
              #if(_DP_HDCP_2_2_SUPPORT == _ON)
                          SET_DP_RX_HDCP2_UPSTREAM_PORT(_HDCP_D0_PORT);
