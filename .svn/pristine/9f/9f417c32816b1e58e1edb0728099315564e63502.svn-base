                     (ucInputPortType != _PORT_DVI) && (ucInputPortType != _PORT_HDMI) &&
                     (ucInputPortType != _PORT_MHL) && (ucInputPortType != _PORT_DUAL_DVI))
                  {
                      ScalerTMDSFreqDetectDisable();
              
              #if(_HDMI_2_0_SUPPORT == _ON)
                      ScalerTMDSScrambleDetectDisable();
              #endif
