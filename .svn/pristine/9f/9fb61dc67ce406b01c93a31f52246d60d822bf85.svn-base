  54          void ScalerOsdWindowSpecialColorMask(bit bEnable, EnumOsdWindowsType enumOsdWindowsType, EnumOsdSpecialCol
             -orMaskOperation enumOsdSpecialColorMaskOperation)
  55          {
  56   1          BYTE ucTemp = 0;
  57   1          WORD usTempWindowNumber = 0;
  58   1      
  59   1          usTempWindowNumber = 0x177 + (enumOsdWindowsType * 7);
  60   1          ucTemp = ScalerOsdFrameControlByteGet(usTempWindowNumber, _OSD_BYTE0);
  61   1          ucTemp = ((ucTemp & ~(_BIT3 | _BIT2)) | (((BYTE)enumOsdSpecialColorMaskOperation << 3) | ((BYTE)bEnabl
             -e << 2)));
  62   1      
  63   1          ScalerOsdFrameControlByte(usTempWindowNumber, _OSD_BYTE0, ucTemp);
  64   1      }
