  52          // Description  : Enable Access Port
  53          // Input Value  : usAddr    --> Start address of register
  54          //                ucValue   --> Data Port Value we want to set
  55          // Output Value : Return Access Port Value
  56          //--------------------------------------------------
  57          BYTE ScalerEnableAccessPort(WORD usAddr, BYTE ucValue)
  58          {
  59   1          usAddr = usAddr;
  60   1          return ucValue;
  61   1      }
  62          
  63          //--------------------------------------------------
  64          // Description  : Disable Access Port
  65          // Input Value  : usAddr   --> Start address of register
  66          // Output Value : None
  67          //--------------------------------------------------
  68          void ScalerDisableAccessPort(WORD usAddr)
  69          {
  70   1          usAddr = usAddr;
  71   1      }
  72          
  73          //--------------------------------------------------
  74          // Description  : Set the value into selected register in data port
  75          // Input Value  : usAddr    --> Access Port Address of register
  76          //                ucValue1  --> Data Port Value we want to set
  77          //                ucValue2  --> Data Value we want to set
  78          // Output Value : None
  79          //--------------------------------------------------
  80          void ScalerSetDataPortByte(WORD usAddr, BYTE ucValue1, BYTE ucValue2)
  81          {
  82   1          ScalerSetByte(usAddr, ScalerEnableAccessPort(usAddr, ucValue1));
  83   1          ScalerSetByte(usAddr + 1, ucValue2);
  84   1      
  85   1          ScalerDisableAccessPort(usAddr);
  86   1      }
  87          
  88          //--------------------------------------------------
  89          // Description  : Get bytes from selected register in data port
  90          // Input Value  : usAddr    --> Access Port Address of register
  91          //                ucValue   --> Data Port Address we want to Get
  92          //                ucLength  --> Numbers of data we want to read
  93          //                pArray    --> Pointer of the reading data array
  94          //                bAutoInc  --> Address auto increasing select
  95          // Output Value : None
  96          //--------------------------------------------------
  97          void ScalerGetDataPortByte(WORD usAddr, BYTE ucValue, WORD usLength, BYTE *pucArray, bit bAutoInc)
  98          {
  99   1          BYTE ucAccessValue = 0;
 100   1          WORD usIndex = 0;
 101   1      
 102   1          if(usLength > 0)
 103   1          {
 104   2              ucAccessValue = ScalerEnableAccessPort(usAddr, ucValue);
 105   2      
 106   2              for(usIndex = 0; usIndex < usLength; usIndex++)
 107   2              {
 108   3                  if(bAutoInc == _AUTOINC)
 109   3                  {
 110   4                      ScalerSetByte(usAddr, ucAccessValue + usIndex);
 111   4                  }
 112   3                  else
 113   3                  {
C51 COMPILER V8.12   SCALERCOMMONDATAPORTACCESS                                            03/11/2025 19:55:38 PAGE 3   

 114   4                      ScalerSetByte(usAddr, ucAccessValue);
 115   4                  }
 116   3      
 117   3                  pucArray[usIndex] = ScalerGetByte(usAddr + 1);
 118   3              }
 119   2      
 120   2              ScalerDisableAccessPort(usAddr);
 121   2          }
 122   1      }
 123          
 124          //--------------------------------------------------
 125          // Description  : Set some bits of selected register in data port
 126          // Input Value  : usAddr    --> Access Port Address of register
 127          //                ucValue   --> Data Port Value we want to set
 128          //                ucAnd     --> & operation
 129          //                ucOr      --> | operation
 130          // Output Value : None
 131          //--------------------------------------------------
 132          void ScalerSetDataPortBit(WORD usAddr, BYTE ucValue, BYTE ucAnd, BYTE ucOr)
 133          {
 134   1          BYTE ucValueTemp = 0;
 135   1      
 136   1          ScalerSetByte(usAddr, ScalerEnableAccessPort(usAddr, ucValue));
 137   1          ucValueTemp = ScalerGetByte(usAddr + 1);
 138   1      
 139   1          ucValueTemp = (ucValueTemp & ucAnd) | ucOr;
 140   1      
 141   1          ScalerSetByte(usAddr, ScalerEnableAccessPort(usAddr, ucValue));
 142   1          ScalerSetByte(usAddr + 1, ucValueTemp);
 143   1      
 144   1          ScalerDisableAccessPort(usAddr);
 145   1      }
 146          
 147          //--------------------------------------------------
 148          // Description  : Set some bits of selected register in data port
 149          // Input Value  : usAddr    --> Access Port Address of register
 150          //                ucValue   --> Data Port Value we want to set
 151          //                ucAnd     --> & operation
 152          // Output Value : Value after & operation
 153          //--------------------------------------------------
 154          BYTE ScalerGetDataPortBit(WORD usAddr, BYTE ucValue, BYTE ucAnd)
 155          {
 156   1          BYTE ucValueTemp = 0;
 157   1      
 158   1          ScalerSetByte(usAddr, ScalerEnableAccessPort(usAddr, ucValue));
 159   1          ucValueTemp = (ScalerGetByte(usAddr + 1) & ucAnd);
 160   1          ScalerDisableAccessPort(usAddr);
 161   1      
 162   1          return ucValueTemp;
 163   1      }
