5203   1                              UserCommonFlashRead(1, 0xfffe, 2, (BYTE *)&usValue);
5204   1                              ucPar= ucPar;
5205   1      
5206   1                              pData[0]=_0__;
5207   1                              pData[1]=_0__;
5208   1      
5209   1                              t =(usValue & 0x0f);
5210   1                              if(t < 10)
5211   1                              l = t +_0__;
5212   1                              else
5213   1                              l = t -10+ _A__;
5214   1      
5215   1                              t = (usValue >> 4) & 0x0f;
5216   1                              if(t < 10)
5217   1                              h = t +_0__;
5218   1                              else
5219   1                              h = t -10+_A__;
5220   1      
5221   1                              t = (usValue >> 8) & 0x0f;
5222   1                              if(t < 10)
5223   1                              l1 = t +_0__;
5224   1                              else
5225   1                              l1 = t -10+_A__;
5226   1      
5227   1                              t = (usValue >> 12) & 0x0f;
5228   1                              if(t < 10)
5229   1                              h1 = t +_0__;
5230   1                              else
5231   1                              h1 = t -10+_A__;
5232   1      
5233   1                              pData[3]=l ;
5234   1                              pData[2]=h;
5235   1                              pData[1]=l1 ;
5236   1                              pData[0]=h1 ;
5237   1      
5238   1                              pData[4] = _END_;
5239   1      
5240   1                              RTDFactoryOsdFuncPutStringProp(ucRow, ucCol, ucFontPoint, tFONT_FACTORY_EUROPE, pData, _ENGLISH);       
5241   1      
5242   1                               
5243   1      }
