5195          void RTDFactoryOsdFuncShowChecksum(BYTE ucRow, BYTE ucCol, BYTE ucPar ,BYTE ucFontPoint)
5196          {
5197   1                              BYTE h,l,t,h1,l1;
5198   1                              BYTE idata ucIndex = 0;
5199   1                              BYTE idata ucTemp = 0;
5200   1                              BYTE idata i = 0;
5201   1                              // BYTE xdata pData[7] = {0};
