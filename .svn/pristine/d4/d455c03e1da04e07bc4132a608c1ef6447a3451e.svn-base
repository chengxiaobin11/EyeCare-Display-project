  53          void ScalerOsdChange1BitColorFont256_511(BYTE ucRow, BYTE ucCol, BYTE ucLength, BYTE ucHeight, BYTE ucFore
             -groundColor, BYTE ucBackgroundColor)
  54          {
  55   1          BYTE ucTemp = 0;
  56   1          BYTE ucColorByte0 = (_BIT6 | _BIT5);
  57   1          bit bOSDOn = _OFF;
  58   1      
  59   1          // Get OSD Status for Write-Protection Function setting OSD circuit enable.
  60   1          bOSDOn = ScalerGetBit(P3A_02_FRAME_CTRL_02, _BIT0);
  61   1      
  62   1          for(ucTemp = 0; ucTemp < ucHeight; ucTemp++)
  63   1          {
  64   2              ScalerOsdSramDataValue(ucRow + ucTemp, ucCol, ucLength, ((ucForegroundColor << 4) | ucBackgroundCo
             -lor), _OSD_BYTE2);
  65   2          }
  66   1      
  67   1          ScalerOsdWriteProtection(_ENABLE, _OSD_BYTE0, (_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0));
  68   1      
  69   1          for(ucTemp = 0; ucTemp < ucHeight; ucTemp++)
  70   1          {
  71   2              ScalerOsdSramDataValue(ucRow + ucTemp, ucCol, ucLength, ucColorByte0, _OSD_BYTE0);
  72   2          }
  73   1      
  74   1          ScalerOsdWriteProtection(_DISABLE, _OSD_BYTE0, (_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0));
  75   1      
  76   1          // Recovery OSD Status
  77   1          if(bOSDOn == _OFF)
  78   1          {
  79   2              ScalerOsdCircuitActivated(bOSDOn);
  80   2          }
  81   1      }
