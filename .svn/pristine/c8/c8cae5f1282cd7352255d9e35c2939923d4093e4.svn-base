 122          //--------------------------------------------------
 123          // Description  : Set Rotation double switch style
 124          // Input Value  : bInputFasterStatus
 125          // Output Value : None
 126          //--------------------------------------------------
 127          void ScalerRotationSetRotInputSlowerFasterStyle(bit bInputFasterStatus)
 128          {
 129   1          // Rotation double switch style
 130   1          if(bInputFasterStatus == _FALSE)
 131   1          {
 132   2              // input slower than display
 133   2              ScalerSetBit(P5_F3_MN_TEST, ~_BIT1, 0x00);
 134   2          }
 135   1          else
 136   1          {
 137   2              // input faster than display
 138   2              ScalerSetBit(P5_F3_MN_TEST, ~_BIT1, _BIT1);
 139   2          }
 140   1      }
 141          
 142          //--------------------------------------------------
 143          // Description  : Set Rotation Enable/Disable
 144          // Input Value  : bEn --> Enable/Disable
 145          // Output Value : None
 146          //--------------------------------------------------
 147          void ScalerRotationSetEnable(bit bEn)
 148          {
 149   1          if(bEn == _DISABLE)
 150   1          {
 151   2              // Set Rotation Disable
 152   2              ScalerSetBit(P20_F0_ROTATION_CTRL0, ~(_BIT7), 0x00);
 153   2          }
 154   1          else
 155   1          {
 156   2              if(ScalerGetBit(P20_F0_ROTATION_CTRL0, _BIT7) == 0x00)
 157   2              {
 158   3                  // Set Rotation Enable
 159   3                  ScalerSetBit(P20_F0_ROTATION_CTRL0, ~(_BIT7), _BIT7);
 160   3              }
 161   2          }
 162   1      }
