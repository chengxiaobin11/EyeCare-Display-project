  48          //--------------------------------------------------
  49          // Description  : Rotation control
  50          // Input Value  : stFIFOSize --> FIFO Size
  51          // Output Value : None
  52          //--------------------------------------------------
  53          void ScalerRotationControl(const StructSDRAMDataInfo *pstFIFOSize)
  54          {
  55   1          switch(GET_ROT_TYPE())
  56   1          {
  57   2              case _ROT_CW180:
  58   2      #if(_DISPLAY_HOR_MIRROR_SUPPORT == _ON)
                      case _ROT_HOR_MIRROR:
              #endif
  61   2                  DebugMessageFRC("R_Type", GET_ROT_TYPE());
  62   2                  DebugMessageFRC("R_Size", GET_ROT_DISP_SIZE());
  63   2                  DebugMessageFRC("R-IH", pstFIFOSize->usInputHWidth);
  64   2                  DebugMessageFRC("R_IV", pstFIFOSize->usInputVHeight);
  65   2                  DebugMessageFRC("R-OH", pstFIFOSize->usOutputHWidth);
  66   2                  DebugMessageFRC("R_OV", pstFIFOSize->usOutputVHeight);
  67   2      
  68   2                  // Set Roation Enable
  69   2                  ScalerRotationSetEnable(_ENABLE);
  70   2      
  71   2                  // Set Rotation Source Pixel Number
  72   2                  ScalerSetBit(P20_F1_ROTATION_IN_WID_H, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (pstFIFOSize->usInput
             -HWidth >> 8) & 0x0F);
  73   2                  ScalerSetByte(P20_F2_ROTATION_IN_WID_L, (pstFIFOSize->usInputHWidth & 0xFF));
  74   2      
  75   2                  ScalerFRCControl(pstFIFOSize);
  76   2      
  77   2                  break;
  78   2      
  79   2      #if(_DISPLAY_VER_MIRROR_SUPPORT == _ON)
                      case _ROT_VER_MIRROR:
              
                          ScalerFRCControl(pstFIFOSize);
              
                          break;
              #endif
  86   2      
  87   2              default:
  88   2                  break;
  89   2          }
  90   1      }
  91          
  92          //--------------------------------------------------
  93          // Description  : Rotation Reset
  94          // Input Value  : None
  95          // Output Value : None
  96          //--------------------------------------------------
  97          void ScalerRotationReset(void)
  98          {
  99   1          switch(GET_ROT_TYPE())
 100   1          {
 101   2              case _ROT_CW180:
 102   2      #if(_DISPLAY_VER_MIRROR_SUPPORT == _ON)
                      case _ROT_VER_MIRROR:
              #endif
 105   2      
 106   2                  if(GET_MEMORY_FRAME_BUFFER() != _MEMORY_3_FRAME_BUFFER)
 107   2                  {
 108   3                      // Set CW180 reset
C51 COMPILER V9.60.0.0   RL6432_SERIES_ROTATION                                            08/21/2025 10:45:14 PAGE 3   

 109   3                      ScalerSetBit(P5_B9_IN1_SDR_CTRL, ~_BIT0, 0x00);
 110   3                      ScalerTimerWaitForEvent(_EVENT_IVS);
 111   3                      ScalerTimerWaitForEvent(_EVENT_IVS);
 112   3                      ScalerSetBit(P5_B9_IN1_SDR_CTRL, ~_BIT0, _BIT0);
 113   3                  }
 114   2      
 115   2                  break;
 116   2      
 117   2              default:
 118   2                  break;
 119   2          }
 120   1      }
