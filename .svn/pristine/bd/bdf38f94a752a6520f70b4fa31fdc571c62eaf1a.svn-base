  62          //--------------------------------------------------
  63          // Description  : Get Scaling By pass
  64          // Input Value  : enumSelRegion
  65          // Output Value : _TRUE or _FALSE
  66          //--------------------------------------------------
  67          bit ScalerColorScalingGetScalingUpBypassStatus(void)
  68          {
  69   1          ScalerGetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_03_VER_SCALE_FACTOR_H, 3, &pData[0], _AUTOINC);
  70   1          ScalerGetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_00_HOR_SCALE_FACTOR_H, 3, &pData[3], _AUTOINC);
  71   1      
  72   1          if(((pData[0] & 0x0F) == 0x0F) && (pData[1] == 0xFF) && (pData[2] == 0xFF) &&
  73   1             ((pData[3] & 0x0F) == 0x0F) && (pData[4] == 0xFF) && (pData[5] == 0xFF))
  74   1          {
  75   2              return _TRUE;
  76   2          }
  77   1          else
  78   1          {
  79   2              return _FALSE;
  80   2          }
  81   1      }
