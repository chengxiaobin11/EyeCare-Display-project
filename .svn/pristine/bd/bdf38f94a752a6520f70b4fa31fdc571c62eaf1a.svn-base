  88          bit ScalerColorScalingGetScalingDownBypassStatus(void)
  89          {
  90   1          ScalerGetDataPortByte(P0_24_SD_ADDRESS_PORT_M1, _P0_25_PT_05_H_SD_FACTOR_H_M1, 3, &pData[0], _AUTOINC)
             -;
  91   1          ScalerGetDataPortByte(P0_24_SD_ADDRESS_PORT_M1, _P0_25_PT_01_V_SD_FACTOR_H_M1, 3, &pData[3], _AUTOINC)
             -;
  92   1      
  93   1          if((pData[0] != 0x10) || (pData[1] != 0x00) || (pData[2] != 0x00) ||
  94   1             (pData[3] != 0x02) || (pData[4] != 0x00) || (pData[5] != 0x00))
  95   1          {
  96   2              return _FALSE;
  97   2          }
  98   1      
  99   1      #if(_SCALING_DOWN_VSD_TYPE == _SD_VSD_GEN_0)
 100   1          ScalerGetDataPortByte(P0_24_SD_ADDRESS_PORT_M1, _P0_25_PT_42_V_SD_FACTOR_L1_M1, 1, &pData[6], _AUTOINC
             -);
 101   1      
 102   1          if((pData[6] & 0xE0) != 0x00)
 103   1          {
 104   2              return _FALSE;
 105   2          }
 106   1      #endif
 107   1      
 108   1          return _TRUE;
 109   1      }
