 158          //--------------------------------------------------
 159          // Description  : Detect TMDS video mode
 160          // Input Value  : bWait => Whether to wait then read
 161          // Output Value : TMDS video type
 162          //--------------------------------------------------
 163          BYTE ScalerTMDSVideoDetect(bit bWait)
 164          {
 165   1          BYTE ucTemp = _TMDS_VIDEO_DATA_NONE;
 166   1      
 167   1          if(bWait == _WAIT)
 168   1          {
 169   2              // Wait at least 1 frame for HW auto update TMDS video RGBHV valid value
 170   2              ScalerTimerPollingFlagProc(45, P2_A4_TMDS_CTRL, _BIT3, _TRUE);
C51 COMPILER V8.12   SCALERTMDS_COMBOPHY                                                   03/10/2025 13:50:31 PAGE 4   

 171   2      
 172   2              // Wait for HW update DE flag
 173   2              if(ScalerTimerPollingFlagProc(20, P2_A4_TMDS_CTRL, (_BIT7 | _BIT6 | _BIT5), _TRUE) == _TRUE)
 174   2              {
 175   3                  // H/Vsync received
 176   3                  if(ScalerGetBit(P2_A4_TMDS_CTRL, (_BIT4 | _BIT3)) == (_BIT4 | _BIT3))
 177   3                  {
 178   4                      ucTemp = _TMDS_VIDEO_DATA_RGBHV;
 179   4                  }
 180   3                  else
 181   3                  {
 182   4                      ucTemp = _TMDS_VIDEO_DATA_DE_ONLY;
 183   4                  }
 184   3              }
 185   2              else
 186   2              {
 187   3                  ucTemp = _TMDS_VIDEO_DATA_NONE;
 188   3              }
 189   2      
 190   2              CLR_TMDS_RGBHV_DETECTING();
 191   2      
 192   2              return ucTemp;
 193   2          }
 194   1          else
 195   1          {
 196   2              // R/G/B data detected
 197   2              if(ScalerGetBit(P2_A4_TMDS_CTRL, (_BIT7 | _BIT6 | _BIT5)) == (_BIT7 | _BIT6 | _BIT5))
 198   2              {
 199   3                  // H/Vsync received
 200   3                  if(ScalerGetBit(P2_A4_TMDS_CTRL, (_BIT4 | _BIT3)) == (_BIT4 | _BIT3))
 201   3                  {
 202   4                      ucTemp = _TMDS_VIDEO_DATA_RGBHV;
 203   4                  }
 204   3                  else
 205   3                  {
 206   4                      ucTemp = _TMDS_VIDEO_DATA_DE_ONLY;
 207   4                  }
 208   3              }
 209   2              else
 210   2              {
 211   3                  ucTemp = _TMDS_VIDEO_DATA_NONE;
 212   3              }
 213   2      
 214   2              // Clear video Detection Flag
 215   2              ScalerSetBit(P2_A4_TMDS_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), (_BIT7 | _BIT6 | _BIT5 | _
             -BIT4 | _BIT3));
 216   2      
 217   2              SET_TMDS_RGBHV_DETECTING();
 218   2      
 219   2              // Activate TMDS video Detection Event
 220   2              ScalerTimerActiveTimerEvent(45, _SCALER_TIMER_EVENT_RX0_TMDS_VIDEO_DETECT);
 221   2      
 222   2              return ucTemp;
 223   2          }
 224   1      }
