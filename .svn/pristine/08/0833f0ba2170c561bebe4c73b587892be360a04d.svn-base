              StructHdmiSpdInfo ScalerTMDSHdmiGetSpdPdInfo(EnumSourceSearchPort enumInputPort)
              {
                  enumInputPort = enumInputPort;
              
                  return g_stTmdsMacRx0SpdInfo;
              }
