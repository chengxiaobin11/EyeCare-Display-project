 296   2              else if(ScalerGetBit(P2_B4_TMDS_DPC0, 0x07) == 0x07)
 297   2              {
 298   3                  return _COLOR_DEPTH_16_BITS;
 299   3              }
 300   2          }
 301   1      
 302   1          return _COLOR_DEPTH_8_BITS;
