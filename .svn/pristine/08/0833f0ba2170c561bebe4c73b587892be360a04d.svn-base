 308          //--------------------------------------------------
 309          void ScalerTMDSHdmiPacketDetect(bit bWait)
 310          {
 311   1          if(bWait == _WAIT)
 312   1          {
 313   2              // Polling 3 frame for detect Packet signals
 314   2              if(ScalerTimerPollingFlagProc(130, P2_CC_HDMI_GPVS, (_BIT6 | _BIT5), _TRUE) == _TRUE)
 315   2              {
 316   3                  // Both GCP & AVI infoframe packet have been received
 317   3                  if(ScalerGetBit(P2_CC_HDMI_GPVS, (_BIT6 | _BIT5)) == (_BIT6 | _BIT5))
 318   3                  {
 319   4                      SET_HDMI_GCP_RECEIVED();
 320   4      
 321   4                      SET_HDMI_RX0_AVI_INFO_FRAME_RECEIVED();
 322   4                  }
 323   3                  // Only AVI infoframe packet have been received
 324   3                  else if(ScalerGetBit(P2_CC_HDMI_GPVS, (_BIT6 | _BIT5)) == _BIT5)
 325   3                  {
 326   4                      SET_HDMI_RX0_AVI_INFO_FRAME_RECEIVED();
 327   4      
 328   4                      // Polling more time to wait GCP when AVI IF has been received.
 329   4                      if(ScalerTimerPollingFlagProc(180, P2_CC_HDMI_GPVS, _BIT6, _TRUE) == _TRUE)
 330   4                      {
 331   5                          SET_HDMI_GCP_RECEIVED();
 332   5                      }
 333   4                      else
 334   4                      {
 335   5                          CLR_HDMI_GCP_RECEIVED();
 336   5                      }
 337   4                  }
 338   3                  // Only GCP Packet have been received
 339   3                  else if(ScalerGetBit(P2_CC_HDMI_GPVS, (_BIT6 | _BIT5)) == _BIT6)
 340   3                  {
 341   4                      SET_HDMI_GCP_RECEIVED();
 342   4      
 343   4                      // Polling more time to wait AVI IF when GCP has been received.
 344   4                      if(ScalerTimerPollingFlagProc(180, P2_CC_HDMI_GPVS, _BIT5, _TRUE) == _TRUE)
 345   4                      {
 346   5                          SET_HDMI_RX0_AVI_INFO_FRAME_RECEIVED();
 347   5                      }
 348   4                      else
 349   4                      {
 350   5                          CLR_HDMI_RX0_AVI_INFO_FRAME_RECEIVED();
 351   5                      }
 352   4                  }
 353   3              }
 354   2              // Neither AVI infoframe nor GCP packet received
 355   2              else
