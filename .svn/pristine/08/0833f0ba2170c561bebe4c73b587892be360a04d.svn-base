 671   1          ScalerSetByte(PB5_A1_MN_SCLKG_DIVM, LOBYTE(usM - 2));
 672   1      
 673   1          // Set DPPLL N Code
 674   1          ScalerSetByte(PB5_A2_MN_SCLKG_DIVN, (ucN - 2));
 675   1      
 676   1          // Load offset value
 677   1          ScalerSetBit(PB5_A4_MN_SCLKG_OFFS_H, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), _BIT7);
 678   1      
 679   1          // Double Buffer for M/N Tracking
 680   1          ScalerSetBit(PB5_A0_MN_SCLKG_CTRL, ~_BIT4, _BIT4);
 681   1      
 682   1          // DPLL VCORSTB Set to Normal
 683   1          ScalerSetBit(PB5_C0_MN_SCLKG_PLL_INSEL, ~_BIT0, _DPLL_VCORSTB_NORMAL_VALUE);
 684   1      
 685   1          // DPLL Power On
 686   1          ScalerSetBit(PB5_BD_MN_SCLKG_PLL_PWR, ~_BIT7, 0x00);
 687   1      
 688   1          ScalerTimerDelayXms(2);
 689   1      
 690   1          ////////////////////////////////
 691   1          // DPPLL VCO Band Calibration //
 692   1          ////////////////////////////////
 693   1      
 694   1          // Reg DPLL_CMPEN
 695   1          ScalerSetBit(PB5_BD_MN_SCLKG_PLL_PWR, ~_BIT2, _BIT2);
 696   1      
 697   1          ScalerTimerDelayXms(2);
 698   1      
 699   1          // Reg DPLL_CALLCH
 700   1          ScalerSetBit(PB5_BD_MN_SCLKG_PLL_PWR, ~_BIT3, _BIT3);
 701   1      
 702   1          ScalerTimerDelayXms(2);
 703   1      
 704   1          // Reg DPLL_CALSW
 705   1          ScalerSetBit(PB5_BD_MN_SCLKG_PLL_PWR, ~_BIT4, _BIT4);
 706   1      
 707   1          // Check VCO Band is '10
 708   1          if(ScalerGetBit(PB5_C0_MN_SCLKG_PLL_INSEL, (_BIT5 | _BIT4)) != _BIT5)
 709   1          {
 710   2              switch(ScalerGetBit(PB5_C0_MN_SCLKG_PLL_INSEL, (_BIT5 | _BIT4)) >> 4)
 711   2              {
 712   3                  case 00:
 713   3      
