 494          //--------------------------------------------------
 495          // Description  : Set Deep Color PLL
 496          // Input Value  : usTMDSClkCount, ucColorDepth
 497          // Output Value : None
 498          //--------------------------------------------------
 499          bit ScalerTMDSHdmiSetDeepColorPll(WORD usTMDSClkCount, BYTE ucColorDepth)
 500          {
 501   1          DWORD ulTMDSClkValue = 0;
 502   1          WORD usM = 0;
 503   1          BYTE ucN = 0;
 504   1          BYTE ucDivS = 0;
 505   1          BYTE ucFactor = 0;
 506   1      
 507   1          ////////////////////////////////////////////////////////////////////////////////////////////////
 508   1          // Fin = TMDS_clk
 509   1          // Fref = Fin / N
 510   1          // Fvco = Fin * M / N
 511   1          // Freq = Fvco / Divs
 512   1          //
 513   1          // Restriction
 514   1          // A. BW = Kvco * Icp * R / (M * 2pi) = 700k (Band10 Kvco = 1880), R = 13k)
 515   1          // B. 300MHz < Fvco < 600MHz
 516   1          // C. (Fin / N) >= 10 * BW --> (Fin / N) >= 7MHz
 517   1          // D. YCbCr 420, Ratio = 2, other case Ratio = 1
 518   1          //
 519   1          // note 1.   According A, Icp = 2.5 ~ 20 --> 14 <= M <= 111
 520   1          // note 2.   According B and note 1. --> 3 <= (Fin / N) <= 42
 521   1          // note 3.   According C and note 2. --> 7 <= (Fin / N) <= 42
 522   1          // note 4_a. 10bit : (M / N / Divs) = (4 / 5 * Ratio) --> M = N * Divs * (4 / 5 * Ratio), N or Divs: m
             -ultiple of 5
 523   1          // note 4_b. 12bit : (M / N / Divs) = (2 / 3 * Ratio) --> M = N * Divs * (2 / 3 * Ratio), N or Divs: m
             -ultiple of 3
 524   1          // note 4_b. 16bit : (M / N / Divs) = (1 / 2 * Ratio) --> M = N * Divs * (1 / 2 * Ratio), N or Divs: m
             -ultiple of 2
 525   1          ////////////////////////////////////////////////////////////////////////////////////////////////
 526   1      
 527   1          // Reset DP Stream Clock Block
 528   1          ScalerSetBit(PB5_00_MAC_DIG_RESET_CTRL, ~_BIT2, _BIT2);
 529   1          ScalerSetBit(PB5_00_MAC_DIG_RESET_CTRL, ~_BIT2, 0x00);
C51 COMPILER V8.12   SCALERTMDS_COMBOPHY                                                   03/10/2025 13:50:31 PAGE 10  

 530   1      
 531   1          // PLL Input Clock select to HDMI video Clock, Output Clock Select to PLL Clock
 532   1          ScalerSetBit(PB5_A0_MN_SCLKG_CTRL, ~(_BIT7 | _BIT6 | _BIT5), _BIT7);
 533   1      
 534   1          // If Measure Divider = /2 then TMDS_CLK x 2, unit:kHz
 535   1          if(ScalerGetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_28_PORT_PAGE2_HDMI_NTX1024TR0, _BIT6) == _BIT6)
 536   1          {
 537   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 * 2 / usTMDSClkCount;
 538   2          }
 539   1          else
 540   1          {
 541   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 / usTMDSClkCount;
 542   2          }
 543   1      
 544   1          DebugMessageRx0("TMDS clk", ulTMDSClkValue);
 545   1          DebugMessageRx0("Color Depth", ucColorDepth);
 546   1      
 547   1          switch(ucColorDepth)
 548   1          {
 549   2              case _COLOR_DEPTH_10_BITS:
 550   2      
 551   2                  ucFactor = 5;
 552   2      
 553   2                  break;
 554   2      
 555   2              case _COLOR_DEPTH_12_BITS:
 556   2      
 557   2                  ucFactor = 3;
 558   2      
 559   2                  break;
 560   2      
 561   2              case _COLOR_DEPTH_16_BITS:
 562   2      
 563   2                  ucFactor = 2;
 564   2      
 565   2                  break;
 566   2      
 567   2              default:
 568   2      
 569   2                  return _FALSE;
 570   2          }
 571   1      
 572   1          // N <= (Fin / 7)
 573   1          PDATA_WORD(0) = (ulTMDSClkValue / 7000);
 574   1      
 575   1          if(PDATA_WORD(0) < 2)
 576   1          {
 577   2              return _FALSE;
 578   2          }
 579   1          else if(PDATA_WORD(0) >= ucFactor)
 580   1          {
 581   2              // N: Multiple of factor
 582   2              PDATA_WORD(0) -= (PDATA_WORD(0) % ucFactor);
 583   2          }
 584   1          else if(PDATA_WORD(0) > 255)
 585   1          {
 586   2              // N: Multiple of factor
 587   2              PDATA_WORD(0) = 255 - (255 % ucFactor);
 588   2          }
 589   1      
 590   1          ucN = PDATA_WORD(0);
 591   1      
C51 COMPILER V8.12   SCALERTMDS_COMBOPHY                                                   03/10/2025 13:50:31 PAGE 11  

 592   1          // for differenct Divs, find suitable Divs and M
 593   1          for(pData[15] = 0; pData[15] <= 254; pData[15] += 2)
 594   1          {
 595   2              // N or Divs: Multiple of factor
 596   2              if(((ucN % ucFactor) == 0x00) || ((pData[15] % ucFactor) == 0x00))
 597   2              {
 598   3                  usM = (WORD)ucN * ((pData[15] == 0) ? 1 : pData[15]) * (ucFactor - 1) / ucFactor;
 599   3      
 600   3                  // Fvco = Fin * M / N
 601   3                  PDATA_DWORD(0) = (ulTMDSClkValue * usM / ucN);
 602   3      
 603   3                  if((PDATA_DWORD(0) >= 300000) && (PDATA_DWORD(0) <= 600000))
 604   3                  {
 605   4                      ucDivS = ((pData[15] == 0) ? 1 : pData[15]);
 606   4                      break;
 607   4                  }
 608   3              }
 609   2      
 610   2              if((pData[15] == 254) && (ucDivS == 0))
 611   2              {
 612   3                  DebugMessageRx0("4. PLL Setting Error", 0);
 613   3                  return _FALSE;
 614   3              }
 615   2          }
 616   1      
 617   1          //////////////////////////////////////////////////////////////////////////////////////////////////
 618   1          // Precise formula of Chrage Pump Current depends on DPM, resistor, and band.                   //
 619   1          // If VCO band = 'b00, Icp = (700 * M * 2 * pi) / (778 * 0x01C1[7:5]).                          //
 620   1          // If VCO band = 'b01, Icp = (700 * M * 2 * pi) / (1340 * 0x01C1[7:5]).                         //
 621   1          // If VCO band = 'b10, Icp = (700 * M * 2 * pi) / (1880 * 0x01C1[7:5]).                         //
 622   1          // If VCO band = 'b11, Icp = (700 * M * 2 * pi) / (2340 * 0x01C1[7:5]).                         //
 623   1          // 700: DPLL max frequency design target is 700MHz; 778: Frequency curve in band00 is 778MHz.   //
 624   1          // Assume DPLL_M=0x13, DPM=0x13+2=21; DPN=2; reg_dpll_vcomd='b01; reg_dpll_rs[2:0]='b011;       //
 625   1          // Icp = (700 * 21 * 2 * 3.14) / (1340 * 13)                                                    //
 626   1          //////////////////////////////////////////////////////////////////////////////////////////////////
 627   1      
 628   1          // Set VCO resister = 3b'011(13K), Capacitor = 2b'11(66pF) (Analog DIC suggust)
 629   1          ScalerSetBit(PB5_BE_MN_SCLKG_PLL_CHP, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), (_BIT6 | _BIT5 | _BIT4
             - | _BIT3));
 630   1      
 631   1          // BW = Kvco * Icp * R / (M * 2pi) = 700k --> Icp = M * BW * 2pi / Kvco / R
 632   1          PDATA_WORD(1) = ((DWORD)usM * 700UL * 2 * 314UL * 20) / _PLL_VCO_BAND_10 / ((7 + (ScalerGetBit(PB5_BE_
             -MN_SCLKG_PLL_CHP, (_BIT7 | _BIT6 | _BIT5)) >> 5) * 2) * 100);
 633   1          pData[5] = (PDATA_WORD(1) + 25) / 50;
 634   1          pData[5] -= ((pData[5] == 0) ? 0 : 1);
 635   1      
 636   1          if(pData[5] > 0x07)
 637   1          {
 638   2              pData[5] = 0x07;
 639   2          }
 640   1      
 641   1          DebugMessageRx0("Deep Color Charge Pump icp =", pData[5]);
 642   1      
 643   1          // DPPLL Power Down
 644   1          ScalerSetByte(PB5_BD_MN_SCLKG_PLL_PWR, 0x80);
 645   1      
 646   1          // Disable M/N Tracking, VS/HS Tracking
 647   1          ScalerSetBit(PB5_A7_MN_SCLKG_TRK_CTRL, ~(_BIT7 | _BIT6), 0x00);
 648   1      
 649   1          // Set PLL Charge Pump Current
 650   1          ScalerSetBit(PB5_BE_MN_SCLKG_PLL_CHP, ~(_BIT2 | _BIT1 | _BIT0), (pData[5] & 0x07));
 651   1      
C51 COMPILER V8.12   SCALERTMDS_COMBOPHY                                                   03/10/2025 13:50:31 PAGE 12  

 652   1          // Set VCOMD, phase Swallow Circuit Clock Select, SCLKGSTOP
 653   1          ScalerSetBit(PB5_BF_MN_SCLKG_PLL_WD, ~(0x7F), 0x16);
 654   1      
 655   1          // Set DPPLL Div_2 & Div_s
 656   1          ScalerSetByte(PB5_A3_MN_SCLKG_DIVS, (ucDivS >> 1));
 657   1      
 658   1          // Set DPPLL Div_O.
 659   1          ScalerSetBit(PB5_BD_MN_SCLKG_PLL_PWR, ~(_BIT1 | _BIT0), (0 & (_BIT1 | _BIT0)));
 660   1      
 661   1          // Offset Value Setting
 662   1          ScalerSetByte(PB5_A6_MN_SCLKG_OFFS_L, 0);
 663   1          ScalerSetByte(PB5_A5_MN_SCLKG_OFFS_M, 0);
 664   1          ScalerSetBit(PB5_A4_MN_SCLKG_OFFS_H, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
 665   1      
 666   1          // Enable phase swallow
