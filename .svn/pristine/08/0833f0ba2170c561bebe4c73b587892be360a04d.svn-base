 714   3                      PDATA_WORD(0) = _PLL_VCO_BAND_00;
 715   3                      break;
 716   3      
 717   3                  case 01:
 718   3      
 719   3                      PDATA_WORD(0) = _PLL_VCO_BAND_01;
 720   3                      break;
 721   3      
 722   3                  case 10:
 723   3      
 724   3                      PDATA_WORD(0) = _PLL_VCO_BAND_10;
 725   3                      break;
 726   3      
 727   3                  case 11:
