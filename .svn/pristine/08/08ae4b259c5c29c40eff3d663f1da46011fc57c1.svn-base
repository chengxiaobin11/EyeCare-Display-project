  48          //--------------------------------------------------
  49          // Description  : Enable/Disable double buffer
  50          // Input Value  : bEn --> _ENABLE or _DISABLE
  51          // Output Value : None
C51 COMPILER V8.12   RL6449_SERIES_COLORDDOMAINDBENABLE                                    03/11/2025 19:56:14 PAGE 2   

  52          //--------------------------------------------------
  53          void ScalerColorDDomainDBEnable(bit bEn)
  54          {
  55   1          if(ScalerGlobalGetIDCode() >= _RL6449_VER_D_ID_CODE)
  56   1          {
  57   2              if(bEn == _ENABLE)
  58   2              {
  59   3                  // D Domain Double Buffer Enable
  60   3                  ScalerSetBit(P31_B0_D_DB_CTRL0, ~(_BIT7 | _BIT6), _BIT7);
  61   3              }
  62   2              else
  63   2              {
  64   3                  // D Domain Double Buffer Disable
  65   3                  ScalerSetBit(P31_B0_D_DB_CTRL0, ~(_BIT7 | _BIT6), 0x00);
  66   3              }
  67   2          }
  68   1      }
