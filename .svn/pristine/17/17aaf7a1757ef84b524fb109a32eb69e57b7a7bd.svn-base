 696          void RTDFactoryMenuOperation(void)
 697          {
 698   1          if((GET_OSD_STATE() >= _MENU_FACTORY_AUTOCOLOR) &&
 699   1             (GET_OSD_STATE() < _MENU_FACTORY_OSD_END) &&
 700   1             (GET_KEYMESSAGE() <_KEY_AMOUNT))
 701   1          {  
 702   2              DebugMessageOsd("My_KEY",GET_KEYMESSAGE());
 703   2              #if(_PROJECT_ID==_ID_ZQ_2313E01_BOE_MV238FHB_N63_8BIT_FHD100_WLCD_24FH25_20250207)
                                      if(GET_KEYMESSAGE()==_LEFT_KEY_MESSAGE)
                                       SET_KEYMESSAGE(_MENU_KEY_MESSAGE);
                                      else if(GET_KEYMESSAGE()==_MENU_KEY_MESSAGE)
                                       SET_KEYMESSAGE(_LEFT_KEY_MESSAGE);
                       #endif
 709   2      #if(_PROJECT_ID==_ID_ZQ_2513E05_PANDA_LC215DTBA_8BIT_FHD75_VA2271_H_20241223)||(_PROJECT_ID==_ID_ZQ_2513E0
             -5_BOE_HV320FHB_F4A_8BIT_FHD75_VA2271_H_20250301)||(_PROJECT_ID==_ID_ZQ_2313E01_BOE_MV238FHB_N63_8BIT_FHD100_WLCD_24FH25_
             -20250207)
                     (*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][GET_KEYMESSAGE()])();
              #else
 712   2                      if(GET_KEYMESSAGE()==_UP_KEY_MESSAGE)
 713   2              (*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][2])();
 714   2                      else if(GET_KEYMESSAGE()==_DOWN_KEY_MESSAGE)
 715   2                      (*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][1])();       
 716   2                      else if(GET_KEYMESSAGE()==_LEFT_KEY_MESSAGE)
 717   2              (*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][3])();
 718   2                      else if((GET_KEYMESSAGE()==_RIGHT_KEY_MESSAGE))
 719   2                   (*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][0])();
