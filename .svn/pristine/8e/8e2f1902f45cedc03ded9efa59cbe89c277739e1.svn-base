                      ScalerDpRx0SetDpcdValue_EXINT0(0x00, 0x05, 0x0A, _DP_1_2_BRANCH_RTK_FW_VERSION_H);
                      ScalerDpRx0SetDpcdValue_EXINT0(0x00, 0x05, 0x0B, _DP_1_2_BRANCH_RTK_FW_VERSION_L);
