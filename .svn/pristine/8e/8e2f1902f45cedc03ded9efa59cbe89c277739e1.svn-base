 281          void ScalerDpRx0TrainingPatternEnd_EXINT0(void) using 1
 282          {
 283   1          switch(g_ucDpRx0LaneCount)
 284   1          {
 285   2              case _DP_ONE_LANE:
 286   2                  ScalerSetBit_EXINT(PB_01_PHY_DIG_RESET_CTRL, ~(_BIT4 | _BIT3), _BIT3);
 287   2      
 288   2                  // Clear Lane1/2/3 Link status
 289   2                  ScalerDpRx0SetDpcdBitValue_EXINT0(0x00, 0x02, 0x02, ~(_BIT6 | _BIT5 | _BIT4), 0x00);
 290   2                  ScalerDpRx0SetDpcdBitValue_EXINT0(0x00, 0x02, 0x03, ~(_BIT6 | _BIT5 | _BIT4 | _BIT2 | _BIT1 | 
             -_BIT0), 0x00);
 291   2      
 292   2                  break;
 293   2      
 294   2              case _DP_TWO_LANE:
 295   2                  ScalerSetBit_EXINT(PB_01_PHY_DIG_RESET_CTRL, ~(_BIT4 | _BIT3), _BIT4);
 296   2      
 297   2                  // Clear Lane2/3 Link status
 298   2                  ScalerDpRx0SetDpcdBitValue_EXINT0(0x00, 0x02, 0x03, ~(_BIT6 | _BIT5 | _BIT4 | _BIT2 | _BIT1 | 
             -_BIT0), 0x00);
 299   2      
 300   2                  break;
 301   2      
 302   2              case _DP_FOUR_LANE:
 303   2              default:
 304   2                  ScalerSetBit_EXINT(PB_01_PHY_DIG_RESET_CTRL, ~(_BIT4 | _BIT3), (_BIT4 | _BIT3));
 305   2                  break;
 306   2          }
 307   1      
 308   1          // De-Skew Circuit Reset
 309   1          ScalerSetBit_EXINT(PB_0E_DESKEW_PHY, ~(_BIT7 | _BIT6), 0x00);
 310   1          ScalerSetBit_EXINT(PB_0E_DESKEW_PHY, ~(_BIT7 | _BIT6), _BIT6);
 311   1      
 312   1          if((ScalerDpRx0GetDpcdInfo_EXINT0(0x00, 0x01, 0x01) & _BIT7) == _BIT7)
 313   1          {
 314   2              // Enable Enhancement Control Mode --> MAC
 315   2              ScalerSetBit_EXINT(PB_01_PHY_DIG_RESET_CTRL, ~_BIT2, _BIT2);
 316   2          }
 317   1          else
 318   1          {
 319   2              // Disable Enhancement Control Mode --> MAC
 320   2              ScalerSetBit_EXINT(PB_01_PHY_DIG_RESET_CTRL, ~_BIT2, 0x00);
 321   2          }
 322   1      
 323   1          if((ScalerDpRx0GetDpcdInfo_EXINT0(0x00, 0x01, 0x02) & _BIT5) == _BIT5)
 324   1          {
 325   2              // Disable Scrambling
 326   2              ScalerSetBit_EXINT(PB_07_SCRAMBLE_CTRL, ~_BIT5, _BIT5);
 327   2          }
 328   1          else
 329   1          {
 330   2              // Enable Scrambling
 331   2              ScalerSetBit_EXINT(PB_07_SCRAMBLE_CTRL, ~_BIT5, 0x00);
 332   2          }
 333   1      }
 334          
 335          #if((_DP_TX_SUPPORT == _ON) && (_D0_DP_MST_PORT_SUPPORT == _ON))
              //--------------------------------------------------
              // Description  : Reset Dp Rx HDCP info
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
C51 COMPILER V9.60.0.0   SCALERDPRX0_INT_SEPTPHY                                           09/09/2025 18:03:32 PAGE 7   

              void ScalerDpRx0HDCPResetDpcdInfo_EXINT0(void) using 1
              {
              #if(_DP_HDCP_2_2_SUPPORT == _ON)
                  // Clear RxStatus REAUTH_REQ and Link Intergrity Failure for HDCP 2.2
                  ScalerDpRx0SetDpcdValue_EXINT0(0x06, 0x94, 0x93, (ScalerDpRx0GetDpcdInfo_EXINT0(0x06, 0x94, 0x93) & 0x
             -E0));
              #endif
              
                  // Check if nead to clear HDCP dpcd info
                  if((ScalerDpRx0GetDpcdInfo_EXINT0(0x06, 0x80, 0x2A) != 0x00) || (ScalerDpRx0GetDpcdInfo_EXINT0(0x06, 0
             -x80, 0x2B) != 0x00))
                  {
                      ScalerDpRx0SetDpcdValue_EXINT0(0x06, 0x80, 0x29, 0x00);
                      ScalerDpRx0SetDpcdValue_EXINT0(0x06, 0x80, 0x2A, 0x00);
                      ScalerDpRx0SetDpcdValue_EXINT0(0x06, 0x80, 0x2B, 0x00);
              
                      for(pData_EXINT[0] = 0; pData_EXINT[0] < 20; pData_EXINT[0]++)
                      {
                          ScalerDpRx0SetDpcdValue_EXINT0(0x06, 0x80, (0x14 + pData_EXINT[0]), 0x00);
                      }
              
                      for(pData_EXINT[0] = 0; pData_EXINT[0] < 15; pData_EXINT[0]++)
                      {
                          ScalerDpRx0SetDpcdValue_EXINT0(0x06, 0x80, (0x2C + pData_EXINT[0]), 0x00);
                      }
              
                      // Delay Time us [200,x] Waiting for R0 Calculate Finish
                      DELAY_XUS_EXINT(200);
              
                      ScalerDpRx0SetDpcdValue_EXINT0(0x06, 0x80, 0x29, 0x02);
                  }
              }
              //--------------------------------------------------
              // Description  : Load KSV List to Rx KSV FIFO
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerDpRx0HDCPResetKsvFifoToFirst_EXINT0(void) using 1
              {
                  for(g_usDpRx0HdcpKsvFifoOffset = 0; g_usDpRx0HdcpKsvFifoOffset < 15; g_usDpRx0HdcpKsvFifoOffset++)
                  {
                      ScalerDpRx0SetDpcdValue_EXINT0(0x06, 0x80, (0x2C + g_usDpRx0HdcpKsvFifoOffset), g_pucDpTxHdcpKsvFi
             -fo[g_usDpRx0HdcpKsvFifoOffset]);
                  }
              }
              //--------------------------------------------------
              // Description  : Load KSV List to Rx KSV FIFO
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerDpRx0HDCPSetKsvFifo_EXINT0(void) using 1
              {
                  for(pData_EXINT[0] = 0; pData_EXINT[0] < 15; pData_EXINT[0]++)
                  {
                      ScalerDpRx0SetDpcdValue_EXINT0(0x06, 0x80, (0x2C + pData_EXINT[0]), g_pucDpTxHdcpKsvFifo[g_usDpRx0
             -HdcpKsvFifoOffset + pData_EXINT[0]]);
                  }
              
