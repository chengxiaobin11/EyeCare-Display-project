  45          //****************************************************************************
  46          // FUNCTION DEFINITIONS
  47          //****************************************************************************
  48          //--------------------------------------------------
  49          // Description  : Set vertical boundary function
  50          // Input Value  : bEnable   -> _ENABLE or _DISABLE
  51          // Output Value :
C51 COMPILER V8.12   RL6449_SERIES_OSDVERTICALBOUNDARYFUNCTION                             03/11/2025 19:56:18 PAGE 2   

  52          //--------------------------------------------------
  53          void ScalerOsdVerticalBoundary(bit bEnable)
  54          {
  55   1          ScalerSetBit(P3A_18_FRAME_CTRL_18, ~_BIT5, ((BYTE)bEnable << 5));
  56   1      }
  57          
  58          
  59          /*
  60          //--------------------------------------------------
  61          // example
  62          //--------------------------------------------------
  63              ScalerOsdVerticalBoundary(_ENABLE);
  64          */
  65          
  66          
  67          //--------------------------------------------------
  68          // Description  : Set vertical boundary size
  69          // Input Value  : usUpperBoundary -> 0 ~ 2047
  70          //                usLowerBoundary -> 0 ~ 2047
  71          // Output Value :
  72          //--------------------------------------------------
  73          void ScalerOsdVerticalBoundarySize(WORD usUpperBoundary, WORD usLowerBoundary)
  74          {
  75   1          ScalerSetBit(P3A_1E_FRAME_CTRL_1E, ~(_BIT6 | _BIT5 | _BIT4), ((HIBYTE(usUpperBoundary) & 0x07) << 4));
             -   // OSD Vertical Upper Boundary [10:8]
  76   1          ScalerSetBit(P3A_1E_FRAME_CTRL_1E, ~(_BIT2 | _BIT1 | _BIT0), (HIBYTE(usLowerBoundary) & 0x07));       
             -   // OSD Vertical Lower Boundary [10:8]
  77   1      
  78   1          ScalerSetByte(P3A_1F_FRAME_CTRL_1F, LOBYTE(usUpperBoundary)); // OSD Vertical Upper Boundary [7:0]
  79   1          ScalerSetByte(P3A_20_FRAME_CTRL_20, LOBYTE(usLowerBoundary)); // OSD Vertical Lower Boundary [7:0]
  80   1      }
  81          
  82          
  83          /*
  84          //--------------------------------------------------
  85          // example
  86          //--------------------------------------------------
  87              ScalerOsdVerticalBoundarySize(YSTART(100), YEND(1000));
  88          */
  89          


