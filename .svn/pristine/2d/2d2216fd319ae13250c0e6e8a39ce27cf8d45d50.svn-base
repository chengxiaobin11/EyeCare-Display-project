  82          // Description  : Calculate Cos(x)
  83          // Input Value  : shDegree x (in 360 unit)
  84          // Output Value : SWORD Cos(x)
  85          //--------------------------------------------------
  86          SWORD ScalerColorSRGBCosine(SWORD shDegree)
  87          {
  88   1          BYTE ucI = 0;
  89   1          BYTE ucQuadrant = 0;
  90   1          BYTE ucDegreeTemp = 0;
  91   1          BYTE ucDegreeSpan = 0;
  92   1          SWORD shCosValueSpan = 0;
  93   1          SWORD shCosValue = 0;
  94   1      
  95   1          if(shDegree < 0)
  96   1          {
  97   2              shDegree += 360;
  98   2          }
  99   1      
 100   1          shDegree = shDegree % 360;
 101   1      
 102   1          // Locate degree on which quadrant
 103   1          ucQuadrant = (BYTE)(shDegree / 90);
 104   1          ucQuadrant++;
 105   1      
 106   1          switch(ucQuadrant)
 107   1          {
 108   2              // First quadrant
 109   2              case 1:
 110   2      
C51 COMPILER V8.12   RL6449_SERIES_COLORGLOBALHUESAT                                       03/11/2025 19:56:04 PAGE 3   

 111   2                  shDegree = shDegree;
 112   2      
 113   2                  break;
 114   2      
 115   2              // Second quadrant
 116   2              case 2:
 117   2      
 118   2                  shDegree = 180 - shDegree;
 119   2      
 120   2                  break;
 121   2      
 122   2              // Third quadrant
 123   2              case 3:
 124   2      
 125   2                  shDegree = shDegree - 180;
 126   2      
 127   2                  break;
 128   2      
 129   2              // Forth quadrant
 130   2              case 4:
 131   2      
 132   2                  shDegree = 360 - shDegree;
 133   2      
 134   2                  break;
 135   2      
 136   2              default:
 137   2      
 138   2                  break;
 139   2          }
 140   1      
 141   1          // Locate degree on which quadrant
 142   1          if(shDegree <= tCosCurveAngle[0])
 143   1          {
 144   2              shCosValue = tCosCurveValue[0];
 145   2          }
 146   1          else
 147   1          {
 148   2              for(ucI = 1; tCosCurveAngle[ucI] < shDegree; ucI++) {}
 149   2      
 150   2              ucI--;
 151   2      
 152   2              ucDegreeTemp = shDegree - tCosCurveAngle[ucI];
 153   2              ucDegreeSpan = tCosCurveAngle[ucI + 1] - tCosCurveAngle[ucI];
 154   2              shCosValueSpan = tCosCurveValue[ucI + 1] - tCosCurveValue[ucI];
 155   2              shCosValue = tCosCurveValue[ucI] + (SWORD)ucDegreeTemp * shCosValueSpan / ucDegreeSpan;
 156   2          }
 157   1      
 158   1          if((ucQuadrant == 2) || (ucQuadrant == 3))
 159   1          {
 160   2              shCosValue = shCosValue * (-1);
 161   2          }
 162   1      
 163   1          return shCosValue;
 164   1      }
