 252          //--------------------------------------------------
 253          // Description  : Do matrix multiply(3x3)  C = A*B
 254          // Input Value  : shArrayA, shArrayB
 255          // Output Value : shArrayC (SWORD)
 256          //--------------------------------------------------
 257          void ScalerColorSRGBMatrixMultiply(SWORD (*ppshArrayA)[3], SWORD (*ppshArrayB)[3], SWORD (*ppshArrayC)[3])
 258          {
 259   1          BYTE ucI = 0;
 260   1          BYTE ucJ = 0;
 261   1      
