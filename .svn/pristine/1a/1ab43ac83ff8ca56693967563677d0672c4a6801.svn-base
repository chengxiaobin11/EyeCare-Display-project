 511   3      
 512   3                  case _AVI_INFO_SCAN_INFO:
 513   3      
 514   3                      return ScalerGetDataPortBit(P71_CD_HDMI_PSAP, 0x04, (_BIT1 | _BIT0));
 515   3      
 516   3                  case _AVI_INFO_IT_CONTENT:
 517   3      
 518   3                      return (ScalerGetDataPortBit(P71_CD_HDMI_PSAP, 0x06, _BIT7) >> 7);
 519   3      
 520   3                  case _AVI_INFO_PIXEL_REPETITION:
 521   3      
 522   3                      return (ScalerGetDataPortBit(P71_CD_HDMI_PSAP, 0x08, (_BIT3 | _BIT2 | _BIT1 | _BIT0)));
 523   3      
 524   3                  case _AVI_INFO_AR:
 525   3      
 526   3                      return (ScalerGetDataPortBit(P71_CD_HDMI_PSAP, 0x05, (_BIT5 | _BIT4)) >> 4);
 527   3      
 528   3                  case _AVI_INFO_VIC:
 529   3      
 530   3                      return (ScalerGetDataPortBit(P71_CD_HDMI_PSAP, 0x07, (_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT
             -3 | _BIT2 | _BIT1 | _BIT0)));
 531   3      
