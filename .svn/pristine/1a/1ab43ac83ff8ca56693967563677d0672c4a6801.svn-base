1034   3                  return _TRUE;
1035   3              }
1036   2          }
1037   1      
1038   1          // Enable DDC Toggle IRQ
1039   1          if(((MCU_FE69_DDC2_EDID_IRQ & _BIT3) != _BIT3) && (GET_TMDS_RX2_DDC_DETECTED() != _TRUE))
1040   1          {
