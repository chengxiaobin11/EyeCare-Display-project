 540          //--------------------------------------------------
 541          // Description  : Get Color Depth
 542          // Input Value  : None
 543          // Output Value : Received Color Depth
 544          //--------------------------------------------------
 545          BYTE ScalerTMDSRx2HdmiGetColorDepth(void)
 546          {
 547   1          if(GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR422)
 548   1          {
 549   2              return _COLOR_DEPTH_12_BITS;
 550   2          }
 551   1      
 552   1          if(GET_HDMI_RX2_GCP_RECEIVED() == _TRUE)
 553   1          {
 554   2              if(ScalerGetBit(P71_B4_TMDS_DPC0, 0x07) == 0x05)
 555   2              {
 556   3                  return _COLOR_DEPTH_10_BITS;
 557   3              }
 558   2              else if(ScalerGetBit(P71_B4_TMDS_DPC0, 0x07) == 0x06)
 559   2              {
 560   3                  return _COLOR_DEPTH_12_BITS;
 561   3              }
 562   2              else if(ScalerGetBit(P71_B4_TMDS_DPC0, 0x07) == 0x07)
 563   2              {
 564   3                  return _COLOR_DEPTH_16_BITS;
 565   3              }
 566   2          }
 567   1      
 568   1          return _COLOR_DEPTH_8_BITS;
 569   1      }
