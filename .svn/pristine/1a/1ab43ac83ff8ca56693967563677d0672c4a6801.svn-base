 101          //--------------------------------------------------
 102          // Description  : TMDS Video Setting
 103          // Input Value  : Source Type
 104          // Output Value : None
 105          //--------------------------------------------------
 106          void ScalerTMDSRx2DviVideoSetting(void)
 107          {
 108   1          // Manual Set Color Space and disable pixel repetition
 109   1          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_51_PORT_PAGE71_HDMI_ACRCR, ~(_BIT6 | _BIT5 | _BIT4 | _
C51 COMPILER V9.01   SCALERTMDSRX2_SEPTPHY                                                 05/24/2025 15:51:27 PAGE 3   

             -BIT3 | _BIT2), 0x00);
 110   1      
 111   1          // Disable Down Sampling
 112   1          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_50_PORT_PAGE71_HDMI_VCR, ~(_BIT3 | _BIT2 | _BIT1 | _BI
             -T0), 0x00);
 113   1      
 114   1          // Waiting for Down Sampling Effect
 115   1          ScalerTimerDelayXms(20);
 116   1      
 117   1          SET_COLOR_SPACE(_COLOR_SPACE_RGB);
 118   1          SET_COLOR_RGB_QUANTIZATION_RANGE(_RGB_QUANTIZATION_FULL_RANGE);
 119   1      
 120   1          ScalerTMDSRx2SetPorchColor(GET_COLOR_SPACE());
 121   1      }
