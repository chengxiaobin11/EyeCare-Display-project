 862   2      
 863   2              case _HDMI_2_0_READ_REQUEST_NACK1:
 864   2      
 865   2                  if(GET_HDMI_2_0_RX2_RR_ENABLE() == _TRUE)
 866   2                  {
 867   3                      // FW Manual Enable Read Request
 868   3                      ScalerSetBit_EXINT(P71_1B_HDMI_CTRL_1B, ~_BIT7, _BIT7);
 869   3                  }
 870   2      
 871   2                  break;
 872   2      
 873   2              case _HDMI_2_0_READ_REQUEST_NACK2:
 874   2      
 875   2      #if(_WD_TIMER_INT_SUPPORT == _ON)
 876   2                  if(GET_HDMI_2_0_RX2_RR_ENABLE() == _TRUE)
 877   2                  {
 878   3                      // Enable Read Request Retry
 879   3                      ScalerTimerWDActivateTimerEvent_EXINT0(10, _SCALER_WD_TIMER_EVENT_RX2_HDMI_RR_RETRY);
 880   3                  }
 881   2      #endif
 882   2      
 883   2                  break;
 884   2      
 885   2              default:
 886   2      
 887   2                  break;
 888   2          }
 889   1      }
