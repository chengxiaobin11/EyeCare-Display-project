 702   2                  pucIDArry[2] = MCU_FF69_COMMON_INST_READ_PORT2;
 703   2      
 704   2                  // Repeatedly read flash ID code and check flash ID code data between twice RDID instructions
 705   2                  for(ucIndex = 0; ucIndex < ucTryCount; ucIndex++)
 706   2                  {
 707   3                      MCU_SET_BYTE_WITH_CKCON(MCU_FF60_COMMON_INST_EN, 0x46, _CKCON_MCU_SLOW_CYCLE);
 708   3                      MCU_FF61_COMMON_OP_CODE = ucRDIDOPCode;
 709   3                      MCU_SET_BYTE_WITH_CKCON(MCU_FF60_COMMON_INST_EN, 0x47, _CKCON_MCU_SLOW_CYCLE);
 710   3                      ucID0 = MCU_FF67_COMMON_INST_READ_PORT0;
 711   3                      ucID1 = MCU_FF68_COMMON_INST_READ_PORT1;
 712   3                      ucID2 = MCU_FF69_COMMON_INST_READ_PORT2;
 713   3      
 714   3                      if((pucIDArry[0] == ucID0) && (pucIDArry[1] == ucID1) && (pucIDArry[2] == ucID2))
 715   3                      {
 716   4                          break;
 717   4                      }
 718   3                      else
 719   3                      {
 720   4                          pucIDArry[0] = ucID0;
 721   4                          pucIDArry[1] = ucID1;
 722   4                          pucIDArry[2] = ucID2;
