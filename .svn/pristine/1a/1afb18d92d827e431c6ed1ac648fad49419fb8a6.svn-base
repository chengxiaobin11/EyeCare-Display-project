 698   2                  MCU_FF61_COMMON_OP_CODE = ucRDIDOPCode;
 699   2                  MCU_SET_BYTE_WITH_CKCON(MCU_FF60_COMMON_INST_EN, 0x47, _CKCON_MCU_SLOW_CYCLE);
