6992          //--------------------------------------------------
6993          // Description  : Erase page
6994          // Input Value  : ucBank: bank index
6995          //                ucPage: page index (0 ~ 15)
6996          // Output Value : _TRUE for erase success and _FALSE for erase fail
6997          //--------------------------------------------------
6998          bit ScalerFlashErasePage(BYTE ucBank, BYTE ucPage)
6999          {
7000   1          // The access bank is smaller than than the start bank
7001   1          if(ucBank < MCU_FFFD_XDATA_BANK_START)
7002   1          {
7003   2              return _FALSE;
7004   2          }
7005   1      
7006   1          if(g_ucFlashType == _FLASH_UNDETECT)
7007   1          {
7008   2              ScalerFlashDetectFlashType();
7009   2          }
7010   1      
7011   1          if(g_ucFlashType >= (sizeof(tFlashInformation) / sizeof(tFlashInformation[0])))
7012   1          {
7013   2              return _FALSE;
7014   2          }
7015   1      
7016   1          ScalerFlashWREN(ucBank, ucPage);
7017   1      
7018   1          // Sector Erase
7019   1          MCU_SET_BYTE_WITH_CKCON(MCU_FF60_COMMON_INST_EN, 0xB8, _CKCON_MCU_SLOW_CYCLE);
7020   1          MCU_FF61_COMMON_OP_CODE = tFlashInformation[g_ucFlashType].ucPageEraseOpCode;
7021   1          // Set WR address
7022   1          MCU_FF64_FLASH_PROG_ISP0 = ucBank;
7023   1          MCU_FF65_FLASH_PROG_ISP1 = (BYTE)((ucPage << 4) & 0xF0);
7024   1          MCU_FF66_FLASH_PROG_ISP2 = 0x00;
7025   1          // Start Bit0
7026   1          MCU_SET_BYTE_WITH_CKCON(MCU_FF60_COMMON_INST_EN, 0xB9, _CKCON_MCU_SLOW_CYCLE);
7027   1      
7028   1          // No need to polling, 8051 will halt when common instruction executes
7029   1      
7030   1          MCU_FF61_COMMON_OP_CODE = 0xFF;
7031   1      
7032   1          ScalerFlashWRDis();
7033   1      
7034   1          return _TRUE;
7035   1      }
