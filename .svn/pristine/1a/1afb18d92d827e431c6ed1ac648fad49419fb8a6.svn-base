 676          //--------------------------------------------------
 677          // Description  : Read flash ID code
 678          // Input Value  : ucRDIDOPCode: Read ID code op code
 679          //                pucIDArry: Saved the ID code read from flash
 680          // Output Value : _TRUE for read success, else return _FALSE
 681          //--------------------------------------------------
 682          bit ScalerFlashReadFlashIDCode(BYTE ucRDIDOPCode, BYTE *pucIDArry)
 683          {
 684   1          BYTE ucIndex = 0;
 685   1          BYTE ucTryCount = 10;
 686   1          BYTE ucID0 = 0;
