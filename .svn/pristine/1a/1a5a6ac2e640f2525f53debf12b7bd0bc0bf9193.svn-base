  55          void ScalerOsdCharCommandByteSeries(WORD usCharAddr, EnumOsdWriteType enumOsdWriteType, BYTE ucData, WORD 
             -usLength)
  56          {
  57   1          ScalerOsdSramAddressSet(usCharAddr, enumOsdWriteType);
  58   1      
  59   1          do
  60   1          {
  61   2              ScalerSetByte(P0_92_OSD_DATA_PORT, ucData);
  62   2          }
  63   1          while(--usLength);
  64   1      }


