  67   1          ScalerSetBit(P5_BE_MN_PXL_NUM_H, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (HIBYTE(usHWidth) & 0x0F));
  68   1          ScalerSetByte(P5_BF_MN_PXL_NUM_L, LOBYTE(usHWidth));
  69   1      
  70   1          // Set Capture Line Number
  71   1          ScalerSetBit(P5_B7_IN1_LINE_NUM_H, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (usVHeight >> 8) & 0x0F);
  72   1          ScalerSetByte(P5_B8_IN1_LINE_NUM_L, LOBYTE(usVHeight));
  73   1      
  74   1          // Set Display Line Number
  75   1          ScalerSetBit(P5_CD_MN_LINE_NUM_H, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (usVHeight >> 8) & 0x0F);
  76   1          ScalerSetByte(P5_CE_MN_LINE_NUM_L, LOBYTE(usVHeight));
  77   1      
  78   1          // FRC display double buffer apply
  79   1          ScalerSetBit(P5_D0_MN_SDR_STATUS, ~_BIT4, _BIT4);
  80   1      }
