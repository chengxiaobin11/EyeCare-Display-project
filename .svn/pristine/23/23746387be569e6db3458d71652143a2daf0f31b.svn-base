  63   1          ScalerSetByte(P5_BC_MN_PRRD_VST_H, HIBYTE(_PRE_READ_LINE_BUFFER));
  64   1          ScalerSetByte(P5_BD_MN_PRRD_VST_L, LOBYTE(_PRE_READ_LINE_BUFFER));
  65   1      
