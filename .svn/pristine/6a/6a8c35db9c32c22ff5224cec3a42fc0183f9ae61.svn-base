  47          //--------------------------------------------------
  48          // Description  : Set OSD 2 bit font offset
  49          // Input Value  : ucOffset -> 0 ~ 511
  50          // Output Value :
  51          //--------------------------------------------------
C51 COMPILER V8.12   OSD2BITFONTOFFSET                                                     03/11/2025 19:55:54 PAGE 2   

  52          void ScalerOsd2BitFontOffset(WORD usOffset)
  53          {
  54   1          ScalerSetBit(P3A_21_FRAME_CTRL_21, ~(_BIT1), ((usOffset & 0x100) >> 7));
  55   1          ScalerSetByte(P3A_22_FRAME_CTRL_22, (BYTE)usOffset);
  56   1      }


