 112          // FUNCTION DEFINITIONS
 113          //****************************************************************************
 114          //--------------------------------------------------
 115          // Description  : 6 Color ICM adjust
 116          // Input Value  : ucColorIndex --> Color Adjusted Now
 117          //                ucHuePosition --> Hue position after mapping
 118          //                ucSatPosition --> Sat position after mapping
 119          // Output Value : None
 120          //--------------------------------------------------
 121          void ScalerColorSixColorAdjustBriCompensate(BYTE ucColorIndex, BYTE ucHuePosition, BYTE ucSatPosition)
 122          {
 123   1          BYTE pucCentDeltaUV[16];
 124   1          BYTE ucLastIndex = 0;
 125   1          BYTE ucNextIndex = 0;
 126   1          BYTE ucPointIndex = 0;
 127   1          SWORD shDeltaSat = 0;
 128   1          SWORD shDeltaUmax1 = 0;
 129   1          SWORD shDeltaVmax1 = 0;
 130   1          SWORD shDeltaUmax = 0;
 131   1          SWORD shDeltaVmax = 0;
 132   1          SWORD shDeltaY = 0;
 133   1          SWORD shDeltaU = 0;
 134   1          SWORD shDeltaV = 0;
 135   1          memset(pucCentDeltaUV, 0, sizeof(pucCentDeltaUV));
 136   1      
 137   1          ucLastIndex = (ucColorIndex == 0) ? 5 : (ucColorIndex - 1);
 138   1          ucNextIndex = (ucColorIndex == 5) ? 0 : (ucColorIndex + 1);
 139   1      
 140   1          // Not Use SCM
 141   1          ScalerSetBit(P7_CD_SCM_BLOCK_SELECT, ~_BIT4, 0x00);
 142   1      
 143   1          // Delta Saturation = (-512 * 200 + ((512 - (-512)) * ucSatPosition)) / 200
 144   1          shDeltaSat = ((SDWORD)-102400 + ((SDWORD)ucSatPosition << 10)) / 200;
 145   1      
 146   1          if(ucHuePosition > 50)
 147   1          {
 148   2              shDeltaUmax = (SDWORD)tSIX_COLOR_CTOC_DELTA_UV_DOWN_BRI_COMPENSATE[ucColorIndex][0] * (ucHuePositi
             -on - 50) / 50;
 149   2              shDeltaVmax = (SDWORD)tSIX_COLOR_CTOC_DELTA_UV_DOWN_BRI_COMPENSATE[ucColorIndex][1] * (ucHuePositi
             -on - 50) / 50;
 150   2              shDeltaY = (SDWORD)tSIX_COLOR_CTOC_DELTA_Y_DOWN_BRI_COMPENSATE[ucColorIndex] * (ucHuePosition - 50
             -) / 50;
 151   2          }
 152   1          else if(ucHuePosition < 50)
 153   1          {
 154   2              shDeltaUmax = (SDWORD)tSIX_COLOR_CTOC_DELTA_UV_UP_BRI_COMPENSATE[ucColorIndex][0] * (50 - ucHuePos
             -ition) / 50;
 155   2              shDeltaVmax = (SDWORD)tSIX_COLOR_CTOC_DELTA_UV_UP_BRI_COMPENSATE[ucColorIndex][1] * (50 - ucHuePos
             -ition) / 50;
 156   2              shDeltaY = (SDWORD)tSIX_COLOR_CTOC_DELTA_Y_UP_BRI_COMPENSATE[ucColorIndex] * (50 - ucHuePosition) 
             -/ 50;
 157   2          }
 158   1          else
 159   1          {
 160   2              shDeltaUmax = 0;
 161   2              shDeltaVmax = 0;
 162   2              shDeltaY = 0;
 163   2          }
 164   1      
 165   1          shDeltaUmax1 = tSIX_COLOR_U_MAX_8_BRI_COMPENSATE[ucColorIndex] + shDeltaUmax;
 166   1          shDeltaVmax1 = tSIX_COLOR_V_MAX_8_BRI_COMPENSATE[ucColorIndex] + shDeltaVmax;
 167   1      
C51 COMPILER V8.12   RL6449_SERIES_COLORSIXCOLORADJUSTBRICOMPE                             03/11/2025 19:56:12 PAGE 4   

 168   1          shDeltaUmax1 = (SDWORD)shDeltaSat * shDeltaUmax1 >> 9;
 169   1          shDeltaVmax1 = (SDWORD)shDeltaSat * shDeltaVmax1 >> 9;
 170   1      
 171   1          shDeltaUmax = (shDeltaUmax1 + shDeltaUmax) >> 3;
 172   1          shDeltaVmax = (shDeltaVmax1 + shDeltaVmax) >> 3;
 173   1      
 174   1          for(ucPointIndex = 0; ucPointIndex < 8; ucPointIndex++)
 175   1          {
 176   2              shDeltaU = (shDeltaUmax * (ucPointIndex + 1)) >> 3;
 177   2              shDeltaV = (shDeltaVmax * (ucPointIndex + 1)) >> 3;
 178   2      
 179   2              shDeltaU = MAXOF(-128, MINOF(127, shDeltaU));
 180   2              shDeltaV = MAXOF(-128, MINOF(127, shDeltaV));
 181   2      
 182   2              pucCentDeltaUV[ucPointIndex << 1] = shDeltaU & 0xFF;
 183   2              pucCentDeltaUV[(ucPointIndex << 1) + 1] = shDeltaV & 0xFF;
 184   2          }
 185   1      
 186   1          ScalerColorSixColorICMLoadBriCompensate(shDeltaY, pucCentDeltaUV, ucColorIndex, _SIX_COLOR_CENTER_BRI_
             -COMPENSATE);
 187   1          ScalerColorSixColorICMLoadBriCompensate(shDeltaY, pucCentDeltaUV, ucColorIndex, _SIX_COLOR_LEFTWIDTH_B
             -RI_COMPENSATE);
 188   1          ScalerColorSixColorICMLoadBriCompensate(shDeltaY, pucCentDeltaUV, ucColorIndex, _SIX_COLOR_LEFTBUFFER_
             -BRI_COMPENSATE);
 189   1          ScalerColorSixColorICMLoadBriCompensate(shDeltaY, pucCentDeltaUV, ucNextIndex, _SIX_COLOR_RIGHTWIDTH_B
             -RI_COMPENSATE);
 190   1          ScalerColorSixColorICMLoadBriCompensate(shDeltaY, pucCentDeltaUV, ucNextIndex, _SIX_COLOR_RIGHTBUFFER_
             -BRI_COMPENSATE);
 191   1      
 192   1          // Set LSB to 0
 193   1          ScalerSetBit(P7_D1_ICM_SEL, ~(_BIT2 | _BIT1 | _BIT0), ucColorIndex);
 194   1          ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_6F_PORT_CMN_MST_00_01_UV_OFFSET_L);
 195   1          ScalerBurstWrite(tICM_TABLE_GRAY_LSB_BRI_COMPENSATE, _SIXCOLOR_TO_GRAY_TABLE_SIZE_LSB_BRI_COMPENSATE, 
             -GET_CURRENT_BANK_NUMBER(), P7_D3_ICM_DATA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
 196   1      
 197   1          // Set dy LSB to 0
 198   1          ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_87_PORT_CMN_AXIS_DELY_L);
 199   1          ScalerSetByte(P7_D3_ICM_DATA, 0x00);
 200   1      }
 201          
 202          //--------------------------------------------------
 203          // Description   : Fill 6 Color ICM Data
 204          // Input Value   : pucICMData --> Point to ICM uvoffset
 205          //                 ucCMSel --> Color selected
 206          //                   ucLoadSelect --> Axis selected
 207          // Output Value  : None
 208          //--------------------------------------------------
 209          void ScalerColorSixColorICMLoadBriCompensate(SWORD shDeltaY, BYTE *pucICMData, BYTE ucCMSel, BYTE ucLoadSe
             -lect)
 210          {
 211   1          ScalerSetBit(P7_D1_ICM_SEL, ~(_BIT2 | _BIT1 | _BIT0), ucCMSel);
 212   1      
 213   1          switch(ucLoadSelect)
 214   1          {
 215   2              case _SIX_COLOR_RIGHTBUFFER_BRI_COMPENSATE:
 216   2                  ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_33_PORT_CMN_RBUF_00_DU_H);
 217   2                  break;
 218   2      
 219   2              case _SIX_COLOR_RIGHTWIDTH_BRI_COMPENSATE:
 220   2                  ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_13_PORT_CMN_RWID_00_DU_H);
 221   2                  break;
 222   2      
C51 COMPILER V8.12   RL6449_SERIES_COLORSIXCOLORADJUSTBRICOMPE                             03/11/2025 19:56:12 PAGE 5   

 223   2              case _SIX_COLOR_CENTER_BRI_COMPENSATE:
 224   2                  ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_03_PORT_CMN_MST_00_DU_H);
 225   2                  break;
 226   2      
 227   2              case _SIX_COLOR_LEFTWIDTH_BRI_COMPENSATE:
 228   2                  ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_23_PORT_CMN_LWID_00_DU_H);
 229   2                  break;
 230   2      
 231   2              case _SIX_COLOR_LEFTBUFFER_BRI_COMPENSATE:
 232   2                  ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_43_PORT_CMN_LBUF_00_DU_H);
 233   2                  break;
 234   2      
 235   2              default:
 236   2                  ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_23_PORT_CMN_LWID_00_DU_H);
 237   2                  break;
 238   2          }
 239   1      
 240   1          ScalerBurstWrite(pucICMData, _SIXCOLOR_TABLE_SIZE_AXIS_BRI_COMPENSATE, GET_CURRENT_BANK_NUMBER(), P7_D
             -3_ICM_DATA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_XRAM);
 241   1      
 242   1          switch(ucLoadSelect)
 243   1          {
 244   2              case _SIX_COLOR_RIGHTBUFFER_BRI_COMPENSATE:
 245   2                  return;
 246   2      
 247   2              case _SIX_COLOR_RIGHTWIDTH_BRI_COMPENSATE:
 248   2                  ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_6B_PORT_CMN_R_AXIS_DELY_H);
 249   2                  break;
 250   2      
 251   2              case _SIX_COLOR_CENTER_BRI_COMPENSATE:
 252   2                  ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_69_PORT_CMN_M_AXIS_DELY_H);
 253   2                  break;
 254   2      
 255   2              case _SIX_COLOR_LEFTWIDTH_BRI_COMPENSATE:
 256   2                  ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_6D_PORT_CMN_L_AXIS_DELY_H);
 257   2                  break;
 258   2      
 259   2              case _SIX_COLOR_LEFTBUFFER_BRI_COMPENSATE:
 260   2                  return;
 261   2      
 262   2              default:
 263   2                  return;
 264   2          }
 265   1      
 266   1          ScalerSetByte(P7_D3_ICM_DATA, (BYTE)((shDeltaY >> 8) & 0xFF));
 267   1          ScalerSetByte(P7_D3_ICM_DATA, (BYTE)(shDeltaY & 0xFF));
 268   1      }


