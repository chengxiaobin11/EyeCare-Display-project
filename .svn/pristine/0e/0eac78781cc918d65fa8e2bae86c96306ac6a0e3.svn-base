 208   2      
 209   2              case _POWER_ACTION_PS_TO_OFF:
 210   2      
 211   2                  break;
 212   2      
 213   2              default:
 214   2                  break;
 215   2          }
 216   1      
 217   1          return ucPowerIsoFlg;
 218   1      }
