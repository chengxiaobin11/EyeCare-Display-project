  64          //--------------------------------------------------
  65          // Description  : Power cut block flow
  66          // Input Value  : enumSwitch    --> Power action description.
  67          // Output Value : return power group enter isolation area
  68          //--------------------------------------------------
  69          BYTE ScalerPowerIsolation(EnumPowerAction enumSwitch)
  70          {
  71   1          BYTE ucPowerIsoFlg = 0x00;
  72   1      
  73   1          switch(enumSwitch)
  74   1          {
  75   2              case _POWER_ACTION_NORMAL_TO_PS:
  76   2              case _POWER_ACTION_NORMAL_TO_OFF:
  77   2              case _POWER_ACTION_AC_ON_TO_OFF:
  78   2              case _POWER_ACTION_AC_ON_INITIAL:
  79   2      
  80   2      #if(_PANEL_STYLE == _PANEL_LVDS)
  81   2                  // LVDS Pad Power Off
  82   2                  ScalerDisplayLvdsPadPower(_OFF);
  83   2      #elif(_PANEL_STYLE == _PANEL_DPTX)
                          // LVDS Pad Power Off for eDP
                          ScalerDisplayUseLvdsPadPower(_OFF);
              #endif
  87   2      
  88   2                  // Group A block isolation control
  89   2      #if(_MHL_SUPPORT == _ON)
                          if((ScalerGlobalGetIDCode() != _RL6432_VER_A_ID_CODE) || (enumSwitch == _POWER_ACTION_AC_ON_IN
             -ITIAL))
              #endif
  92   2                  {
  93   3                      ScalerPowerGroupAIsolation(_ON);
  94   3                  }
  95   2      
  96   2                  ucPowerIsoFlg |= _BIT0;
  97   2      
  98   2                  // Group B block isolation control
  99   2                  ScalerPowerGroupBIsolation(_ON);
 100   2                  ucPowerIsoFlg |= _BIT1;
 101   2      
 102   2                  // Group ADI block isolation control
 103   2                  ScalerPowerGroupADIIsolation(_ON);
 104   2                  ucPowerIsoFlg |= _BIT2;
 105   2      
 106   2      #if(_MHL_SUPPORT == _ON)
                          if((ScalerGlobalGetIDCode() != _RL6432_VER_A_ID_CODE) || (enumSwitch == _POWER_ACTION_AC_ON_IN
             -ITIAL))
C51 COMPILER V9.60.0.0   RL6432_SERIES_POWER                                               08/27/2025 11:01:40 PAGE 3   

              #endif
 109   2                  {
 110   3                      // Group D1 to D3 block isolation control
 111   3                      ScalerPowerGroupD1Isolation(_ON);
 112   3                      ScalerPowerGroupD2Isolation(_ON);
 113   3                      ScalerPowerGroupD3Isolation(_ON);
 114   3                  }
 115   2      
 116   2                  ucPowerIsoFlg |= _BIT3;
 117   2      
 118   2                  // Group D0 block isolation control
 119   2                  ScalerPowerGroupD0Isolation(_ON);
 120   2                  ucPowerIsoFlg |= _BIT4;
 121   2      
 122   2                  // Group B power control
 123   2                  ScalerPowerGroupBPowerCut(_ON);
 124   2      
 125   2                  // Group ADI power control
 126   2                  ScalerPowerGroupADIPowerCut(_ON);
 127   2      
 128   2      #if(_MHL_SUPPORT == _ON)
                          if((ScalerGlobalGetIDCode() != _RL6432_VER_A_ID_CODE) || (enumSwitch == _POWER_ACTION_AC_ON_IN
             -ITIAL))
              #endif
 131   2                  {
 132   3                      // Group D1 to D3 power control
 133   3                      ScalerPowerGroupD1PowerCut(_ON);
 134   3                      ScalerPowerGroupD2PowerCut(_ON);
 135   3                      ScalerPowerGroupD3PowerCut(_ON);
 136   3                  }
 137   2      
 138   2                  // Group D0 power control
 139   2                  ScalerPowerGroupD0PowerCut(_ON);
 140   2      
 141   2                  // Group A power control control by GPIO
 142   2      #if(_MHL_SUPPORT == _ON)
                          if((ScalerGlobalGetIDCode() != _RL6432_VER_A_ID_CODE) || (enumSwitch == _POWER_ACTION_AC_ON_IN
             -ITIAL))
              #endif
 145   2                  {
 146   3                      ScalerPowerGroupAPowerCut(_ON);
 147   3                  }
 148   2      
 149   2                  break;
 150   2      
 151   2              case _POWER_ACTION_AC_ON_TO_NORMAL:
 152   2              case _POWER_ACTION_OFF_TO_NORMAL:
 153   2              case _POWER_ACTION_PS_TO_NORMAL:
 154   2      
 155   2                  // All power group Reset
 156   2                  ScalerPowerAllGroupPowerCutReset(_ON);
 157   2      
 158   2                  // Group A power supply control by GPIO
 159   2                  ScalerPowerGroupAPowerCut(_OFF);
 160   2      
 161   2                  // Group B power control
 162   2                  ScalerPowerGroupBPowerCut(_OFF);
 163   2      
 164   2                  // Group ADI power control
 165   2                  ScalerPowerGroupADIPowerCut(_OFF);
 166   2      
 167   2                  // Group D2 to D3 power control
C51 COMPILER V9.60.0.0   RL6432_SERIES_POWER                                               08/27/2025 11:01:40 PAGE 4   

 168   2                  ScalerPowerGroupD2PowerCut(_OFF);
 169   2                  ScalerPowerGroupD3PowerCut(_OFF);
 170   2      
 171   2                  // Group D0 to D1 power control
 172   2                  ScalerPowerGroupD0PowerCut(_OFF);
 173   2                  ScalerPowerGroupD1PowerCut(_OFF);
 174   2      
 175   2                  // Group A block isolation control
 176   2                  ScalerPowerGroupAIsolation(_OFF);
 177   2      
 178   2                  // Group B block isolation control
 179   2                  ScalerPowerGroupBIsolation(_OFF);
 180   2      
 181   2                  // Group ADI block isolation control
 182   2                  ScalerPowerGroupADIIsolation(_OFF);
 183   2      
 184   2                  // Group D2 to D3 block isolation control
 185   2                  ScalerPowerGroupD2Isolation(_OFF);
 186   2                  ScalerPowerGroupD3Isolation(_OFF);
 187   2      
 188   2                  // Group D0 to D1 block isolation control
 189   2                  ScalerPowerGroupD0Isolation(_OFF);
 190   2                  ScalerPowerGroupD1Isolation(_OFF);
 191   2      
 192   2                  // All power group Relase
 193   2                  ScalerPowerAllGroupPowerCutReset(_OFF);
 194   2      
 195   2      #if(_PANEL_STYLE == _PANEL_LVDS)
 196   2                  // LVDS Pad Power On
 197   2                  ScalerDisplayLvdsPadPower(_ON);
 198   2      #elif(_PANEL_STYLE == _PANEL_DPTX)
