 485          //--------------------------------------------------
 486          // Description  : Group A Power on/off
 487          // Input Value  : ON --> Group A(Low Power) ; OFF --> Group A (Normal Operation)
 488          // Output Value : None
 489          //--------------------------------------------------
 490          void ScalerPowerGroupAPowerCut(BYTE ucOn)
 491          {
 492   1          if(ucOn == _ON)
 493   1          {
 494   2              PCB_VCCK_OFF_POWER(_VCCK_OFF_POWER_OFF);
 495   2      
 496   2              // Wait for 1.1V release to 0V, can't delete
 497   2              PCB_VCCKOFF_POWER_RELEASE_TIME(_VCCKOFF_POWER_OFF_TIME);
 498   2          }
 499   1          else
 500   1          {
 501   2              // Group A power block power cut on
 502   2              if((ScalerGetBit(P0_F0_VCCKOFF_CONTROL0, _BIT4) == _BIT4) || (ScalerGetBit(P0_09_GA_POWER_CTRL, _B
             -IT1) == _BIT1))
 503   2              {
 504   3                  PCB_VCCK_OFF_POWER(_VCCK_OFF_POWER_ON);
 505   3      
 506   3                  // Wait for 1.1V stable, can't delete
 507   3                  ScalerTimerDelayXms(10);
 508   3              }
 509   2          }
 510   1      }
