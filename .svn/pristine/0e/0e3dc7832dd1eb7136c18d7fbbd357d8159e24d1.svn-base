 348          //--------------------------------------------------
 349          // Description  : Switch DDC pin to GPIO or viceversa
 350          // Input Value  : ucPinType -->
 351          //                PIN65-65/212-213/214-215 for GPIO/DDC
 352          // Output Value : None
 353          //--------------------------------------------------
 354          void ScalerPinshareGpioDdcPinSwitch(BYTE ucPinType)
 355          {
 356   1          switch(ucPinType)
 357   1          {
 358   2              case _DDC_VGA_SWITCH_GPIO:
 359   2                  ScalerSetBit(P10_02_PIN_SHARE_CTRL12__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_OPEN_DRAIN))); // Pin_65
 360   2                  ScalerSetByte(P10_03_PIN_SHARE_CTRL13__ADION, (BYTE)_GPIO_OPEN_DRAIN); // Pin_66
 361   2                  break;
 362   2      
 363   2              case _DDC_VGA_SWITCH_DDC:
 364   2                  ScalerSetBit(P10_02_PIN_SHARE_CTRL12__ADION, ~_BIT7, 0x00); // Pin_65-66, DDCVGA
 365   2                  break;
 366   2      
 367   2              case _DDC2_SWITCH_GPIO:
 368   2                  ScalerSetBit(P10_49_PIN_SHARE_CTRLB1__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_OPEN_DRAIN))); // Pin_212
 369   2                  ScalerSetByte(P10_4A_PIN_SHARE_CTRLB2__ADION, (BYTE)_GPIO_OPEN_DRAIN); // Pin_213
 370   2                  break;
 371   2      
 372   2              case _DDC2_SWITCH_DDC:
 373   2                  ScalerSetBit(P10_49_PIN_SHARE_CTRLB1__ADION, ~_BIT7, 0x00); // Pin_212/213, DDC2
 374   2                  break;
 375   2      
 376   2              case _DDC2_SWITCH_GPI:
 377   2                  ScalerSetBit(P10_49_PIN_SHARE_CTRLB1__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_INPUT))); // Pin_212
 378   2                  ScalerSetByte(P10_4A_PIN_SHARE_CTRLB2__ADION, (BYTE)_GPIO_INPUT); // Pin_213
 379   2                  break;
 380   2      
 381   2              case _DDC3_SWITCH_GPIO:
 382   2                  ScalerSetBit(P10_4B_PIN_SHARE_CTRLB3__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_OPEN_DRAIN))); // Pin_214
 383   2                  ScalerSetByte(P10_4C_PIN_SHARE_CTRLB4__ADION, (BYTE)_GPIO_OPEN_DRAIN); // Pin_215
 384   2                  break;
 385   2      
 386   2              case _DDC3_SWITCH_DDC:
 387   2                  ScalerSetBit(P10_4B_PIN_SHARE_CTRLB3__ADION, ~_BIT7, 0x00); // Pin_214/215, DDC3
 388   2                  break;
 389   2      
 390   2              case _DDC3_SWITCH_GPI:
 391   2                  ScalerSetBit(P10_4B_PIN_SHARE_CTRLB3__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_INPUT))); // Pin_214
 392   2                  ScalerSetByte(P10_4C_PIN_SHARE_CTRLB4__ADION, (BYTE)_GPIO_INPUT); // Pin_215
 393   2                  break;
 394   2      
 395   2              default:
 396   2                  break;
 397   2          }
 398   1      }
