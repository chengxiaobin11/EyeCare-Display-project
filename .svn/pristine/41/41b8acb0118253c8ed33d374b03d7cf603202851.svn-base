  47          
  48          //--------------------------------------------------
  49          // Description  : Set D domain double buffer apply
  50          // Input Value  : DB apply polling/ no polling/ none
  51          // Output Value : None
C51 COMPILER V8.12   RL6449_SERIES_COLORDDOMAINDBAPPLY                                     03/11/2025 19:56:14 PAGE 2   

  52          //--------------------------------------------------
  53          void ScalerColorDDomainDBApply(EnumDBApply enumDBApply)
  54          {
  55   1          if(ScalerGlobalGetIDCode() >= _RL6449_VER_D_ID_CODE)
  56   1          {
  57   2              if(enumDBApply != _DB_APPLY_NONE)
  58   2              {
  59   3                  // Check D domain status
  60   3                  if((ScalerGetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, _BIT0) == 0x00) ||
  61   3                     (GET_DPLL_POWER_STATUS() == _FALSE))
  62   3                  {
  63   4                      return;
  64   4                  }
  65   3              }
  66   2      
  67   2              switch(enumDBApply)
  68   2              {
  69   3                  case _DB_APPLY_NO_POLLING:
  70   3      
  71   3                      // Set D apply bit
  72   3                      ScalerSetBit(P31_B0_D_DB_CTRL0, ~(_BIT6), (_BIT6));
  73   3      
  74   3                      break;
  75   3      
  76   3                  case _DB_APPLY_POLLING:
  77   3      
  78   3                      // Set D apply bit
  79   3                      ScalerSetBit(P31_B0_D_DB_CTRL0, ~(_BIT6), (_BIT6));
  80   3      
  81   3                      if(enumDBApply == _DB_APPLY_POLLING)
  82   3                      {
  83   4                          // Wait D double buffer
  84   4                          ScalerTimerPollingFlagProc(_DOUBLE_BUFFER_WAIT_TIME, P31_B0_D_DB_CTRL0, (_BIT6), 0);
  85   4                      }
  86   3      
  87   3                      break;
  88   3      
  89   3                  default:
  90   3      
  91   3                      break;
  92   3              }
  93   2          }
  94   1      }


