 432          //--------------------------------------------------
 433          // Description  : DP Scramble Setting
 434          // Input Value  : None
 435          // Output Value : None
 436          //--------------------------------------------------
 437          void ScalerDpRx1ScrambleSetting(void)
 438          {
 439   1          BYTE ucBackUp = ScalerGetByte(PBA_D0_AUX_MODE_SET);
 440   1          bit bEnhanceChange = _FALSE;
 441   1          bit bScrambleChange = _FALSE;
 442   1      
 443   1          SET_DP_RX1_AUX_MANUAL_MODE();
 444   1      
 445   1          if((ScalerDpRx1GetDpcdBitInfo(0x00, 0x01, 0x01, _BIT7) == _BIT7) != (ScalerGetBit(PB0_01_PHY_DIG_RESET
             -_CTRL, _BIT2) == _BIT2))
 446   1          {
 447   2              bEnhanceChange = _TRUE;
 448   2      
 449   2              if(ScalerDpRx1GetDpcdBitInfo(0x00, 0x01, 0x01, _BIT7) == _BIT7)
 450   2              {
 451   3                  // Enable Enhancement Control Mode --> MAC
 452   3                  ScalerSetBit(PB0_01_PHY_DIG_RESET_CTRL, ~_BIT2, _BIT2);
 453   3              }
 454   2              else
 455   2              {
 456   3                  // Disable Enhancement Control Mode --> MAC
 457   3                  ScalerSetBit(PB0_01_PHY_DIG_RESET_CTRL, ~_BIT2, 0x00);
 458   3              }
 459   2          }
 460   1      
 461   1          if((ScalerDpRx1GetDpcdBitInfo(0x00, 0x01, 0x02, _BIT5) == _BIT5) != (ScalerGetBit(PB0_07_SCRAMBLE_CTRL
             -, _BIT5) == _BIT5))
 462   1          {
 463   2              bScrambleChange = _TRUE;
 464   2      
 465   2              if(ScalerDpRx1GetDpcdBitInfo(0x00, 0x01, 0x02, _BIT5) == _BIT5)
 466   2              {
 467   3                  // Disable Scrambling
 468   3                  ScalerSetBit(PB0_07_SCRAMBLE_CTRL, ~_BIT5, _BIT5);
 469   3              }
 470   2              else
C51 COMPILER V8.12   SCALERDPRX1_SEPTPHY                                                   01/02/2025 16:30:50 PAGE 9   

 471   2              {
 472   3                  // Enable Scrambling
 473   3                  ScalerSetBit(PB0_07_SCRAMBLE_CTRL, ~_BIT5, 0x00);
 474   3              }
 475   2          }
 476   1      
 477   1          if((bEnhanceChange == _TRUE) || (bScrambleChange == _TRUE))
 478   1          {
 479   2              SET_DP_RX1_AUX_AUTO_MODE();
 480   2      
 481   2              // Delay 2ms for Scramble
 482   2              ScalerTimerDelayXms(2);
 483   2      
 484   2              SET_DP_RX1_AUX_MANUAL_MODE();
 485   2          }
 486   1      
 487   1          if((ucBackUp & _BIT1) == _BIT1)
 488   1          {
 489   2              SET_DP_RX1_AUX_AUTO_MODE();
 490   2          }
 491   1      }
