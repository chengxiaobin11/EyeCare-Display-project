 265          //--------------------------------------------------
 266          // Description  : DP RGB Output Disable
 267          // Input Value  : None
 268          // Output Value : None
 269          //--------------------------------------------------
 270          void ScalerDpRx1AVMute(void)
 271          {
 272   1          if(ScalerGetBit(PB9_3A_DP_IRQ_CTRL0, (_BIT1 | _BIT0)) == (_BIT1 | _BIT0))
 273   1          {
 274   2              // Set free run & force to BG
 275   2              ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~(_BIT5 | _BIT3), _BIT5);
 276   2          }
 277   1      
 278   1          // Disable fifo overflwo/ underflwo IRQ
 279   1          ScalerSetBit(PB9_3A_DP_IRQ_CTRL0, ~(_BIT1 | _BIT0), 0x00);
 280   1      
 281   1          // Disable RGB Output
 282   1          ScalerSetBit(PB8_31_DP_OUTPUT_CTRL, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
 283   1      
 284   1      #if(_AUDIO_SUPPORT == _ON)
 285   1          // Disable Audio Channel
 286   1          ScalerAudioDpAudioEnable(_DISABLE, _D1_INPUT_PORT);
 287   1      #endif
 288   1      }
