             -SUPPORT() << 1) | _BIT0));
              #else
                      // Enable HDCP and repeater support
                      ScalerDpRx1SetDpcdValue(0x06, 0x80, 0x28, 0x03);
              #endif
              #else
2491   2              // Enable HDCP support
2492   2              ScalerDpRx1SetDpcdValue(0x06, 0x80, 0x28, 0x01);
