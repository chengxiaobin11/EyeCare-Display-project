5504   1          // 2% Tolerance
5505   1          if((ABSDWORD(PDATA_WORD(2), usVTotalCount)) > (usVTotalCount * 2 / 100))
5506   1          {
5507   2              return _FALSE;
5508   2          }
5509   1      
5510   1          return _TRUE;
5511   1      }
