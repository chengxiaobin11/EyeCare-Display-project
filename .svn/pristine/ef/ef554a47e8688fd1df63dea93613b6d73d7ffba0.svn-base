 627          //--------------------------------------------------
 628          void ScalerDpRx1CrcCalculate(void)
 629          {
 630   1          if(GET_DP_RX1_CRC_CALCULATE() == _TRUE)
 631   1          {
 632   2              DebugMessageRx1("7. DP CRC Test Start", 0);
 633   2      
 634   2              if(GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR422)
 635   2              {
 636   3                  ScalerSetBit(PB8_70_DP_CRC_CTRL, ~_BIT4, _BIT4);
 637   3              }
C51 COMPILER V8.12   SCALERDPRX1_SEPTPHY                                                   01/02/2025 16:30:50 PAGE 12  

 638   2              else
 639   2              {
 640   3                  ScalerSetBit(PB8_70_DP_CRC_CTRL, ~_BIT4, 0x00);
 641   3              }
 642   2      
 643   2              // Start CRC Calculation
 644   2              ScalerSetBit(PB8_70_DP_CRC_CTRL, ~_BIT7, _BIT7);
 645   2      
 646   2              if((ScalerTimerPollingFlagProc(_DP_MEASURE_POLLING_TIMEOUT, PB8_70_DP_CRC_CTRL, _BIT6, _TRUE) && (
             -ScalerDpRx1FifoCheck(_DP_FIFO_POLLING_CHECK))) == _TRUE)
 647   2              {
 648   3                  ScalerDpRx1SetDpcdValue(0x00, 0x02, 0x40, ScalerGetByte(PB8_72_DP_CRC_R_L));
 649   3                  ScalerDpRx1SetDpcdValue(0x00, 0x02, 0x41, ScalerGetByte(PB8_71_DP_CRC_R_M));
 650   3                  ScalerDpRx1SetDpcdValue(0x00, 0x02, 0x42, ScalerGetByte(PB8_74_DP_CRC_G_L));
 651   3                  ScalerDpRx1SetDpcdValue(0x00, 0x02, 0x43, ScalerGetByte(PB8_73_DP_CRC_G_M));
 652   3                  ScalerDpRx1SetDpcdValue(0x00, 0x02, 0x44, ScalerGetByte(PB8_76_DP_CRC_B_L));
 653   3                  ScalerDpRx1SetDpcdValue(0x00, 0x02, 0x45, ScalerGetByte(PB8_75_DP_CRC_B_M));
 654   3      
 655   3                  CLR_DP_RX1_CRC_CALCULATE();
 656   3      
 657   3                  // Update _TEST_CRC_COUNT
 658   3                  ScalerDpRx1SetDpcdValue(0x00, 0x02, 0x46, 0x21);
 659   3              }
 660   2      
 661   2              // Stop CRC Calculation
 662   2              ScalerSetBit(PB8_70_DP_CRC_CTRL, ~_BIT7, 0x00);
 663   2          }
 664   1      }
