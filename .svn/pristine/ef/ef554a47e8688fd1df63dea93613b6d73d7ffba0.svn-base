                          ScalerDpRx1SetDpcdValue(0x06, 0x80, (0x14 + (pData[0] * 4) + pData[1]), ScalerGetByte(PB0_39_S
             -HA_3 + (pData[0] * 4) - pData[1]));
                      }
                  }
              
                  SET_DP_RX1_AUX_AUTO_MODE();
              }
