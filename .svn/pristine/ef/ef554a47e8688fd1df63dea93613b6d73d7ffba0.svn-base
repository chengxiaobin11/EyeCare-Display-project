 289          //--------------------------------------------------
 290          // Description  : DP Adjust Vsync Delay
 291          // Input Value  : None
 292          // Output Value : None
 293          //--------------------------------------------------
 294          void ScalerDpRx1AdjustVsyncDelay(void)
 295          {
 296   1          DWORD ulBStoVSDelayDeltaOverflow = 0;
 297   1          DWORD ulBStoVSDelayDeltaUnderflow = 0;
 298   1      
 299   1          if(ScalerGetBit(PB8_21_PG_CTRL_1, (_BIT1 | _BIT0)) == 0x00)// Fifo Ok
 300   1          {
 301   2              return;
 302   2          }
 303   1          else if(ScalerGetBit(PB8_21_PG_CTRL_1, _BIT0) == _BIT0) // Fifo Overflow
 304   1          {
 305   2              // Get Htotal
 306   2              ScalerRead(PB9_08_MSA_HTT_0, 2, &pData[0], _AUTOINC);
 307   2      
 308   2              // ((Link Clk * 256)/ Stream CLK) * Htotal / 256 --> 1 Line
 309   2              ulBStoVSDelayDeltaOverflow = (((DWORD)ScalerDpRx1GetDpcdInfo(0x00, 0x01, 0x00) * 270UL) * 256) / (
             -(DWORD)GET_INPUT_PIXEL_CLK()) * ((DWORD)PDATA_WORD(0)) / 256;
 310   2      
 311   2              DebugMessageRx1("7. Fifo Overflow --> nVidia Case", ulBStoVSDelayDeltaOverflow);
 312   2          }
 313   1          else if(ScalerGetBit(PB8_21_PG_CTRL_1, _BIT1) == _BIT1) // Fifo Underflow
 314   1          {
 315   2              // Get Hactive
 316   2              ScalerRead(PB9_0C_MSA_HWD_0, 2, &pData[0], _AUTOINC);
 317   2      
 318   2              if(PDATA_WORD(0) != 1366)
 319   2              {
 320   3                  return;
 321   3              }
 322   2      
 323   2              PDATA_WORD(0) = PDATA_WORD(0) - 2;
 324   2      
 325   2              // Set Hactive
 326   2              ScalerSetByte(PB8_45_MN_DPF_HWD_M, pData[0]);
 327   2              ScalerSetByte(PB8_46_MN_DPF_HWD_L, pData[1]);
 328   2      
 329   2              // ((Link Clk * 2)/ Stream CLK) --> 2 pixels
 330   2              ulBStoVSDelayDeltaUnderflow = (((DWORD)ScalerDpRx1GetDpcdInfo(0x00, 0x01, 0x00) * 270) * 2) / ((DW
             -ORD)GET_INPUT_PIXEL_CLK());
 331   2      
 332   2              DebugMessageRx1("7. Fifo Underflow --> QD882 Case", ulBStoVSDelayDeltaUnderflow);
 333   2          }
 334   1      
 335   1          // For Initial Value Before Use PDATA_DWORD(0)
 336   1          pData[0] = 0;
 337   1      
 338   1          // Get BStoVSDelay Even
 339   1          ScalerRead(PB8_32_EVBLK2VS_H, 3, &pData[1], _AUTOINC);
 340   1      
 341   1          // For Initial Value Before Use PDATA_DWORD(1)
 342   1          pData[4] = 0;
 343   1      
 344   1          // Get BStoVSDelay Odd
 345   1          ScalerRead(PB8_35_OVBLK2VS_H, 3, &pData[5], _AUTOINC);
 346   1      
 347   1          // BStoVSDelay = BStoVSDelay + (Nvid * 256 / Mvid) * ((DWORD)Htotal) / 256;
 348   1          PDATA_DWORD(0) = PDATA_DWORD(0) - ((ulBStoVSDelayDeltaOverflow + ulBStoVSDelayDeltaUnderflow) / 2);
C51 COMPILER V8.12   SCALERDPRX1_SEPTPHY                                                   01/02/2025 16:30:50 PAGE 7   

 349   1      
 350   1          // BStoVSDelay = BStoVSDelay + (Nvid * 256 / Mvid) * ((DWORD)Htotal) / 256;
 351   1          PDATA_DWORD(1) = PDATA_DWORD(1) - ((ulBStoVSDelayDeltaOverflow + ulBStoVSDelayDeltaUnderflow) / 2);
 352   1      
 353   1          // Set Even Field BS to VS Delay
 354   1          ScalerSetByte(PB8_32_EVBLK2VS_H, pData[1]);
 355   1          ScalerSetByte(PB8_33_EVBLK2VS_M, pData[2]);
 356   1          ScalerSetByte(PB8_34_EVBLK2VS_L, pData[3]);
 357   1      
 358   1          // Set Odd Field BS to VS Delay
 359   1          ScalerSetByte(PB8_35_OVBLK2VS_H, pData[5]);
 360   1          ScalerSetByte(PB8_36_OVBLK2VS_M, pData[6]);
 361   1          ScalerSetByte(PB8_37_OVBLK2VS_L, pData[7]);
 362   1      
 363   1          // Enable Double Buffer
 364   1          ScalerSetBit(PB8_30_DPF_CTRL_0, ~_BIT6, _BIT6);
 365   1      
 366   1          // Reset Display Format Gen
 367   1          ScalerSetBit(PB8_30_DPF_CTRL_0, ~_BIT7, 0x00);
 368   1          ScalerSetBit(PB8_30_DPF_CTRL_0, ~_BIT7, _BIT7);
 369   1      
 370   1          // Polling Vertical BS
 371   1          if(ScalerDpRx1PollingFlagLinkCheck(50, PB9_01_DP_VBID, _BIT0, _TRUE) == _FALSE)
 372   1          {
 373   2              return;
 374   2          }
 375   1      
 376   1          // Delay for PG Stable
 377   1          if(ScalerDpRx1TimerDelayXmsLinkCheck(_DP_ONE_FRAME_TIME_MAX) == _FALSE)
 378   1          {
 379   2              return;
 380   2          }
 381   1      }
 382          //--------------------------------------------------
 383          // Description  : Check Valid Lane Alignment
 384          // Input Value  : None
 385          // Output Value : True --> Align
 386          //--------------------------------------------------
 387          bit ScalerDpRx1AlignCheck(void)
 388          {
 389   1      #if(_DP_ILLEGAL_IDLE_PATTERN_CHECK_SUPPORT == _ON)
              
                  if(GET_DP_ILLEGAL_IDLE_PATTERN_CHECK() == _TRUE)
                  {
                      if(GET_DP_RX1_SOURCE_TYPE_JUDGE() == _FALSE)
                      {
              #if(_HW_DP_LANE_VALID_CHECK_SUPPORT == _ON)
                          if(ScalerDpRx1LaneValidCheck() == _FALSE)
                          {
                              return _TRUE;
                          }
              #else
                          return _TRUE;
              #endif
                      }
                  }
              
              #endif
 407   1      
 408   1          if((ScalerDpRx1GetDpcdInfo(0x00, 0x01, 0x01) & 0x1F) == _DP_ONE_LANE)
 409   1          {
 410   2              return _TRUE;
C51 COMPILER V8.12   SCALERDPRX1_SEPTPHY                                                   01/02/2025 16:30:50 PAGE 8   

 411   2          }
 412   1          else
 413   1          {
 414   2              if(ScalerGetBit(PB0_0E_DESKEW_PHY, _BIT4) == 0x00)
 415   2              {
 416   3                  if(ScalerGetBit(PB0_0E_DESKEW_PHY, (_BIT7 | _BIT6)) != (_BIT7 | _BIT6))
 417   3                  {
 418   4                      ScalerSetBit(PB0_0E_DESKEW_PHY, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 419   4      
 420   4                      ScalerTimerDelayXms(3);
 421   4                  }
 422   3                  else
