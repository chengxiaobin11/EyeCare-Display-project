              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerDpRx1HDCPLoadShaToDpcd(void)
              {
                  SET_DP_RX1_AUX_MANUAL_MODE();
              
                  for(pData[0] = 0; pData[0] < 5; pData[0]++)
                  {
                      for(pData[1] = 0; pData[1] < 4; pData[1]++)
