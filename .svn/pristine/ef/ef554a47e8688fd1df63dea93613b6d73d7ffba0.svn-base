2469   1          {
2470   2              // Clear flag for write 68xxx int
2471   2              ScalerSetBit(PBA_DA_AUX_FIFO_RST, ~_BIT1, _BIT1);
2472   2      
2473   2              // Enable Write 68xxx int
2474   2              ScalerSetBit(PBA_DA_AUX_FIFO_RST, ~_BIT2, _BIT2);
2475   2      
2476   2      #if((_DP_TX_SUPPORT == _ON) && (_D1_DP_MST_PORT_SUPPORT == _ON))
                      // Clear flag for Write AKSV int
                      ScalerSetBit(PBA_A5_AUX_RESERVE5, ~(_BIT2 | _BIT1 | _BIT0), _BIT2);
              
                      // Enable Write AKSV int
                      ScalerSetBit(PBA_A5_AUX_RESERVE5, ~_BIT6, _BIT6);
              
              #if(_DP_HDCP14_REPEATER_BIT_DISABLE_FOR_TX_CLONE_OFF == _ON)
                      // Enable Hdcp Repeater, _BIT1: Repeater,  _BIT0: HDCP Capable
