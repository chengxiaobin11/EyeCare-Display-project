5449   2              {
5450   3                  PDATA_WORD(0) = 0x4E20;
5451   3              }
5452   2              else if(ScalerDpRx1GetDpcdInfo(0x00, 0x01, 0x00) == _DP_LINK_HBR)
5453   2              {
5454   3                  PDATA_WORD(0) = 0x2710;
5455   3              }
