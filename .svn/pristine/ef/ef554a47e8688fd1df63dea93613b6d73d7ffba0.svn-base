                  if(ScalerDpRx1MstToSstFifoCheck(_DP_FIFO_POLLING_CHECK) == _FALSE)
                  {
                      return _FALSE;
                  }
              
                  if(ScalerDpRx1MstToSstMSAActiveChange() == _TRUE)
                  {
                      return _FALSE;
                  }
              
                  if(ScalerDpRxMstToSstTxMeasureTimingChange() == _TRUE)
                  {
