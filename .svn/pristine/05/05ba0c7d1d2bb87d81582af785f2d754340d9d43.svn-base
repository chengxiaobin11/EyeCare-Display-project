 590   1      
 591   1          switch(ucResetTarget)
 592   1          {
 593   2              case _MODE_ACTION_RESET_TO_SEARCH:
 594   2      
 595   2                  // User Reset Process
 596   2                  UserCommonInterfaceOsdResetProc();
 597   2      
