 805          void SysModeColorSpaceConvert(EnumColorSpace enumColorFormat, EnumDBApply enumDBApply)
 806          {
 807   1          enumDBApply = enumDBApply;
 808   1          enumColorFormat = enumColorFormat;
 809   1      
 810   1      #if(_VGA_SUPPORT == _ON)
                  if(GET_SOURCE_TYPE(g_ucSearchIndex) == _SOURCE_VGA)
                  {
                      ScalerADCClampMode(enumColorFormat);
              
                      // Download adc data from NVRam
                      UserCommonNVRamLoadADCSetting(enumColorFormat);
              
                      // Gain Offset Adjust.
                      UserCommonInterfaceAdjustADCData();
                  }
              #endif
 822   1      
 823   1      #if((_DVI_SUPPORT == _ON) && (_UNDERSCAN_SUPPORT == _ON))
 824   1          if(GET_SOURCE_TYPE(g_ucSearchIndex) == _SOURCE_DVI)
 825   1          {
 826   2              // Adjust porch color for DVI
 827   2              ScalerTMDSSetPorchColor(SysSourceGetInputPort(), enumColorFormat);
 828   2          }
 829   1      #endif
 830   1      
 831   1      #if(_COLOR_IP_COLOR_CONVERT == _ON)
 832   1          // Wait for D-domain DB apply ready
 833   1          ScalerColorWaitDDomainDBApply();
 834   1      
 835   1      #if((_M_DOMAIN_FORCE_YUV_FORMAT == _ON) || (_GLOBAL_COLOR_CONVERT_HUE_SATURATION_FUNCTION == _ON))
                  ScalerColorMdomainForceYUV(enumColorFormat, enumDBApply);
              #elif(_ULTRA_VIVID_SUPPORT == _ON)
 838   1          ScalerColorSpaceConvertUltraVividSupport(enumColorFormat, enumDBApply);
 839   1      #else
                  ScalerColorSpaceConvert(enumColorFormat, enumDBApply);
              #endif
 842   1      #endif // End of #if(_COLOR_IP_COLOR_CONVERT == _ON)
 843   1      }
