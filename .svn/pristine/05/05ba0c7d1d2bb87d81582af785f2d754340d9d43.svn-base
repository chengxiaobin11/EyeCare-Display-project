 615   2                  ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_JUDGE_ACTIVE_STATE);
 616   2                  ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_JUDGE_NOSIGNAL_STATE);
 617   2                  ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_JUDGE_NOSUPPORT_STATE);
 618   2      
 619   2                  break;
 620   2      
 621   2              case _MODE_ACTION_RESET_TO_DISPLAY_SETTING_WITHOUT_FORCETOBG:
 622   2              case _MODE_ACTION_RESET_TO_DISPLAY_SETTING:
 623   2      
 624   2                  if(GET_MODE_STATE() != _MODE_STATUS_ACTIVE)
 625   2                  {
 626   3                      // User Reset Process
 627   3                      UserCommonInterfaceOsdResetProc();
 628   3                  }
 629   2      
 630   2                  // Clear M Domain Ready Flag
 631   2                  CLR_MODE_DISPLAY_SETTING_READY();
 632   2      
 633   2                  // Set No Wait For Active Flag
 634   2                  SET_MODE_NO_WAIT_FOR_ACTIVE();
 635   2      
 636   2                  // Clear Mode Active Ready Flag
 637   2                  CLR_MODE_ACTIVE_READY();
 638   2      
 639   2                  break;
 640   2      
 641   2              case _MODE_ACTION_RESET_TO_NOSUPPORT:
 642   2      
 643   2                  if(GET_MODE_STATE() == _MODE_STATUS_DISPLAY_SETTING)
 644   2                  {
 645   3                      // Clear M Domain Ready Flag
 646   3                      CLR_MODE_DISPLAY_SETTING_READY();
 647   3      
 648   3                      SysModeSetFreeRun();
 649   3                  }
 650   2      
 651   2                  break;
 652   2      
 653   2              case _MODE_ACTION_RESET_TO_POWER_SAVING:
 654   2      
 655   2                  // User Reset Process
 656   2                  UserCommonInterfaceOsdResetProc();
 657   2      
 658   2                  // Clear Source Ready Flag
 659   2                  SET_SOURCE_TYPE(g_ucSearchIndex, _SOURCE_NONE);
 660   2      
C51 COMPILER V9.60.0.0   SYSMODE                                                           09/09/2025 18:16:13 PAGE 12  

 661   2                  // Clear Source Judge
 662   2                  CLR_SOURCE_JUDGE(g_ucSearchIndex);
 663   2      
 664   2      #if(_SOURCE_BACKGROUND_DETECT_SUPPORT == _ON)
                          CLR_SOURCE_BG_JUDGE(g_ucBgDetectIndex);
              #endif
 667   2      
 668   2                  // Clear Measure Ready Flag
 669   2                  CLR_MODE_TIMING_CONFIRM();
 670   2      
 671   2                  // Clear M Domain Ready Flag
 672   2                  CLR_MODE_DISPLAY_SETTING_READY();
 673   2      
 674   2                  // Clear No Wait For Active Flag
 675   2                  CLR_MODE_NO_WAIT_FOR_ACTIVE();
 676   2      
 677   2                  // Clear Mode Active Ready Flag
