 697          void RTDFactoryMenuOperation(void)
 698          {
 699   1          if((GET_OSD_STATE() >= _MENU_FACTORY_AUTOCOLOR) &&
 700   1             (GET_OSD_STATE() < _MENU_FACTORY_OSD_END) &&
 701   1             (GET_KEYMESSAGE() <_KEY_AMOUNT))
 702   1          {  
 703   2              DebugMessageOsd("My_KEY",GET_KEYMESSAGE());
 704   2      
 705   2                      if(GET_KEYMESSAGE()==_UP_KEY_MESSAGE)
 706   2              (*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][2])();
 707   2                      else if(GET_KEYMESSAGE()==_DOWN_KEY_MESSAGE)
 708   2                      (*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][1])();       
 709   2                      else if(GET_KEYMESSAGE()==_LEFT_KEY_MESSAGE)
 710   2              (*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][3])();
 711   2                      else if((GET_KEYMESSAGE()==_RIGHT_KEY_MESSAGE))
 712   2                   (*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][0])();
 713   2      
 714   2      
 715   2          }
 716   1      }
