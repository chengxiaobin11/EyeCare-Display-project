3902          #if(_DEF_INDICATO_LIGHT_Flick_EANBLE)
              
              
              void IndicatoLlghtFlickerEvent(void)
              {
                      if(GET_OSD_BURNING_MODE()) // łČŔ¶ÉÁË¸
                      {
              
                              if((bLED1 == _LED_OFF) && (bLED2 == _LED_ON))
                              {
                                      bLED1=_LED_ON;
                                      bLED2=_LED_OFF;
                              }
                              else
                              {
                                      bLED1=_LED_OFF;
                                      bLED2=_LED_ON;
                              }
              
                      }
                      else    // łČµĆÉÁË¸ 
                      {
                      
                              if((bLED1 == _LED_OFF) && (bLED2 == _LED_OFF))
                              {
                                      bLED1=_LED_ON;
                              bLED2=_LED_OFF;
                              }
                              else
                              {
                                      bLED1=_LED_OFF;
                              bLED2=_LED_OFF;
                              }
              
                      }
              
              
                      ScalerTimerActiveTimerEvent(SEC(1), _USER_TIMER_EVENT_OSD_INDICATO_LIGHT_FACTORY_FLICKER);
              }
              
              #endif


