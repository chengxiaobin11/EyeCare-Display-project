              void GetOSDEDIDResult(BYTE *pDDCRAMData,BYTE PortType)
              {
                BYTE index=0;
                BYTE CheckSum=0;
                
                for(index=0;index<127;index++)
                {
                  CheckSum+=pDDCRAMData[index];
                }
              
                CheckSum = ~CheckSum +1;
                
                if(PortType==_PORT_VGA)//VGA
                {
                  if ((pDDCRAMData[127] == CheckSum)&&((pDDCRAMData[0x14]&0x80)==0))//&&(( _PANEL_DH_WIDTH == Hactive||(_P
             -ANEL_DH_WIDTH == (Hactive+6))) && ( _PANEL_DV_HEIGHT== Vactive)))
                  {
                    pData[0]=_O__;
                    pData[1]=_K__;
                    pData[2]=_END_;
                  }
                  else
                  {
                    pData[0]=_N__;
                    pData[1]=_G__;
                    pData[2]=_END_;
                  }
                }
                else if((PortType==_PORT_DVI)||(PortType==_PORT_DUAL_DVI))//Digital Port
                {
                  if ((pDDCRAMData[127] == CheckSum)&&((pDDCRAMData[0x14]&0x80)==0x80))//&&(( _PANEL_DH_WIDTH == Hactive||
             -(_PANEL_DH_WIDTH == (Hactive+6))) && ( _PANEL_DV_HEIGHT== Vactive)))
                  {
                    pData[0]=_O__;
                    pData[1]=_K__;
                    pData[2]=_END_;
                  }
                  else
C51 COMPILER V9.60.0.0   RTDFACTORYFUNCTION                                                09/09/2025 18:05:01 PAGE 76  

                  {
                    pData[0]=_N__;
                    pData[1]=_G__;
                    pData[2]=_END_;
                  }
              
                }
                else if((PortType==_PORT_HDMI)||(PortType==_PORT_HDMI20)||(PortType==_PORT_DP))//Digital Port
                {
                  if ((pDDCRAMData[127] == CheckSum)&&(pDDCRAMData[126] == 0x01)&&((pDDCRAMData[0x14]&0x80)==0x80)&&(( _PA
             -NEL_DH_WIDTH == Hactive||(_PANEL_DH_WIDTH == (Hactive+6))) && ( _PANEL_DV_HEIGHT== Vactive)))
                  {
                    pData[0]=_O__;
                    pData[1]=_K__;
                    pData[2]=_END_;
                  }
                  #if(_DEF_GAME_MODE)
                  if ((pDDCRAMData[127] == CheckSum)&&(pDDCRAMData[126] == 0x01)&&(GET_OSD_OVERCLOCK()==_ON))
                    {
