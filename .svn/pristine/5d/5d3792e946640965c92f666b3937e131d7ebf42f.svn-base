5311          void RTDFactoryOsdFuncShowChecksum(BYTE ucRow, BYTE ucCol, BYTE ucPar ,BYTE ucFontPoint)
5312          {
5313   1            BYTE h,l,t,h1,l1;
5314   1            BYTE idata ucIndex = 0;
5315   1            BYTE idata ucTemp = 0;
5316   1            BYTE idata i = 0;
5317   1            // BYTE xdata pData[7] = {0};
5318   1            WORD usValue =  0;
5319   1            UserCommonFlashRead(1, 0xfffe, 2, (BYTE *)&usValue);
5320   1            ucPar= ucPar;
5321   1      
5322   1            pData[0]=_0__;
5323   1            pData[1]=_0__;
5324   1      
5325   1            t =(usValue & 0x0f);
5326   1            if(t < 10)
5327   1            l = t +_0__;
5328   1            else
5329   1            l = t -10+ _A__;
5330   1      
5331   1            t = (usValue >> 4) & 0x0f;
5332   1            if(t < 10)
5333   1            h = t +_0__;
5334   1            else
5335   1            h = t -10+_A__;
5336   1      
5337   1            t = (usValue >> 8) & 0x0f;
5338   1            if(t < 10)
5339   1            l1 = t +_0__;
5340   1            else
5341   1            l1 = t -10+_A__;
5342   1      
5343   1            t = (usValue >> 12) & 0x0f;
5344   1            if(t < 10)
5345   1            h1 = t +_0__;
5346   1            else
5347   1            h1 = t -10+_A__;
5348   1      
5349   1            pData[3]=l ;
5350   1            pData[2]=h;
5351   1            pData[1]=l1 ;
5352   1            pData[0]=h1 ;
5353   1      
5354   1            pData[4] = _END_;
5355   1      
5356   1            RTDFactoryOsdFuncPutStringProp(ucRow, ucCol, ucFontPoint, tFONT_FACTORY_EUROPE, pData, _ENGLISH); 
5357   1      
5358   1             
5359   1      }
