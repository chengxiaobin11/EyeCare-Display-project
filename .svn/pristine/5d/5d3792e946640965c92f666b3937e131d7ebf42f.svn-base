                  pData[1]=Hactive/100+_0__;
                  pData[2]=(Hactive%100)/10+_0__;
                  pData[3]=Hactive%10+_0__;
                }
                else
                {
                  pData[0]=Hactive/1000+_0__;
                  pData[1]=(Hactive%1000)/100+_0__;
                  pData[2]=(Hactive%100)/10+_0__;
                  pData[3]=Hactive%10+_0__;
                }
                
                pData[4]=_X__;
                 
                if (Vactive<1000)
                {
                  pData[5]=Vactive/100+_0__;
