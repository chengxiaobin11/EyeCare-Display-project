                  V_Low8 = pDDCRAMData[0x43];
                
                  H_high4 = pDDCRAMData[0x44]>>4;
                  V_high4 = pDDCRAMData[0x44]&0x0F;
                  
                  Hor = ((H_high4 << 8) + H_Low8);
                  Ver = ((V_high4 << 8) + V_Low8);
                
