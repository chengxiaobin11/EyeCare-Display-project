C51 COMPILER V8.12   RL6449_SERIES_COLORPCMOUTPUTGAMMAADJUST                               03/11/2025 19:56:08 PAGE 2   

  52          //--------------------------------------------------
  53          // Description  : Adjust output gamma for PCM
  54          // Input Value  : Gamma table type and gamma tables banks and Latch&Sram Length
  55          // Output Value : None
  56          //--------------------------------------------------
  57          void ScalerColorPCMOutputGammaAdjust(BYTE *pucGammaTableArray, BYTE ucBankNum)
  58          {
  59   1          WORD usTotalLength = _PCM_OUTPUTGAMMA_LATCH_TABLE_SIZE + _PCM_OUTPUTGAMMA_SRAM_TABLE_SIZE;
  60   1      
  61   1          // Load gamma table of R Channel
  62   1          ScalerColorOutputGammaChannelCtrl(_GAMMA_RED_CHANNEL, 0x00, _GAMMA_WRITE_TO_LATCH);
  63   1          ScalerBurstWrite(pucGammaTableArray, _PCM_OUTPUTGAMMA_LATCH_TABLE_SIZE, ucBankNum, P0_66_GAMMA_PORT_SE
             -TA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  64   1      
  65   1          ScalerColorOutputGammaChannelCtrl(_GAMMA_RED_CHANNEL, 0x00, _GAMMA_WRITE_TO_SRAM);
  66   1          ScalerBurstWrite(pucGammaTableArray + _PCM_OUTPUTGAMMA_LATCH_TABLE_SIZE, _PCM_OUTPUTGAMMA_SRAM_TABLE_S
             -IZE, ucBankNum, P0_66_GAMMA_PORT_SETA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  67   1      
  68   1          // Load gamma table of G Channel
  69   1          ScalerColorOutputGammaChannelCtrl(_GAMMA_GREEN_CHANNEL, 0x00, _GAMMA_WRITE_TO_LATCH);
  70   1          ScalerBurstWrite(pucGammaTableArray + usTotalLength, _PCM_OUTPUTGAMMA_LATCH_TABLE_SIZE, ucBankNum, P0_
             -66_GAMMA_PORT_SETA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  71   1      
  72   1          ScalerColorOutputGammaChannelCtrl(_GAMMA_GREEN_CHANNEL, 0x00, _GAMMA_WRITE_TO_SRAM);
  73   1          ScalerBurstWrite(pucGammaTableArray + usTotalLength + _PCM_OUTPUTGAMMA_LATCH_TABLE_SIZE, _PCM_OUTPUTGA
             -MMA_SRAM_TABLE_SIZE, ucBankNum, P0_66_GAMMA_PORT_SETA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  74   1      
  75   1          // Load gamma table of B Channel
  76   1          ScalerColorOutputGammaChannelCtrl(_GAMMA_BLUE_CHANNEL, 0x00, _GAMMA_WRITE_TO_LATCH);
  77   1          ScalerBurstWrite(pucGammaTableArray + usTotalLength * 2, _PCM_OUTPUTGAMMA_LATCH_TABLE_SIZE, ucBankNum,
             - P0_66_GAMMA_PORT_SETA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  78   1      
  79   1          ScalerColorOutputGammaChannelCtrl(_GAMMA_BLUE_CHANNEL, 0x00, _GAMMA_WRITE_TO_SRAM);
  80   1          ScalerBurstWrite(pucGammaTableArray + usTotalLength * 2 + _PCM_OUTPUTGAMMA_LATCH_TABLE_SIZE, _PCM_OUTP
             -UTGAMMA_SRAM_TABLE_SIZE, ucBankNum, P0_66_GAMMA_PORT_SETA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  81   1      
  82   1          // Disable Port Access
  83   1          ScalerSetBit(P0_67_GAMMA_CTRL_SETA, ~_BIT7, 0x00);
  84   1      }
  85          


