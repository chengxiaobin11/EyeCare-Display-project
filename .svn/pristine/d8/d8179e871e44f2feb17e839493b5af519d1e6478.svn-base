  52          void ScalerColorIDitherEnable(EnumFunctionOnOFF enumOn)
  53          {
  54   1          if(enumOn == _FUNCTION_ON)
  55   1          {
  56   2              ScalerSetBit(P0_1F_M1_ICLK_GATED_CTRL1, ~_BIT5, _BIT5);
  57   2              ScalerSetBit(P0_89_I_DITHER_COMMON_CTRL1_SETA, ~_BIT5, _BIT5);
  58   2          }
  59   1          else if(enumOn == _FUNCTION_OFF)
  60   1          {
  61   2              ScalerSetBit(P0_89_I_DITHER_COMMON_CTRL1_SETA, ~_BIT5, 0x00);
  62   2          }
  63   1          else // GATED
  64   1          {
  65   2              ScalerSetBit(P0_89_I_DITHER_COMMON_CTRL1_SETA, ~_BIT5, 0x00);
  66   2              ScalerTimerDelayXms(2);
  67   2              ScalerTimerWaitForEvent(_EVENT_IVS);
  68   2              ScalerSetBit(P0_1F_M1_ICLK_GATED_CTRL1, ~_BIT5, 0x00);
  69   2          }
  70   1      }


