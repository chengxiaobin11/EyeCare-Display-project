 248   1          EnumAutoResult (*pucFunctionCompensate)(EnumAutoColorType);
 249   1      
 250   1          // Select functions to update gain & compensate
 251   1          switch(enumAutoType)
 252   1          {
 253   2      #if((_YPBPR_SUPPORT == _ON) && (_YPBPR_AUTO_METHOD == _YPBPR_AUTO_BY_SOURCE))
 254   2              case _AUTO_TUNE_YPBPR:
 255   2                  pucFunctionUpdateGain = &ScalerAutoUpdateAdcGain;
 256   2                  pucFunctionCompensate = &ScalerAutoCompensateYPbPr;
 257   2                  break;
 258   2      
 259   2              case _AUTO_TUNE_YPBPR_GAIN_ONLY:
 260   2                  pucFunctionUpdateGain = &ScalerAutoUpdateAdcGainOnly;
 261   2                  pucFunctionCompensate = &ScalerAutoCompensateYPbPr;
 262   2                  break;
 263   2      #endif
 264   2      #if(_ADC_SELF_CALIBRATION == _ON)
 265   2              case _AUTO_CALIBRATE_RGB:
 266   2                  pucFunctionUpdateGain = &ScalerAutoUpdateAdcGainCalibrationRGB;
 267   2                  pucFunctionCompensate = &ScalerAutoCompensateCalibrationRGB;
 268   2                  break;
 269   2      #endif
 270   2      
 271   2              case _AUTO_TUNE_RGB_KNOWNWHITE:
 272   2                  pucFunctionUpdateGain = &ScalerAutoCustomUpdateAdcGain;
 273   2                  pucFunctionCompensate = &ScalerAutoCompensateRGB;
 274   2                  break;
 275   2      
 276   2              case _AUTO_TUNE_RGB:
 277   2                  pucFunctionUpdateGain = &ScalerAutoUpdateAdcGain;
 278   2                  pucFunctionCompensate = &ScalerAutoCompensateRGB;
 279   2                  break;
 280   2      
 281   2              case _AUTO_TUNE_RGB_GAIN_ONLY:
 282   2                  pucFunctionUpdateGain = &ScalerAutoUpdateAdcGainOnly;
 283   2                  pucFunctionCompensate = &ScalerAutoCompensateRGB;
 284   2                  break;
 285   2      
 286   2              default:
