 289   1      
 290   1          for(ucIndex = 0; ucIndex < _AUTO_COLOR_END; ++ucIndex)
 291   1          {
 292   2              if((enumAutoType != _AUTO_TUNE_RGB_GAIN_ONLY) &&
 293   2                 (enumAutoType != _AUTO_TUNE_YPBPR_GAIN_ONLY))
 294   2              {
 295   3                  // Adjust offset by ABL
 296   3                  if(ScalerAutoHardwareAbl(ucTarget, ucABLFrame) == _AUTO_FAIL)
 297   3                  {
 298   4                      return _AUTO_FAIL;
 299   4                  }
 300   3              }
 301   2      
 302   2              // Adjust gain by auto-function
 303   2              if(pucFunctionUpdateGain(ucGainBias, ucStepRatio) == _AUTO_FAIL)
 304   2              {
 305   3                  return _AUTO_FAIL;
 306   3              }
 307   2      
 308   2              // Auto-tuning process control
 309   2              switch(ucIndex)
 310   2              {
 311   3                  case _AUTO_COLOR_TUNING:
 312   3                      if(enumAutoType != _AUTO_TUNE_YPBPR)
 313   3                      {
 314   4                          ucTarget = 4;
 315   4                      }
 316   3                      ucGainBias = 3;
 317   3                      ucABLFrame = ((enumAutoType == _AUTO_CALIBRATE_RGB) ? 2 : 1);
 318   3                      break;
 319   3      
 320   3                  case _AUTO_COLOR_STAGE1:
 321   3                  case _AUTO_COLOR_STAGE2:
 322   3                      // Do nothing
 323   3                      break;
 324   3      
 325   3                  case _AUTO_COLOR_COMPENSTE:
 326   3                  default:
 327   3                      if(pucFunctionCompensate(enumAutoType) == _AUTO_FAIL)
 328   3                      {
 329   4                          return _AUTO_FAIL;
 330   4                      }
 331   3                      break;
 332   3              }
 333   2          }
 334   1      
 335   1          return _AUTO_SUCCESS;
 336   1      }
