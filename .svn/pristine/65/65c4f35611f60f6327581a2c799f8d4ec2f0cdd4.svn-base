 228   1          ScalerSetBit(P0_48_SYNC_INVERT, ~_BIT2, 0x00);
 229   1          ScalerSetDataPortByte(P0_5C_SYNC_PROC_PORT_ADDR, _P0_5D_PT_01_G_CLAMP_END, ucClampEnd);
 230   1          ScalerSetBit(P0_48_SYNC_INVERT, ~_BIT2, _BIT2);
