 343          void ScalerAutoInitializeAutoColor(EnumAutoColorType enumAutoType)
 344          {
 345   1          BYTE ucClampEnd = 0;
 346   1      
 347   1      #if(_ADC_SELF_CALIBRATION == _ON)
 348   1          if(enumAutoType == _AUTO_CALIBRATE_RGB)
C51 COMPILER V8.12   SCALERAUTOFUNC                                                        03/10/2025 13:50:18 PAGE 7   

 349   1          {
