1385   2              else
1386   2              {
1387   3                  ucGain = 0;
1388   3              }
1389   2          }
1390   1          else
1391   1          {
1392   2              // Target value exceeded. Rewind gain.
1393   2              pData[1] = (ucMax - ucTarget);
1394   2      
1395   2              // Increase gain with overflow check
1396   2              if(((WORD)ucGain + pData[1]) > 0xFF)
1397   2              {
1398   3                  ucGain = 0xFF;
1399   3              }
1400   2              else
1401   2              {
1402   3                  ucGain += pData[1];
1403   3              }
1404   2          }
1405   1      
