 354   1          {
 355   2              // Disable calibration voltage
 356   2              ScalerAutoResetCalibration();
 357   2          }
 358   1      #endif
 359   1      
 360   1          // Enlarge clamp end
 361   1          PDATA_WORD(0) = (WORD)((DWORD)GET_INPUT_TIMING_HTOTAL() * GET_INPUT_TIMING_HSYNCWIDTH() / GET_SYNC_H_P
             -ERIOD());
 362   1          PDATA_WORD(1) = PDATA_WORD(0); // Record H-Sync Pulse Width
