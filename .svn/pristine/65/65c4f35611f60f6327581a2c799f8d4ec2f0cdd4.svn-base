 368   1          ScalerSetByte(P0_C0_ADC_GAI_RED_MSB, _DEFAULT_GAIN);
 369   1          ScalerSetByte(P0_C1_ADC_GAI_GRN_MSB, _DEFAULT_GAIN);
 370   1          ScalerSetByte(P0_C2_ADC_GAI_BLU_MSB, _DEFAULT_GAIN);
 371   1          ScalerSetBit(P0_BE_ADC_GAI_LSB, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 372   1      
 373   1          // Load default ADC offset
 374   1          if((enumAutoType != _AUTO_TUNE_RGB_GAIN_ONLY) && (enumAutoType != _AUTO_TUNE_YPBPR_GAIN_ONLY))
 375   1          {
 376   2              ScalerSetByte(P0_C3_ADC_OFF_RED_MSB, _DEFAULT_OFFSET);
 377   2              ScalerSetByte(P0_C4_ADC_OFF_GRN_MSB, _DEFAULT_OFFSET);
 378   2              ScalerSetByte(P0_C5_ADC_OFF_BLU_MSB, _DEFAULT_OFFSET);
 379   2              ScalerSetBit(P0_BF_ADC_OFF_LSB, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 380   2              ScalerSetBit(P0_D3_ADC_OFF_LSB2, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
 381   2          }
 382   1      
 383   1          ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS);
 384   1          ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS);
 385   1      
 386   1          // Disable ADC channel swapping
 387   1          g_stRegVgaCapture.b1_06_4_ADC_R_G_SWAP = _FALSE;
 388   1          g_stRegVgaCapture.b1_06_5_ADC_R_B_SWAP = _FALSE;
 389   1          g_stRegVgaCapture.b1_06_6_ADC_G_B_SWAP = _FALSE;
 390   1      
 391   1          // Set ABL vertical start; Average 4 lines
 392   1          pData[0] = ((GET_VGA_MODE_VSTART() / 2) > 8) ? 8 : ((GET_VGA_MODE_VSTART() / 2) + 1);
 393   1          ScalerSetBit(P0_E3_AUTO_BLACK_LEVEL_CTRL2, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _
             -BIT0), (_BIT5 | (pData[0] & 0x1F)));
 394   1      
 395   1          // Select RGB or YPbPr mode; Off-line ABL; 64-pixels in each line; Clear status;
 396   1          ScalerSetBit(P0_E2_AUTO_BLACK_LEVEL_CTRL1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1), (
             -(enumAutoType == _AUTO_TUNE_YPBPR) ? (_BIT7 | _BIT5) : (_BIT5)));
 397   1      
 398   1          // ABL starts at 4 pixels after the reference signal in each line
 399   1          ScalerSetByte(P0_E6_AUTO_BLACK_LEVEL_CTRL5, (PDATA_WORD(1) + ucClampEnd + 4));
 400   1          ScalerSetBit(P0_EF_AUTO_BLACK_LEVEL_CTRL8, ~(_BIT7 | _BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00); // EQ cond
