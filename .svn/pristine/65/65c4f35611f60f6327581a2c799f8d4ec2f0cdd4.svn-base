1365   1                  (_AUTO_CUSTOM_WHITE_VEND - _AUTO_CUSTOM_WHITE_VSTART + 1) /
1366   1                  (_AUTO_CUSTOM_WHITE_HEND - _AUTO_CUSTOM_WHITE_HSTART + 1);
1367   1      
