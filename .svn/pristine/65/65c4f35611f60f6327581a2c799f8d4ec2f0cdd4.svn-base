 176          //--------------------------------------------------
 177          // Description  : ADC AutoWhiteBalance
 178          // Input Value  : enumAutoType -> auto color for RGB / YPbPr / Self-calibration
 179          // Output Value : _AUTO_SUCCESS or _AUTO_FAIL
 180          //--------------------------------------------------
 181          EnumAutoResult ScalerAutoDoWhiteBalance(EnumAutoColorType enumAutoType)
 182          {
 183   1          EnumAutoResult enumResult = 0;
 184   1          BYTE ucClampEnd = 0;
 185   1      
 186   1          struct StructAdcSwapStatus
 187   1          {
 188   1              BYTE b1_ADC_R_G_SWAP : 1;
 189   1              BYTE b1_ADC_R_B_SWAP : 1;
 190   1              BYTE b1_ADC_G_B_SWAP : 1;
 191   1          } stAdcSwapStatus = {0};
 192   1      
 193   1      #if(_VGA_CHROMA_PATTERN12_SUPPORT == _ON)
                  // For clamp-to-top case, do nothing.
                  if(ScalerADCGetClampToTopStatus() == _TRUE)
                  {
                      return _AUTO_SUCCESS;
                  }
              #endif
 200   1      
 201   1      #if(_VGA_ADC_SF_SHA_LPF_UNDER_25MHZ_SUPPORT == _ON)
                  // Disable SF bandwidth
                  ScalerSetBit(P0_C8_ADC_SF_CTRL, ~_BIT5, 0x00);
              #endif
 205   1      
 206   1          // Store ADC channel swapping, and clamp end
 207   1          stAdcSwapStatus.b1_ADC_R_G_SWAP = g_stRegVgaCapture.b1_06_4_ADC_R_G_SWAP;
 208   1          stAdcSwapStatus.b1_ADC_R_B_SWAP = g_stRegVgaCapture.b1_06_5_ADC_R_B_SWAP;
 209   1          stAdcSwapStatus.b1_ADC_G_B_SWAP = g_stRegVgaCapture.b1_06_6_ADC_G_B_SWAP;
 210   1          ScalerGetDataPortByte(P0_5C_SYNC_PROC_PORT_ADDR, _P0_5D_PT_01_G_CLAMP_END, 1, &ucClampEnd, _AUTOINC);
 211   1      
 212   1          // Initialization for auto-color
 213   1          ScalerAutoInitializeAutoColor(enumAutoType);
 214   1      
 215   1          // Perform auto-color process
 216   1          enumResult = ScalerAutoBalanceHandler(enumAutoType);
 217   1      
 218   1      #if(_ADC_SELF_CALIBRATION == _ON)
 219   1          ScalerAutoResetCalibration();
 220   1      #endif
 221   1      
 222   1          // Restore ADC channel swapping
 223   1          g_stRegVgaCapture.b1_06_4_ADC_R_G_SWAP = stAdcSwapStatus.b1_ADC_R_G_SWAP;
 224   1          g_stRegVgaCapture.b1_06_5_ADC_R_B_SWAP = stAdcSwapStatus.b1_ADC_R_B_SWAP;
