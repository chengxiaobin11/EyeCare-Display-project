             -CH_FROM_D0)))
                  if(GET_DP_RX_HDCP_UPSTREAM_PORT() == _HDCP_D0_PORT)
                  {
                      return GET_DP_RX0_HDCP_UPSTREAM_EVENT();
                  }
              #endif
              
              #if(_D1_DP_EXIST == _ON)
                  if(GET_DP_RX_HDCP_UPSTREAM_PORT() == _HDCP_D1_PORT)
                  {
