              #if(_YCC_QUANTIZATION_RANGE_SUPPORT == _ON)
                  if((GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR420) || (GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR422) || (GE
