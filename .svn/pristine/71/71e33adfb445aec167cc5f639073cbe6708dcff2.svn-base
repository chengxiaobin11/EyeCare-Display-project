                              SET_COLORIMETRY(_COLORIMETRY_RGB_SRGB);
              
                              break;
              
                          case _AVI_COLORIMETRY_11:
              
                              DebugMessageRx5("Get Colorimetry RGB_SRGB", 0x00);
              
                              SET_COLORIMETRY(_COLORIMETRY_EXT);
              
                              ScalerSyncTMDSRx5HdmiColorimetryExtSetting();
              
                              break;
              
