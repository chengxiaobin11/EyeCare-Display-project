                      SET_TMDS_RX4_COLORIMETRY_PREVALUE(ScalerTMDSRx4HdmiGetAVIInfo(_AVI_INFO_COLORIMETRY));
              
                      switch(GET_TMDS_RX4_COLORIMETRY_PREVALUE())
