              #if(_D1_DP_EXIST == _ON)
                  if(GET_DP_RX_HDCP_UPSTREAM_PORT() == _HDCP_D1_PORT)
                  {
                      return ((ScalerDpRx1HdcpCheckValid() == _TRUE) && (ScalerDpRx1HDCPCheckLvp() == _TRUE));
                  }
              #endif
              
                  return _FALSE;
              }
              
