             - _BIT0), 0x00);
              
                      SET_TMDS_RX4_AVI_PIXEL_REPETITION(_AVI_PIXEL_REPETITION_0);
              
                      // Waiting for down sampling  effect
                      ScalerTimerDelayXms(20);
                  }
