                   11229     ;------------------------------------------------------------------------------
                   11230     ;  This file is part of the C51 Compiler package
                   11231     ;  Copyright (c) 1988-2002 Keil Elektronik GmbH and Keil Software, Inc.
                   11232     ;------------------------------------------------------------------------------
                   11233     ;  STARTUP.A51:  This code is executed after processor reset.
                   11234     ;
                   11235     ;  To translate this file use A51 with the following invocation:
                   11236     ;
                   11237     ;     A51 STARTUP.A51
                   11238     ;
                   11239     ;  To link the modified STARTUP.OBJ file to your application use the following
                   11240     ;  BL51 invocation:
                   11241     ;
                   11242     ;     BL51 <your object file list>, STARTUP.OBJ <controls>
                   11243     ;
                   11244     ;------------------------------------------------------------------------------
                   11245     ;
                   11246     ;  User-defined Power-On Initialization of Memory
                   11247     ;
                   11248     ;  With the following EQU statements the initialization of memory
                   11249     ;  at processor reset can be defined:
                   11250     ;
                   11251     ;               ; the absolute start-address of IDATA memory is always 0
  0100             11252     IDATALEN        EQU     0100H     ; the length of IDATA memory in bytes.
                   11253     ;
                   11254     ; the absolute start-address of XDATA memory
  E000             11255     XDATASTART      EQU     (0xE000)
                   11256     ; the length of XDATA memory in bytes.
  0600             11257     XDATALEN        EQU     ((0xE5FF) - (0xE000) + 1)
                   11258     ;
  0000             11259     PDATASTART      EQU     0H      ; the absolute start-address of PDATA memory
  0000             11260     PDATALEN        EQU     0H      ; the length of PDATA memory in bytes.
                   11261     ;
                   11262     ;  Notes:  The IDATA space overlaps physically the DATA and BIT areas of the
                   11263     ;          8051 CPU. At minimum the memory space occupied from the C51
                   11264     ;          run-time routines must be set to zero.
                   11265     ;------------------------------------------------------------------------------
                   11266     ;
                   11267     ;  Reentrant Stack Initilization
                   11268     ;
                   11269     ;  The following EQU statements define the stack pointer for reentrant
                   11270     ;  functions and initialized it:
