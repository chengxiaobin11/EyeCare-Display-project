  41          void ScalerOsdSpecificColorBlending(bit bEnable, BYTE ucIndex);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Set specific color blending
  49          // Input Value  :     bEnable -> _ENABLE or _DISABLE
  50          //                    ucIndex -> BlendingColor LUT index (0~63)
  51          // Output Value :
C51 COMPILER V8.12   OSDSPECIFICCOLORBLENDING                                              03/11/2025 19:55:53 PAGE 2   

  52          //--------------------------------------------------
  53          void ScalerOsdSpecificColorBlending(bit bEnable, BYTE ucIndex)
  54          {
  55   1          // Set Match blending type 2 color bit[5:0]
  56   1          ScalerSetBit(P3A_08_FRAME_CTRL_08, ~(_BIT4), (_BIT4));
  57   1      
  58   1          // Set Specific Color Blending (blending Type 2) Enable/Disable
  59   1          ScalerSetBit(P3A_09_FRAME_CTRL_09, ~_BIT7, ((BYTE)bEnable << 7));
  60   1      
  61   1          // Set Blending Color from 64-color LUT [5:0] (blending Type 2)
  62   1          ScalerSetBit(P3A_08_FRAME_CTRL_08, ~(_BIT3 | _BIT2), ((ucIndex & (_BIT5 | _BIT4)) >> 2));
  63   1          ScalerSetBit(P3A_09_FRAME_CTRL_09, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (ucIndex & 0x0F));
  64   1      }
  65          
  66          
  67          /*
  68          //--------------------------------------------------
  69          // example
  70          //--------------------------------------------------
  71              ScalerOsdSpecificColorBlending(_ENABLE,15);
  72          */


