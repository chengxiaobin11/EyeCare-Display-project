// Description  :
// Input Value  : None
// Output Value : None
//--------------------------------------------------
void OsdFontPut2Bit(BYTE ucRow, BYTE ucCol, BYTE ucIcon, BYTE ucColor0, BYTE ucColor1, BYTE ucColor2, BYTE ucColor3)
{
    WORD xdata usOsdAddr = (WORD)ucRow * g_ucOsdWidth + ucCol;
    BYTE xdata ucByte0 = 0;
    BYTE xdata ucByte2 = 0;

   bit MAPB = _FALSE;

  if(ucRow >= _OSD_MAP_B_ROW_OFFSET)
  {
	ucRow -= _OSD_MAP_B_ROW_OFFSET;
	usOsdAddr = (WORD)ucRow * g_ucOsdWidthB + ucCol;
	MAPB = _TRUE;
  }


#if(_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE)
    if(GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_90)
    {
        usOsdAddr = (WORD)((g_ucOsdWidth - ucRow - 1) + g_ucOsdWidth * ucCol);
    }
    else if(GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_270)
    {
        usOsdAddr = (WORD)(g_ucOsdHeight - 1 - ucCol) * g_ucOsdWidth + ucRow;
    }
#endif

    ucColor0 &= 0x0F;
    ucByte0 = (_BIT7) | ((ucColor0 & _BIT3) << 2) | ((ucColor1 & _BIT3) << 1) | ((ucColor3 & 0x07) << 1) | ((ucColor0 & _BIT2) >> 2);
    ucByte2 = ((ucColor0 & 0x03) << 6) | ((ucColor2 & 0x07) << 3) | (ucColor1 & 0x07);


	if(MAPB == _TRUE)
	{
		ScalerOsdCommandAllByte(usOsdAddr + (g_usFontSelectStart + ((WORD)(g_ucOsdWidth) * g_ucOsdHeight)), ucByte0, ucIcon, ucByte2);
	}
    else
    	ScalerOsdCommandAllByte(usOsdAddr + g_usFontSelectStart, ucByte0, ucIcon, ucByte2);
}

//--------------------------------------------------
// Description  :
// Input Value  : None
// Output Value : None
//--------------------------------------------------
void OsdFontPut2BitTable(BYTE ucRow, BYTE ucCol, BYTE *pucArray, BYTE ucColor0, BYTE ucColor1, BYTE ucColor2, BYTE ucColor3)
{
    BYTE ucOsdWidth = 0;
    BYTE ucCount = 0;
    BYTE ucHTemp = ucCol;

#if(_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE)
    if((GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_90) ||
       (GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_270))
    {
        ucOsdWidth = g_ucOsdHeight;
    }
    else
#endif
    {
        ucOsdWidth = g_ucOsdWidth;
    }

	if(ucRow >= _OSD_MAP_B_ROW_OFFSET)
	{
		ucOsdWidth = g_ucOsdWidthB;
	}

    while(*pucArray != _END_)
    {
        if(*pucArray == _NEXT_)
        {
            ucRow++;
            ucHTemp =ucCol;
            pucArray++;
        }
        else if(*pucArray == _SPACE_)
        {
            ucHTemp++;
            pucArray++;
        }
        else if(*pucArray == _REPEAT_)
        {
            ucCount = *(pucArray + 1) - 1;

            while(ucCount > 0)
            {
                if(*(pucArray - 1) != _SPACE_)
                {
                    OsdFontPut2Bit(ucRow, ucHTemp, *(pucArray - 1), ucColor0, ucColor1, ucColor2, ucColor3);
                }

                ucHTemp++;

                if((ucHTemp == ucOsdWidth) && (*(pucArray + 1) != _NEXT_))
                {
                    ucRow++;
                    ucHTemp =ucCol;
                }
                ucCount--;
            }
            pucArray += 2;
        }
        else
        {
            OsdFontPut2Bit(ucRow, ucHTemp, *pucArray, ucColor0, ucColor1, ucColor2, ucColor3);
            ucHTemp++;

            if((ucHTemp == ucOsdWidth) && (*(pucArray + 1) != _NEXT_))
            {
                ucRow++;
                ucHTemp = ucCol;
            }
            pucArray++;
        }
    }
}




#if(_LOGO_TYPE == _LOGO_TYPE_THREE_BIRDS)


BYTE COsdLogoGetColor(BYTE ucType, BYTE ucOffset, BYTE ucColorIndex)
{
    BYTE ucColor = 0; 

    switch(ucType)
    {
        case _LOGO_THREE_BIRDS_1BIT:
			
	     if(ucColorIndex > 1)
	     {
                return 0;
	     }
            ucColor = tiOSD_THREE_BIRDS_1BIT_COLOR[ucOffset][ucColorIndex];
			
            break;

        case _LOGO_THREE_BIRDS_2BIT:
			
	     if(ucColorIndex > 3)
	     {
                return 0;
	     }
		 
            ucColor = tiOSD_THREE_BIRDS_2BIT_COLOR[ucOffset][ucColorIndex];
			
            break;

    }

    return ucColor;
}


void OsdFuncPutIcon1BitLogo(BYTE ucRow, BYTE ucCol, BYTE ucIcon,  BYTE ucSelect)
{
    WORD usOsdAddr = ((WORD)ucRow * g_ucOsdWidth) + ucCol;
    BYTE ucByte0 = 0x4c;
    BYTE ucByte2 = 0;
    BYTE ucForeground = 0; 
    BYTE ucBackground = 0;
    bit MAPB = _FALSE;

	ucSelect=ucSelect;

	if(ucRow >= _OSD_MAP_B_ROW_OFFSET)
	{
		ucRow -= _OSD_MAP_B_ROW_OFFSET;
		usOsdAddr = ((WORD)ucRow * g_ucOsdWidthB) + ucCol;
		MAPB = _TRUE;
	}

        ucForeground = COsdLogoGetColor(_LOGO_THREE_BIRDS_1BIT, ucIcon, 0);
        ucBackground = COsdLogoGetColor(_LOGO_THREE_BIRDS_1BIT, ucIcon, 1);
        ucIcon += _LOGO_1BIT_OFFSET;


	#if(_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE)
    if(GET_OSD_ROTATE_STATUS() != _OSD_ROTATE_DEGREE_0)
    {
        usOsdAddr = ((WORD)(g_ucOsdHeight - 1 - ucCol) * g_ucOsdWidth) + ucRow;
        ucByte0 = 0x8e;
    }
	#endif

    ucForeground &= 0x0f;

    ucByte2 = ((ucForeground << 4) | ucBackground);



    	ScalerOsdCommandAllByte(usOsdAddr + g_usFontSelectStart, ucByte0, ucIcon, ucByte2);
	
}

void OsdTableFuncPutIcon1BitLogo(BYTE ucRow, BYTE ucCol, BYTE *pucArray)
{
    BYTE ucOsdWidth = 0;
    BYTE ucCount = 0;
    BYTE ucHTemp = ucCol;

    
        ucOsdWidth = g_ucOsdWidth;
    

	if(ucRow >= _OSD_MAP_B_ROW_OFFSET)
	{
		ucOsdWidth = g_ucOsdWidthB;
	}

    while(*pucArray != _END_)
    {
        if(*pucArray == _NEXT_)
        {
            ucRow++;
            ucHTemp =ucCol;
            pucArray++;
        }
        else if(*pucArray == _SPACE_)
        {
            ucHTemp++;
            pucArray++;

        }
        else if(*pucArray == _REPEAT_)
        {
            ucCount =*(pucArray + 1) - 1;

            while(ucCount > 0)
            {
                if(*(pucArray - 1) != _SPACE_)
                {
                    OsdFuncPutIcon1BitLogo(ucRow,  ucHTemp, *(pucArray - 1), *(pucArray - 1));
                }

                ucHTemp++;

                if(ucHTemp == ucOsdWidth && (*(pucArray + 1) != _NEXT_))
                {
                    ucRow++;
                    ucHTemp =ucCol;
                }
                ucCount--;
            }
            pucArray += 2;
        }
        else
        {
            OsdFuncPutIcon1BitLogo(ucRow, ucHTemp, *pucArray, *pucArray);
            ucHTemp++;

            if((ucHTemp == ucOsdWidth) && (*(pucArray + 1) != _NEXT_))
            {
                ucRow++;
                ucHTemp = ucCol;
            }
            pucArray++;
        }
    }
}

void OsdFuncPutIcon2BitLogo(BYTE ucRow, BYTE ucCol, BYTE ucIcon, BYTE ucIndex)
{
    WORD xdata usOsdAddr = (WORD)ucRow * g_ucOsdWidth + ucCol;
    BYTE xdata ucByte0 = 0;
    BYTE xdata ucByte2 = 0;
    BYTE ucColor0 = 0; 
    BYTE ucColor1 = 0;
    BYTE ucColor2 = 0; 
    BYTE ucColor3 = 0;
    bit bpaletteindex = 0;
	
	ucIndex=ucIndex;
	
    ucColor0 = COsdLogoGetColor(_LOGO_THREE_BIRDS_2BIT, ucIcon, 0);
    ucColor1 = COsdLogoGetColor(_LOGO_THREE_BIRDS_2BIT, ucIcon, 1);
    ucColor2 = COsdLogoGetColor(_LOGO_THREE_BIRDS_2BIT, ucIcon, 2);
    ucColor3 = COsdLogoGetColor(_LOGO_THREE_BIRDS_2BIT, ucIcon, 3);
	

    ucColor0 &= 0x0f;

    ucByte0 = (_BIT7) | ((ucColor0 & _BIT3) << 2) | ((ucColor3 & _BIT3) << 2) | ((ucColor1 & _BIT3) << 1) | ((ucColor2 & _BIT3) << 1) | ((ucColor3 & 0x07) << 1) | ((ucColor0 & _BIT2) >> 2);
    ucByte2 = ((ucColor0 & 0x03) << 6) | ((ucColor2 & 0x07) << 3) | (ucColor1 & 0x07);


    	ScalerOsdCommandAllByte(usOsdAddr + g_usFontSelectStart, ucByte0, ucIcon, ucByte2);
	
}

