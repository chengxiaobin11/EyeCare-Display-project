                  BYTE pucHMACSHA256CipherInput[64] = {0};
              
                  // V = HMAC-SHA256(Receiver ID List || RxInfo || seq_num_V, kd)
                  // HMAC(text) = HMAC(K, text) = SHA256((K0 XOR opad) || SHA256((KO XOR ipad) || text))
