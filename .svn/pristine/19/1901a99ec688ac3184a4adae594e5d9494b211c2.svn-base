              bit ScalerHdcp2VprimeCalculate(BYTE *pucHdcp2dKey0, BYTE *pucHdcp2dKey1, BYTE *pucReceiverIdList, BYTE *pu
             -cRxinfo, BYTE *pucSeqNumV)
              {
