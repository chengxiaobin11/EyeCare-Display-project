                  *(pucInputArray1 + 32) = 0x80;
                  *(pucInputArray1 + 62) = 0x03;
              
                  // SHA256((KO XOR opad) || SHA256(KO XOR ipad) || text)
                  if(ScalerHdcp2RxSha256Calculate(pucInputArray2, 0) == _TRUE)
                  {
                      if(ScalerHdcp2RxSha256Calculate(pucInputArray1, 1) == _TRUE)
                      {
                          return _TRUE;
                      }
                  }
              
                  return _FALSE;
              }
              
