                  memcpy(&pucHMACSHA256Input[pData[0] + 2], pucSeqNumV, 3);
                  pucHMACSHA256Input[pData[0] + 5] = 0x80;
                  pucHMACSHA256Input[(pData[1] * 64) - 2] = pData[2];
