 309          void TPVNVRamSaveFactoryDate(void)
 310          {
 311   1              #if(_SYSTEM_EEPROM_EMULATION_SUPPORT == _OFF)
                  UserCommonEepromWrite(_TPV_FACTORY_ADDRESS, sizeof(StructFactoryType), (BYTE *)(&g_stFactoryData));
              
                      #else
 315   1              UserCommonFlashSaveItem(_FLASH_ITEMID_FACTORY_DATA, (BYTE *)(&g_stFactoryData), sizeof(StructFactoryType)
             -);
 316   1              #endif
 317   1      }
 318          
 319          void TPVNVRamLoadFactoryDate(void)
 320          {
 321   1              //DebugMessageOsd("1.LoadFactoryDate",1);
 322   1              #if(_SYSTEM_EEPROM_EMULATION_SUPPORT == _OFF)
                  UserCommonEepromRead(_TPV_FACTORY_ADDRESS, sizeof(StructFactoryType), (BYTE *)(&g_stFactoryData));
                      //UserNVRamCheckRange(g_stFactoryData);
              
                      #else
 327   1              if(UserCommonFlashLoadItem(_FLASH_ITEMID_FACTORY_DATA, pData, sizeof(StructFactoryType)) == _TRUE)
 328   1              {
 329   2                      memcpy(&g_stFactoryData, pData, sizeof(StructFactoryType));
 330   2              }
 331   1              else
 332   1              {
 333   2                      g_stFactoryData = g_stFactoryDataDefault;
 334   2              }
 335   1              #endif
 336   1      }
