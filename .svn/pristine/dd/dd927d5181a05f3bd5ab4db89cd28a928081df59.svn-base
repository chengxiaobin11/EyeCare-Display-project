1768          // Output Value : checksum
1769          //--------------------------------------------------
1770          void TPVFCReplyCommand(BYTE ucResult, BYTE ucLength)
1771          {
1772   1          WORD usCRC = 0;
1773   1          BYTE i = 0;
1774   1      
1775   1          for(i = 0; i < ucLength; i++ )
1776   1          {
1777   2              usCRC = TPVFCCrc16(g_pucDdcciRxBuf[_FC_BYTE4 + i], usCRC);
1778   2          }
1779   1      
C51 COMPILER V8.12   TPVFACTORYCOMMAND                                                     01/02/2025 16:32:40 PAGE 31  

1780   1          g_pucDdcciTxBuf[_DDCCI_SOURCE] = _DDCCI_DEST_ADDRESS;
1781   1          g_pucDdcciTxBuf[_DDCCI_LENGTH] = _DDCCI_CONTROL_STATUS_FLAG | 0x03;
1782   1          g_pucDdcciTxBuf[_DDCCI_COMMAND] = ucResult;
1783   1          g_pucDdcciTxBuf[3] = (BYTE)((usCRC&0xff00)>>8);
1784   1          g_pucDdcciTxBuf[4] = (BYTE)(usCRC&0x00ff);
1785   1          g_pucDdcciTxBuf[5] = UserCommonDdcciCalCheckSum();
1786   1      
1787   1          ScalerMcuDdcciSendData(g_pucDdcciTxBuf);
1788   1      }
