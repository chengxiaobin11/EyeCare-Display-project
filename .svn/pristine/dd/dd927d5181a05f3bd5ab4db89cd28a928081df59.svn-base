1737          // Description  : TPV Factory Command CRC calculation for HDCP
1738          // Input Value  : None
1739          // Output Value : None
1740          //--------------------------------------------------
1741          
1742          
1743          //--------------------------------------------------
1744          // Description  : TPV Factory Command CRC calculation
1745          // Input Value  : None
1746          // Output Value : CRC
1747          //--------------------------------------------------
1748          WORD TPVFCCrc16(BYTE nData, WORD nCRC)
1749          {
1750   1          BYTE nMask;
1751   1          bit fFeedback;
1752   1          for (nMask= 0x80; nMask; nMask >>= 1)
1753   1          {
1754   2              fFeedback= (bit)(((nCRC & 0x8000) ? 1 : 0) ^ ((nMask & nData) ? 1 : 0));
1755   2              nCRC <<= 1;
1756   2              if (fFeedback)
1757   2              {
1758   3                  nCRC ^= 0x1021;
1759   3              }
1760   2          }
1761   1      
1762   1          return nCRC;
1763   1      }
