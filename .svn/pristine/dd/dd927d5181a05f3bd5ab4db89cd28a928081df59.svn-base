 712                  BYTE EDID_DATA[16];
 713                  BYTE j = 0;
 714          
 715              //UserCommonFlashRead(_EDID_FLASH_BANK, (_EDID_D0_ADDRESS_FLASH), _D0_EMBEDDED_DDCRAM_MAX_SIZE, MCU_DD
             -CRAM_D1);
 716          
 717                  ScalerPinshareGpioDdcPinSwitch(_DDC1_SWITCH_GPIO);
 718                  ScalerTimerDelayXms(1); 
 719                  UserCommonEepromIICRead(_EEPROM_SLAVE_ADDRESS, 0x10, 1, 2, EDID_DATA, _IIC_FOR_DDC1, _SW_IIC_PIN_GPIO);
 720                  ScalerPinshareGpioDdcPinSwitch(_DDC1_SWITCH_DDC);
 721                  ScalerTimerDelayXms(1); 
 722                  
 723              for(ucCount = 0; ucCount < 2; ucCount++)
 724                   MCU_DDCRAM_D1[0x10+ucCount] = EDID_DATA[ucCount];// year week
 725          
 726                  ScalerPinshareGpioDdcPinSwitch(_DDC1_SWITCH_GPIO);
 727                  ScalerTimerDelayXms(1); 
 728                  UserCommonEepromIICRead(_EEPROM_SLAVE_ADDRESS, _EDID_SN_START_ADDRESS, 1, _EDID_SN_LENTH, EDID_DATA, _IIC
             -_FOR_DDC1, _SW_IIC_PIN_GPIO);
 729                  ScalerPinshareGpioDdcPinSwitch(_DDC1_SWITCH_DDC);
 730                  ScalerTimerDelayXms(1); 
 731                  
 732             for(ucCount = 0; ucCount <_EDID_SN_LENTH; ucCount++)
 733                   MCU_DDCRAM_D1[_EDID_SN_START_ADDRESS+ucCount] = EDID_DATA[ucCount];// sn
 734          
 735                j = 0;
 736                                          
 737               for(ucCount = 0; ucCount < 127; ucCount++)
 738                     j += MCU_DDCRAM_D1[ucCount];
