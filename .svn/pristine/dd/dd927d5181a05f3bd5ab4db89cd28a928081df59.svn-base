 338          void TPVNVRamRestoreFactoryDate(void)
 339          {
 340   1              g_stFactoryData = g_stFactoryDataDefault;
 341   1      
 342   1              #if(_SYSTEM_EEPROM_EMULATION_SUPPORT == _OFF)
                      UserCommonEepromWrite(_TPV_FACTORY_ADDRESS, sizeof(StructFactoryType), (BYTE *)(&g_stFactoryData));
              
                      #else
 346   1              if(UserCommonFlashLoadItem(_FLASH_ITEMID_FACTORY_DATA, pData, 1) == _TRUE)
 347   1              {
 348   2                      TPVNVRamSaveFactoryDate();
 349   2              }
 350   1              #endif
 351   1      }
