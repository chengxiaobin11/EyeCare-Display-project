  50          // Description  : OSD Addr Msb 0x90
C51 COMPILER V8.12   OSDADDRESS90_91_92                                                    03/11/2025 19:55:49 PAGE 2   

  51          // Input Value  : ucValue -> 0x90 data
  52          // Output Value :
  53          //--------------------------------------------------
  54          void ScalerOsdAddrMsb(BYTE ucValue)
  55          {
  56   1          ScalerSetBit(P0_90_OSD_ADR_PORT_MSB, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (ucValu
             -e & 0x7F));
  57   1      }
  58          
  59          //--------------------------------------------------
  60          // Description  : OSD Addr Lsb 0x91
  61          // Input Value  : ucValue -> 0x91 data
  62          // Output Value :
  63          //--------------------------------------------------
  64          void ScalerOsdAddrLsb(BYTE ucValue)
  65          {
  66   1          ScalerSetByte(P0_91_OSD_ADR_PORT_LSB, ucValue);
  67   1      }
  68          
  69          //--------------------------------------------------
  70          // Description  : OSD Data Port 0x92
  71          // Input Value  : ucValue -> 0x92 data
  72          // Output Value :
  73          //--------------------------------------------------
  74          void ScalerOsdDataPort(BYTE ucValue)
  75          {
  76   1          ScalerSetByte(P0_92_OSD_DATA_PORT, ucValue);
  77   1      }
  78          
  79          //--------------------------------------------------
  80          // Description  : OSD Addr: 0x90[6:0], 0x91[7:0]
  81          // Input Value  : ucAddrIndicator -> _OSD_WIN_CONTROL or _OSD_SRAM
  82          //                ucByteSel       -> _OSD_BYTE0       or _OSD_BYTE1       or _OSD_BYTE2       or
  83          //                                   _OSD_BYTE0_BYTE1 or _OSD_BYTE0_BYTE2 or _OSD_BYTE1_BYTE2 or _OSD_BYTE
             -ALL
  84          //                usAddress       -> SRAM address
  85          //                ucDbufEnable    -> _ENABLE or _DISABLE
  86          // Output Value :
  87          //--------------------------------------------------
  88          void ScalerOsdAddrSet(EnumOsdAddrIndicateType enumAddrIndicator, EnumOsdWriteType enumByteSel, WORD usAddr
             -ess, EnumOsdDBufType enumDbufEnable)
  89          {
  90   1          enumDbufEnable = enumDbufEnable;
  91   1      
  92   1          // Set Address Indicator: 00: Window control registers, 10: Font Select and font map SRAM
  93   1          ScalerSetBit(P0_94_OSD_WRITE_OPTION, ~(_BIT3 | _BIT2), enumAddrIndicator);
  94   1      
  95   1          // Select Which Byte to Write:  001: Byte0, 010: Byte1, 100: Byte2, 011: Byte0 & Byte1, 101: Byte0 & B
             -yte2, 110: Byte1 & Byte2,111: All
  96   1          ScalerSetBit(P0_94_OSD_WRITE_OPTION, ~(_BIT7 | _BIT6 | _BIT5), enumByteSel);
  97   1      
  98   1          // Set Address
  99   1          ScalerOsdAddrMsb(HIBYTE(usAddress));
 100   1          ScalerOsdAddrLsb(LOBYTE(usAddress));
 101   1      }
