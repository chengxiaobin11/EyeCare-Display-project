 619          //--------------------------------------------------
 620          void ScalerFRCSetDDomainSourceSelect(EnumDDomainSourceSelect enumSourceSelect)
 621          {
 622   1          if(enumSourceSelect == _DDOMAIN_SRC_FRAM_FRAME_SYNC_MODE)
 623   1          {
 624   2              // Set Frame sync with line buffer mode
 625   2              ScalerSetBit(P5_CF_MN_DISP_CTRL, ~(_BIT2 | _BIT1), _BIT2);
 626   2          }
 627   1          else
 628   1          {
 629   2              ScalerSetBit(P5_CF_MN_DISP_CTRL, ~(_BIT2 | _BIT1), 0x00);
 630   2          }
 631   1      
 632   1          // Enable Display double buffer
 633   1          ScalerSetBit(P5_D0_MN_SDR_STATUS, ~_BIT4, _BIT4);
 634   1      }
