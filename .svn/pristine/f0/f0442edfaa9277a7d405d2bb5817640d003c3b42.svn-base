  47          //--------------------------------------------------
  48          // Description  : Set Osd Font Rotation
  49          // Input Value  : enumRotType
  50          // Input Value  : ucFontDownloadRotEn
  51          // Input Value  : ucDispRotEn
C51 COMPILER V8.12   RL6449_SERIES_OSDFONTROTATECTRL                                       03/11/2025 19:56:19 PAGE 2   

  52          // Output Value :
  53          //--------------------------------------------------
  54          void ScalerOsdFontRotateCtrl(EnumOsdRotateType enumRotType, BYTE ucFontDownloadRotEn, BYTE ucDispRotEn)
  55          {
  56   1          switch(enumRotType)
  57   1          {
  58   2              default:
  59   2              case _OSD_ROTATE_DEGREE_0:
  60   2                  ScalerSetBit(P3A_0B_FRAME_CTRL_0B, ~(_BIT7 | _BIT6), 0x00);
  61   2                  break;
  62   2      
  63   2              case _OSD_ROTATE_DEGREE_90:
  64   2                  ScalerSetBit(P3A_0B_FRAME_CTRL_0B, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
  65   2                  break;
  66   2      
  67   2              case _OSD_ROTATE_DEGREE_270:
  68   2                  ScalerSetBit(P3A_0B_FRAME_CTRL_0B, ~(_BIT7 | _BIT6), _BIT7);
  69   2                  break;
  70   2      
  71   2              case _OSD_ROTATE_DEGREE_180:
  72   2                  ScalerSetBit(P3A_0B_FRAME_CTRL_0B, ~(_BIT7 | _BIT6), _BIT6);
  73   2                  break;
  74   2          }
  75   1      
  76   1          if(((bit)ucFontDownloadRotEn) == _ENABLE)
  77   1          {
  78   2              ScalerSetBit(P3A_0B_FRAME_CTRL_0B, ~_BIT2, _BIT2);
  79   2          }
  80   1          else
  81   1          {
  82   2              ScalerSetBit(P3A_0B_FRAME_CTRL_0B, ~_BIT2, 0x00);
  83   2          }
  84   1      
  85   1          if((enumRotType == _OSD_ROTATE_DEGREE_0) || (enumRotType == _OSD_ROTATE_DEGREE_180))
  86   1          {
  87   2              ScalerSetBit(P3A_0B_FRAME_CTRL_0B, ~_BIT0, 0x00);
  88   2          }
  89   1          else
  90   1          {
  91   2              ScalerSetBit(P3A_0B_FRAME_CTRL_0B, ~_BIT0, (bit)ucDispRotEn);
  92   2          }
  93   1      }
  94          
  95          /*
  96          //--------------------------------------------------
  97          // example
  98          //--------------------------------------------------
  99              ScalerOsdFontRotateCtrl(_OSD_ROTATE_DEGREE_90, _ENABLE, _OSD_ROTATE_ROTATION);
 100          */
 101          
