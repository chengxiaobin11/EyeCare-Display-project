 631   2              DWORD ulC = (DWORD)_PANEL_DPTX_DCLK_DIV * GET_DISPLAY_DP_TX1_LANE_NUM() * 27UL * GET_DISPLAY_DP_TX
             -1_LINK_RATE() * 9975UL;
 632   2      
 633   2              // Average TU = TU Size x Color Depth x Stream_Clk / Lane Number * SSCG of Link Rate)
 634   2              PDATA_WORD(1) = GET_DWORD_MUL_DIV(ulA, ulB, ulC);
 635   2          }
 636   1      
 637   1          PDATA_WORD(1) = PDATA_WORD(1) / 10UL + (PDATA_WORD(1) % 10 >= 5 ? 1 : 0);
 638   1      
