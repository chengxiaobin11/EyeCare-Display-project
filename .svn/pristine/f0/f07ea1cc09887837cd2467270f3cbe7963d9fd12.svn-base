 466   4      
 467   4                      continue;
 468   4                  }
 469   3      
 470   3                  // (abs(PDATA_DWORD(2) - PDATA_DWORD(3)) < 0x50) for avoid get the measurement value far away 
             -from the average value
 471   3                  if(abs(((PDATA_DWORD(3) + (ucValidHwMvidMeaCnt / 2)) / ucValidHwMvidMeaCnt) - PDATA_DWORD(2)) 
             -< 0x50)
 472   3                  {
 473   4                      if(PDATA_DWORD(2) < ulHwMvidMin)
 474   4                      {
 475   5                          ulHwMvidMin = PDATA_DWORD(2);
 476   5                      }
 477   4      
 478   4                      if(PDATA_DWORD(2) > ulHwMvidMax)
 479   4                      {
 480   5                          ulHwMvidMax = PDATA_DWORD(2);
 481   5                      }
 482   4      
 483   4                      // Accumulate every hw measure mvid
 484   4                      PDATA_DWORD(3) += PDATA_DWORD(2);
 485   4      
 486   4                      // Record total valid hw measure times
 487   4                      ucValidHwMvidMeaCnt++;
 488   4                  }
 489   3              }
 490   2              while(ucCnt > 0);
 491   2      
 492   2              if(bMvidHWMode == _TRUE)
 493   2              {
 494   3                  // Drop the min and max value of hw mvid measurement result
