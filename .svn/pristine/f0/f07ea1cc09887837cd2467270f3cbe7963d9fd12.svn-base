 332   2          }
 333   1          else
 334   1          {
 335   2              SET_DISPLAY_DP_TX1_LANE_NUM(_DP_ONE_LANE);
 336   2          }
 337   1      
 338   1          // Set Enhanceed Framing
 339   1          SET_DISPLAY_DP_TX1_ENHANCE_FRAMING((bit)(pData[2] & _BIT7));
 340   1      
 341   1          // Set Max Downspread
