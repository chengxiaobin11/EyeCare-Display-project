 507   5                      }
 508   4                  }
 509   3                  else
 510   3                  {
 511   4                      // HW Auto Mvid is wrong Set Mvid for FW mode
 512   4                      PDATA_DWORD(3) = PDATA_DWORD(0);
 513   4                  }
 514   3      
 515   3                  // Set Mvid value
 516   3                  ScalerSetByte(P9C_A9_MN_M_VID_H, pData[13]);
 517   3                  ScalerSetByte(P9C_AA_MN_M_VID_M, pData[14]);
