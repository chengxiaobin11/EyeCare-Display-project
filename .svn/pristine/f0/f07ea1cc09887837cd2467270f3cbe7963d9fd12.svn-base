                          }
                          break;
              
                      case _DP_TWO_LANE:
              
                          if((GET_DISPLAY_DP_TX1_LANE1_CR_DONE() != _TRUE) ||
                             (GET_DISPLAY_DP_TX1_LANE0_CR_DONE() != _TRUE))
                          {
                              SET_DISPLAY_DP_TX1_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL);
                          }
                          else if((GET_DISPLAY_DP_TX1_LANE1_EQ_DONE() == _TRUE) &&
                                  (GET_DISPLAY_DP_TX1_LANE0_EQ_DONE() == _TRUE))
                          {
                              if(GET_DISPLAY_DP_TX1_LANE_ALIGN_DONE() == _TRUE)
                              {
                                  SET_DISPLAY_DP_TX1_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_PASS);
                              }
                          }
              
                          if((GET_DISPLAY_DP_TX2_LANE1_CR_DONE() != _TRUE) ||
                             (GET_DISPLAY_DP_TX2_LANE0_CR_DONE() != _TRUE))
                          {
                              SET_DISPLAY_DP_TX2_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL);
                          }
                          else if((GET_DISPLAY_DP_TX2_LANE1_EQ_DONE() == _TRUE) &&
                                  (GET_DISPLAY_DP_TX2_LANE0_EQ_DONE() == _TRUE))
                          {
                              if(GET_DISPLAY_DP_TX2_LANE_ALIGN_DONE() == _TRUE)
                              {
                                  SET_DISPLAY_DP_TX2_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_PASS);
                              }
                          }
                          break;
              
                      case _DP_ONE_LANE:
                      default:
              
                          if(GET_DISPLAY_DP_TX1_LANE0_CR_DONE() != _TRUE)
                          {
                              SET_DISPLAY_DP_TX1_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL);
                          }
                          else if(GET_DISPLAY_DP_TX1_LANE0_EQ_DONE() == _TRUE)
                          {
                              if(GET_DISPLAY_DP_TX1_LANE_ALIGN_DONE() == _TRUE)
                              {
                                  SET_DISPLAY_DP_TX1_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_PASS);
                              }
                          }
              
                          if(GET_DISPLAY_DP_TX2_LANE0_CR_DONE() != _TRUE)
                          {
                              SET_DISPLAY_DP_TX2_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL);
                          }
                          else if(GET_DISPLAY_DP_TX2_LANE0_EQ_DONE() == _TRUE)
C51 COMPILER V9.01   SCALERDISPLAYDPTX                                                     05/24/2025 15:51:04 PAGE 99  

                          {
                              if(GET_DISPLAY_DP_TX2_LANE_ALIGN_DONE() == _TRUE)
                              {
                                  SET_DISPLAY_DP_TX2_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_PASS);
                              }
                          }
                          break;
                  }
              
                  if(GET_DISPLAY_DP_TX_TP2_CNT() == 5)
                  {
                      SET_DISPLAY_DP_TX1_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL);
                      SET_DISPLAY_DP_TX2_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL);
                  }
                  else
                  {
                      ADD_DISPLAY_DP_TX_TP2_CNT();
                  }
              
                  if((GET_DISPLAY_DP_TX1_LT_RESULT() == _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS) &&
                     (GET_DISPLAY_DP_TX2_LT_RESULT() == _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS))
                  {
                      CLR_DISPLAY_DP_TX_TP2_CNT();
              
                      return _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS;
                  }
                  else if((GET_DISPLAY_DP_TX1_LT_RESULT() == _DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL) ||
                          (GET_DISPLAY_DP_TX2_LT_RESULT() == _DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL))
                  {
                      CLR_DISPLAY_DP_TX_TP2_CNT();
              
                      return _DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL;
                  }
              
                  switch(GET_DISPLAY_DP_TX_LANE_NUM())
                  {
                      case _DP_FOUR_LANE:
              
                          if(GET_DISPLAY_DP_TX1_LT_RESULT() != _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS)
                          {
                              ScalerDisplayDPTx1TP2Lane3Adjust();
                              ScalerDisplayDPTx1TP2Lane2Adjust();
                              ScalerDisplayDPTx1TP2Lane1Adjust();
                              ScalerDisplayDPTx1TP2Lane0Adjust();
                          }
              
                          if(GET_DISPLAY_DP_TX2_LT_RESULT() != _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS)
                          {
                              ScalerDisplayDPTx2TP2Lane3Adjust();
                              ScalerDisplayDPTx2TP2Lane2Adjust();
                              ScalerDisplayDPTx2TP2Lane1Adjust();
                              ScalerDisplayDPTx2TP2Lane0Adjust();
                          }
                          break;
              
                      case _DP_TWO_LANE:
              
                          if(GET_DISPLAY_DP_TX1_LT_RESULT() != _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS)
                          {
                              ScalerDisplayDPTx1TP2Lane1Adjust();
                              ScalerDisplayDPTx1TP2Lane0Adjust();
                          }
C51 COMPILER V9.01   SCALERDISPLAYDPTX                                                     05/24/2025 15:51:04 PAGE 100 

              
                          if(GET_DISPLAY_DP_TX2_LT_RESULT() != _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS)
                          {
                              ScalerDisplayDPTx2TP2Lane1Adjust();
                              ScalerDisplayDPTx2TP2Lane0Adjust();
                          }
                          break;
              
                      case _DP_ONE_LANE:
                      default:
              
                          if(GET_DISPLAY_DP_TX1_LT_RESULT() != _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS)
                          {
                              ScalerDisplayDPTx1TP2Lane0Adjust();
                          }
              
                          if(GET_DISPLAY_DP_TX2_LT_RESULT() != _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS)
                          {
                              ScalerDisplayDPTx2TP2Lane0Adjust();
                          }
                          break;
                  }
              
                  SET_DISPLAY_DP_TX1_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_FAIL);
                  SET_DISPLAY_DP_TX2_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_FAIL);
              
                  return _DISPLAY_DP_TX_TRAINING_PATTERN2_FAIL;
              }
              
              //--------------------------------------------------
              // Description  : DP Tx Link Training Pattern End
              // Input Value  :
              // Output Value :
              //--------------------------------------------------
              void ScalerDisplayDPTxTrainPatternEnd(void)
              {
              #if(_PANEL_DPTX_AUX_SET_TP_END_SEQUENCE == _TRAIN_PATTERN_END_BEFORE_IDEL_PATTERN)
                  // Write TRAINING_PATTERN_SET = 00
                  pData[0] = _DISPLAY_DP_TX_TP_NONE;
                  ScalerDisplayDPTx1NativeAuxWrite(0x00, 0x01, 0x02, 1, pData);
              
                  // Write TRAINING_PATTERN_SET = 00
                  pData[0] = _DISPLAY_DP_TX_TP_NONE;
                  ScalerDisplayDPTx2NativeAuxWrite(0x00, 0x01, 0x02, 1, pData);
              #endif
              
                  if(GET_DISPLAY_DP_TX2_TP3_SUPPORT() == _TRUE)
                  {
                      // Switch A-PHY1 mux to D-PHY1
                      ScalerDisplayDPTx2SetTps3PatternMux(_OFF);
                  }
              
                  if(GET_DISPLAY_DP_TX_LT_RESULT() == _DISPLAY_DP_TX_TRAINING_PASS)
                  {
              #if(_PANEL_DPTX_SCRAMBLE_SEED_TYPE == _PANEL_DPTX_SCRAMBLE_SEED_AUTO)
                      if(GET_DISPLAY_DP_TX1_ALTERNATE_SR_CAPABLE() == _TRUE)
                      {
                          // Scambling Seed Select to 0xFFFE
                          ScalerSetBit(P38_88_PHY0_TXBIST_00_L1, ~_BIT4, 0x00);
              
                          pData[0] = ((BYTE)GET_DISPLAY_DP_TX1_FRAMING_CHANGE_CAPABLE() << 1) | _BIT0;
                          ScalerDisplayDPTx1NativeAuxWrite(0x00, 0x01, 0x0A, 1, pData);
C51 COMPILER V9.01   SCALERDISPLAYDPTX                                                     05/24/2025 15:51:04 PAGE 101 

                      }
                      else
                      {
                          // Scambling Seed Select to 0xFFFF
                          ScalerSetBit(P38_88_PHY0_TXBIST_00_L1, ~_BIT4, _BIT4);
                      }
              
                      if(GET_DISPLAY_DP_TX2_ALTERNATE_SR_CAPABLE() == _TRUE)
                      {
                          // Scambling Seed Select to 0xFFFE
                          ScalerSetBit(P38_88_PHY0_TXBIST_00_L1, ~_BIT4, 0x00);
              
                          pData[0] = ((BYTE)GET_DISPLAY_DP_TX2_FRAMING_CHANGE_CAPABLE() << 1) | _BIT0;
                          ScalerDisplayDPTx2NativeAuxWrite(0x00, 0x01, 0x0A, 1, pData);
                      }
                      else
                      {
                          // Scambling Seed Select to 0xFFFF
                          ScalerSetBit(P38_88_PHY0_TXBIST_00_L1, ~_BIT4, _BIT4);
                      }
              #elif(_PANEL_DPTX_SCRAMBLE_SEED_TYPE == _PANEL_DPTX_SCRAMBLE_SEED_0XFFFE)
              
                      // Scambling Seed Select to 0xFFFE
                      ScalerSetBit(P38_88_PHY0_TXBIST_00_L1, ~_BIT4, 0x00);
              
              #elif(_PANEL_DPTX_SCRAMBLE_SEED_TYPE == _PANEL_DPTX_SCRAMBLE_SEED_0XFFFF)
              
                      // Scambling Seed Select to 0xFFFF
                      ScalerSetBit(P38_88_PHY0_TXBIST_00_L1, ~_BIT4, _BIT4);
              
              #endif // End of #if(_PANEL_DPTX_SCRAMBLE_SEED_TYPE == _PANEL_DPTX_SCRAMBLE_SEED_AUTO)
              
                      // Enable Scrambling
                      ScalerSetBit(P38_89_PHY0_TXBIST_01_H2, ~_BIT1, 0x00);
              
                      // Enable BS replaced by SR
                      ScalerSetBit(P9C_0D_DPTX_PHY_CTRL, ~_BIT4, _BIT4);
                      ScalerSetBit(P9E_0D_DPTX_PHY_CTRL, ~_BIT4, _BIT4);
              
                      // Main Link switch to IDLE Pattern
                      ScalerDisplayDPTx1VideoStreamOutput(_DISABLE);
                      ScalerDisplayDPTx2VideoStreamOutput(_DISABLE);
              
                      // Panel DPTx Power Sequence Check Point
                      PCB_DPTX1_POWER_SEQUENCE(_DPTX_POWER_SEQUENCE_IDLE_PATTERN);
                      PCB_DPTX2_POWER_SEQUENCE(_DPTX_POWER_SEQUENCE_IDLE_PATTERN);
              
                      // Disable bist mode
                      ScalerSetBit(P38_88_PHY0_TXBIST_00_L1, ~(_BIT3 | _BIT2), 0x00);
              
                      // Disable Bist Pattern --> for Video Data
                      ScalerSetBit(P38_85_PHY0_TXBIST_00_H2, ~_BIT7, 0x00);
                  }
                  else
                  {
                      // Main Link switch to IDLE Pattern
                      ScalerDisplayDPTx1VideoStreamOutput(_DISABLE);
                      ScalerDisplayDPTx2VideoStreamOutput(_DISABLE);
              
                      // Panel DPTx Power Sequence Check Point
                      PCB_DPTX1_POWER_SEQUENCE(_DPTX_POWER_SEQUENCE_IDLE_PATTERN);
                      PCB_DPTX2_POWER_SEQUENCE(_DPTX_POWER_SEQUENCE_IDLE_PATTERN);
C51 COMPILER V9.01   SCALERDISPLAYDPTX                                                     05/24/2025 15:51:04 PAGE 102 

              
                      // Disable bist mode
                      ScalerSetBit(P38_88_PHY0_TXBIST_00_L1, ~(_BIT3 | _BIT2), 0x00);
              
                      // Disable Bist Pattern --> for Video Data
                      ScalerSetBit(P38_85_PHY0_TXBIST_00_H2, ~_BIT7, 0x00);
                  }
              }
              
              //--------------------------------------------------
              // Description  : DP Tx Link Training
              // Input Value  :
              // Output Value :
              //--------------------------------------------------
              void ScalerDisplayDPTxLinkTraining(void)
              {
                  if((GET_DISPLAY_DP_TX1_LINK_CONFIG() == _TRUE) && (GET_DISPLAY_DP_TX2_LINK_CONFIG() == _TRUE))
                  {
                      ScalerDisplayDPTxTPInitialSet();
              
                      while((GET_DISPLAY_DP_TX_LT_RESULT() != _DISPLAY_DP_TX_TRAINING_PASS) && (GET_DISPLAY_DP_TX_LT_RES
             -ULT() != _DISPLAY_DP_TX_TRAINING_FAIL))
                      {
                          switch(GET_DISPLAY_DP_TX_LT_STATE())
                          {
                              case _DISPLAY_DP_TX_TRAINING_PATTERN1:
              
                                  SET_DISPLAY_DP_TX_LT_RESULT(ScalerDisplayDPTxTrainPattern1());
              
                                  // CR OK
                                  if(GET_DISPLAY_DP_TX_LT_RESULT() == _DISPLAY_DP_TX_TRAINING_PATTERN1_PASS)
                                  {
                                      SET_DISPLAY_DP_TX_LT_STATE(_DISPLAY_DP_TX_TRAINING_PATTERN2);
              
                                      DebugMessageCheck("eDP Tx LT1 Pass", 0x00);
                                  }
                                  else if(GET_DISPLAY_DP_TX_LT_RESULT() == _DISPLAY_DP_TX_TRAINING_PATTERN1_ADJUST_FAIL)
             - // Can not Adjust voltage swing
                                  {
                                      SET_DISPLAY_DP_TX_LT_STATE(_DISPLAY_DP_TX_TRAINING_PATTERN_END);
              
                                      DebugMessageCheck("eDP Tx LT1 Freq Fail", 0x00);
                                  }
              
                                  break;
              
                              case _DISPLAY_DP_TX_TRAINING_PATTERN2:
              
                                  SET_DISPLAY_DP_TX_LT_RESULT(ScalerDisplayDPTxTrainPattern2());
              
                                  if(GET_DISPLAY_DP_TX_LT_RESULT() == _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS)
                                  {
                                      SET_DISPLAY_DP_TX_LT_STATE(_DISPLAY_DP_TX_TRAINING_PATTERN_END);
              
                                      DebugMessageCheck("eDP Tx LT2 Pass", 0x00);
                                  }
                                  else if(GET_DISPLAY_DP_TX_LT_RESULT() == _DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL)
                                  {
                                      SET_DISPLAY_DP_TX_LT_STATE(_DISPLAY_DP_TX_TRAINING_PATTERN_END);
              
                                      DebugMessageCheck("eDP Tx LT2 Lane or PN Fail", 0x00);
                                  }
C51 COMPILER V9.01   SCALERDISPLAYDPTX                                                     05/24/2025 15:51:04 PAGE 103 

              
                                  break;
              
                              case _DISPLAY_DP_TX_TRAINING_PATTERN_END:
              
                                  if(GET_DISPLAY_DP_TX_LT_RESULT() != _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS)
                                  {
                                      SET_DISPLAY_DP_TX_LT_RESULT(_DISPLAY_DP_TX_TRAINING_FAIL);
              
                                      DebugMessageCheck("eDP Tx LTend Fail", 0x00);
                                  }
                                  else
                                  {
                                      SET_DISPLAY_DP_TX_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PASS);
              
                                      DebugMessageCheck("eDP Tx LTend Pass", 0x00);
                                  }
              
                                  ScalerDisplayDPTxTrainPatternEnd();
              
                                  break;
              
                              default:
              
                                  break;
                          }
                      }
                  }
                  else
                  {
                      DebugMessageCheck("eDP Tx Link Config Fail", 0x00);
                  }
              }
              #endif
              #endif
