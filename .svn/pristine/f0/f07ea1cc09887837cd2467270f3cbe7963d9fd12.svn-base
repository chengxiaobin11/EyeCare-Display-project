              //--------------------------------------------------
              // Description  : Dp Tx2 INT Handle
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerDisplayDPTx2IrqIntHandler_EXINT0(void) using 1
              {
                  // Short HPD IRQ
                  if((ScalerGetBit_EXINT(P9E_72_HPD_IRQ_EN, _BIT6) == _BIT6) &&
                     (ScalerGetBit_EXINT(P9E_71_HPD_IRQ, _BIT6) == _BIT6))
                  {
                      ScalerSetBit_EXINT(P9E_71_HPD_IRQ, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1), _BIT6
             -);
              
                      if(ScalerDisplayDPTx2NativeAuxRead_EXINT0(0x00, 0x02, 0x00, 6, pData_EXINT) == _TRUE)
                      {
                          // Link Status Change Irq
                          if(((GET_DISPLAY_DP_TX2_LANE_NUM() == 1) && ((pData_EXINT[2] & 0x07) != 0x07)) ||
                             ((GET_DISPLAY_DP_TX2_LANE_NUM() == 2) && ((pData_EXINT[2] & 0x77) != 0x77)) ||
                             ((GET_DISPLAY_DP_TX2_LANE_NUM() == 4) && (((pData_EXINT[2] & 0x77) != 0x77) || ((pData_EXIN
             -T[3] & 0x77) != 0x77))) ||
                             ((GET_DISPLAY_DP_TX2_LANE_NUM() != 1) && ((pData_EXINT[4] & 0x01) != 0x01)))
                          {
                              SET_DISPLAY_DP_TX2_IRQ_HPD_DETECTED();
                          }
              
                          // Downstream Port Status Change
                          if((pData_EXINT[4] & _BIT6) == _BIT6)
                          {
                              SET_DISPLAY_DP_TX2_IRQ_HPD_DETECTED();
                          }
                      }
                  }
              }
              #endif
