                          // Dig PHY Set
                          ScalerSetBit(P9E_00_DP_PHY_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_BIT7 | _BIT6 | _BIT5 | _B
             -IT4));
              
                          // Reset Small FIFO Before Output Enable
                          ScalerSetBit(P9E_10_DPTX_SFIFO_CTRL0, ~_BIT7, 0x00);
                          ScalerSetBit(P9E_10_DPTX_SFIFO_CTRL0, ~_BIT7, _BIT7);
              
                          // Lane:0-3 power on
                          ScalerSetBit(P38_A1_DPTX_PHY_CTRL1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_BIT7 | _BIT6 | _BIT5 |
             - _BIT4));
              
