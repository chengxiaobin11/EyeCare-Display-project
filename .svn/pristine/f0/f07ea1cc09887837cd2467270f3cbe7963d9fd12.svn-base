                      g_stDisplayDPTx1LTInfo.ucAdjustReqLane01 = pData[4];
                      g_stDisplayDPTx1LTInfo.ucAdjustReqLane23 = pData[5];
                  }
              
                  if(GET_DISPLAY_DP_TX2_LT_RESULT() != _DISPLAY_DP_TX_TRAINING_PATTERN2_PASS)
                  {
                      ScalerDisplayDPTx2NativeAuxRead(0x00, 0x02, 0x02, 6, pData);
                      g_stDisplayDPTx2LTInfo.ucLane01LTStatus = pData[0];
                      g_stDisplayDPTx2LTInfo.ucLane23LTStatus = pData[1];
                      g_stDisplayDPTx2LTInfo.ucLaneAlignStatus = pData[2];
                      g_stDisplayDPTx2LTInfo.ucAdjustReqLane01 = pData[4];
                      g_stDisplayDPTx2LTInfo.ucAdjustReqLane23 = pData[5];
                  }
              
                  // CDR unlock => Reduce bit rate and return to TP1
                  switch(GET_DISPLAY_DP_TX_LANE_NUM())
                  {
                      case _DP_FOUR_LANE:
              
                          if((GET_DISPLAY_DP_TX1_LANE3_CR_DONE() != _TRUE) ||
                             (GET_DISPLAY_DP_TX1_LANE2_CR_DONE() != _TRUE) ||
                             (GET_DISPLAY_DP_TX1_LANE1_CR_DONE() != _TRUE) ||
                             (GET_DISPLAY_DP_TX1_LANE0_CR_DONE() != _TRUE))
                          {
                              SET_DISPLAY_DP_TX1_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL);
                          }
                          else if((GET_DISPLAY_DP_TX1_LANE3_EQ_DONE() == _TRUE) &&
                                  (GET_DISPLAY_DP_TX1_LANE2_EQ_DONE() == _TRUE) &&
                                  (GET_DISPLAY_DP_TX1_LANE1_EQ_DONE() == _TRUE) &&
                                  (GET_DISPLAY_DP_TX1_LANE0_EQ_DONE() == _TRUE))
                          {
                              if(GET_DISPLAY_DP_TX1_LANE_ALIGN_DONE() == _TRUE)
                              {
                                  SET_DISPLAY_DP_TX1_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_PASS);
                              }
                          }
              
                          if((GET_DISPLAY_DP_TX2_LANE3_CR_DONE() != _TRUE) ||
                             (GET_DISPLAY_DP_TX2_LANE2_CR_DONE() != _TRUE) ||
                             (GET_DISPLAY_DP_TX2_LANE1_CR_DONE() != _TRUE) ||
                             (GET_DISPLAY_DP_TX2_LANE0_CR_DONE() != _TRUE))
                          {
                              SET_DISPLAY_DP_TX2_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_ADJUST_FAIL);
                          }
                          else if((GET_DISPLAY_DP_TX2_LANE3_EQ_DONE() == _TRUE) &&
C51 COMPILER V9.01   SCALERDISPLAYDPTX                                                     05/24/2025 15:51:04 PAGE 98  

                                  (GET_DISPLAY_DP_TX2_LANE2_EQ_DONE() == _TRUE) &&
                                  (GET_DISPLAY_DP_TX2_LANE1_EQ_DONE() == _TRUE) &&
                                  (GET_DISPLAY_DP_TX2_LANE0_EQ_DONE() == _TRUE))
                          {
                              if(GET_DISPLAY_DP_TX2_LANE_ALIGN_DONE() == _TRUE)
                              {
                                  SET_DISPLAY_DP_TX2_LT_RESULT(_DISPLAY_DP_TX_TRAINING_PATTERN2_PASS);
