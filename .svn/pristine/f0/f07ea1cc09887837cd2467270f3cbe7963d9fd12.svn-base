 843   2              pData[1] = g_stDisplayDPTx1LTInfo.ucLane1Adjust;
 844   2              pData[2] = g_stDisplayDPTx1LTInfo.ucLane2Adjust;
 845   2              pData[3] = g_stDisplayDPTx1LTInfo.ucLane3Adjust;
 846   2      
