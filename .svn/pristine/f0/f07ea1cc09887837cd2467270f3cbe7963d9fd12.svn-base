 593   2      
 594   2              case _PANEL_DISP_24_BIT:
 595   2                  pData[0] = 8;
 596   2                  break;
 597   2      
 598   2              case _PANEL_DISP_30_BIT:
 599   2                  pData[0] = 10;
 600   2                  break;
 601   2      
 602   2              case _PANEL_DISP_36_BIT:
 603   2                  pData[0] = 12;
 604   2                  break;
 605   2      
 606   2              case _PANEL_DISP_48_BIT:
 607   2                  pData[0] = 16;
 608   2                  break;
 609   2      
 610   2              default:
 611   2      
 612   2                  pData[0] = 8;
 613   2                  break;
 614   2          }
 615   1      
 616   1          // Calculate Vaild Symbol in TU
 617   1          // Average TU = TU Size x (Stream_Clk x Byte of 1 pixel / Lane Number) / Link Rate
 618   1          if(GET_DISPLAY_DP_TX_SSCG_CONFIG() == _FALSE)
 619   1          {
 620   2              DWORD ulA = (DWORD)_DISPLAY_DP_TX1_TU_SIZE * 3UL * pData[0];
