 363          void ScalerDisplayDPTx1VideoStreamOutput(bit bOutput)
 364          {
 365   1          bit bMvidHWMode = _TRUE;
 366   1          BYTE ucCnt = 0;
 367   1          BYTE ucValidHwMvidMeaCnt = 0;
 368   1          WORD usLoopCnt = 0;
 369   1          WORD usMeasureTime = 0;
 370   1          DWORD ulHwMvidMin = 0xFFFFFFFF;
 371   1          DWORD ulHwMvidMax = 0x00000000;
 372   1      
 373   1          if(bOutput == _ENABLE)
 374   1          {
 375   2      #if(_DISPLAY_DP_TX_FB_MODE == _ON)
                      // Set Front-Back Mode
                      ScalerSetBit(P9C_D9_DPTX_TOP_CTL, ~(_BIT3 | _BIT2), (((BYTE)_PANEL_DPTX_FB_SWAP << 3) | _BIT2));
              #else
 379   2      #if(_PANEL_DPTX_LANE_NUMBER == _PANEL_DPTX_LANE_NUMBER_8)
                      // Set Progressive Mode for TX1(MAC0)
                      ScalerSetBit(P9C_D9_DPTX_TOP_CTL, ~(_BIT3 | _BIT2), ((BYTE)_PANEL_DPTX_FB_SWAP << 3));
              #else
 383   2              // Set Progressive Mode for TX1(MAC0)
 384   2              ScalerSetBit(P9C_D9_DPTX_TOP_CTL, ~(_BIT3 | _BIT2), 0x00);
 385   2      #endif
 386   2      #endif
 387   2              // DPTx CTS Fifo reset
 388   2              ScalerSetBit(P9C_D7_DPTX_CTSFIFO_CTRL, ~_BIT2, 0x00);
 389   2              ScalerSetBit(P9C_D7_DPTX_CTSFIFO_CTRL, ~_BIT2, _BIT2);
 390   2      
 391   2              ScalerDisplayDPTx1MeasureInputInfo();
 392   2      
 393   2              PDATA_DWORD(0) = 0;
 394   2              PDATA_DWORD(1) = 0x8000;
 395   2              PDATA_DWORD(2) = 0;
 396   2              PDATA_DWORD(3) = 0;
 397   2      
 398   2              // Mvid = Stream clk x Nvid / Link clk
 399   2              PDATA_DWORD(0) = GET_DWORD_MUL_DIV(GET_D_CLK_FREQ(), PDATA_DWORD(1), ((DWORD)_PANEL_DPTX_DCLK_DIV 
             -* 10UL));
 400   2              PDATA_DWORD(0) /= ((GET_DISPLAY_DP_TX_SSCG_CONFIG() == _TRUE) ? (270UL * GET_DISPLAY_DP_TX1_LINK_R
             -ATE() * 9975UL / 10000UL) : (270UL * GET_DISPLAY_DP_TX1_LINK_RATE()));
 401   2      
C51 COMPILER V9.01   SCALERDISPLAYDPTX                                                     05/24/2025 15:51:04 PAGE 8   

 402   2              PDATA_DWORD(0) = PDATA_DWORD(0) / 10UL + (PDATA_DWORD(0) % 10 > 5 ? 1 : 0);
 403   2      
 404   2              // Calculate HW measure Mvid period time, / 5 for get 5us times
 405   2              usMeasureTime = (WORD)(PDATA_DWORD(1) / ((GET_DISPLAY_DP_TX_SSCG_CONFIG() == _TRUE) ? (27UL * GET_
             -DISPLAY_DP_TX1_LINK_RATE() * 9975UL / 10000UL) : (27UL * GET_DISPLAY_DP_TX1_LINK_RATE())) / 5UL);
 406   2              usMeasureTime *= 2;
 407   2      
 408   2              // Debounce 10 times
 409   2              ucCnt = 0x0A;
 410   2      
 411   2              do
 412   2              {
 413   3                  --ucCnt;
 414   3      
 415   3                  // Enable HW Mvid measure
 416   3                  ScalerSetBit(P9C_A8_MN_VID_AUTO_EN_1, ~_BIT7, _BIT7);
 417   3      
 418   3                  // Delay time for one HW mvid measurement period time
 419   3                  for(usLoopCnt = 0; usLoopCnt < usMeasureTime; usLoopCnt++)
 420   3                  {
 421   4                      DELAY_5US();
 422   4                  }
 423   3      
 424   3                  // Disable HW Mvid measure
 425   3                  ScalerSetBit(P9C_A8_MN_VID_AUTO_EN_1, ~_BIT7, 0x00);
 426   3      
 427   3                  PDATA_DWORD(2) = (((DWORD)ScalerGetByte(P9C_AF_MVID_AUTO_H) << 16) | ((DWORD)ScalerGetByte(P9C
             -_B0_MVID_AUTO_M) << 8) | ScalerGetByte(P9C_B1_MVID_AUTO_L));
 428   3      
 429   3                  // For RLE0779A/RL6449A disable auto Mvid is zero
 430   3                  if(PDATA_DWORD(2) == 0)
 431   3                  {
 432   4                      // HW Auto Mvid is wrong Set Mvid for FW mode
 433   4                      ScalerSetByte(P9C_A9_MN_M_VID_H, pData[1]);
 434   4                      ScalerSetByte(P9C_AA_MN_M_VID_M, pData[2]);
 435   4                      ScalerSetByte(P9C_AB_MN_M_VID_L, pData[3]);
 436   4      
 437   4                      bMvidHWMode = _FALSE;
 438   4      
 439   4                      break;
 440   4                  }
 441   3      
 442   3                  // (abs(PDATA_DWORD(0) - PDATA_DWORD(2)) > (PDATA_DWORD(0) >> 2)) for HW measure abnormal
 443   3                  if(abs(PDATA_DWORD(0) - PDATA_DWORD(2)) > (PDATA_DWORD(0) >> 2))
 444   3                  {
 445   4                      // Drop this time measure result
 446   4                      continue;
 447   4                  }
 448   3      
 449   3                  // (PDATA_DWORD(3) != 0) for get the first time measurement result
 450   3                  if(PDATA_DWORD(3) == 0)
 451   3                  {
 452   4                      if(PDATA_DWORD(2) < ulHwMvidMin)
 453   4                      {
 454   5                          ulHwMvidMin = PDATA_DWORD(2);
 455   5                      }
 456   4      
 457   4                      if(PDATA_DWORD(2) > ulHwMvidMax)
 458   4                      {
 459   5                          ulHwMvidMax = PDATA_DWORD(2);
 460   5                      }
