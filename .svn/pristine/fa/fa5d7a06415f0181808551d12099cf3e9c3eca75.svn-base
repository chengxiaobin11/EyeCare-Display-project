  41          void ScalerOsdPosition(EnumOsdPositionType enumOsdPositionType, WORD usX, WORD usY);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Set osd position
  49          // Input Value  : enumOsdPositionType -> _OSD_POSITION_GLOBAL_A or _OSD_POSITION_GLOBAL_B or _OSD_POSITION
             -_FONT_A or _OSD_POSITION_FONT_B
  50          //                usX                 -> Horizontal delay value (min:2)
C51 COMPILER V8.12   RL6449_SERIES_OSDPOSITION                                             03/11/2025 19:56:17 PAGE 2   

  51          //                usY                 -> Vertical  delay value (min:1)
  52          // Output Value :
  53          //--------------------------------------------------
  54          void ScalerOsdPosition(EnumOsdPositionType enumOsdPositionType, WORD usX, WORD usY)
  55          {
  56   1          // Check Osd Double Buffer
  57   1          if(ScalerGetBit(P0_93_OSD_MISC_PORT, _BIT7) == 0x00)
  58   1          {
  59   2              ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  60   2          }
  61   1      
  62   1          if(enumOsdPositionType == _OSD_POSITION_GLOBAL_A)
  63   1          {
  64   2              // First Horizontal Delay Bit[11:10]
  65   2              ScalerSetBit(P3A_06_FRAME_CTRL_06, ~(_BIT3 | _BIT2), ((usX & 0xC00) >> 8));
  66   2      
  67   2              // First Horizontal Delay [9:2]
  68   2              ScalerSetByte(P3A_01_FRAME_CTRL_01, (BYTE)(usX >> 2));
  69   2      
  70   2              // First Vertical Delay [10:3]
  71   2              ScalerSetByte(P3A_00_FRAME_CTRL_00, (BYTE)(usY >> 3));
  72   2      
  73   2              // (_BIT7 | _BIT6) : First Horizontal Delay Bit [1:0], (_BIT5 | _BIT4 | _BIT3) : First Vertical De
             -lay [2:0].
  74   2              ScalerSetBit(P3A_02_FRAME_CTRL_02, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), (((usX & 0x0003) << 6
             -) | ((usY & 0x07) << 3)));
  75   2          }
  76   1          else if(enumOsdPositionType == _OSD_POSITION_GLOBAL_B)
  77   1          {
  78   2              // Second Horizontal Delay Bit[11:10]
  79   2              ScalerSetBit(P3A_06_FRAME_CTRL_06, ~(_BIT1 | _BIT0), ((usX & 0xC00) >> 10));
  80   2      
  81   2              // Second Horizontal Delay [9:2]
  82   2              ScalerSetByte(P3A_04_FRAME_CTRL_04, (BYTE)(usX >> 2));
  83   2      
  84   2              // Second Vertical Delay [10:3]
  85   2              ScalerSetByte(P3A_03_FRAME_CTRL_03, (BYTE)(usY >> 3));
  86   2      
  87   2              // (_BIT7 | _BIT6) : Second Horizontal Delay Bit [1:0],  (_BIT5 | _BIT4 | _BIT3) : Second Vertical
             - Delay [2:0]
  88   2              ScalerSetBit(P3A_05_FRAME_CTRL_05, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), (((usX & 0x0003) << 6
             -) | ((usY & 0x07) << 3)));
  89   2          }
  90   1          else if(enumOsdPositionType == _OSD_POSITION_FONT_A)
  91   1          {
  92   2              // (_BIT7 | _BIT6 | _BIT5 | _BIT4) : FONT A Horizontal Delay [11:8]
  93   2              // (_BIT3 | _BIT2 | _BIT1 | _BIT0) : FONT A Vertical Delay [11:8]
  94   2              ScalerSetByte(P3A_24_FRAME_CTRL_24, (((usX & 0xF00) >> 4) | ((usY & 0xF00) >> 8)));
  95   2      
  96   2              // FONT A Horizontal Delay [7:0]
  97   2              ScalerSetByte(P3A_25_FRAME_CTRL_25, (usX & 0x0FF));
  98   2      
  99   2              // FONT A Vertical Delay [7:0]
 100   2              ScalerSetByte(P3A_26_FRAME_CTRL_26, (usY & 0x0FF));
 101   2          }
 102   1          else if(enumOsdPositionType == _OSD_POSITION_FONT_B)
 103   1          {
 104   2              // (_BIT7 | _BIT6 | _BIT5 | _BIT4) : FONT B Horizontal Delay [11:8]
 105   2              // (_BIT3 | _BIT2 | _BIT1 | _BIT0) : FONT B Vertical Delay [11:8]
 106   2              ScalerSetByte(P3A_27_FRAME_CTRL_27, (((usX & 0xF00) >> 4) | ((usY & 0xF00) >> 8)));
 107   2      
 108   2              // FONT B Horizontal Delay [7:0]
C51 COMPILER V8.12   RL6449_SERIES_OSDPOSITION                                             03/11/2025 19:56:17 PAGE 3   

 109   2              ScalerSetByte(P3A_28_FRAME_CTRL_28, (usX & 0x0FF));
 110   2      
 111   2              // FONT B Vertical Delay [7:0]
 112   2              ScalerSetByte(P3A_29_FRAME_CTRL_29, (usY & 0x0FF));
 113   2          }
 114   1      }
