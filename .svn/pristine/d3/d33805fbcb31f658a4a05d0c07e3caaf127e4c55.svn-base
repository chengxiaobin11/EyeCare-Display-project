                  SET_COLOR_TEMP_TYPE_USER_B(g_pucDdcciRxBuf[8]); 
              
                  UserAdjustContrast(GET_OSD_CONTRAST());
                  RTDDdccireply(_TRUE);
                }
              /***********************************SAVE****************************/
