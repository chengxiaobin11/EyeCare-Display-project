                  SET_COLOR_TEMP_TYPE(_CT_9300);
                  RTDNVRamSaveColorSetting(GET_COLOR_TEMP_TYPE());
                  RTDDdccireply(_TRUE);
                }
                else  if(IS_SAVE_7500())
                {
              
                  SET_COLOR_TEMP_TYPE(_CT_7500);
                  RTDNVRamSaveColorSetting(GET_COLOR_TEMP_TYPE());
                  RTDDdccireply(_TRUE);
                }
                else  if(IS_SAVE_6500())
