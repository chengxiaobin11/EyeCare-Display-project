                      // Internal IRQ Enable (Global)
                      ScalerGlobalIRQControl(_ENABLE);
              
                      // Enable Input HVsync error IRQ and fifo under/overflow IRQ
                      ScalerSetBit(P0_04_IRQ_CTRL0, ~(_BIT5 | _BIT1), (_BIT5 | _BIT1));
              
                      EX0 = 1;
              #else
 275   2              // Disable WD First & Write 1 Clear Display Vertival Time-Out WD Flag
 276   2              ScalerSetBit(P30_17_MEAS_HS_VS_DELTA_WD, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
 277   2              ScalerSetBit(P30_18_MEAS_HS_VS_ERROR_WD, ~(_BIT5 | _BIT4), 0x00);
