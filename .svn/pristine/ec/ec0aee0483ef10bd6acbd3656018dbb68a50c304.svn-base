  41          void ScalerOsdSramBaseAddressSet(EnumOsdMapType enumOsdMapType, BYTE ucRowCommandStart, WORD usCharactorCo
             -mmandStart, WORD usFontStart);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Row command & Charactor command & Font base address
  49          // Input Value  : enumOsdMapType          -> _OSD_A or _OSD_B
  50          //                ucRowCommandStart       -> Row command start address
C51 COMPILER V8.12   RL6449_SERIES_OSDSRAMBASEADDRESSSET                                   03/11/2025 19:56:19 PAGE 2   

  51          //                ucCharactorCommandStart -> Charactor command start address
  52          //                ucFontStart             -> Font start address
  53          // Output Value :
  54          //--------------------------------------------------
  55          void ScalerOsdSramBaseAddressSet(EnumOsdMapType enumOsdMapType, BYTE ucRowCommandStart, WORD usCharactorCo
             -mmandStart, WORD usFontStart)
  56          {
  57   1          ScalerSetBit(P3A_17_FRAME_CTRL_17, ~(_BIT5 | _BIT4 | _BIT3), ((usFontStart & 0x7000) >> 9));    // Fon
             -t Base Address[14:12]
  58   1          ScalerSetByte(P3A_0E_FRAME_CTRL_0E, ((usFontStart & 0xFF0) >> 4));                              // Fon
             -t Base Address[11:4]
  59   1          ScalerSetBit(P3A_0D_FRAME_CTRL_0D, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (usFontStart & 0x0F));     // Fon
             -t Base Address[3:0]
  60   1      
  61   1          if(enumOsdMapType == _OSD_A)
  62   1          {
  63   2              ScalerSetBit(P3A_0D_FRAME_CTRL_0D, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), ((usCharactorCommandStart & 0
             -xF00) >> 4));     // Font Select Base Address[11:8]
  64   2              ScalerSetByte(P3A_0C_FRAME_CTRL_0C, (usCharactorCommandStart & 0x0FF));                           
             -                  // Font Select Base Address[7:0]
  65   2      
  66   2              ScalerSetByte(P3A_19_FRAME_CTRL_19, ucRowCommandStart);                                           
             -              // Row Command Base 0 [7:0]
  67   2      
  68   2              ScalerSetBit(P3A_1B_FRAME_CTRL_1B, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), ((usCharactorCommandStart & 0
             -xF00) >> 4)); // Font Select Base 0 [11:8]
  69   2              ScalerSetByte(P3A_1C_FRAME_CTRL_1C, (usCharactorCommandStart & 0x0FF));                           
             -              // Font Select Base 0 [7:0]
  70   2          }
  71   1          else if(enumOsdMapType == _OSD_B)
  72   1          {
  73   2              ScalerSetByte(P3A_1A_FRAME_CTRL_1A, ucRowCommandStart);                                           
             -              // Row Command Base 1 [7:0]
  74   2      
  75   2              ScalerSetBit(P3A_1B_FRAME_CTRL_1B, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), ((usCharactorCommandStart & 0
             -xF00) >> 8)); // Font Select Base 1 [11:8]
  76   2              ScalerSetByte(P3A_1D_FRAME_CTRL_1D, (usCharactorCommandStart & 0x0FF));                           
             -              // Font Select Base 1 [7:0]
  77   2          }
  78   1      }


