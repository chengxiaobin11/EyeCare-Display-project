                  }
                  else if((ucAfifoCurrent < (g_stHDMID1AudioFwTrackingInfo.ucAfifoBackup - 0x02)) ||
                          (ucAfifoCurrent <= 0x06))  // AFIFO water level going down  -> increase SUMC
                  {
                      if(ucAfifoCurrent > 0x06)
