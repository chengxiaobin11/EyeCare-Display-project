1160          void ScalerAudioSourceInputSwitch(EnumAudioInputSource enumAudioSource, BYTE ucInputPort)
1161          {
1162   1          if(enumAudioSource == _DIGITAL_AUDIO)
1163   1          {
1164   2              // Select DAC Mux to Digital input
1165   2              ScalerSetBit(P6_D1_DA_MUTE, ~_BIT3, 0x00);
1166   2      
1167   2      #if(_LINE_IN_SUPPORT == _ON)
                      // Power down Audio ADC PLL
                      ScalerSetBit(PBF_BD_MN_SCLKG_PLL_PWR, ~_BIT7, _BIT7);
              
              #if(_LINE_IN_AA_PATH_SUPPORT == _ON)
                      // Set DAC Path
                      ScalerSetByte(P6_E0_REG_MUX_ANA_OUT, 0x00);
              #endif
              #endif
1176   2              if(ucInputPort == _D0_INPUT_PORT)
1177   2              {
1178   3      #if(_INTERNAL_AUDIO_TEST_SUPPORT == _ON)
                          if(ScalerAudioDpGetInternalAudioGenEnable() == _ENABLE)
                          {
                              ScalerAudioInputPortSwitch(_AUDIO_FROM_D2_PORT);
                          }
                          else
              #endif
1185   3                  {
1186   4                      ScalerAudioInputPortSwitch(_AUDIO_FROM_D0_PORT);
1187   4                  }
1188   3              }
1189   2              else if(ucInputPort == _D1_INPUT_PORT)
1190   2              {
1191   3      #if(_D1_DP_EXIST == _ON)
              #if(_INTERNAL_AUDIO_TEST_SUPPORT == _ON)
                          if(ScalerAudioDpGetInternalAudioGenEnable() == _ENABLE)
                          {
                              ScalerAudioInputPortSwitch(_AUDIO_FROM_D2_PORT);
                          }
                          else
              #endif
                          {
                              ScalerAudioInputPortSwitch(_AUDIO_FROM_D1_PORT);
                          }
              
              #elif(_D1_HDMI_SUPPORT == _ON)
1204   3                  ScalerAudioInputPortSwitch(_AUDIO_FROM_D2_PORT);
1205   3      #endif
1206   3              }
C51 COMPILER V9.60.0.0   RL6432_SERIES_AUDIO                                               08/27/2025 11:01:20 PAGE 21  

1207   2              else if(ucInputPort == _D2_INPUT_PORT)
1208   2              {
1209   3                  ScalerAudioInputPortSwitch(_AUDIO_FROM_D2_PORT);
1210   3              }
1211   2              else if(ucInputPort == _D3_INPUT_PORT)
1212   2              {
1213   3                  ScalerAudioInputPortSwitch(_AUDIO_FROM_D3_PORT);
1214   3              }
1215   2      #if((_D6_INPUT_PORT_TYPE != _D6_NO_PORT) && (_D6_INPUT_PORT_SWITCH_FROM == _SWITCH_FROM_D0))
                      else if(ucInputPort == _D6_INPUT_PORT)
                      {
                          ScalerAudioInputPortSwitch(_AUDIO_FROM_D0_PORT);
                      }
              #endif
1221   2              // Resolve Audio Phase Delay of L/R Channel
1222   2              ScalerAudioDVCResetProc();
1223   2      
1224   2      #if(_EMBEDDED_DAC_SUPPORT == _ON)
1225   2              // Set AOUT and HPOUT Gain After DAC Block
1226   2              ScalerAudioDACSetOutputGain(_AUDIO_DAC_OUTPUT_SPEAKER, _DIGITAL_DAC_AOUT_GAIN_DB);
1227   2              ScalerAudioDACSetOutputGain(_AUDIO_DAC_OUTPUT_HEADPHONE, _DIGITAL_DAC_HPOUT_GAIN_DB);
1228   2      #endif
1229   2      
1230   2      #if(_AUDIO_DVC_ADJUST_HARD_GAIN_SUPPORT == _ON)
                      // Set Hard Gain for Digital Audio
                      ScalerSetBit(P8_A9_DVC_GAIN_DONE, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _DIGITAL_HARD_GAIN_VALUE);
              #endif
1234   2          }
1235   1      #if(_LINE_IN_SUPPORT == _ON)
                  else if(enumAudioSource == _LINE_IN_AUDIO)
                  {
                      // Enable Audio ADC PLL
                      ScalerAudioSetADCAudioPLL();
              
                      // Select DAC Mux to ADC input
                      ScalerSetBit(P6_D1_DA_MUTE, ~_BIT3, _BIT3);
              
                      // Switch port to Audio ADC
                      ScalerAudioInputPortSwitch(_AUDIO_FROM_ADC_PORT);
              
                      // Resolve Audio Phase Delay of L/R Channel
                      ScalerAudioDVCResetProc();
              
              #if(_EMBEDDED_DAC_SUPPORT == _ON)
                      // Set AOUT and HPOUT Gain After DAC Block
                      ScalerAudioDACSetOutputGain(_AUDIO_DAC_OUTPUT_SPEAKER, _LINE_IN_DAC_AOUT_GAIN_DB);
                      ScalerAudioDACSetOutputGain(_AUDIO_DAC_OUTPUT_HEADPHONE, _LINE_IN_DAC_HPOUT_GAIN_DB);
              #endif
              
              #if(_LINE_IN_AA_PATH_SUPPORT == _ON)
                      // Set A-A Path
                      ScalerSetByte(P6_E0_REG_MUX_ANA_OUT, 0xAA);
              #endif
              
              #if(_AUDIO_DVC_ADJUST_HARD_GAIN_SUPPORT == _ON)
                      // Set Hard Gain for Line in Audio
                      ScalerSetBit(P8_A9_DVC_GAIN_DONE, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _LINE_IN_HARD_GAIN_VALUE);
              #endif
