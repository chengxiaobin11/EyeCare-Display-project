C51 COMPILER V9.60.0.0   RL6432_SERIES_AUDIO                                               08/27/2025 11:01:20 PAGE 63  

3702   2              if(ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0, (_BIT1 | _BIT0)) != 0x00)
3703   2              {
3704   3                  DebugMessageAudio("WD : D0 DP Audio Over/Underflow", ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0, (_
             -BIT1 | _BIT0)));
3705   3      
3706   3                  // Reset Audio FSM
3707   3                  ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~_BIT7, 0x00);
3708   3      
3709   3                  // Clear audio FIFO overflow and underflow status
3710   3                  ScalerSetBit(PB6_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
3711   3      
3712   3                  // Enable Audio FSM
3713   3                  ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~_BIT7, _BIT7);
3714   3      
3715   3                  // Waiting for 2ms(Audio Freq. Detect || Audio FIFO Write (1/2 FIFO depth = 64 packet)) + 1ms(
