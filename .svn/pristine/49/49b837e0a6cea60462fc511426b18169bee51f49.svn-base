                              if(g_stHDMID1AudioFwTrackingInfo.ucAfifoTrackStableCnt < (_AUDIO_FW_TRCK_FIRST_STABLE_CNT 
             -/ 2))
                              {
                                  usbackupSumc += (((_AUDIO_FW_TRCK_FIRST_STABLE_CNT / 2) - g_stHDMID1AudioFwTrackingInf
             -o.ucAfifoTrackStableCnt) * ((g_stHDMID1AudioFwTrackingInfo.ucAfifoBackup - 0x01) - ucAfifoCurrent));
                              }
                              else
                              {
                                  usbackupSumc += 0x01;
                              }
              
                              // Set D code
                              ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_14_PORT_PAGE71_HDMI_DCAPR1, LOBYTE(usback
