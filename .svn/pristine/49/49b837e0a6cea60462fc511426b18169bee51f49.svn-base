3690   1          {
3691   2              // Clear audio buffer overflow and underflow status
3692   2              ScalerSetBit(PB6_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
3693   2      
3694   2              // Enable Audio Watch Dog for Buffer Overflow/Underflow
3695   2              ScalerSetBit(PB6_39_DP_AWD_CTRL, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
3696   2          }
3697   1          else
3698   1          {
