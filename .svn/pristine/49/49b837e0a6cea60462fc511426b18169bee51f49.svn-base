 471   1          {
 472   2              case _AUDIO_FROM_D0_PORT:
 473   2      
 474   2      #if(_D0_DP_EXIST == _ON)
 475   2                  // Check Audio Packet
C51 COMPILER V9.60.0.0   RL6432_SERIES_AUDIO                                               08/27/2025 11:01:20 PAGE 9   

 476   2                  if(ScalerAudioD0GetAudioDetected() == _FALSE)
 477   2                  {
 478   3                      // Reset Coding Type Detect
 479   3                      SET_DP_D0_AUDIO_CODING_TYPE_FORMAT(_AUDIO_CODING_TYPE_NONE);
 480   3      
 481   3                      return _FALSE;
 482   3                  }
 483   2      
 484   2                  // Check First Time Check or Coding Type Change before Playback
 485   2                  if((GET_DP_D0_AUDIO_CODING_TYPE_FORMAT() == _AUDIO_CODING_TYPE_NONE) ||
 486   2                     ((ScalerGetBit(PB6_3B_DP_IRQ_CTRL1, _BIT0) == 0x00) && (ScalerGetBit(PB6_36_DP_GLB_STATUS, 
             -_BIT2) == _BIT2)))
 487   2                  {
 488   3                      // =================================
 489   3                      // Flag Reset
 490   3                      // =================================
 491   3      
 492   3                      // Disable Audio Coding Type Change INT
 493   3                      ScalerSetBit(PB6_3B_DP_IRQ_CTRL1, ~_BIT0, 0x00);
 494   3      
 495   3                      // Clear Audio Coding Type Change Flag
 496   3                      ScalerSetBit(PB6_36_DP_GLB_STATUS, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1
             -), _BIT2);
 497   3      
 498   3      
 499   3                      // =================================
 500   3                      // Detect Coding Type at First Time
 501   3                      // =================================
 502   3      
 503   3                      DebugMessageAudio("[Audio] Rx0 Coding Type First Time Detect", 0);
 504   3      
 505   3      
 506   3                      // ---------------------------------
 507   3                      // Valid_Bit Detect at First
 508   3                      // ---------------------------------
 509   3      
 510   3                      // Set Audio Coding Type Source to Valid_Bit
 511   3                      ScalerSetBit(PB6_B0_DP_AUD_CTRL, ~_BIT5, _BIT5);
 512   3      
 513   3                      // Update Detect Result
 514   3                      if(ScalerGetBit(PB6_B0_DP_AUD_CTRL, _BIT4) == 0x00)
 515   3                      {
 516   4                          DebugMessageAudio("[Audio] Rx0 initial at LPCM via Valid_Bit", 0);
 517   4      
 518   4                          SET_DP_D0_AUDIO_CODING_TYPE_FORMAT(_AUDIO_LPCM);
 519   4                      }
 520   3                      else
 521   3                      {
 522   4                          WORD usDelayTime = 12;
 523   4                          EnumAudioSamplingFreqType enumAudioFreq = ScalerAudioD0SamplingFreqDetect();
 524   4                          EnumAudioSamplingFreqPacket enumAudioPacket = ScalerAudioGetSamplingFreqPacket(enumAud
             -ioFreq);
 525   4      
 526   4                          // -----------------------------
 527   4                          // Channel Status Detect Flow
 528   4                          // -----------------------------
