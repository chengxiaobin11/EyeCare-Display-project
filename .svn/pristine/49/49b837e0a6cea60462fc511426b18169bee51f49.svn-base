1573   3      
1574   3                  DebugMessageAudio("HDMI D1 Audio Auto_Load Mode", 0);
1575   3              }
C51 COMPILER V9.60.0.0   RL6432_SERIES_AUDIO                                               08/27/2025 11:01:20 PAGE 27  

1576   2      #endif
1577   2              if(ScalerGetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_15_PORT_PAGE71_HDMI_PSCR, (_BIT3 | _BIT2)) == 0
             -x00)
