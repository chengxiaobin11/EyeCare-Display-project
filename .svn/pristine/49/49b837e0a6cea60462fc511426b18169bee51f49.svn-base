3721          //--------------------------------------------------
3722          // Description  : D0 Audio HBR Packet Detect
3723          // Input Value  : None
3724          // Output Value : None
3725          //--------------------------------------------------
3726          void ScalerAudioD0HbrAudioDetect(void)
3727          {
3728   1          // Check HBR Audio Receive
3729   1          if(ScalerGetBit(PB6_B0_DP_AUD_CTRL, (_BIT3 | _BIT2 | _BIT1 | _BIT0)) == _BIT0)
3730   1          {
3731   2              // Check Current Detect Mode
3732   2              if(ScalerGetBit(PB6_B0_DP_AUD_CTRL, _BIT6) != _BIT6)
3733   2              {
3734   3                  // Enable Audio HBR Mode Detect
3735   3                  ScalerAudioD0HbrModeControl(_ON);
3736   3      
3737   3                  // Wait for New Audio Packet Recived via detect interval + 1ms
3738   3                  ScalerTimerDelayXms((ScalerGetBit(PB6_50_AUD_FREQUENY_DET_0, (_BIT3 | _BIT2)) >> 2) + 1);
3739   3      
3740   3                  DebugMessageAudio("Dp D0 HBR Mode Detect Enable", _ENABLE);
3741   3              }
3742   2          }
3743   1          else
3744   1          {
3745   2              // Check Current Detect Mode
3746   2              if(ScalerGetBit(PB6_B0_DP_AUD_CTRL, _BIT6) != 0x00)
3747   2              {
3748   3                  // Disable Audio HBR Mode Detect
3749   3                  ScalerAudioD0HbrModeControl(_OFF);
3750   3      
3751   3                  // Wait for New Audio Packet Recived via detect interval + 1ms
3752   3                  ScalerTimerDelayXms((ScalerGetBit(PB6_50_AUD_FREQUENY_DET_0, (_BIT3 | _BIT2)) >> 2) + 1);
3753   3      
3754   3                  DebugMessageAudio("Dp D0 HBR Mode Detect Disable", _DISABLE);
3755   3              }
3756   2          }
3757   1      }
