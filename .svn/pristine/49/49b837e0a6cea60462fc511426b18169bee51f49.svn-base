3547          //--------------------------------------------------
3548          // Description  : Get D0 Audio Detected
3549          // Input Value  : None
3550          // Output Value : TRUE => Audio Detected
3551          //--------------------------------------------------
3552          bit ScalerAudioD0GetAudioDetected(void)
3553          {
3554   1          // Check audio packet
3555   1          if(GET_AUDIO_D0_PACKET_DETECT() == _FALSE)
3556   1          {
3557   2              DebugMessageAudio("False : D0 Audio Packet", 0);
3558   2              return _FALSE;
3559   2          }
3560   1      
3561   1          // Check Audio FSM
3562   1          if(ScalerGetBit(PB6_74_AUD_FSM_CTRL_0, _BIT7) == 0x00)
3563   1          {
3564   2              DebugMessageAudio("False : D0 DP Audio Fsm Disable", 0);
3565   2      
3566   2              return _FALSE;
3567   2          }
3568   1      
3569   1          // Check Audio Tracking
3570   1          if(ScalerGetBit(PB6_81_AUD_BDRY_0, _BIT7) == 0x00)
3571   1          {
3572   2              DebugMessageAudio("False : D0 DP Audio Tracking Disable", 0);
3573   2      
3574   2              return _FALSE;
3575   2          }
3576   1      
3577   1          // Check DP audio buffer overflow and underflow
3578   1          if(ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0, (_BIT1 | _BIT0)) != 0x00)
3579   1          {
3580   2              DebugMessageAudio("False : D0 DP Audio Buffer", ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0, (_BIT1 | _B
             -IT0)));
3581   2      
C51 COMPILER V9.60.0.0   RL6432_SERIES_AUDIO                                               08/27/2025 11:01:20 PAGE 61  

3582   2              if(ScalerGetBit(PB6_39_DP_AWD_CTRL, (_BIT7 | _BIT6)) == 0x00)
3583   2              {
3584   3                  // Clear audio FIFO overflow and underflow status
3585   3                  ScalerSetBit(PB6_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
3586   3      
3587   3                  // Waiting for 2ms(Audio Freq. Detect || Audio FIFO Write (1/2 FIFO depth = 64 packet)) + 1ms(
             -Audio Stable Time Count = 5 x 200us)
3588   3                  ScalerTimerDelayXms(3);
3589   3      
3590   3                  if(ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0, (_BIT1 | _BIT0)) != 0x00)
3591   3                  {
3592   4                      DebugMessageAudio("False : D0 DP Audio FSM Reset", ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0, 
             -(_BIT1 | _BIT0)));
3593   4      
3594   4                      // Reset Audio FSM
3595   4                      ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~_BIT7, 0x00);
3596   4      
3597   4                      // Clear audio FIFO overflow and underflow status
3598   4                      ScalerSetBit(PB6_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
3599   4      
3600   4                      // Enable Audio FSM
3601   4                      ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~_BIT7, _BIT7);
3602   4      
3603   4                      // Waiting for 2ms(Audio Freq. Detect || Audio FIFO Write (1/2 FIFO depth = 64 packet)) + 
             -1ms(Audio Stable Time Count = 5 x 200us)
3604   4                      ScalerTimerDelayXms(3);
3605   4                  }
3606   3              }
3607   2      
3608   2              return _FALSE;
3609   2          }
3610   1      
3611   1          return _TRUE;
3612   1      }
