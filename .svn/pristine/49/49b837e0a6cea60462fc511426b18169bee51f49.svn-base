 241          void ScalerAudioDisableAudioPLL(void)
 242          {
 243   1      #if(_LINE_IN_SUPPORT == _ON)
                  // Power Down ADC PLL
                  ScalerSetBit(PBF_BD_MN_SCLKG_PLL_PWR, ~_BIT7, _BIT7);
              #endif
 247   1      
 248   1      #if(_D0_DP_EXIST == _ON)
 249   1          // Power Down D0 DPLL
 250   1          ScalerSetBit(PB6_D3_MN_SCLKG_PLL_PWR, ~_BIT7, _BIT7);
 251   1      #endif
 252   1      
 253   1      #if(_D1_DP_EXIST == _ON)
                  // Power Down D1 DPLL
                  ScalerSetBit(PB9_D3_MN_SCLKG_PLL_PWR, ~_BIT7, _BIT7);
              #endif
 257   1      
 258   1      #if((_D1_HDMI_SUPPORT == _ON) || (_D2_HDMI_SUPPORT == _ON))
 259   1          // Power Down D2 DPLL
 260   1          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_38_PORT_PAGE71_HDMI_DPCR0, ~_BIT7, _BIT7);
 261   1      #endif
 262   1      
