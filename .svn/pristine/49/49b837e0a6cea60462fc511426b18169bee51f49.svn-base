C51 COMPILER V9.60.0.0   RL6432_SERIES_AUDIO                                               08/27/2025 11:01:20 PAGE 41  

                              // Load D code
                              ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, ~_BIT6, _BIT6);
                              ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, ~_BIT6, 0x00);
              
                              g_stHDMID1AudioFwTrackingInfo.ucAfifoTrackStableCnt = 0;
              
                              DebugMessageAudio("D1 Audio: AFIFO current", ucAfifoCurrent);
                              DebugMessageAudio("D1 Audio: SUMC+", usbackupSumc);
                          }
                      }
                      else
                      {
                          usbackupSumc += 0x10;
              
                          // Set D code
                          ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_14_PORT_PAGE71_HDMI_DCAPR1, LOBYTE(usbackupSu
             -mc));
                          ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_13_PORT_PAGE71_HDMI_DCAPR0, HIBYTE(usbackupSu
             -mc));
              
                          // Set Double Buffer
                          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_10_PORT_PAGE71_HDMI_CMCR, ~_BIT4, _BIT4);
              
                          // Load D code
                          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, ~_BIT6, _BIT6);
                          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, ~_BIT6, 0x00);
              
                          g_stHDMID1AudioFwTrackingInfo.ucAfifoTrackStableCnt = 0;
              
                          DebugMessageAudio("D1 Audio: AFIFO Empty", ucAfifoCurrent);
                          DebugMessageAudio("D1 Audio: SUMC+ Empty", usbackupSumc);
                      }
              
                      SET_AUDIO_D1_WL_TARGET_DIRECTION(_AUDIO_WL_GOES_UP);
              
                      g_stHDMID1AudioFwTrackingInfo.ucAfifoBackup = ucAfifoCurrent;
                  }
                  else    // AfifoBackup-2 < AfifoCurrent < AfifoBackup+2
                  {
                      if(g_stHDMID1AudioFwTrackingInfo.ucAfifoTrackStableCnt < _AUDIO_FW_TRCK_FIRST_STABLE_CNT)
                      {
                          g_stHDMID1AudioFwTrackingInfo.ucAfifoTrackStableCnt++;
                      }
                  }
              
                  // check stable
                  if(g_stHDMID1AudioFwTrackingInfo.ucAfifoTrackStableCnt >= _AUDIO_FW_TRCK_FIRST_STABLE_CNT)
                  {
                      g_stHDMID1AudioFwTrackingInfo.b1AudioFwTrackStable = 0x01;
              
                      DebugMessageAudio("D1 Audio: Find Stable D", usbackupSumc);
                  }
