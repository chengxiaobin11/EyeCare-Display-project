2114          #if(_HDMI_AUDIO_FW_TRACKING_MODE_SUPPORT == _ON)
              //--------------------------------------------------
              // Description  : D1 HDMI FW tracking Handler
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerAudioD1FwTrackingHandler(void)
              {
                  switch(GET_AUDIO_D1_FW_TRACKING_STATE())
                  {
                      case _AUDIO_FW_TRACKING_INITIAL:
              
                          if(GET_D1_DIGITAL_AUDIO_SOURCE() != _DIGITAL_AUDIO_SOURCE_NONE)
                          {
                              SET_AUDIO_D1_FW_TRACKING_STATE(_AUDIO_FW_TRACKING_PROCESS_PREPARING);
              
                              // Initialize Audio Tracking By FW Control
                              ScalerAudioD1FwTrackingInitial();
              
                              SET_AUDIO_D1_FW_TRACKING_EVENT();
              
                              CLR_AUDIO_D1_FW_TRACKING_RESET();
              
                              DebugMessageAudio("D1 Audio: FW Tracking Start", 0);
                          }
              
                          break;
              
                      case _AUDIO_FW_TRACKING_PROCESS_PREPARING:
              
                          if(GET_AUDIO_D1_FW_TRACKING_EVENT() == _TRUE)
                          {
                              CLR_AUDIO_D1_FW_TRACKING_EVENT();
              
                              // Find stable SUMC or already 4s --> boundary tracking
                              if((g_stHDMID1AudioFwTrackingInfo.b1AudioFwTrackStable != 0x00) || (GET_AUDIO_D1_FW_TRACKI
             -NG_TIMEOUT() == _TRUE))
                              {
                                  if(g_stHDMID1AudioFwTrackingInfo.b1AudioFwTrackStable != 0x00)
                                  {
                                      g_stHDMID1AudioFwTrackingInfo.b1AudioFwTrackStable = 0x00;
              
                                      DebugMessageAudio("D1 Audio: SUMC Stable", g_stHDMID1AudioFwTrackingInfo.b1AudioFw
             -TrackStable);
                                  }
                                  else
                                  {
                                      DebugMessageAudio("D1 Audio: SUMC Final", 0);
                                  }
              
                                  SET_AUDIO_D1_FW_TRACKING_STATE(_AUDIO_FW_TRACKING_PROCESS_PLAYBACK);
              
                                  CLR_AUDIO_D1_FW_TRACKING_TIMEOUT();
                                  ScalerTimerCancelTimerEvent(_SCALER_TIMER_EVENT_AUDIO_D1_FW_TRACKING_TIMEOUT);
                              }
                              else
                              {
                                  // FW tracking - preparing tracking
                                  ScalerAudioD1FwPreparingTracking();
                              }
C51 COMPILER V9.60.0.0   RL6432_SERIES_AUDIO                                               08/27/2025 11:01:20 PAGE 37  

              
                              ScalerTimerActiveTimerEvent(ScalerAudioD1FwTrackingTimerEventPeriod(), _SCALER_TIMER_EVENT
             -_AUDIO_D1_FW_TRACKING_PREPARING);
                          }
              
                          break;
              
                      case _AUDIO_FW_TRACKING_PROCESS_PLAYBACK:
              
                          if(GET_AUDIO_D1_FW_TRACKING_EVENT() == _TRUE)
                          {
                              CLR_AUDIO_D1_FW_TRACKING_EVENT();
              
                              // FW tracking - boundary tracking
                              ScalerAudioD1FwBoundaryTracking();
              
                              ScalerTimerActiveTimerEvent(ScalerAudioD1FwTrackingTimerEventPeriod(), _SCALER_TIMER_EVENT
             -_AUDIO_D1_FW_TRACKING_PREPARING);
                          }
              
                          break;
              
                      default:
                          break;
                  }
              }
              
              //--------------------------------------------------
              // Description  : D1 HDMI FW tracking Initial
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerAudioD1FwTrackingInitial(void)
              {
                  g_stHDMID1AudioFwTrackingInfo.b1AudioFwTrackStable = 0x00;
                  g_stHDMID1AudioFwTrackingInfo.ucAfifoTrackStableCnt = 0x00;
                  g_stHDMID1AudioFwTrackingInfo.ucAudioFreqRecord = ScalerGetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_8B_P
             -ORT_PAGE71_AUDIO_FREQ_RESULT, (_BIT3 | _BIT2 | _BIT1 | _BIT0));
              
                  // Set I code of trend
                  ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_20_PORT_PAGE71_HDMI_ICTPSR0, 0x00);
                  ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_21_PORT_PAGE71_HDMI_ICTPSR1, 0x00);
              
                  // Set P code of trend
                  ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_22_PORT_PAGE71_HDMI_PCTPSR0, 0x00);
                  ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_23_PORT_PAGE71_HDMI_PCTPSR1, 0x00);
              
                  // Set I code of boundary
                  ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_24_PORT_PAGE71_HDMI_ICBPSR0, 0x00);
                  ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_25_PORT_PAGE71_HDMI_ICBPSR1, 0x00);
              
                  // Set P code of boundary
                  ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_26_PORT_PAGE71_HDMI_PCBPSR0, 0x00);
                  ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_27_PORT_PAGE71_HDMI_PCBPSR1, 0x00);
              
                  // Disable Auto Load S/D Code
                  ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_8A_PORT_PAGE71_AUDIO_FREQDET, ~_BIT6, 0x00);
                  ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_10_PORT_PAGE71_HDMI_CMCR, ~_BIT4, _BIT4);
              
                  // Initialize D Code for FW Audio Tracking
                  ScalerAudioD1DcodeSettingInitial();
              
C51 COMPILER V9.60.0.0   RL6432_SERIES_AUDIO                                               08/27/2025 11:01:20 PAGE 38  

                  CLR_AUDIO_D1_FW_TRACKING_TIMEOUT();
              
                  // When the stable N.F Code is not found within 4 seconds, tracking state force to playback for play a
             -udio
                  ScalerTimerReactiveTimerEvent(SEC(4), _SCALER_TIMER_EVENT_AUDIO_D1_FW_TRACKING_TIMEOUT);
              }
              
              //--------------------------------------------------
              // Description  : Initial D code setting by fs
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerAudioD1DcodeSettingInitial(void)
              {
                  if(GET_AUDIO_D1_SAMPLING_FREQ() == _AUDIO_FREQ_32K)
                  {
                      // Set S code for 32kHz
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_12_PORT_PAGE71_HDMI_SCAPR, _HDMI_SAMPLING_FREQ_32
             -K_GROUP_S_CODE);
                      // Set D code for 32kHz
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_13_PORT_PAGE71_HDMI_DCAPR0, HIBYTE(_HDMI_SAMPLING
             -_FREQ_32K_GROUP_D_CODE));
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_14_PORT_PAGE71_HDMI_DCAPR1, LOBYTE(_HDMI_SAMPLING
             -_FREQ_32K_GROUP_D_CODE));
                  }
                  else if(GET_AUDIO_D1_SAMPLING_FREQ() == _AUDIO_FREQ_44_1K)
                  {
                      // Set S code for 44.1kHz
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_12_PORT_PAGE71_HDMI_SCAPR, _HDMI_SAMPLING_FREQ_44
             -K_GROUP_S_CODE);
                      // Set D code for 44.1kHz
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_13_PORT_PAGE71_HDMI_DCAPR0, HIBYTE(_HDMI_SAMPLING
             -_FREQ_44K_GROUP_D_CODE));
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_14_PORT_PAGE71_HDMI_DCAPR1, LOBYTE(_HDMI_SAMPLING
             -_FREQ_44K_GROUP_D_CODE));
                  }
                  else if(GET_AUDIO_D1_SAMPLING_FREQ() == _AUDIO_FREQ_48K)
                  {
                      // Set S code for 48kHz
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_12_PORT_PAGE71_HDMI_SCAPR, _HDMI_SAMPLING_FREQ_48
             -K_GROUP_S_CODE);
                      // Set D code for 48kHz
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_13_PORT_PAGE71_HDMI_DCAPR0, HIBYTE(_HDMI_SAMPLING
             -_FREQ_48K_GROUP_D_CODE));
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_14_PORT_PAGE71_HDMI_DCAPR1, LOBYTE(_HDMI_SAMPLING
             -_FREQ_48K_GROUP_D_CODE));
                  }
              
                  // Set Double Buffer bit
                  ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_10_PORT_PAGE71_HDMI_CMCR, ~_BIT4, _BIT4);
              
                  // Load D code
                  ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, ~_BIT6, _BIT6);
                  ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, ~_BIT6, 0x00);
              }
              
              //--------------------------------------------------
