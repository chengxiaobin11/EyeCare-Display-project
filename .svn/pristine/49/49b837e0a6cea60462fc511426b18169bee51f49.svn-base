3282          //--------------------------------------------------
3283          // Description  : Initial D0 Auido PLL Settings
3284          // Input Value  : None
3285          // Output Value : None
3286          //--------------------------------------------------
3287          void ScalerAudioD0SetAudioPLL(void)
3288          {
3289   1          // DPLL power down
3290   1          ScalerSetBit(PB6_D3_MN_SCLKG_PLL_PWR, ~_BIT7, _BIT7);
3291   1      
3292   1          // Set M code
3293   1          ScalerSetByte(PB6_D1_MN_SCLKG_DIVM, (_AUDIO_PLL_M - 2));
3294   1      
3295   1          // Set O code
3296   1          ScalerSetBit(PB6_D3_MN_SCLKG_PLL_PWR, ~(_BIT1 | _BIT0), 0x00);
3297   1      
3298   1          // Set N(K) code and enable double buffer
3299   1          ScalerSetByte(PB6_D2_MN_SCLKG_DIVN, (_AUDIO_PLL_K - 2));
3300   1      
3301   1          // Initial VCO Band = 10
3302   1          ScalerSetBit(PB6_D5_MN_SCLKG_PLL_WD, ~(_BIT4 | _BIT3), _BIT4);
3303   1      
3304   1          // Set MN PLL Path1 => [2]: 1 = Path1, 0 = Path2
3305   1          ScalerSetBit(PB6_D5_MN_SCLKG_PLL_WD, ~(_BIT7 | _BIT2), _BIT2);
3306   1      
3307   1          // DPLL VCORSTB Set to Normal
3308   1          ScalerSetBit(PB6_D6_MN_SCLKG_PLL_INSEL, ~_BIT0, _DPLL_VCORSTB_NORMAL_VALUE);
3309   1      
3310   1          // DPLL power up
3311   1          ScalerSetBit(PB6_D3_MN_SCLKG_PLL_PWR, ~_BIT7, 0x00);
3312   1      
3313   1          // Delay 2000us
3314   1          ScalerTimerDelayXms(2);
3315   1      
3316   1          // DPLL CMP enable
3317   1          ScalerSetBit(PB6_D3_MN_SCLKG_PLL_PWR, ~_BIT2, _BIT2);
3318   1      
3319   1          // Delay at least 1000us
3320   1          ScalerTimerDelayXms(2);
3321   1      
3322   1          // DPLL latch calibration enable
3323   1          ScalerSetBit(PB6_D3_MN_SCLKG_PLL_PWR, ~_BIT3, _BIT3);
3324   1      
3325   1          // Delay at least 1000us
3326   1          ScalerTimerDelayXms(2);
3327   1      
3328   1          // DPLL calibration validated
3329   1          ScalerSetBit(PB6_D3_MN_SCLKG_PLL_PWR, ~_BIT4, _BIT4);
3330   1      }
