3614          //--------------------------------------------------
3615          // Description  : Detect D0 Audio Sampling Freq
3616          // Input Value  : None
3617          // Output Value : Audio Sampling Freq
3618          //--------------------------------------------------
3619          EnumAudioSamplingFreqType ScalerAudioD0SamplingFreqDetect(void)
3620          {
3621   1          EnumAudioSamplingFreqType enumAudioFreq = _AUDIO_FREQ_NO_AUDIO;
3622   1      
3623   1      #if(_INTERNAL_AUDIO_TEST_SUPPORT == _ON)
                  if(ScalerAudioDpGetInternalAudioGenEnable() == _ENABLE)
                  {
                      // For Audio test pattern
                      SET_AUDIO_D0_SAMPLING_FREQ(_AUDIO_FREQ_48K);
                      return _AUDIO_FREQ_48K;
                  }
              #endif
3631   1      
3632   1          // HBR Audio Detect
3633   1          ScalerAudioD0HbrAudioDetect();
3634   1      
3635   1          // Get Audio Sample Count
3636   1          enumAudioFreq = (ScalerGetBit(PB6_61_AUD_SAMPLE_CNT_0, (_BIT7 | _BIT6 | _BIT5 | _BIT4)) >> 4);
3637   1      
3638   1          if(enumAudioFreq != GET_AUDIO_D0_SAMPLING_FREQ())
3639   1          {
3640   2      #if(_EMBEDDED_DAC_SUPPORT == _ON)
C51 COMPILER V9.60.0.0   RL6432_SERIES_AUDIO                                               08/27/2025 11:01:20 PAGE 62  

3641   2              if(enumAudioFreq <= _AUDIO_FREQ_64K)
3642   2              {
3643   3                  ScalerSetBit(P6_D4_DA_CLK_CTRL, ~(_BIT7 | _BIT6), 0x00);
3644   3              }
3645   2              else if(enumAudioFreq <= _AUDIO_FREQ_128K)
3646   2              {
3647   3                  ScalerSetBit(P6_D4_DA_CLK_CTRL, ~(_BIT7 | _BIT6), _BIT6);
3648   3              }
3649   2              else
3650   2              {
3651   3                  ScalerSetBit(P6_D4_DA_CLK_CTRL, ~(_BIT7 | _BIT6), _BIT7);
3652   3              }
3653   2      #endif
3654   2      
3655   2              // Audio DVC Setting
3656   2              ScalerAudioD0DPSetDVCWindowSize(_DP_DVC_ADJUST_TYPE, ScalerAudioGetSamplingFreqPacket(enumAudioFre
             -q));
3657   2          }
3658   1      
3659   1          SET_AUDIO_D0_SAMPLING_FREQ(enumAudioFreq);
3660   1      
3661   1          return enumAudioFreq;
3662   1      }
