             -o.ucAfifoTrackStableCnt) * (ucAfifoCurrent - (g_stHDMID1AudioFwTrackingInfo.ucAfifoBackup + 0x01)));
                              }
                              else
                              {
                                  usbackupSumc -= 0x01;
                              }
              
                              // Set D code
                              ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_14_PORT_PAGE71_HDMI_DCAPR1, LOBYTE(usback
             -upSumc));
                              ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_13_PORT_PAGE71_HDMI_DCAPR0, HIBYTE(usback
             -upSumc));
              
                              // Set Double Buffer
                              ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_10_PORT_PAGE71_HDMI_CMCR, ~_BIT4, _BIT4);
              
                              // Load D code
                              ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, ~_BIT6, _BIT6);
                              ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, ~_BIT6, 0x00);
              
                              g_stHDMID1AudioFwTrackingInfo.ucAfifoTrackStableCnt = 0;
              
