C51 COMPILER V8.12   RL6449_SERIES_TCON9                                                   03/11/2025 19:56:21 PAGE 2   

  52          //--------------------------------------------------
  53          void ScalerTcon9Enable(bit bEnable)
  54          {
  55   1          ScalerSetDataPortBit(P15_A3_TCON_ADDR, _P15_A4_PT_A8_TC9_CTRL, ~(_BIT7), ((BYTE)bEnable << 7));
  56   1      }
  57          
  58          //--------------------------------------------------
  59          // Description  : Set Tcon9 Region
  60          // Input Value  : usHstart --> Horizon start
  61          //                usHend --> Horizon end
  62          //                usVstart --> Vertical start
  63          //                usVend --> Vertical end
  64          // Output Value : None
  65          //--------------------------------------------------
  66          void ScalerTcon9Adjust(WORD usHstart, WORD usHend, WORD usVstart, WORD usVend)
  67          {
  68   1          usVstart &= 0x1FFF;
  69   1          usVend &= 0x1FFF;
  70   1      
  71   1          usHstart &= 0x1FFF;
  72   1          usHend &= 0x1FFF;
  73   1      
  74   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_A0_TC9_VS_MSB, HIBYTE(usVstart));
  75   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_A1_TC9_VS_LSB, LOBYTE(usVstart));
  76   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_A2_TC9_VE_MSB, HIBYTE(usVend));
  77   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_A3_TC9_VE_LSB, LOBYTE(usVend));
  78   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_A4_TC9_HS_MSB, HIBYTE(usHstart));
  79   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_A5_TC9_HS_LSB, LOBYTE(usHstart));
  80   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_A6_TC9_HE_MSB, HIBYTE(usHend));
  81   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_A7_TC9_HE_LSB, LOBYTE(usHend));
  82   1      }
