  52          // Description  : Get SRGB precision
  53          // Input Value  :
  54          // Output Value : SRGB Precision Enum
  55          //--------------------------------------------------
  56          EnumSrgbPrecision ScalerColorSRGBGetPrecision(void)
  57          {
  58   1          EnumSrgbPrecision enumPrecision = _SRGB_1_BIT_SHIFT_LEFT;
