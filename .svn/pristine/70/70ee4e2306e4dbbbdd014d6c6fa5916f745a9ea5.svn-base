              BYTE GetDynamicODValue(BYTE ucOdMode)
              {
                      BYTE *odgain = ODValue[0];
                      if(GET_INPUT_TIMING_VFREQ() >= 1790)
                              {
                                      odgain = ODValue[7];
                              }
                              else if(GET_INPUT_TIMING_VFREQ() >= 1640)
                              {
                                      odgain = ODValue[6];
                              }
                              else if(GET_INPUT_TIMING_VFREQ() >= 1430)
                              {
                                      odgain = ODValue[5];
                              }
                              else if(GET_INPUT_TIMING_VFREQ() >= 1190)
                              {
