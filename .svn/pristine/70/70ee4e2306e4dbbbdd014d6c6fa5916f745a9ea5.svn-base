                              else if(GET_INPUT_TIMING_VFREQ() >= 990)
                              {
                                      odgain = ODValue[3];
                              }
                              else if(GET_INPUT_TIMING_VFREQ() >= 790)
                              {
                                      odgain = ODValue[2];
                              }
                              else if(GET_INPUT_TIMING_VFREQ() >= 590)
                              {
                                      odgain = ODValue[1];
                              }
                              else if(GET_INPUT_TIMING_VFREQ() >= 470)
                              {
                                      odgain = ODValue[0];
                              }
                              return odgain[ucOdMode];
              }
              #endif
