3076   1      
3077   1          ////////////////////////////////////////////////////////////////////////////////////////////////
3078   1          // Fin = TMDS_clk
3079   1          // Fref = Fin / N
3080   1          // Fvco = Fin * M / N
3081   1          // Freq = Fvco / Divs
3082   1          //
3083   1          // Restriction
3084   1          // A. BW = Kvco * Icp * R / (M * 2pi) = 700k (Band10 Kvco = 1880), R = 13k)
3085   1          // B. 300MHz < Fvco < 600MHz
3086   1          // C. (Fin / N) >= 10 * BW --> (Fin / N) >= 7MHz
3087   1          // D. YCbCr 420, Ratio = 2, other case Ratio = 1
3088   1          //
3089   1          // note 1.   According A, Icp = 2.5 ~ 20 --> 14 <= M <= 111
3090   1          // note 2.   According B and note 1. --> 3 <= (Fin / N) <= 42
3091   1          // note 3.   According C and note 2. --> 7 <= (Fin / N) <= 42
3092   1          // note 4_a. 10bit : (M / N / Divs) = (4 / 5 * Ratio) --> M = N * Divs * (4 / 5 * Ratio), N or Divs: m
             -ultiple of 5
3093   1          // note 4_b. 12bit : (M / N / Divs) = (2 / 3 * Ratio) --> M = N * Divs * (2 / 3 * Ratio), N or Divs: m
             -ultiple of 3
3094   1          // note 4_b. 16bit : (M / N / Divs) = (1 / 2 * Ratio) --> M = N * Divs * (1 / 2 * Ratio), N or Divs: m
             -ultiple of 2
3095   1          ////////////////////////////////////////////////////////////////////////////////////////////////
3096   1      
3097   1          // If Measure Divider = /2 then TMDS_CLK x 2, unit:kHz
3098   1          if(ScalerGetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0, _BIT6) == _BIT6)
3099   1          {
3100   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 * 2 / usTMDSClkCount;
3101   2          }
3102   1          else
3103   1          {
3104   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 / usTMDSClkCount;
3105   2          }
3106   1      
3107   1      #if(_D3_HDMI_2_0_SUPPORT == _ON)
