2917          // Description  : Measure Clk
2918          // Input Value  : Clk Source to be measured
2919          // Output Value : Measured Clk Count
2920          //--------------------------------------------------
2921          WORD ScalerTMDSRx3MeasureClk(BYTE ucMeasureClk)
2922          {
2923   1          BYTE ucDelayCount = 0;
2924   1      
2925   1      #if(_D3_INPUT_PORT_TYPE == _D3_MHL_PORT)
                  if(GET_D3_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
                      // Enable Rx_EN (Lane0,3)
                      ScalerSetBit(P7C_1A_CMU_00, ~(_BIT7 | _BIT4), (_BIT7 | _BIT4));
C51 COMPILER V9.60.0.0   RL6432_SERIES_TMDSRX3                                             08/21/2025 10:45:19 PAGE 50  

                  }
                  else
              #endif
2933   1          {
2934   2              // Enable Rx_EN (Lane3)
2935   2              ScalerSetBit(P7C_1A_CMU_00, ~_BIT7, _BIT7);
2936   2          }
2937   1      
2938   1          // Disable Measure for Reset Measure Window
2939   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2940   1          ScalerSetBit(P72_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), 0x00);
2941   1      
2942   1          // Select reference clk to Xtal Clk and measure clk
2943   1          ScalerSetBit(P72_AD_TMDS_CPS, ~(_BIT6 | _BIT5 | _BIT4), ((ucMeasureClk << 5) | _BIT4));
2944   1      
2945   1          // Start Measure
2946   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2947   1          ScalerSetBit(P72_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), _BIT3);
2948   1      
2949   1          // Delay at least 40us at Xtal = 27MHz
2950   1          for(ucDelayCount = 0; ucDelayCount <= 8; ucDelayCount++)
2951   1          {
2952   2              DELAY_5US();
2953   2      
2954   2              ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2955   2              if(ScalerGetBit(P72_CA_HDMI_DP, _BIT3) == 0x00)
2956   2              {
2957   3                  break;
2958   3              }
2959   2          }
2960   1      
2961   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2962   1          pData[0] = ScalerGetByte(P72_CA_HDMI_DP);
2963   1      
2964   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_29_PORT_PAGE72_HDMI_NTX1024TR1);
2965   1          pData[1] = ScalerGetByte(P72_CA_HDMI_DP);
2966   1      
2967   1          return ((WORD)(pData[0] & 0x07) << 8) | pData[1];
2968   1      }
