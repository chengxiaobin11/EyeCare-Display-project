 307          //--------------------------------------------------
 308          // Description  : Initialize TMDS Interrupt Required Settings
 309          // Input Value  : None
 310          // Output Value : None
 311          //--------------------------------------------------
 312          void ScalerTMDSRx3InterruptInitial(void)
 313          {
 314   1          if(ScalerGetBit(P72_E6_HDMI_FREQDET_CTRL, _BIT1) == 0x00)
 315   1          {
 316   2              CLR_TMDS_RX3_PHY_SET();
 317   2          }
 318   1      
 319   1          // Enable Rx_En for Clk pair Z0
 320   1          ScalerSetBit(P7C_1A_CMU_00, ~_BIT7, _BIT7);
 321   1      
 322   1          // Choose Measure Clk to TMDS Clk
 323   1          ScalerSetBit(P72_E6_HDMI_FREQDET_CTRL, ~(_BIT7 | _BIT5 | _BIT4), 0x00);
 324   1      
 325   1          // Set Freq. Reference Counter = 2000
 326   1          ScalerSetBit(P72_F6_HDMI_FREQDET_BOUND_H, ~(_BIT1 | _BIT0), _BIT0);
 327   1      
 328   1          // Set Online Measure Input Clock Divider = /2 (No Matter if Input Clock >300Mhz or <=300Mhz)
 329   1          ScalerSetBit(P72_E7_HDMI_FREQDET_OFFSET, ~_BIT6, _BIT6);
 330   1      
 331   1          // Settings for IRQ set PHY
 332   1          // Consider using table to fill all required initial settings
 333   1          // Set pre-set threshold (225MHz * 0.01 / 26.8KHz = 0x54)
 334   1      
 335   1      #if(_D3_INPUT_PORT_TYPE == _D3_MHL_PORT)
                  if(GET_D3_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
                      // Set TMDS Offset = 1/32
                      ScalerSetBit(P72_E7_HDMI_FREQDET_OFFSET, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
              
                      // Set Upper Bound
                      ScalerSetByte(P72_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_MHL_FREQ_NORMAL_UPPER_BOUND));
                      ScalerSetByte(P72_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_MHL_FREQ_NORMAL_UPPER_BOUND));
                  }
C51 COMPILER V9.60.0.0   RL6432_SERIES_TMDSRX3                                             08/21/2025 10:45:19 PAGE 7   

                  else
              #endif
 347   1          {
 348   2              // Set TMDS Offset = 1/32
 349   2              ScalerSetBit(P72_E7_HDMI_FREQDET_OFFSET, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
 350   2      
 351   2              // Set Upper Bound
 352   2              ScalerSetByte(P72_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
 353   2              ScalerSetByte(P72_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
 354   2          }
 355   1      
 356   1          // Set Lower Bound
 357   1          ScalerSetByte(P72_EA_HDMI_FREQDET_LOWER_M, HIBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 358   1          ScalerSetByte(P72_EB_HDMI_FREQDET_LOWER_L, LOBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 359   1      
 360   1          // Set Stable Time (0x3F = about 5ms)
 361   1          ScalerSetByte(P72_EC_HDMI_FREQDET_STABLE, 0x3F);
 362   1      
 363   1          // Disable Freq. Unstable IRQ
 364   1          ScalerSetBit(P72_E6_HDMI_FREQDET_CTRL, ~_BIT1, 0x00);
 365   1      
 366   1          // Enable Freq. Stable IRQ
 367   1          ScalerSetBit(P72_EF_HDMI_ERROR_TH, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 368   1      
 369   1      #if(_D3_HDMI_2_0_SUPPORT == _ON)
 370   1          // Enable SCDC 0x20 Change IRQ
 371   1          ScalerSetBit(P72_26_HDMI_CTRL_26, ~_BIT4, _BIT4);
 372   1      #endif
 373   1      
 374   1          // Clear IRQ Pending Flag
 375   1          ScalerSetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_60_PORT_PAGE72_HDMI_INTCR, ~_BIT7, _BIT7);
 376   1      
 377   1          // Internal IRQ Enable (Global)
 378   1          ScalerGlobalIRQControl(_ENABLE);
 379   1      
 380   1          EX0 = 1;
 381   1      
 382   1          // Start Freq. Detection
 383   1          ScalerSetBit(P72_E6_HDMI_FREQDET_CTRL, ~_BIT7, _BIT7);
 384   1      }
