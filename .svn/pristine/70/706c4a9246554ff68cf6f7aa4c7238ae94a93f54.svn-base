4160          //--------------------------------------------------
4161          // Description  : DFE Adaptation in Normal Signal
4162          // Input Value  : None
4163          // Output Value : True --> DFE Normal
4164          //                False --> DFE Abnormal
4165          //--------------------------------------------------
4166          bit ScalerTMDSRx3CheckDataDFE(void)
4167          {
4168   1          BYTE ucTemp = 0;
4169   1          BYTE ucCnt = 0;
4170   1      
4171   1          // DFE Check only under HDMI Mode.
4172   1          // MHL has only 1 data Lane --> Skip DFE Check Process and Function return True!
4173   1          if(ScalerGetBit(P7C_17_BANDGAP_03, _BIT1) != _BIT1)
4174   1          {
4175   2              for(pData[0] = 0; pData[0] <= 2; pData[0]++)
4176   2              {
4177   3                  // Sel lane
4178   3                  ScalerSetBit(P7C_F2_COEF_3, ~(_BIT7 | _BIT6), pData[0] << 6);
4179   3      
4180   3                  // Read VTH
4181   3                  ScalerSetBit(P7C_F0_COEF_1, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
4182   3      
4183   3                  if((ScalerGetByte(P7C_F1_COEF_2) & 0x1F) == 0)
4184   3                  {
4185   4                      for(ucCnt = 0; ucCnt < 3; ucCnt++)
4186   4                      {
4187   5                          // Read TAP0
4188   5                          ScalerSetBit(P7C_F0_COEF_1, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT0);
4189   5      
4190   5                          ucTemp = (ScalerGetByte(P7C_F1_COEF_2) & 0x1F);
4191   5      
C51 COMPILER V9.60.0.0   RL6432_SERIES_TMDSRX3                                             08/21/2025 10:45:19 PAGE 71  

4192   5                          if(ucTemp < 21)
4193   5                          {
4194   6                              return _TRUE;
4195   6                          }
4196   5                          else if(ucCnt == 2)
4197   5                          {
4198   6                              DebugMessageRx3("DFE Abnormal ", 0);
4199   6                              return _FALSE;
4200   6                          }
4201   5                      }
4202   4                  }
4203   3              }
4204   2          }
4205   1      
4206   1          return _TRUE;
4207   1      }
