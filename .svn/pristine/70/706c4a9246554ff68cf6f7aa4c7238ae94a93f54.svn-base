3118   1          {
3119   2              case _COLOR_DEPTH_10_BITS:
3120   2      
3121   2                  ucFactor = 5;
3122   2      
3123   2                  break;
3124   2      
3125   2              case _COLOR_DEPTH_12_BITS:
3126   2      
3127   2                  ucFactor = 3;
3128   2      
3129   2                  break;
3130   2      
3131   2              case _COLOR_DEPTH_16_BITS:
3132   2      
3133   2                  ucFactor = 2;
3134   2      
3135   2                  break;
3136   2      
3137   2              default:
3138   2      
3139   2                  return _FALSE;
3140   2          }
3141   1      
3142   1          // N <= (Fin / 7)
3143   1          PDATA_WORD(0) = (ulTMDSClkValue / 7000);
3144   1      
