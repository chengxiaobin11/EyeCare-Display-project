3146   1          {
3147   2              return _FALSE;
3148   2          }
3149   1          else if(PDATA_WORD(0) >= ucFactor)
3150   1          {
3151   2              // N: Multiple of factor
3152   2              PDATA_WORD(0) -= (PDATA_WORD(0) % ucFactor);
3153   2          }
3154   1          else if(PDATA_WORD(0) > 255)
3155   1          {
