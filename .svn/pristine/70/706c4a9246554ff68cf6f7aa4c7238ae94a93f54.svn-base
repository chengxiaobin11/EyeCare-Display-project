3194   1          // Assume DPLL_M=0x13, DPM=0x13+2=21; DPN=2; reg_dpll_vcomd='b01; reg_dpll_rs[2:0]='b011;       //
3195   1          // Icp = (700 * 21 * 2 * 3.14) / (1340 * 13)                                                    //
