3200          // Description  : Check Whther ADC Data is Reasonable
3201          // Input Value  : LOAD or SAVE
3202          // Output Value : _TRUE => Reasonable
3203          //--------------------------------------------------
3204          bit UserInterfaceGetNVRamDataStatus(EnumNvramCheckType enumNvramCheckType)
3205          {
3206   1          switch(enumNvramCheckType)
3207   1          {
3208   2      #if(_VGA_SUPPORT == _ON)
                      case _CHECK_ADC_LOAD:
              
                          if(g_stAdcData.ucAdcPGA >= 0xF0)
                          {
                              // Assign Prefered Value
                              g_stAdcData.ucAdcPGA = 8;
                          }
              
