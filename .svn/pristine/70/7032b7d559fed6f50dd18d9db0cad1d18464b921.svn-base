4816          BYTE UserAdjustDCRCalPwm(BYTE ucRGBValValue)
4817          {
4818   1              BYTE i=0;
4819   1              BYTE ucPwm=0;
4820   1              BYTE tRGBValValue[5] = {0,55,110,165,233};//{0,50,75,175,255};
4821   1              BYTE tBacklightPwm[5] = 0;
4822   1      
4823   1      #if 0   //MPRTÓëDCR»Ąłâ
                      if((GET_OSD_MPRT()!=_OFF)&&(SysModeGetModeState() ==_MODE_STATUS_ACTIVE)&&(GET_INPUT_TIMING_VFREQ()> _MPR
             -T_MIN_FRAME_RATE)&&(GET_OSD_FREE_SYNC_STATUS() == _OFF))
                      {
                              tBacklightPwm[0] = MPRTBacklightDefault[0];
                              tBacklightPwm[1] = (MPRTBacklightDefault[1]-MPRTBacklightDefault[0])/2+MPRTBacklightDefault[0];
                              tBacklightPwm[2] = MPRTBacklightDefault[1];
                              tBacklightPwm[3] = (MPRTBacklightDefault[2]-MPRTBacklightDefault[1])/2+MPRTBacklightDefault[1];
                              tBacklightPwm[4] = MPRTBacklightDefault[2];
              
                      }
                      else
              #endif
4835   1              {
4836   2      
4837   2                      tBacklightPwm[0] = BacklightDefault[0];
4838   2                      tBacklightPwm[1] = (BacklightDefault[1]-BacklightDefault[0])/2+BacklightDefault[0];
4839   2                      tBacklightPwm[2] = BacklightDefault[1];
4840   2                      tBacklightPwm[3] = (BacklightDefault[2]-BacklightDefault[1])/2+BacklightDefault[1];
4841   2                      tBacklightPwm[4] = BacklightDefault[2];
4842   2      
4843   2              }
4844   1              
4845   1              for(i=0;i < 4;i++)
4846   1              {
4847   2                      if((tRGBValValue[i] <= ucRGBValValue) && (ucRGBValValue < tRGBValValue[i+1]))
4848   2                      {
4849   3                              break;
4850   3                      }
4851   2              }
4852   1              
4853   1              if(ucRGBValValue>=233)
4854   1                      i=4;
4855   1              
4856   1              ucPwm =tBacklightPwm[i] +(WORD)(ucRGBValValue-tRGBValValue[i])*(tBacklightPwm[i+1] - tBacklightPwm[i])/(t
             -RGBValValue[i+1] -tRGBValValue[i]);
4857   1      
4858   1              return ucPwm;
4859   1      }
