 910   2                              ucCount = 1;
 911   2                      if(ucCount ==1)
 912   2                      return;
 913   2              }
 914   1              else if(GET_OSD_DCR_STATUS() == _DCR_Level_2)
 915   1              {
 916   2                      if(ucCount>5)
 917   2                              ucCount = 1;
 918   2                      if(ucCount ==2||ucCount ==4)
 919   2                      return;
 920   2              }
 921   1              else if(GET_OSD_DCR_STATUS() == _DCR_Level_3)
 922   1              {
 923   2                      if(ucCount>4)
 924   2                              ucCount = 1;
 925   2                      if(ucCount ==4)
 926   2                      return;
 927   2              }
 928   1              else if(GET_OSD_DCR_STATUS() == _DCR_Level_4)
 929   1              {
 930   2      
 931   2              }
 932   1      
 933   1      
 934   1          if(GET_DCR_HOLD_STATUS() == _TRUE)
