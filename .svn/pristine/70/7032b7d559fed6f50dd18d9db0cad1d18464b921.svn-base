              //--------------------------------------------------
              // Description  : Check VGA First Auto Config
              // Input Value  : None
              // Output Value : _TRUE => Do Auto Config
              //--------------------------------------------------
              bit UserInterfaceGetFirstAutoConfigStatus(void)
              {
                  if((GET_VGA_MODE_DO_FIRST_AUTO() == _TRUE) &&
                     (GET_INPUT_TIMING_HWIDTH() > 600))
                  {
                      return _TRUE;
                  }
              
                  return _FALSE;
              }
              
