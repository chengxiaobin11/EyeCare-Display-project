 172          //-------------------------------------------------
 173          // Description  : Calculate DVTotal for OneFrame FRC
 174          // Input Value  : None
 175          // Output Value : usDVTotal
 176          //-------------------------------------------------
 177          WORD ScalerFRCSetOneFrameDVTotal(void)
 178          {
 179   1          DWORD ulFrameDiff = 0;
 180   1          DWORD ulActiveRegionDiff = 0;
 181   1          WORD usIHF = 0;
 182   1          WORD usDHF = 0;
 183   1          WORD usDVTotal = 0;
 184   1      
 185   1          if((DWORD)g_stMDomainOutputData.usVHeight * 1066 / 1000 < _PANEL_DV_TOTAL)
 186   1          {
 187   2              usDHF = (DWORD)_PANEL_MAX_FRAME_RATE * _PANEL_DV_TOTAL / 1000;
 188   2          }
 189   1          else
 190   1          {
 191   2              usDHF = (DWORD)_PANEL_MAX_FRAME_RATE * (DWORD)g_stMDomainOutputData.usVHeight * 1066 / 1000 / 1000
             -;
 192   2          }
 193   1      
 194   1          usIHF = (DWORD)g_stMDomainInputData.usVFreq * g_stMDomainInputData.usVTotal / 1000;
 195   1          ulFrameDiff = (DWORD)1000 * ((DWORD)1000 * g_stMDomainInputData.usVFreq - (DWORD)1000 * _PANEL_MAX_FRA
             -ME_RATE) / ((DWORD)g_stMDomainInputData.usVFreq * _PANEL_MAX_FRAME_RATE);
 196   1          ulActiveRegionDiff = (DWORD) 1000 * ((DWORD)g_stMDomainOutputData.usVHeight * usIHF - (DWORD)g_stMDoma
             -inInputData.usVHeight * usDHF) / ((DWORD)usIHF * usDHF);
 197   1      
 198   1          if((ulFrameDiff * 100 / ulActiveRegionDiff) < 125)
 199   1          {
 200   2              usDVTotal = (DWORD)1000 * g_stMDomainOutputData.usVHeight / ((ulFrameDiff * 100 / 125) + ((DWORD)1
             -000 * g_stMDomainInputData.usVHeight / usIHF)) * 1000 / _PANEL_MAX_FRAME_RATE;
 201   2          }
 202   1          else if((DWORD)g_stMDomainOutputData.usVHeight * 1066 / 1000 < _PANEL_DV_TOTAL)
 203   1          {
 204   2              usDVTotal = _PANEL_DV_TOTAL;
 205   2          }
 206   1          else
 207   1          {
 208   2              usDVTotal = (DWORD)g_stMDomainOutputData.usVHeight * 1066 / 1000;
 209   2          }
 210   1      
 211   1          if(usDVTotal > _PANEL_DV_TOTAL_MAX)
 212   1          {
 213   2              usDVTotal = _PANEL_DV_TOTAL_MAX;
 214   2          }
 215   1          else if(usDVTotal < _PANEL_DV_TOTAL_MIN)
 216   1          {
 217   2              usDVTotal = _PANEL_DV_TOTAL_MIN;
 218   2          }
 219   1      
 220   1          return usDVTotal;
 221   1      }
