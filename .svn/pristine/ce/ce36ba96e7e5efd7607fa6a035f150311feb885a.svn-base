 798          //--------------------------------------------------
 799          void ScalerFRCOneFrameCtrl(DWORD ulIHF, DWORD ulDHF)
 800          {
 801   1          SWORD shMargin = 0;
 802   1          WORD usPreRead = 0;
 803   1          WORD usLeadingLine = 0;
 804   1          WORD usLength = g_stMDomainInputData.usVHeight;
 805   1          bit bAutoMode = 1; // 1:auto mode; 0:manual mode
 806   1      
 807   1          if(g_stMDomainInputData.usVHeight > g_stMDomainOutputData.usVHeight)
 808   1          {
 809   2              usLength = g_stMDomainOutputData.usVHeight;
 810   2          }
 811   1      
 812   1          if(ulIHF > ulDHF)
 813   1          {
 814   2              usPreRead = g_stMDomainOutputData.usVStart - _PRE_READ_MEMORY;
 815   2              ulIHF = (ulIHF % 10) ? (ulIHF / 10 + 1) : (ulIHF / 10);
 816   2              shMargin = 0x02;
 817   2              ulDHF = ulDHF * usLength / 10;
 818   2          }
 819   1          else
 820   1          {
 821   2              // forbidden lines
 822   2              usPreRead = ((DWORD)g_stMDomainOutputData.usVHeight * ulDHF / ulIHF - g_stMDomainOutputData.usVHei
             -ght);
 823   2              usPreRead = (usPreRead < 10) ? 10 : usPreRead;
 824   2      
 825   2              if(g_stMDomainInputData.usVFreq > _PANEL_MAX_FRAME_RATE)
 826   2              {
 827   3                  // input frame leading lines in display
 828   3                  usLeadingLine = (DWORD)(g_stMDomainInputData.usVFreq - _PANEL_MAX_FRAME_RATE) * _PANEL_DV_TOTA
             -L_MIN / g_stMDomainInputData.usVFreq;
 829   3              }
 830   2              else if(g_stMDomainInputData.usVFreq < _PANEL_MIN_FRAME_RATE)
 831   2              {
 832   3                  // input frame leading lines in display
 833   3                  usLeadingLine = (DWORD)(_PANEL_MAX_FRAME_RATE - g_stMDomainInputData.usVFreq) * _PANEL_DV_TOTA
             -L_MIN / g_stMDomainInputData.usVFreq;
 834   3              }
 835   2      
 836   2              if(usPreRead <= g_stMDomainOutputData.usVStart)
 837   2              {
 838   3                  if((usPreRead * 15 / 10) < usLeadingLine)
 839   3                  {
