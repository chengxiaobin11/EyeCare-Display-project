4568          WORD OsdDisplayDetOverRange(WORD usValue, WORD usMax, WORD usMin, bit bCycle)
4569          {
4570   1      //if(_OSD_FUN_START<=GET_OSD_STATE() && GET_OSD_STATE()< _OSD_FUN_END)
4571   1      {
4572   2          switch(GET_KEYMESSAGE())
4573   2          {
4574   3              case _RIGHT_KEY_MESSAGE:
4575   3          case _DOWN_KEY_MESSAGE:
4576   3                  if(usValue >= usMax)
4577   3                  {
4578   4                      if(bCycle == _ON)
4579   4                      {
4580   5                          return usMin;
4581   5                      }
4582   4                      else
4583   4                      {
4584   5                          return usMax;
4585   5                      }
4586   4                  }
4587   3                  else
4588   3                  {
4589   4                      usValue++;
4590   4                  }
4591   3      
4592   3                  break;
4593   3      
4594   3              case _LEFT_KEY_MESSAGE:
4595   3          case _UP_KEY_MESSAGE:
4596   3                  if (usValue <= usMin)
4597   3                  {
4598   4                      if(bCycle == _ON)
4599   4                      {
4600   5                          return usMax;
4601   5                      }
4602   4                      else
4603   4                      {
4604   5                          return usMin;
4605   5                      }
4606   4                  }
4607   3                  else
4608   3                  {
4609   4                      usValue--;
4610   4                  }
4611   3                  break;
4612   3      
4613   3              default:
4614   3                  break;
4615   3          }
4616   2      }
4617   1          return usValue;
4618   1      }
