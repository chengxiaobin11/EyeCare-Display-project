 292   1      
 293   1          // Disable Scrambling Status
C51 COMPILER V9.60.0.0   SCALERTMDSRX1_SEPTPHY                                             09/09/2025 14:04:11 PAGE 6   

 294   1          ScalerSetDataPortBit(P71_39_HDMI_CTRL_39, _P71_3A_PT_21_PORT_PAGE71_HDMI_SCDC_21, ~_BIT0, 0x00);
 295   1      
 296   1          // Clear Scrambling Detection Flag
 297   1          ScalerSetBit(P71_01_HDMI_CTRL_01, ~_BIT3, _BIT3);
 298   1      
 299   1          ScalerTimerCancelTimerEvent(_SCALER_TIMER_EVENT_RX1_HDMI2_SCRAMBLE_DETECT_TIMEOUT);
 300   1      }
