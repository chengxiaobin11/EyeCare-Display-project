  91          //--------------------------------------------------
  92          // Description  : Set Config of TMDS Mac Deonly mode
  93          // Input Value  : None
  94          // Output Value : enumInputPort, enumDeonlyConfig
  95          //--------------------------------------------------
  96          void ScalerTMDSRx1SetDeOnlyModeConfig(EnumDeOnlyConfig enumDeonlyConfig)
  97          {
  98   1          // De only enable?
  99   1          if((enumDeonlyConfig & _DE_ONLY_DISABLE) == _DE_ONLY_DISABLE)
 100   1          {
 101   2              ScalerSetBit(P71_A7_TMDS_PWDCTL, ~_BIT7, 0x00);
 102   2          }
 103   1          else if((enumDeonlyConfig & _DE_ONLY_ENABLE) == _DE_ONLY_ENABLE)
 104   1          {
 105   2              ScalerSetBit(P71_A7_TMDS_PWDCTL, ~_BIT7, _BIT7);
 106   2          }
 107   1      
 108   1          // Set HS
 109   1          if((enumDeonlyConfig & _DE_ONLY_HS_8T) == _DE_ONLY_HS_8T)
C51 COMPILER V9.60.0.0   SCALERTMDSRX1_SEPTPHY                                             09/09/2025 14:04:11 PAGE 3   

 110   1          {
 111   2              ScalerSetBit(P71_AB_TMDS_ACC2, ~_BIT7, _BIT7);
 112   2          }
 113   1          else if((enumDeonlyConfig & _DE_ONLY_HS_72T) == _DE_ONLY_HS_72T)
 114   1          {
 115   2              ScalerSetBit(P71_AB_TMDS_ACC2, ~_BIT7, 0x00);
 116   2          }
 117   1      }
