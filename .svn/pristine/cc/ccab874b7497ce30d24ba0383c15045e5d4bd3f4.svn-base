 188   1      
 189   1          return _FALSE;
 190   1      }
 191          //--------------------------------------------------
 192          // Description  : HDMI Deep Color Proc
 193          // Input Value  : void
 194          // Output Value : _TRUE or _FALSE
 195          //--------------------------------------------------
 196          bit ScalerTMDSRx1HdmiDeepColorProc(WORD usTmdsClkCnt)
 197          {
 198   1          // Setting Deep Color PLL
 199   1          if(ScalerTMDSRx1HdmiSetDeepColorPll(usTmdsClkCnt, GET_COLOR_DEPTH()) == _FALSE)
 200   1          {
 201   2              return _FALSE;
 202   2          }
 203   1      
 204   1          // Wait for Phase lock
 205   1          if(ScalerTMDSRx1HdmiWaitDeepColorPllLock() == _FALSE)
 206   1          {
 207   2              return _FALSE;
 208   2          }
 209   1      
 210   1          return _TRUE;
 211   1      }
