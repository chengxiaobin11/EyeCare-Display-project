 119          //--------------------------------------------------
 120          // Description  : Get Config of TMDS Mac Deonly mode
 121          // Input Value  : None
 122          // Output Value : EnumDeOnlyConfig
 123          //--------------------------------------------------
 124          EnumDeOnlyConfig ScalerTMDSRx1GetDeOnlyModeConfig(void)
 125          {
 126   1          EnumDeOnlyConfig enumDeConfig = _DE_NO_INDICATED;
 127   1      
 128   1          if(ScalerGetBit(P71_A7_TMDS_PWDCTL, _BIT7) == _BIT7)
 129   1          {
 130   2              enumDeConfig = _DE_ONLY_ENABLE;
 131   2          }
 132   1          else
 133   1          {
 134   2              enumDeConfig = _DE_ONLY_DISABLE;
 135   2          }
 136   1      
 137   1          if(ScalerGetBit(P71_AB_TMDS_ACC2, _BIT7) == _BIT7)
 138   1          {
 139   2              enumDeConfig |= _DE_ONLY_HS_8T;
 140   2          }
 141   1          else
 142   1          {
 143   2              enumDeConfig |= _DE_ONLY_HS_72T;
 144   2          }
 145   1      
 146   1          return enumDeConfig;
 147   1      }
