 464   1      #endif
 465   1          {
 466   2              PCB_D1_HOTPLUG(_D1_HOT_PLUG_LOW);
 467   2      
 468   2      #if(_DP_HDMI_COMPATIBLE_MODE == _ON)
                      if(GET_TMDS_RX1_HPD_TRIGGER_EVENT() != _TMDS_HPD_EIZO_PS_WAKEUP)
              #endif
 471   2              {
 472   3                  ScalerTMDSRx1SwitchHdcpSlaveAddr();
 473   3              }
 474   2      
 475   2      #if(_DELL_HDMI_HPD_DDC_STYLE_SUPPORT == _ON)
                      g_ucTmdsD1DdcramNackStatus = ScalerSyncGetDdcForceNackStatus(_D1_INPUT_PORT);
              
                      if(g_ucTmdsD1DdcramNackStatus == _FALSE)
C51 COMPILER V9.60.0.0   SCALERTMDSRX1_SEPTPHY                                             09/09/2025 14:04:11 PAGE 9   

                      {
                          // DDCRAM Force Nack
                          ScalerSyncSetDdcForceNack(_D1_INPUT_PORT, _ON);
