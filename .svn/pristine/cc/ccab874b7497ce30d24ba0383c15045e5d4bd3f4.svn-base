 176          //--------------------------------------------------
 177          // Description  : Detect HDMI AVI pixel repetition
 178          // Input Value  : None
 179          // Output Value : _TRUE => Current Info is different from previous setting
 180          //--------------------------------------------------
 181          bit ScalerTMDSRx1HdmiAviPixelRepInfoChanged(void)
 182          {
 183   1          // Check Tmds Pixel Repetition
 184   1          if(ScalerTMDSRx1HdmiGetAVIInfo(_AVI_INFO_PIXEL_REPETITION) != GET_TMDS_RX1_AVI_PIXEL_REPETITION())
 185   1          {
 186   2              return _TRUE;
