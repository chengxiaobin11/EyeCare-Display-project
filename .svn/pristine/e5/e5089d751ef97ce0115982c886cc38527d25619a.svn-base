  40          bit ScalerFlashRead(BYTE ucBank, WORD usAddr, WORD usLength, BYTE *pucData);
  41          
  42          //****************************************************************************
  43          // FUNCTION DEFINITIONS
  44          //****************************************************************************
  45          //--------------------------------------------------
  46          // Description  : Load data from flash
  47          // Input Value  : ucBank: bank index
  48          //                usAddr: address in ucBank
  49          //                ucLength: the data length to load
  50          //                pucData: data buffer to save the load data
  51          // Output Value : _TRUE for load success and _FALSE for load fail
C51 COMPILER V8.12   SCALERCOMMONFLASHREAD                                                 03/11/2025 19:55:38 PAGE 2   

  52          //--------------------------------------------------
  53          bit ScalerFlashRead(BYTE ucBank, WORD usAddr, WORD usLength, BYTE *pucData)
  54          {
  55   1          WORD usIndex = 0;
  56   1      
  57   1          // The access bank is smaller than than the start bank
  58   1          if(ucBank < MCU_FFFD_XDATA_BANK_START)
  59   1          {
  60   2              return _FALSE;
  61   2          }
  62   1      
  63   1          // Enable flash access and address auto increase
  64   1          MCU_FF7C_ACCESS_FLASH_DATA_CTRL |= (_BIT1 | _BIT0);
  65   1      
  66   1          MCU_FF78_ACCESS_FLASH_ADDR_0 = ucBank;
  67   1          MCU_FF79_ACCESS_FLASH_ADDR_1 = (BYTE)(usAddr >> 8);
  68   1          MCU_FF7A_ACCESS_FLASH_ADDR_2 = (BYTE)(usAddr);
  69   1      
  70   1          for(usIndex = 0; usIndex < usLength; usIndex++)
  71   1          {
  72   2              pucData[usIndex] = MCU_FF7B_ACCESS_FLASH_DATA_PORT;
  73   2          }
  74   1      
  75   1          // Disable flash access
  76   1          MCU_FF7C_ACCESS_FLASH_DATA_CTRL &= ~_BIT0;
  77   1      
  78   1          return _TRUE;
  79   1      }
