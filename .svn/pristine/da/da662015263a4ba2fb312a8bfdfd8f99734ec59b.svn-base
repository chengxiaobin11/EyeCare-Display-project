                   11339     $nomod51  NOLINES
                   11340     $nocond 
                   11341     ;------------------------------------------------------------------------------
                   11342     ;  This file is part of the BL51 / LX51 Banked Linker/Locater package
                   11343     ;  Copyright (c) 1988 - 2001 Keil Elektronik GmbH and Keil Software, Inc.
                   11344     ;  Version 2.21 (Code and Variable Banking for Classic 8051 Derivatives)
                   11345     ;------------------------------------------------------------------------------
A51 MACRO ASSEMBLER  L51_BANK                                                             05/24/2025 14:03:58 PAGE    49

                   11346     ;************************ Configuration Section *******************************
                   11347     ; Define maximum Number of Banks                                              *
  0010             11348     ?B_NBANKS       EQU  0x10;                  *
                   11349     ;                         ; following values are allowed: 2, 4, 8, 16, 32, 64 *
                   11350     ;                         ; for BL51 the maximum value for ?B_BANKS is 32     *
                   11351     ;                         ; for LX51 the maximum value for ?B_BANKS is 64     *
                   11352     ;                                                                             *
  0001             11353     ?B_MODE         EQU  1    ; 0 for Bank-Switching via 8051 Port                *
                   11354     ;                         ; 1 for Bank-Switching via XDATA Port               *
                   11355     ;                         ; 4 for user-provided bank switch code              *
                   11356     ;                                                                             *
  0000             11357     ?B_RTX          EQU  0    ; 0 for applications without real-time OS           *
                   11358     ;                         ; 1 for applications using the RTX-51 real-time OS  *
                   11359     ;                                                                             *
  0000             11360     ?B_VAR_BANKING  EQU  0    ; Variable Banking via L51_BANK (far memory support)*
                   11361     ;                         ; 0 Variable Banking does not use L51_BANK.A51      *
                   11362     ;                         ; 1 Variable Banking uses this L51_BANK.A51 module  *
                   11363     ; Notes: ?B_VAR_BANKING uses the 'far' and 'far const' C51 memory types to    *
                   11364     ;        extent the space for variables in RAM and/or ROM of classic 8051     *
                   11365     ;        device.  The same hardware as for code banking is used.  Program     *
                   11366     ;        code banking and variable banking share the same hardware I/O pins.  *
                   11367     ;        The C51 Compiler must be used with the VARBANKING directive.         *
                   11368     ;        Variable Banking is only supported with the LX51 linker/locater.     *
                   11369     ;                                                                             *
  00FF             11370     ?B_RST_BANK     EQU  0xFF ; specifies the active code bank number after CPU   *
                   11371     ;                         ; Reset.  Used to reduce the entries in the         *
                   11372     ;                         ; INTERBANK CALL TABLE.  The value 0xFF disables    *
                   11373     ;                         ; this LX51 linker/locater optimization.            *
                   11374     ; Note:  Interbank Call Table optimization is only possible with LX51.        *
                   11375     ;                                                                             *
                   11376     ;-----------------------------------------------------------------------------*
                   11377     ;                                                                             *
                             ENDIF;                                                                        *
                   11390     ;                                                                             *
                   11391     IF  ?B_MODE = 1;                                                              *
                   11392     ;-----------------------------------------------------------------------------*
                   11393     ; if ?BANK?MODE is 1 define the following values                              *
                   11394     ; For Bank-Switching via XDATA Port define XDATA Port Address / Bits          *
  FFFF             11395     ?B_XDATAPORT    EQU     0FFFFH   ; default is XDATA Port Address 0FFFFH       *
  0000             11396     ?B_FIRSTBIT     EQU     0        ; default is Bit 0                           *
                   11397     ;-----------------------------------------------------------------------------*
                   11398     ENDIF;                                                                        *
                   11399     ;                                                                             *
                             ENDIF;                                                                        *
                   11458     ;                                                                             *
                             ENDIF;                                                                        *
                   11479     ;                                                                             *
                   11480     ;******************************************************************************
                   11481     ;                                                                             *
                   11482     ; THEORY OF OPERATION                                                         *
                   11483     ; -------------------                                                         *
                   11484     ; The section below describes the code generated by BL51 or LX51 and the      *
                   11485     ; operation of the L51_BANK.A51 module.  BL51/LX51 generates for each         *
                   11486     ; function that is located in a code memory bank and called from the common   *
                   11487     ; area or a different code bank and entry into the INTRABANK CALL TABLE.  The *
                   11488     ; INTRABANK CALL TABLE is located in the SEGMENT ?BANK?SELECT and listed in   *
                   11489     ; the Linker MAP file. The entries in that TABLE have the following format:   *
                   11490     ;                                                                             *
                   11491     ;   ?FCT?1:  MOV  DPTR,#FCT     ; Load Address of target FCT                  *
                   11492     ;            JMP  ?B_BANKn      ; Switch to Bank and Jump to Target Code      *
                   11493     ;                                                                             *
                   11494     ; Instead of directly calling the function FCT, the Linker changes the entry  *
                   11495     ; to ?FCT?1.  This entry selects the bank where the function FCT is located   *
                   11496     ; and calls that function via the routines defined in this L51_BANK.A51 file. *
                   11497     ; The L51_BANK.A51 file contains two sets of functions for each bank:         *
                   11498     ;                                                                             *
A51 MACRO ASSEMBLER  L51_BANK                                                             05/24/2025 14:03:58 PAGE    50

                   11499     ; ?B_BANKn    is a routine which saves the entry of the ?B_SWITCHn function   *
                   11500     ;             for the current active bank on the STACK and switches to the    *
                   11501     ;             bank 'n'.  Then it jumps to the address specified by the DPTR   *
                   11502     ;             register.  It is allowed to modify the following registers in   *
                   11503     ;             the ?B_BANKn routine:  A, B, R0, DPTR, PSW                      *
                   11504     ;                                                                             *
                   11505     ; ?B_SWITCHn  is a function which selects the bank 'n'.  This function is     *
                   11506     ;             used at the end of a user function to return to the calling     *
                   11507     ;             code bank.  Only the following registers may be altered in the  *
                   11508     ;             ?B_SWITCHn function:  R0, DPTR                                  *
                   11509     ;                                                                             *
                   11510     ; The current active bank is stored in ?B_CURRENTBANK.  RTX-51 uses this      *
                   11511     ; variable to restore the code bank after a task switch.  To get correct      *
                   11512     ; results, ?B_CURRENTBANK must be set to the code bank before the hardware    *
                   11513     ; switch is done, or the code banking sequences must be interrupt protected.  *
                   11514     ;******************************************************************************
                   11515     
                   11516                     NAME    ?BANK?SWITCHING
                   11517     
                   11518                     PUBLIC  ?B_NBANKS, ?B_MODE, ?B_CURRENTBANK, ?B_MASK
                   11519                     PUBLIC  ?B_FACTOR, ?B_RST_BANK
                             ENDIF
                   11523     
                   11524     ; Standard SFR Symbols required in L51_BANK.A51
  00E0             11525     ACC     DATA    0E0H
  00F0             11526     B       DATA    0F0H
  0082             11527     DPL     DATA    82H
  0083             11528     DPH     DATA    83H
  00A8             11529     IE      DATA    0A8H
  00AF             11530     EA      BIT     IE.7
                   11531     
                   11532     
                   11533     ; generate Mask and Bank Number Information
                             ELSEIF  ?B_NBANKS <= 16
  000F             11541       MASK          EQU     00001111B
                             ENDIF
                   11547     
                             ENDIF  ; close block IF ?B_MODE = 0 *******************************************
                   11801     
                   11802     
                   11803     IF ?B_MODE = 1 ;***************************************************************
                   11804     
  0001             11805     ?B_FACTOR       EQU     1 SHL ?B_FIRSTBIT
                   11806     
  000F             11807     ?B_MASK         EQU     MASK SHL ?B_FIRSTBIT
                   11808     
                   11809     BANKN           MACRO   N
                   11810     BANK&N          EQU     N SHL ?B_FIRSTBIT
                   11811                     ENDM
                   11812     
  0000             11813     CNT             SET     0
                   11814     
                   11815                     REPT    ?B_NBANKS
                   11816                     BANKN   %CNT
                   11817     CNT             SET     CNT+1
                   11818                     ENDM
                   11819+1                   BANKN   %CNT
                   11822+1                   BANKN   %CNT
                   11825+1                   BANKN   %CNT
                   11828+1                   BANKN   %CNT
                   11831+1                   BANKN   %CNT
                   11834+1                   BANKN   %CNT
                   11837+1                   BANKN   %CNT
                   11840+1                   BANKN   %CNT
                   11843+1                   BANKN   %CNT
                   11846+1                   BANKN   %CNT
A51 MACRO ASSEMBLER  L51_BANK                                                             05/24/2025 14:03:58 PAGE    51

                   11849+1                   BANKN   %CNT
                   11852+1                   BANKN   %CNT
                   11855+1                   BANKN   %CNT
                   11858+1                   BANKN   %CNT
                   11861+1                   BANKN   %CNT
                   11864+1                   BANKN   %CNT
                   11867     
                   11868     
                   11869     ?C_INITSEG      SEGMENT CODE            ; Segment for Variable Initialization
----               11870                     RSEG    ?C_INITSEG
0000 01            11871                     DB      01H             ; IData
0001 00       F    11872                     DB      ?B_CURRENTBANK  ; Init Current Bank
0002 00            11873                     DB      0               ; Set to Zero
                   11874     
                   11875     
                   11876     
                   11877     
                   11878     
                   11879     ;User/both Code don't do this for use relocte function 30H
                   11880     ;Boot Code and No Dual bank case do this.
0003 41            11881                     DB      41H                        ; XData
0004 FFFF          11882                     DW      ?B_XDATAPORT               ; Init XDATA Port
0006 00            11883                     DB      0 ; Set to intial bank
                   11884     
                   11885     
                   11886                     PUBLIC  ?B_XDATAPORT
                   11887     
                   11888     ?BANK?DATA      SEGMENT DATA
----               11889                     RSEG    ?BANK?DATA
0000               11890     ?B_CURRENTBANK: DS      1
                   11891     
                   11892     
                             ENDIF
                   11969     
                   11970     
                   11971     IF ?B_NBANKS <= 16
                   11972       ; Convert Bank No in Accu to Address * 16
                   11973       IF  ?B_FIRSTBIT = 0
                   11974       CONVBANKNO    MACRO
                   11975                     SWAP    A
                   11976                     ENDM
                   11977       ENDIF
                   11978     
                               ENDIF
                   11985     
                               ENDIF
                   11992     
                               ENDIF
                   11998     
                               ENDIF
                   12003     
                               ENDIF
                   12009     
                               ENDIF
                   12016     
                               ENDIF
                   12023     
                   12024       SWITCH        MACRO   N
                   12025                     ORG     N * 16
                   12026                     PUBLIC  ?B_SWITCH&N
                   12027       ?B_SWITCH&N:
                   12028                     MOV     R0,A
