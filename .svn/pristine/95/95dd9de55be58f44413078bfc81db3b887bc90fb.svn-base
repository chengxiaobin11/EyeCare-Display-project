  51          void ScalerOsdRoundedWindowPattern16x16(BYTE ucIdx, BYTE ucType)
C51 COMPILER V8.12   OSDROUNDEDWINDOWPATTERN16X16                                          03/11/2025 19:55:59 PAGE 2   

  52          {
  53   1          WORD usAddr = P3A_64_FRAME_CTRL_64;
  54   1      
  55   1          usAddr += (ucIdx / 2);
  56   1          if((ucIdx % 2) == 0)
  57   1          {
  58   2              ScalerSetBit(usAddr, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (ucType & 0x0F));
  59   2          }
  60   1          else
