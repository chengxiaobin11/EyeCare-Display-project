  90          // Description  : Set Global IRQ Control Register
  91          // Input Value  : CM_14_IRQ_CTRL0 Register Value
  92          // Output Value : None
  93          //--------------------------------------------------
  94          void ScalerGlobalIRQControl(bit bEn)
  95          {
  96   1          if(bEn == _ENABLE)
  97   1          {
  98   2              ScalerSetBit(P0_04_IRQ_CTRL0, ~_BIT7, _BIT7);
  99   2          }
 100   1          else
 101   1          {
 102   2              ScalerSetBit(P0_04_IRQ_CTRL0, ~_BIT7, 0x00);
 103   2          }
 104   1      }
