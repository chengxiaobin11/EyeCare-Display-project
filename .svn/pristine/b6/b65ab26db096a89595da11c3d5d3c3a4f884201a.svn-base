4194          #if(_DEF_INDICATO_LIGHT_Flick_EANBLE)
              
              
              void IndicatoLlghtFlickerEvent(void)
              {
                if(GET_FACTORY_BURNIN()) // łČŔ¶ÉÁË¸
                {
              
                  if((bLED1 == _LED_OFF) && (bLED2 == _LED_ON))
                  {
                    bLED1=_LED_ON;
                    bLED2=_LED_OFF;
                  }
                  else
C51 COMPILER V9.60.0.0   RTDFACTORYMODE                                                    09/09/2025 18:05:02 PAGE 75  

                  {
                    bLED1=_LED_OFF;
                    bLED2=_LED_ON;
                  }
              
                }
                else  // łČµĆÉÁË¸ 
                {
                
                  if((bLED1 == _LED_ON) && (bLED2 == _LED_ON))
                  {
                    bLED1=_LED_OFF;
                        bLED2=_LED_ON;
                  }
                  else
                  {
                    bLED1=_LED_ON;
                        bLED2=_LED_ON;
                  }
              
                }
              
              
                ScalerTimerActiveTimerEvent(SEC(1), _USER_TIMER_EVENT_OSD_INDICATO_LIGHT_FACTORY_FLICKER);
              }
              
