 696          void RTDFactoryMenuOperation(void)
 697          {
 698   1          if((GET_OSD_STATE() >= _MENU_FACTORY_AUTOCOLOR) &&
 699   1             (GET_OSD_STATE() < _MENU_FACTORY_OSD_END) &&
 700   1             (GET_KEYMESSAGE() <_KEY_AMOUNT))
