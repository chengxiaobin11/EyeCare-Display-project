C51 COMPILER V8.12   RL6449_SERIES_COLORSRGBADJUST                                         03/11/2025 19:56:15 PAGE 2   

  52          //--------------------------------------------------
  53          // Description  : Adjust SRGB function
  54          // Input Value  : SRGB Matrix
  55          //                SRGB Precision
  56          // Output Value : _TRUE/_FALSE
  57          //--------------------------------------------------
  58          bit ScalerColorSRGBAdjust(BYTE *pucSRGBArray, EnumSrgbPrecision enumPrecision)
  59          {
  60   1          // Clear Waiting flag
  61   1          ScalerSetBit(P0_62_SRGB_CTRL, ~_BIT7, 0x00);
  62   1          ScalerSetBit(P0_62_SRGB_CTRL, ~_BIT6, _BIT6); // Reset Port
  63   1      
  64   1          if(ScalerTimerPollingFlagProc(2, P0_62_SRGB_CTRL, _BIT6, 0) == _FALSE) // pollling till Reset port add
             -ress finished
  65   1          {
  66   2              return _FALSE;
  67   2          }
  68   1      
  69   1          ScalerSetBit(P0_62_SRGB_CTRL, ~(_BIT5 | _BIT4 | _BIT3), 0x00); // Write sequence
  70   1      
  71   1          if(ScalerGetBit(P9_A1_INPUT_GAMMA_CTRL, _BIT6) == _BIT6)
  72   1          {
  73   2              ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  74   2          }
  75   1      
  76   1          ScalerBurstWrite(pucSRGBArray, _SRGB_TABLE_SIZE, GET_CURRENT_BANK_NUMBER(), P0_63_SRGB_ACCESS_PORT_SET
             -A, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_XRAM);
  77   1      
  78   1          ScalerSetBit(P0_68_GAMMA_BIST_DITHER_SETA, ~(_BIT6 | _BIT5), (enumPrecision << 5)); // Precision
  79   1      
  80   1          ScalerSetBit(P0_62_SRGB_CTRL, ~_BIT7, _BIT7);   // no apply none, always effective on dvs
  81   1      
  82   1          return _TRUE;
  83   1      }
  84          
  85          


