  49          // Description  : Set Tcon12 local enable
  50          // Input Value  : bEnable --> enable
  51          // Output Value : None
C51 COMPILER V8.12   RL6449_SERIES_TCON12                                                  03/11/2025 19:56:22 PAGE 2   

  52          //--------------------------------------------------
  53          void ScalerTcon12Enable(bit bEnable)
  54          {
  55   1          ScalerSetDataPortBit(P15_A3_TCON_ADDR, _P15_A4_PT_D8_TC12_CTRL, ~(_BIT7), ((BYTE)bEnable << 7));
  56   1      }
  57          
  58          //--------------------------------------------------
  59          // Description  : Set Tcon12 Region
  60          // Input Value  : usHstart --> Horizon start
  61          //                usHend --> Horizon end
  62          //                usVstart --> Vertical start
  63          //                usVend --> Vertical end
  64          // Output Value : None
  65          //--------------------------------------------------
  66          void ScalerTcon12Adjust(WORD usHstart, WORD usHend, WORD usVstart, WORD usVend)
  67          {
  68   1          usVstart &= 0x1FFF;
  69   1          usVend &= 0x1FFF;
  70   1      
  71   1          usHstart &= 0x1FFF;
  72   1          usHend &= 0x1FFF;
  73   1      
  74   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_D0_TC12_VS_MSB, HIBYTE(usVstart));
  75   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_D1_TC12_VS_LSB, LOBYTE(usVstart));
  76   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_D2_TC12_VE_MSB, HIBYTE(usVend));
  77   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_D3_TC12_VE_LSB, LOBYTE(usVend));
  78   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_D4_TC12_HS_MSB, HIBYTE(usHstart));
  79   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_D5_TC12_HS_LSB, LOBYTE(usHstart));
  80   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_D6_TC12_HE_MSB, HIBYTE(usHend));
  81   1          ScalerSetDataPortByte(P15_A3_TCON_ADDR, _P15_A4_PT_D7_TC12_HE_LSB, LOBYTE(usHend));
  82   1      }
