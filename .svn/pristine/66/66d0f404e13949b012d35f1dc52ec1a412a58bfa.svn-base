  49          //--------------------------------------------------
  50          // Description  : Initial for VGIP Input
  51          // Input Value  : Input Source Type
  52          // Output Value : None
  53          //--------------------------------------------------
  54          void ScalerVgipInputInitial(EnumSourceTypeDef enumSourceType, EnumSourceSearchPort enumSourceSearchPort)
  55          {
  56   1          enumSourceSearchPort = enumSourceSearchPort;
  57   1      
  58   1          // Set Input Pixel Format, Disable Double buffer, Analog Capture, and Stop generate DE
  59   1          ScalerSetBit(P0_10_M1_VGIP_CTRL, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), ((enumSourceType == _SOURCE
             -_VGA) ? 0x00 : _BIT2));
  60   1      
  61   1          // HS Sync Edge select to Positive, Disable 1 clock Delay Mode
  62   1          ScalerSetBit(P0_12_M1_VGIP_DELAY_CTRL, ~(_BIT4 | _BIT3 | _BIT2), 0x00);
  63   1      
  64   1          // Reset field detect edge
  65   1          ScalerSetBit(P0_11_M1_VGIP_SIGINV, ~(_BIT5 | _BIT3), 0x00);
  66   1      
  67   1      #if(_FREESYNC_SUPPORT == _ON)
  68   1          if((GET_FREESYNC_ENABLED() == _TRUE) && (enumSourceType == _SOURCE_DP))
  69   1          {
  70   2              // Enable bypass Vsync
  71   2              ScalerVgipVsBypassEnable(_ENABLE);
  72   2          }
  73   1          else
  74   1          {
  75   2              // Disable bypass Vsync
  76   2              ScalerVgipVsBypassEnable(_DISABLE);
  77   2          }
  78   1      #else
                  // Disable bypass Vsync
                  ScalerVgipVsBypassEnable(_DISABLE);
              #endif
  82   1      
  83   1      #if((_MEASURE_ADJUSTED_IHF_SUPPORT == _ON) || (_MEASURE_ADJUSTED_IVF_SUPPORT == _ON))
  84   1          // Set to analog measure
  85   1          ScalerVgipSetDigitalCaptureStatus(_DISABLE);
  86   1      #endif
  87   1      
  88   1          // Initial IVS/IHS Delay for Capture and Auto
  89   1          ScalerVgipSetCaptureHDelay(0x00);
  90   1          ScalerVgipSetCaptureVDelay(0x00);
  91   1      
  92   1      #if((_MEASURE_ADJUSTED_IHF_SUPPORT == _ON) || (_MEASURE_ADJUSTED_IVF_SUPPORT == _ON))
  93   1          ScalerVgipSetCaptureHStartPosition(0x00);
  94   1          ScalerVgipSetCaptureVStartPosition(0x00);
  95   1      
  96   1          // Set to digital measure
  97   1          ScalerVgipSetDigitalCaptureStatus(_ENABLE);
  98   1      #endif
  99   1      }


