 132          //--------------------------------------------------
 133          // Description  : Set Config of TMDS Mac Deonly mode
 134          // Input Value  : None
 135          // Output Value : enumInputPort, enumDeonlyConfig
 136          //--------------------------------------------------
 137          void ScalerTMDSRx3SetDeOnlyModeConfig(EnumDeOnlyConfig enumDeonlyConfig)
 138          {
 139   1          // De only enable?
 140   1          if((enumDeonlyConfig & _DE_ONLY_DISABLE) == _DE_ONLY_DISABLE)
 141   1          {
 142   2              ScalerSetBit(P72_A7_TMDS_PWDCTL, ~_BIT7, 0x00);
 143   2          }
 144   1          else if((enumDeonlyConfig & _DE_ONLY_ENABLE) == _DE_ONLY_ENABLE)
 145   1          {
 146   2              ScalerSetBit(P72_A7_TMDS_PWDCTL, ~_BIT7, _BIT7);
 147   2          }
 148   1      
 149   1          // Set HS
 150   1          if((enumDeonlyConfig & _DE_ONLY_HS_8T) == _DE_ONLY_HS_8T)
 151   1          {
 152   2              ScalerSetBit(P72_AB_TMDS_ACC2, ~_BIT7, _BIT7);
 153   2          }
 154   1          else if((enumDeonlyConfig & _DE_ONLY_HS_72T) == _DE_ONLY_HS_72T)
 155   1          {
 156   2              ScalerSetBit(P72_AB_TMDS_ACC2, ~_BIT7, 0x00);
 157   2          }
 158   1      }
 159          
 160          //--------------------------------------------------
 161          // Description  : Get Config of TMDS Mac Deonly mode
 162          // Input Value  : None
 163          // Output Value : EnumDeOnlyConfig
 164          //--------------------------------------------------
 165          EnumDeOnlyConfig ScalerTMDSRx3GetDeOnlyModeConfig(void)
 166          {
 167   1          EnumDeOnlyConfig enumDeConfig = _DE_NO_INDICATED;
 168   1      
 169   1          if(ScalerGetBit(P72_A7_TMDS_PWDCTL, _BIT7) == _BIT7)
C51 COMPILER V9.60.0.0   SCALERTMDSRX3_SEPTPHY                                             08/21/2025 10:44:29 PAGE 4   

 170   1          {
 171   2              enumDeConfig = _DE_ONLY_ENABLE;
 172   2          }
 173   1          else
 174   1          {
 175   2              enumDeConfig = _DE_ONLY_DISABLE;
 176   2          }
 177   1      
 178   1          if(ScalerGetBit(P72_AB_TMDS_ACC2, _BIT7) == _BIT7)
 179   1          {
 180   2              enumDeConfig |= _DE_ONLY_HS_8T;
 181   2          }
 182   1          else
 183   1          {
 184   2              enumDeConfig |= _DE_ONLY_HS_72T;
 185   2          }
 186   1      
 187   1          return enumDeConfig;
 188   1      }
