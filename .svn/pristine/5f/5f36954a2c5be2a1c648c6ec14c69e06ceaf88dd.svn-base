 206          //--------------------------------------------------
 207          // Description  : Detect TMDS video mode
 208          // Input Value  : bWait => Whether to wait then read
 209          // Output Value : TMDS video type
 210          //--------------------------------------------------
 211          BYTE ScalerTMDSRx3TMDSVideoDetect(bit bWait)
 212          {
 213   1          BYTE ucTemp = _TMDS_VIDEO_DATA_NONE;
 214   1      
 215   1          if(bWait == _WAIT)
 216   1          {
 217   2              // Wait at least 1 frame for HW auto update TMDS video RGBHV valid value
 218   2              ScalerTimerPollingFlagProc(45, P72_A4_TMDS_CTRL, _BIT3, _TRUE);
 219   2      
 220   2              // Wait for HW update DE flag
 221   2              if(ScalerTimerPollingFlagProc(20, P72_A4_TMDS_CTRL, (_BIT7 | _BIT6 | _BIT5), _TRUE) == _TRUE)
 222   2              {
 223   3                  // H/Vsync received
 224   3                  if(ScalerGetBit(P72_A4_TMDS_CTRL, (_BIT4 | _BIT3)) == (_BIT4 | _BIT3))
 225   3                  {
 226   4                      ucTemp = _TMDS_VIDEO_DATA_RGBHV;
 227   4                  }
 228   3                  else
 229   3                  {
 230   4                      ucTemp = _TMDS_VIDEO_DATA_DE_ONLY;
 231   4                  }
C51 COMPILER V9.60.0.0   SCALERTMDSRX3_SEPTPHY                                             08/21/2025 10:44:29 PAGE 5   

 232   3              }
 233   2              else
 234   2              {
 235   3                  ucTemp = _TMDS_VIDEO_DATA_NONE;
 236   3              }
 237   2      
 238   2              CLR_TMDS_RX3_RGBHV_DETECTING();
 239   2      
 240   2              return ucTemp;
 241   2          }
 242   1          else
 243   1          {
 244   2              // R/G/B data detected
 245   2              if(ScalerGetBit(P72_A4_TMDS_CTRL, (_BIT7 | _BIT6 | _BIT5)) == (_BIT7 | _BIT6 | _BIT5))
 246   2              {
 247   3                  // H/Vsync received
 248   3                  if(ScalerGetBit(P72_A4_TMDS_CTRL, (_BIT4 | _BIT3)) == (_BIT4 | _BIT3))
 249   3                  {
 250   4                      ucTemp = _TMDS_VIDEO_DATA_RGBHV;
 251   4                  }
 252   3                  else
 253   3                  {
 254   4                      ucTemp = _TMDS_VIDEO_DATA_DE_ONLY;
 255   4                  }
 256   3              }
 257   2              else
 258   2              {
 259   3                  ucTemp = _TMDS_VIDEO_DATA_NONE;
 260   3              }
 261   2      
 262   2              // Clear video Detection Flag
 263   2              ScalerSetBit(P72_A4_TMDS_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), (_BIT7 | _BIT6 | _BIT5 | 
             -_BIT4 | _BIT3));
 264   2      
 265   2              SET_TMDS_RX3_RGBHV_DETECTING();
 266   2      
 267   2              // Activate TMDS video Detection Event
 268   2              ScalerTimerActiveTimerEvent(45, _SCALER_TIMER_EVENT_RX3_TMDS_VIDEO_DETECT);
 269   2      
 270   2              return ucTemp;
 271   2          }
 272   1      }
