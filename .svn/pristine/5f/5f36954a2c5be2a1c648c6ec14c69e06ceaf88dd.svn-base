 868   3                  }
 869   2      
 870   2                  break;
 871   2      
 872   2              case _HDMI_2_0_READ_REQUEST_NACK2:
 873   2      
 874   2      #if(_WD_TIMER_INT_SUPPORT == _ON)
 875   2                  if(GET_HDMI_2_0_RX3_RR_ENABLE() == _TRUE)
 876   2                  {
 877   3                      // Enable Read Request Retry
 878   3                      ScalerTimerWDActivateTimerEvent_EXINT0(10, _SCALER_WD_TIMER_EVENT_RX3_HDMI_RR_RETRY);
 879   3                  }
 880   2      #endif
 881   2      
 882   2                  break;
