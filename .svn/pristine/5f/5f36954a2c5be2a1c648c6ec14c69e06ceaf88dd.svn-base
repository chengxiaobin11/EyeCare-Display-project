 539          //--------------------------------------------------
 540          // Description  : Get Color Depth
 541          // Input Value  : None
 542          // Output Value : Received Color Depth
 543          //--------------------------------------------------
 544          BYTE ScalerTMDSRx3HdmiGetColorDepth(void)
 545          {
 546   1          if(GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR422)
 547   1          {
 548   2              return _COLOR_DEPTH_12_BITS;
 549   2          }
 550   1      
 551   1          if(GET_HDMI_RX3_GCP_RECEIVED() == _TRUE)
 552   1          {
 553   2              if(ScalerGetBit(P72_B4_TMDS_DPC0, 0x07) == 0x05)
 554   2              {
 555   3                  return _COLOR_DEPTH_10_BITS;
 556   3              }
 557   2              else if(ScalerGetBit(P72_B4_TMDS_DPC0, 0x07) == 0x06)
 558   2              {
 559   3                  return _COLOR_DEPTH_12_BITS;
 560   3              }
 561   2              else if(ScalerGetBit(P72_B4_TMDS_DPC0, 0x07) == 0x07)
 562   2              {
 563   3                  return _COLOR_DEPTH_16_BITS;
 564   3              }
 565   2          }
 566   1      
 567   1          return _COLOR_DEPTH_8_BITS;
 568   1      }
