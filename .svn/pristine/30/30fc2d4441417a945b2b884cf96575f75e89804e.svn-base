             -AUDIO_INPUT == _PS_AUDIO_DP)))
                  if((GET_AUDIO_PLAYING_ALONE() == _TRUE) && (UserInterfaceGetAudioSource() == _DIGITAL_AUDIO))
                  {
                      return _TRUE;
