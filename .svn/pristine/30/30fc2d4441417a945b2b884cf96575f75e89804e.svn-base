              void SysDpTxHandler(void)
              {
                  if(GET_POWER_STATUS() == _POWER_STATUS_NORMAL)
                  {
                      // HPD Detection Function
                      ScalerDpTxHPDProc();
              
                      ScalerDpTxJudgeHandler();
              
                      ScalerDpTxModeHandler();
              
              #if(_DP_HDCP_2_2_SUPPORT == _ON)
                      SysDpTxHdcp2Handler();
