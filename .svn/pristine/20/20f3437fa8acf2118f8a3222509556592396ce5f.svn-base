C51 COMPILER V8.12   RL6449_SERIES_COLORDCCHISTOSETTING                                    03/11/2025 19:56:03 PAGE 2   

  52          // Description  : Set Y_MAX_LB, Y_MIN_HB
  53          // Input Value  : None
  54          // Output Value : None
  55          //--------------------------------------------------
  56          void ScalerColorDCCHistoSetting(void)
  57          {
  58   1          // Set Y max lower bound and Y min higher bound
  59   1          ScalerSetBit(P7_C7_DCC_CTRL_0, ~(_BIT1 | _BIT0), _PAGE0);
  60   1          ScalerSetByte(P7_C9_DCC_ADDRESS_PORT, _P7_CA_PT_07_PORT_PAGE0_Y_MAX_LB_H);
  61   1          ScalerSetByte(P7_CA_DCC_DATA_PORT, (BYTE)(_DCC_HISTO_YMAX_LB >> 2));
  62   1          ScalerSetByte(P7_CA_DCC_DATA_PORT, (BYTE)(_DCC_HISTO_YMIN_HB >> 2));
  63   1          ScalerSetByte(P7_C9_DCC_ADDRESS_PORT, _P7_CA_PT_1A_PORT_PAGE0_Y_MAX_LB_L);
  64   1          ScalerSetByte(P7_CA_DCC_DATA_PORT, (BYTE)(_DCC_HISTO_YMAX_LB & (_BIT1 | _BIT0)));
  65   1          ScalerSetByte(P7_CA_DCC_DATA_PORT, (BYTE)(_DCC_HISTO_YMIN_HB & (_BIT1 | _BIT0)));
  66   1      
  67   1          // Enable DCC
  68   1          ScalerSetBit(P7_C7_DCC_CTRL_0, ~_BIT7, _BIT7);
  69   1      }


