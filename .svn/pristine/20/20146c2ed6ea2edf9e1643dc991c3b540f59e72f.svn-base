  53          //--------------------------------------------------
  54          // Description  : Adjust IDither Setting
  55          // Input Value  :
  56          //                pucDitherTable : Dither Table Pointer
  57          //                ucBankAddress : Bank Address
  58          // Output Value : None
  59          //--------------------------------------------------
  60          void ScalerColorIDitherLoadDitherTable(BYTE code *pucDitherTable, BYTE ucBankAddress)
  61          {
  62   1          if(pucDitherTable != _NULL_POINTER)
  63   1          {
  64   2              ScalerSetBit(P0_89_I_DITHER_COMMON_CTRL1_SETA, ~(_BIT7 | _BIT6), 0x80);
  65   2              ScalerBurstWrite(pucDitherTable, _DITHER_TABLE_LENGTH, ucBankAddress, P0_88_I_DITHER_DATA_ACCESS_S
             -ETA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  66   2              ScalerSetBit(P0_89_I_DITHER_COMMON_CTRL1_SETA, ~(_BIT7 | _BIT6), 0x00);
  67   2          }
  68   1      }
  69          
