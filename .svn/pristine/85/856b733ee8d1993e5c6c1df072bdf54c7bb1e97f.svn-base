1610          void ScalerMcuDdcciInitial(void)
1611          {
1612   1          // Set slave address for debug tool
1613   1          MCU_FF23_IIC_SET_SLAVE = 0x6A;
1614   1          // Set DDCCI Mode for Debug Tool
1615   1          ScalerDebugSelectDDCCIDebugMode(_DEBUG_MODE);
