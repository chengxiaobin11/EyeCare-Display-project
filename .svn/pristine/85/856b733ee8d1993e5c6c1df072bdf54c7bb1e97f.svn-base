                  // DDC from DDC5 channel
                  MCU_FF22_IIC_CH_SEL &= ~(_BIT2 | _BIT1 | _BIT0);
                  MCU_FF22_IIC_CH_SEL |= (_BIT2 | _BIT1);
              #elif(_DEBUG_DDC_CHANNEL_SEL == _DDC4)
                  // DDC from DDC4 channel
                  MCU_FF22_IIC_CH_SEL &= ~(_BIT2 | _BIT1 | _BIT0);
