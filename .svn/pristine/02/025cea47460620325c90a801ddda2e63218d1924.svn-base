  51          void ScalerColorHLWDDomainEnable(EnumFunctionOnOFF enumOn)
C51 COMPILER V8.12   SCALERCOLORHLWDDOMAINENABLE                                           03/11/2025 19:55:45 PAGE 2   

  52          {
  53   1          // If HLW Without Double Buffer, Wait for DEN Stop
  54   1          if(ScalerGlobalGetHLWDBStatus() == _FALSE)
  55   1          {
  56   2              ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  57   2          }
  58   1      
  59   1          if(enumOn == _FUNCTION_ON)
  60   1          {
  61   2              // Ddomain one HLW
  62   2              ScalerSetDataPortBit(P0_60_HLW_ADDR_PORT, _P0_61_PT_0C_HLW_BORDER_EN, ~_BIT0, _BIT0);
  63   2          }
  64   1          else // bOn == _OFF || bOn == _CLOCK_GATED
  65   1          {
  66   2              ScalerSetDataPortBit(P0_60_HLW_ADDR_PORT, _P0_61_PT_0C_HLW_BORDER_EN, ~_BIT0, 0x00);
  67   2          }
  68   1      }
