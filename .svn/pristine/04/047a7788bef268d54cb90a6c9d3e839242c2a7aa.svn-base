1532          //--------------------------------------------------
1533          // Description  : Check the page is vaild or not
1534          // Input Value  : ucPage: The page to be check, must between 0 and (_END_PAGE - _START_PAGE)
1535          // Output Value : _TRUE means the page is valid, _FLASE is invalid
1536          //--------------------------------------------------
1537          bit RTDFlashIsPageInfoValid(BYTE ucPage)
1538          {
1539   1          WORD usPageInfoAddr = ucPage * _FLASH_PAGE_SIZE;
1540   1          BYTE ucPageInfoChecksum = 0;
