1542   1          BYTE pucPageInfoTemp[4] = {0};
1543   1      
1544   1          UserCommonFlashRead(_SYSTEM_EEPROM_EMULATION_FLASH_BANK, usPageInfoAddr + _PAGEINFO_CHECKSUM_ADDR, 5, 
             -pucPageInfo);
1545   1          pucPageInfoTemp[0] = pucPageInfo[1];
1546   1          pucPageInfoTemp[1] = pucPageInfo[2];
1547   1          pucPageInfoTemp[2] = pucPageInfo[3];
1548   1          pucPageInfoTemp[3] = pucPageInfo[4];
1549   1          ucPageInfoChecksum = UserCommonFlashCalculateCheckSumData(pucPageInfoTemp, 4);
1550   1          ucPageInfoChecksum = (ucPageInfoChecksum & 0x7F);
1551   1      
1552   1          if(ucPageInfoChecksum == pucPageInfo[0])
1553   1          {
1554   2              return _TRUE;
1555   2          }
1556   1      
1557   1          return _FALSE;
1558   1      }
