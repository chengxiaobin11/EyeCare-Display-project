1613          // Description  : Search the last saved item address, and next new item position
1614          // Input Value  :
1615          // Output Value :
1616          //--------------------------------------------------
1617          WORD RTDFlashSearchPageAddr(BYTE ucPageID)
1618          {
1619   1          WORD usItemAddr = 0;
