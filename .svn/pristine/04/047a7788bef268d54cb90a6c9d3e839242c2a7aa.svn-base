1483          //--------------------------------------------------
1484          // Description  : Get the free page number of flash
1485          // Input Value  : None
1486          // Output Value : Free page index
1487          //--------------------------------------------------
1488          BYTE RTDFlashGetFreePage(void)
1489          {
1490   1          BYTE ucPageID = _START_OF_PAGEID;
1491   1          BYTE ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1492   1      
1493   1          // If the _END_PAGE page has the biggest move count, suppose first page is free page
1494   1          if(g_ulFlashMoveCount > 0)
1495   1          {
1496   2              if(g_ucFlashLastPage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1497   2              {
1498   3                  ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1499   3              }
1500   2              else
1501   2              {
1502   3                  ucFreePage = g_ucFlashLastPage + 1;
1503   3              }
1504   2          }
1505   1      
1506   1          // Check the supposed free page is actual free page which has not been used ever
1507   1          do
1508   1          {
1509   2              if(ucFreePage == g_pucFlashPageArr[ucPageID])
1510   2              {
1511   3                  if(ucFreePage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1512   3                  {
1513   4                      ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1514   4                  }
1515   3                  else
1516   3                  {
1517   4                      ucFreePage += 1;
1518   4                  }
1519   3      
1520   3                  ucPageID = _START_OF_PAGEID;
1521   3              }
1522   2              else
C51 COMPILER V8.12   RTD2014NVRAMOSD                                                       01/02/2025 16:32:25 PAGE 26  

1523   2              {
1524   3                  ucPageID++;
1525   3              }
1526   2          }
1527   1          while(ucPageID <= _END_OF_PAGEID);
1528   1      
1529   1          return ucFreePage;
1530   1      }
