                      UserCommonEepromWrite(_COLORTEMP_DATA_ADDRESS + (ucColorTempType) * sizeof(StructColorProcDataType
             -), sizeof(StructColorProcDataType), (BYTE *)(&g_stColorProcData.usColorTempR));
                  }
              }
              
