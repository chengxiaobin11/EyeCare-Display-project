              #endif
 811   1      
 812   1      #if((_DVI_SUPPORT == _ON) && (_UNDERSCAN_SUPPORT == _ON))
                  if(GET_SOURCE_TYPE(g_ucSearchIndex) == _SOURCE_DVI)
                  {
