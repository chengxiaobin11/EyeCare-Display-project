 798   1      
 799   1      #if(_VGA_SUPPORT == _ON)
                  if(GET_SOURCE_TYPE(g_ucSearchIndex) == _SOURCE_VGA)
                  {
                      ScalerADCClampMode(enumColorFormat);
              
