 249          //--------------------------------------------------
 250          // Description  : Get DPF Edid Extersion Data Block Start Address
 251          // Input Value  : enumOutputPort (Px), Cta Ext DB Addr Arrary
 252          // Output Value :
 253          //--------------------------------------------------
 254          void ScalerSyncGetCtaExtDbAddress(WORD *pusCtaDataBlockAddr, BYTE *pucDdcRamAddr)
 255          {
 256   1          WORD usEDIDDataBlockStartAddress = 0x84;
 257   1          WORD usCtaBlockDtdStartAddr = 0x84;
 258   1      
 259   1          BYTE ucReadVSDBDataBlockNum = 0x00;
 260   1          BYTE ucEDIDBlockBytesNum = 0x00;
 261   1          EnumEdidCtaDbTagCode enumTag = _CTA_DBTAG_NONE;
 262   1      
 263   1          // With Extension Block
 264   1          if(pucDdcRamAddr[0x7E] != 0x00)
 265   1          {
 266   2              WORD usIndex = 0;
 267   2              BYTE ucExtBlockNum = 0;
 268   2      
 269   2              // Check HF EEODB
 270   2              if(((pucDdcRamAddr[0x84] & 0xE0) == 0xE0) && (pucDdcRamAddr[0x85] == 0x78))
 271   2              {
 272   3                  ucExtBlockNum = pucDdcRamAddr[0x86];
 273   3              }
 274   2              else
 275   2              {
 276   3                  ucExtBlockNum = pucDdcRamAddr[0x7E];
 277   3              }
 278   2      
 279   2              for(usIndex = 0; usIndex < ucExtBlockNum; usIndex++)
 280   2              {
 281   3                  // Stop Extension Analysis if Not CEA Type, Check tag = 0x02
 282   3                  if(pucDdcRamAddr[(usIndex + 1) * 0x80] == _CTA_EXTENSION_TAG)
 283   3                  {
 284   4                      usEDIDDataBlockStartAddress = ((usIndex + 1) * 0x80) + 0x04;
 285   4      
 286   4                      usCtaBlockDtdStartAddr = pucDdcRamAddr[((usIndex + 1) * 0x80) + 0x02] + ((usIndex + 1) * 0
             -x80);
 287   4      
 288   4                      if((pucDdcRamAddr[((usIndex + 1) * 0x80) + 0x02] == 4) || (pucDdcRamAddr[((usIndex + 1) * 
             -0x80) + 0x02] == 0))
 289   4                      {
 290   5                          // No Data Block Situation => d = 4, Record Cta Extend Block 1st DTD Start Addr, Searc
             -h other Block.
C51 COMPILER V9.01   SCALERSYNC                                                            05/24/2025 15:51:18 PAGE 6   

 291   5                          // No DTD & No Data Block Situation => d = 0, Record Cta Extend Block 1st DTD Start Ad
             -dr, Search other Block.
 292   5                          // Generally, the _FIRST_EXT_DTD_ADDR also meaning the last Data Block + 1.
 293   5                          pusCtaDataBlockAddr[_FIRST_EXT_DTD_ADDR] = usEDIDDataBlockStartAddress;
 294   5                          continue;
 295   5                      }
 296   4      
 297   4                      // Data Block Address Scan
 298   4                      while((usEDIDDataBlockStartAddress < usCtaBlockDtdStartAddr) && (ucReadVSDBDataBlockNum <=
             - 0x0F))
 299   4                      {
 300   5                          ucReadVSDBDataBlockNum = (ucReadVSDBDataBlockNum + 1);
 301   5                          enumTag = (pucDdcRamAddr[usEDIDDataBlockStartAddress] & 0xE0) >> 5;
 302   5      
 303   5                          switch(enumTag)
 304   5                          {
 305   6                              // Extension Data Block, Check Tag Code
 306   6                              case _CTA_DBTAG_EXTTAG:
 307   6      
 308   6                                  ucEDIDBlockBytesNum = (pucDdcRamAddr[usEDIDDataBlockStartAddress] & 0x1F);
 309   6      
 310   6                                  // Check Tag Code of Extension Data Block
 311   6                                  switch(pucDdcRamAddr[usEDIDDataBlockStartAddress + 1])
 312   6                                  {
 313   7                                      case _CTA_EXTDBTAG_VCDB:
 314   7                                          pusCtaDataBlockAddr[_CTA_VCDB] = usEDIDDataBlockStartAddress;
 315   7                                          break;
 316   7      
 317   7                                      case _CTA_EXTDBTAG_COLORDB:
 318   7      
 319   7                                          pusCtaDataBlockAddr[_CTA_CDB] = usEDIDDataBlockStartAddress;
 320   7                                          break;
 321   7      
 322   7                                      case _CTA_EXTDBTAG_SHDR_DB:
 323   7      
 324   7                                          pusCtaDataBlockAddr[_CTA_SHDR_DB] = usEDIDDataBlockStartAddress;
 325   7                                          break;
 326   7      
 327   7                                      case _CTA_EXTDBTAG_420VDB:
 328   7      
 329   7                                          pusCtaDataBlockAddr[_CTA_420VDB] = usEDIDDataBlockStartAddress;
 330   7                                          break;
 331   7      
 332   7                                      case _CTA_EXTDBTAG_420CMDB:
 333   7      
 334   7                                          pusCtaDataBlockAddr[_CTA_420CMDB] = usEDIDDataBlockStartAddress;
 335   7                                          break;
 336   7      
 337   7                                      case _CTA_EXTDBTAG_HFEEODB:
 338   7      
 339   7                                          pusCtaDataBlockAddr[_CTA_HF_EEODB] = usEDIDDataBlockStartAddress;
 340   7                                          break;
 341   7      
 342   7                                      // HF-SCDB (same as HF-VSDB)
 343   7                                      case _CTA_EXTDBTAG_HFSCDB:
 344   7      
 345   7                                          pusCtaDataBlockAddr[_CTA_HF_VSDB] = usEDIDDataBlockStartAddress;
 346   7                                          break;
 347   7      
 348   7                                      case _CTA_EXTDBTAG_T7_VTDB:
 349   7      
 350   7                                          pusCtaDataBlockAddr[_CTA_T7_VTDB] = usEDIDDataBlockStartAddress;
C51 COMPILER V9.01   SCALERSYNC                                                            05/24/2025 15:51:18 PAGE 7   

 351   7                                          break;
 352   7      
 353   7                                      default:
 354   7                                          break;
 355   7                                  }
 356   6      
 357   6                                  usEDIDDataBlockStartAddress = (usEDIDDataBlockStartAddress + 1 + ucEDIDBlockBy
             -tesNum);
 358   6      
