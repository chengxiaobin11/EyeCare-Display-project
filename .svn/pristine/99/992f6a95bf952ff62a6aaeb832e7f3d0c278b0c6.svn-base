 738          // Description  : Power Down VGA Function
 739          // Input Value  : None
 740          // Output Value : None
 741          //--------------------------------------------------
 742          void ScalerSyncAdcApllPowerDown(void)
 743          {
 744   1          // Power down APLL
 745   1          ScalerSetBit(P1_AF_PLL_WD, ~_BIT0, _BIT0);
 746   1      
 747   1          // Power down APLL by Misc Control
 748   1          ScalerSetBit(P1_F2_APLL_MISC, ~_BIT7, _BIT7);
 749   1      
 750   1          // Power down ADC VCM/ADC clock/SOG Power/RGB Channel
 751   1          ScalerSetBit(P0_C6_ADC_POWER, ~(_BIT7 | _BIT6 | _BIT5 | _BIT2 | _BIT1 | _BIT0), 0x00);
 752   1      }
