 754          //--------------------------------------------------
 755          // Description  : VGA Power Proc
 756          // Input Value  : enumPowerAction --> Power Action
 757          // Output Value : None
 758          //--------------------------------------------------
 759          void ScalerSyncAdcPowerProc(EnumPowerAction enumPowerAction)
 760          {
 761   1          switch(enumPowerAction)
 762   1          {
 763   2              case _POWER_ACTION_AC_ON_TO_NORMAL:
 764   2              case _POWER_ACTION_OFF_TO_NORMAL:
 765   2              case _POWER_ACTION_PS_TO_NORMAL:
 766   2              case _POWER_ACTION_OFF_TO_FAKE_OFF:
 767   2      
 768   2                  // ADC Bandgap Enable
 769   2                  ScalerADCBandgap(_ON);
C51 COMPILER V9.01   SCALERSYNC                                                            05/24/2025 15:51:18 PAGE 14  

 770   2      
 771   2      #if(_VGA_SUPPORT == _ON)
                          // _BIT3: H-Sync Stable Debounce Tolerance, 0 --> +-2 Crystal Cycle, 1: +- 4 Crytal Cycle
                          // Current Set P0_4F[3] = 1 In PS and Set P0_4F[3] = 0 in Normal,
                          // In order to solve H-Sync not stable when worked on some 6463 PCB Version
                          ScalerSetBit(P0_4F_STABLE_MEASURE, ~_BIT3, 0x00);
              #endif
 777   2      
 778   2                  break;
 779   2      
 780   2              case _POWER_ACTION_NORMAL_TO_PS:
 781   2      
 782   2                  // Power down ADC/APLL
 783   2                  ScalerSyncAdcApllPowerDown();
 784   2      
 785   2                  // ADC Bandgap Disable
 786   2                  ScalerADCBandgap(_OFF);
 787   2      
 788   2      #if(_VGA_SUPPORT == _ON)
                          // Schmitt trigger setting old mode in power saving.
                          ScalerSetByte(P0_F4_HS_SCHMITT_TRIGGE_CTRL, 0xC2);
              
                          // _BIT3: H-Sync Stable Debounce Tolerance, 0 --> +-2 Crystal Cycle, 1: +- 4 Crytal Cycle
                          // Current Set P0_4F[3] = 1 In PS and Set P0_4F[3] = 0 in Normal,
                          // In order to solve H-Sync not stable when worked on some 6463 PCB Version
                          ScalerSetBit(P0_4F_STABLE_MEASURE, ~_BIT3, _BIT3);
              
                          // Disable Sync proc clock
                          ScalerSetBit(P0_47_SYNC_SELECT, ~_BIT7, _BIT7);
              #endif
 800   2      
 801   2                  break;
 802   2      
 803   2              case _POWER_ACTION_NORMAL_TO_OFF:
 804   2              case _POWER_ACTION_AC_ON_TO_OFF:
 805   2              case _POWER_ACTION_PS_TO_OFF:
 806   2      
 807   2                  // Power down ADC/APLL
 808   2                  ScalerSyncAdcApllPowerDown();
 809   2      
 810   2                  // ADC Bandgap Disable
 811   2                  ScalerADCBandgap(_OFF);
 812   2      
 813   2      #if(_VGA_SUPPORT == _ON)
                          // Schmitt trigger setting old mode in power saving.
                          ScalerSetByte(P0_F4_HS_SCHMITT_TRIGGE_CTRL, 0x42);
              
                          // Disable sync pulse detect
                          ScalerSyncProcPulseDetectEnable(_DISABLE);
              
                          // Disable Sync proc clock
                          ScalerSetBit(P0_47_SYNC_SELECT, ~_BIT7, _BIT7);
              #endif
