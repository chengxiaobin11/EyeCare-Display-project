 321          void OsdPaletteLoadPigment(BYTE ucPaletteIndex, BYTE *pucColorPaletteArray)
 322          {
 323   1          BYTE ucAddr = ucPaletteIndex * 16;
 324   1          BYTE ucI = 0;
 325   1      
 326   1          for(ucI = 0; ucI < 16; ucI++)
 327   1          {
 328   2              ScalerOsdSetColorPalette(ucAddr + ucI, *(pucColorPaletteArray + (ucI * 3)), *(pucColorPaletteArray
             - + (ucI * 3) + 1), *(pucColorPaletteArray + (ucI * 3) + 2));
 329   2          }
 330   1      }
