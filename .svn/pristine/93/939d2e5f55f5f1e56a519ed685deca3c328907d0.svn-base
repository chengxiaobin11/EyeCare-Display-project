 126          //--------------------------------------------------
 127          // Description  : Scaler Whole Chip Reset
 128          // Input Value  : None
 129          // Output Value : None
 130          //--------------------------------------------------
 131          void ScalerGlobalWholeChipReset(void)
 132          {
 133   1          // Whole chip reset
 134   1          ScalerSetBit(P0_01_HOST_CTRL, ~_BIT0, _BIT0);
 135   1      
 136   1          // For Delay 10 ms
 137   1          ScalerTimerDelayXms(10);
 138   1      
 139   1          // Clear to 0
 140   1          ScalerSetBit(P0_01_HOST_CTRL, ~_BIT0, 0x00);
 141   1      }
