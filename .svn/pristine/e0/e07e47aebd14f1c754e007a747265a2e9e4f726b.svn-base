  55          void ScalerRead(WORD usAddr, WORD usLength, BYTE *pucArray, bit bAutoInc)
  56          {
  57   1          if(usLength != 0)
  58   1          {
  59   2              if(bAutoInc == _AUTOINC)
  60   2              {
  61   3                  memcpy(pucArray, (BYTE xdata *)usAddr, usLength);
  62   3              }
  63   2              else
  64   2              {
  65   3                  WORD usIndex = 0;
  66   3      
  67   3                  for(usIndex = 0; usIndex < usLength; usIndex++)
  68   3                  {
  69   4                      pucArray[usIndex] = ScalerGetByte(usAddr);
  70   4                  }
  71   3              }
  72   2          }
  73   1      }


