  51          //                usLength  --> Numbers of data we want to write
C51 COMPILER V8.12   SCALERCOMMONMULTIBYTEWRITE                                            03/11/2025 19:55:40 PAGE 2   

  52          //                pArray    --> Pointer of the writing data array
  53          //                bAutoInc  --> Address auto increasing select
  54          // Output Value : None
  55          //--------------------------------------------------
  56          void ScalerWrite(WORD usAddr, WORD usLength, BYTE *pucArray, bit bAutoInc)
  57          {
  58   1          if(usLength != 0)
  59   1          {
  60   2              if(bAutoInc == _AUTOINC)
  61   2              {
  62   3                  memcpy((BYTE xdata *)usAddr, pucArray, usLength);
  63   3              }
  64   2              else
  65   2              {
  66   3                  WORD usIndex = 0;
  67   3      
  68   3                  for(usIndex = 0; usIndex < usLength; usIndex++)
  69   3                  {
  70   4                      ScalerSetByte(usAddr, pucArray[usIndex]);
  71   4                  }
  72   3              }
  73   2          }
  74   1      }


