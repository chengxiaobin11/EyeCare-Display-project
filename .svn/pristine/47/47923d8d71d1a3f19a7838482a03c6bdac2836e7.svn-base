 103          //--------------------------------------------------
 104          // Description  : OD memory & FIFO setting
 105          // Input Value  : usWidth -> Display Width
 106          //                usHeight -> Display Height
 107          // Output Value : None
 108          //--------------------------------------------------
 109          void ScalerODSetFIFO(WORD usWidth, WORD usHeight)
 110          {
 111   1          // Even/odd mode, effective V_HEIGHT of each OD path
 112   1          WORD usODVHeightPerPath = CEILING_OF_INT_DIVISION(usHeight, _OD_PATH_NUM);
C51 COMPILER V8.12   RL6449_SERIES_ODFUNCTION                                              03/11/2025 19:56:17 PAGE 3   

 113   1      
 114   1          // Calculate Memory usage of each OD path
 115   1          PDATA_DWORD(0) = ((DWORD)CEILING(usWidth, _OD_PIXEL_PER_COMP)) * GET_OD_USE_BIT() / 10 * usODVHeightPe
             -rPath;
 116   1          PDATA_DWORD(0) = CEILING_OF_INT_DIVISION(PDATA_DWORD(0), _OD_FIFO_BUS_WIDTH);
 117   1      
 118   1          // Calculate Number and Remain --> (Number x Length + Remain) x OD_FIFO_BUS_WIDTH = Total size
 119   1          PDATA_DWORD(0) = ScalerMemoryCalculateNumberAndRemain(PDATA_DWORD(0), _OD_FIFO_WR_LENGTH, 1);
 120   1      
 121   1          // Set FIFO Write Water Level
 122   1          // M1
 123   1          ScalerSetByte(P3_D0_LS_DDR_FIFO_WTLVL_W_H, (((_OD_FIFO_WR_LENGTH / 2) & _BIT8) >> 8));
 124   1          ScalerSetByte(P3_D1_LS_DDR_FIFO_WTLVL_W_L, ((_OD_FIFO_WR_LENGTH / 2) & 0xFF));
 125   1          // M2
 126   1          ScalerSetByte(P43_D0_LS_DDR_FIFO_WTLVL_W_H, (((_OD_FIFO_WR_LENGTH / 2) & _BIT8) >> 8));
 127   1          ScalerSetByte(P43_D1_LS_DDR_FIFO_WTLVL_W_L, ((_OD_FIFO_WR_LENGTH / 2) & 0xFF));
 128   1      
 129   1          // Set FIFO Read Water Level
 130   1          // M1
 131   1          ScalerSetByte(P3_D2_LS_DDR_FIFO_WTLVL_R_H, ((_OD_FIFO_WR_LENGTH & _BIT8) >> 8));
 132   1          ScalerSetByte(P3_D3_LS_DDR_FIFO_WTLVL_R_L, (_OD_FIFO_WR_LENGTH & 0xFF));
 133   1          // M2
 134   1          ScalerSetByte(P43_D2_LS_DDR_FIFO_WTLVL_R_H, ((_OD_FIFO_WR_LENGTH & _BIT8) >> 8));
 135   1          ScalerSetByte(P43_D3_LS_DDR_FIFO_WTLVL_R_L, (_OD_FIFO_WR_LENGTH & 0xFF));
 136   1      
 137   1          // Set FIFO RW Number
 138   1          // M1
 139   1          ScalerSetByte(P3_D4_LS_DDR_FIFO_RW_NUM_H, pData[2]);
 140   1          ScalerSetByte(P3_D5_LS_DDR_FIFO_RW_NUM_L, pData[3]);
 141   1          // M2
 142   1          ScalerSetByte(P43_D4_LS_DDR_FIFO_RW_NUM_H, pData[2]);
 143   1          ScalerSetByte(P43_D5_LS_DDR_FIFO_RW_NUM_L, pData[3]);
 144   1      
 145   1          // Set FIFO RW Length
 146   1          // M1
 147   1          ScalerSetByte(P3_D6_LS_DDR_FIFO_RW_LEN_H, ((_OD_FIFO_WR_LENGTH & _BIT8) >> 8));
 148   1          ScalerSetByte(P3_D7_LS_DDR_FIFO_RW_LEN_L, (_OD_FIFO_WR_LENGTH & 0xFF));
 149   1          // M2
 150   1          ScalerSetByte(P43_D6_LS_DDR_FIFO_RW_LEN_H, ((_OD_FIFO_WR_LENGTH & _BIT8) >> 8));
 151   1          ScalerSetByte(P43_D7_LS_DDR_FIFO_RW_LEN_L, (_OD_FIFO_WR_LENGTH & 0xFF));
 152   1      
 153   1          // Set FIFO RW Remain
 154   1          // M1
 155   1          ScalerSetByte(P3_D8_LS_DDR_FIFO_RW_REMAIN_H, pData[0]);
 156   1          ScalerSetByte(P3_D9_LS_DDR_FIFO_RW_REMAIN_L, pData[1]);
 157   1          // M2
 158   1          ScalerSetByte(P43_D8_LS_DDR_FIFO_RW_REMAIN_H, pData[0]);
 159   1          ScalerSetByte(P43_D9_LS_DDR_FIFO_RW_REMAIN_L, pData[1]);
 160   1      }
