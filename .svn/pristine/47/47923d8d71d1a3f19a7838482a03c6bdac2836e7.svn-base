  52          //--------------------------------------------------
  53          // Description  : OD initialization setting
  54          // Input Value  : None
  55          // Output Value : None
  56          //--------------------------------------------------
  57          void ScalerODInitial(WORD usPanelHWidth, WORD usPanelVHeight)
  58          {
  59   1          ScalerODEnable(_FUNCTION_OFF);
  60   1      
  61   1          if(GET_OD_USE_BIT() != _OFF)
  62   1          {
  63   2              // Set OD compression settings
  64   2              ScalerODCompressionSetting();
  65   2      
  66   2              // Set OD FIFO settings
  67   2              ScalerODSetFIFO(usPanelHWidth, usPanelVHeight);
  68   2          }
  69   1      }
  70          
  71          //--------------------------------------------------
  72          // Description  : Adjust OD delta gain
  73          // Input Value  : Delta gain
  74          // Output Value : None
  75          //--------------------------------------------------
  76          void ScalerODAdjustDeltaGain(BYTE ucValue)
  77          {
  78   1          ScalerSetByte(P3_A3_DELTA_GAIN, ucValue);
  79   1      }
  80          
  81          //--------------------------------------------------
  82          // Description  : Load OD LUT
  83          // Input Value  :
  84          //                pODTable -> OD TABLE Pointer
  85          //                ucBankNum -> Bank number
  86          //                bLUTMode -> OD LUT Type (8bit/10bit LUT)
  87          // Output Value : None
  88          //--------------------------------------------------
  89          void ScalerODLoadLUT(BYTE code *pucODTable, BYTE ucBankNum, bit bLUTMode)
  90          {
  91   1          // Set OD LUT Mode
  92   1          ScalerSetBit(P3_BF_LS_LUT_CTRL, ~_BIT0, ((bLUTMode == _OD_10BIT_LUT) ? _BIT0 : 0x00));
  93   1      
  94   1          // Enable LUT access
  95   1          ScalerSetBit(P3_BF_LS_LUT_CTRL, ~(_BIT7 | _BIT6), _BIT7);
  96   1      
  97   1          ScalerBurstWrite(pucODTable, ((bLUTMode == _OD_10BIT_LUT) ? _OD_10BIT_LUT_LENGTH : _OD_8BIT_LUT_LENGTH
             -), ucBankNum, P3_C0_LS_LUT_DATA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  98   1      
  99   1          // Disable LUT access
 100   1          ScalerSetBit(P3_BF_LS_LUT_CTRL, ~_BIT7, 0x00);
 101   1      }
