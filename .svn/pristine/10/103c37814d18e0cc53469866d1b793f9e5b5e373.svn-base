  71          #if((_COLOR_CONVERSION_TYPE == _COLOR_CONVERSION_GEN_0) || (_COLOR_CONVERSION_TYPE == _COLOR_CONVERSION_GE
             -N_1) || (_COLOR_CONVERSION_TYPE == _COLOR_CONVERSION_GEN_2))
  72          //--------------------------------------------------
  73          // Description  : Load Table for Color Space Conversion
  74          // Input Value  : None
  75          // Output Value : None
  76          //--------------------------------------------------
  77          void ScalerColorSpaceConvertLoadTable(void)
  78          {
  79   1          // Enable I-Domain RGB2YUV coefficient Access, Set Y_Out/CbCr_Out Shift
  80   1          ScalerSetBit(P0_9C_RGB2YCC_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT3), (_BIT7 | _BIT6 | _BIT3));
  81   1      
  82   1          // Load I-Domain RGB2YUV Table for UltraVivid or RGB Quantization Limit Range Case
  83   1          ScalerBurstWrite(tCOLOR_CONV_RGB2YUV_ITU709, sizeof(tCOLOR_CONV_RGB2YUV_ITU709), GET_CURRENT_BANK_NUMB
             -ER(), P0_9D_RGB2YCC_COEF_DATA, _BURSTWRITE_COMMAND, _BURSTWRITE_FROM_FLASH);
  84   1      
  85   1          // Disable I-Domain RGB2YUV coefficient Access
  86   1          ScalerSetBit(P0_9C_RGB2YCC_CTRL, ~_BIT3, 0x00);
  87   1      }
  88          #endif


