                   11343     ;------------------------------------------------------------------------------
                   11344     ;  STARTUP.A51:  This code is executed after processor reset.
                   11345     ;
                   11346     ;  To translate this file use A51 with the following invocation:
                   11347     ;
                   11348     ;     A51 STARTUP.A51
                   11349     ;
                   11350     ;  To link the modified STARTUP.OBJ file to your application use the following
                   11351     ;  BL51 invocation:
                   11352     ;
                   11353     ;     BL51 <your object file list>, STARTUP.OBJ <controls>
                   11354     ;
                   11355     ;------------------------------------------------------------------------------
                   11356     ;
                   11357     ;  User-defined Power-On Initialization of Memory
                   11358     ;
                   11359     ;  With the following EQU statements the initialization of memory
                   11360     ;  at processor reset can be defined:
                   11361     ;
                   11362     ;               ; the absolute start-address of IDATA memory is always 0
  0100             11363     IDATALEN        EQU     0100H     ; the length of IDATA memory in bytes.
                   11364     ;
                   11365     ; the absolute start-address of XDATA memory
  D700             11366     XDATASTART      EQU     (0xD700)
                   11367     ; the length of XDATA memory in bytes.
  2000             11368     XDATALEN        EQU     ((0xF6FF) - (0xD700) + 1)
                   11369     ;
  0000             11370     PDATASTART      EQU     0H      ; the absolute start-address of PDATA memory
  0000             11371     PDATALEN        EQU     0H      ; the length of PDATA memory in bytes.
                   11372     ;
                   11373     ;  Notes:  The IDATA space overlaps physically the DATA and BIT areas of the
                   11374     ;          8051 CPU. At minimum the memory space occupied from the C51
                   11375     ;          run-time routines must be set to zero.
                   11376     ;------------------------------------------------------------------------------
                   11377     ;
                   11378     ;  Reentrant Stack Initilization
                   11379     ;
                   11380     ;  The following EQU statements define the stack pointer for reentrant
                   11381     ;  functions and initialized it:
                   11382     ;
                   11383     ;  Stack Space for reentrant functions in the SMALL model.
  0000             11384     IBPSTACK        EQU     0       ; set to 1 if small reentrant is used.
  0100             11385     IBPSTACKTOP     EQU     0FFH+1  ; set top of stack to highest location+1.
                   11386     ;
                   11387     ;  Stack Space for reentrant functions in the LARGE model.
  0000             11388     XBPSTACK        EQU     0       ; set to 1 if large reentrant is used.
  0000             11389     XBPSTACKTOP     EQU     0FFFFH+1; set top of stack to highest location+1.
                   11390     ;
                   11391     ;  Stack Space for reentrant functions in the COMPACT model.
  0000             11392     PBPSTACK        EQU     0       ; set to 1 if compact reentrant is used.
  0000             11393     PBPSTACKTOP     EQU     0FFFFH+1; set top of stack to highest location+1.
                   11394     ;
                   11395     ;------------------------------------------------------------------------------
                   11396     ;
                   11397     ;  Page Definition for Using the Compact Model with 64 KByte xdata RAM
                   11398     ;
                   11399     ;  The following EQU statements define the xdata page used for pdata
                   11400     ;  variables. The EQU PPAGE must conform with the PPAGE control used
                   11401     ;  in the linker invocation.
                   11402     ;
  0000             11403     PPAGEENABLE     EQU     0       ; set to 1 if pdata object are used.
                   11404     ;
  0000             11405     PPAGE           EQU     0       ; define PPAGE number.
                   11406     ;
  00A0             11407     PPAGE_SFR       DATA    0A0H    ; SFR that supplies uppermost address byte
                   11408     ;               (most 8051 variants use P2 as uppermost address byte)
A51 MACRO ASSEMBLER  STARTUP                                                              05/24/2025 14:03:59 PAGE   174

                   11409     ;
                   11410     ;------------------------------------------------------------------------------
                   11411     
                   11412     ; Standard SFR Symbols
  00E0             11413     ACC     DATA    0E0H
