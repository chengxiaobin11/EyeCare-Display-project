                   11199     ;
                   11200     ;  Reentrant Stack Initilization
                   11201     ;
                   11202     ;  The following EQU statements define the stack pointer for reentrant
                   11203     ;  functions and initialized it:
                   11204     ;
                   11205     ;  Stack Space for reentrant functions in the SMALL model.
  0000             11206     IBPSTACK        EQU     0       ; set to 1 if small reentrant is used.
  0100             11207     IBPSTACKTOP     EQU     0FFH+1  ; set top of stack to highest location+1.
