                   11213     ;  Stack Space for reentrant functions in the COMPACT model.
  0000             11214     PBPSTACK        EQU     0       ; set to 1 if compact reentrant is used.
  0000             11215     PBPSTACKTOP     EQU     0FFFFH+1; set top of stack to highest location+1.
