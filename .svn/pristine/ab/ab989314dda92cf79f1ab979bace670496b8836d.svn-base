                   11162     ;------------------------------------------------------------------------------
                   11163     ;  This file is part of the C51 Compiler package
                   11164     ;  Copyright (c) 1988-2002 Keil Elektronik GmbH and Keil Software, Inc.
                   11165     ;------------------------------------------------------------------------------
                   11166     ;  STARTUP.A51:  This code is executed after processor reset.
                   11167     ;
                   11168     ;  To translate this file use A51 with the following invocation:
                   11169     ;
                   11170     ;     A51 STARTUP.A51
                   11171     ;
                   11172     ;  To link the modified STARTUP.OBJ file to your application use the following
                   11173     ;  BL51 invocation:
                   11174     ;
                   11175     ;     BL51 <your object file list>, STARTUP.OBJ <controls>
                   11176     ;
                   11177     ;------------------------------------------------------------------------------
                   11178     ;
                   11179     ;  User-defined Power-On Initialization of Memory
                   11180     ;
                   11181     ;  With the following EQU statements the initialization of memory
                   11182     ;  at processor reset can be defined:
                   11183     ;
                   11184     ;               ; the absolute start-address of IDATA memory is always 0
  0100             11185     IDATALEN        EQU     0100H     ; the length of IDATA memory in bytes.
                   11186     ;
                   11187     ; the absolute start-address of XDATA memory
  D700             11188     XDATASTART      EQU     (0xD700)
                   11189     ; the length of XDATA memory in bytes.
  2000             11190     XDATALEN        EQU     ((0xF6FF) - (0xD700) + 1)
                   11191     ;
  0000             11192     PDATASTART      EQU     0H      ; the absolute start-address of PDATA memory
  0000             11193     PDATALEN        EQU     0H      ; the length of PDATA memory in bytes.
                   11194     ;
                   11195     ;  Notes:  The IDATA space overlaps physically the DATA and BIT areas of the
                   11196     ;          8051 CPU. At minimum the memory space occupied from the C51
