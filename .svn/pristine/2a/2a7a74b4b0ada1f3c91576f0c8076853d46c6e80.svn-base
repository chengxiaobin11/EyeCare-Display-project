 220   1          {
 221   2              ScalerVgaTopWaitForEvent(_EVENT_VGA_IVS);
 222   2              pData[0] = g_stRegVgaCapture.b3_02_5_DELAYVSLATCH_VSLATCHHSM_VSLATCH_DELAY;
 223   2          }
 224   1      
 225   1          // If the edge between H-Sync and V-Sync is too close.
 226   1          switch(pData[0])
 227   1          {
 228   2              case 0x00:
 229   2              case 0x04:
 230   2              case 0x06:
 231   2              case 0x07:
