C51 COMPILER V9.01   RL6432_SERIES_EFUSE                                                   08/18/2025 18:02:08 PAGE 2   

  48          //--------------------------------------------------
  49          void ScalerEfuseGetData(EnumEfuseDataState enumEfuseDataState, BYTE ucEfuseLength, BYTE *pucEfuseData)
  50          {
  51   1          WORD usEfuseAddress = 0;
  52   1      
  53   1          switch(enumEfuseDataState)
  54   1          {
  55   2              case _EFUSE_INIT_DATA:
  56   2                  usEfuseAddress = 326;
  57   2                  break;
  58   2      
  59   2              default:
  60   2                  return;
  61   2          }
  62   1      
  63   1          // Enable eFuse Module Clk
  64   1          ScalerSetBit(P24_A3_EFUSE_CTRL_0, ~_BIT0, 0x00);
  65   1      
  66   1          // Set eFuse Read Start Address
  67   1          ScalerSetByte(P24_A1_EFUSE_BURN_IN_1, (usEfuseAddress >> 1));
  68   1      
  69   1          // Enable Read eFuse
  70   1          ScalerSetBit(P24_A3_EFUSE_CTRL_0, ~(_BIT7 | _BIT6 | _BIT5), _BIT6);
  71   1      
  72   1          // Delay Time us [10,x] for eFuse ready
  73   1          DELAY_10US();
  74   1      
  75   1          // Load eFuse data
  76   1          if((usEfuseAddress % 2) == 0)
  77   1          {
  78   2              memcpy(pucEfuseData, (volatile BYTE xdata *)P24_A6_EFUSE_DATA0, ucEfuseLength);
  79   2          }
  80   1          else
  81   1          {
  82   2              memcpy(pucEfuseData, (volatile BYTE xdata *)P24_A7_EFUSE_DATA1, ucEfuseLength);
  83   2          }
  84   1      
  85   1          // Reset eFuse Read Start Address
  86   1          ScalerSetByte(P24_A1_EFUSE_BURN_IN_1, 0x00);
  87   1      
  88   1          // Enable Read eFuse
  89   1          ScalerSetBit(P24_A3_EFUSE_CTRL_0, ~(_BIT7 | _BIT6 | _BIT5), _BIT6);
  90   1      
  91   1          // Delay Time us [10,x] for eFuse ready
  92   1          DELAY_10US();
  93   1      
  94   1          // Disable eFuse Module Clk
  95   1          ScalerSetBit(P24_A3_EFUSE_CTRL_0, ~_BIT0, _BIT0);
  96   1      }
