  47          //--------------------------------------------------
  48          // Description  : Set osd delay reference to which osd
  49          // Input Value  : enumOsdMapType       -> _OSD_A or _OSD_B
  50          //                enumOsdReferenceType -> _OSD_FIRST_DELAY or _OSD_SECOND_DELAY
  51          // Output Value :
C51 COMPILER V8.12   OSDREFERENCEDELAY                                                     03/11/2025 19:55:52 PAGE 2   

  52          //--------------------------------------------------
  53          void ScalerOsdReferenceDelay(EnumOsdMapType enumOsdMapType, EnumOsdReferenceType enumOsdReferenceType)
  54          {
  55   1          if(enumOsdMapType == _OSD_A)
  56   1          {
  57   2              ScalerSetBit(P3A_18_FRAME_CTRL_18, ~_BIT2, (enumOsdReferenceType << 2));
  58   2          }
  59   1          else
  60   1          {
  61   2              ScalerSetBit(P3A_18_FRAME_CTRL_18, ~_BIT1, (enumOsdReferenceType << 1));
  62   2          }
  63   1      }
  64          
  65          
  66          /*
  67          //--------------------------------------------------
  68          // example
  69          //--------------------------------------------------
  70              ScalerOsdReferenceDelay(_OSD_B, _OSD_SECOND_DELAY);
  71          */
