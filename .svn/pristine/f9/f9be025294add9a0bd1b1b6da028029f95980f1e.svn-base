 172          //--------------------------------------------------
 173          // Description  : DDR Power On/Off
 174          // Input Value  : None
 175          // Output Value : None
 176          //--------------------------------------------------
 177          void ScalerDDR1PowerControl(bit bOn)
 178          {
 179   1          // Set MPLL CLK
 180   1          ScalerPLLSetMPLLFreq((DWORD)_MEMORY_PLL_CLOCK * 1000);
 181   1      
 182   1          // Set Mclk Gen Reset Align MPLL
 183   1          ScalerDDR1MclkGenReset();
 184   1      
 185   1          if(bOn == _ON)
 186   1          {
 187   2              // Set DDR1 Module Power Status
 188   2              ScalerDDR1PowerEnable(_ON);
 189   2      
 190   2              // Set DDR1 System Initial
 191   2              ScalerDDR1SystemInitial();
 192   2          }
 193   1          else
 194   1          {
 195   2              // Set DDR1 Module Power Status
 196   2              ScalerDDR1PowerEnable(_OFF);
 197   2      
 198   2              // Power off MPLL
 199   2              ScalerSetBit(P0_F8_MPLL_WD, ~_BIT0, _BIT0);
 200   2          }
 201   1      }
 202          
 203          //--------------------------------------------------
 204          // Description  : DDR1 Mclk Gen Reset
 205          // Input Value  : None
 206          // Output Value : None
 207          //--------------------------------------------------
 208          void ScalerDDR1MclkGenReset(void)
 209          {
 210   1          // Set Mclk Gen Local Reset
 211   1          ScalerSetBit(P4_A8_SDR_CLK_ALIGN, ~_BIT7, _BIT7);
 212   1      
 213   1          // Delay Time us [300,x] Waiting for DDR1 Mclk Reset
 214   1          DELAY_XUS(300);
 215   1      
 216   1          // Set Mclk Gen Local Reset
 217   1          ScalerSetBit(P4_A8_SDR_CLK_ALIGN, ~_BIT7, 0x00);
 218   1      }
 219          
