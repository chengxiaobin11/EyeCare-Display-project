 232   1      
 233   1          // Set DDR1 Module CAS Latency
 234   1          ScalerSetBit(P4_A2_SDR_CTRL1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT3 | _BIT2 | _BIT1), (_BIT6 | _BIT5 | _BIT2
             - | _BIT1));
 235   1      
 236   1          // Set DDR1 Auto Refresh Time
 237   1          ScalerSetByte(P4_A3_SDR_AREF_TIME, 0x0D);
 238   1      
 239   1          // Set DDR1 Precharge Duty Cycle
 240   1          ScalerSetBit(P4_A4_SDR_PRCG, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT1 | _BIT0));
 241   1      
 242   1          ScalerDDR1MemoryType();
