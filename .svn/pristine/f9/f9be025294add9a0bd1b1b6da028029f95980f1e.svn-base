 459   1      #if(_MEMORY_SIZE_CONFIG == _4M_16BIT_DDR1_2PCS)
                  // Set Tx2 clk Initial Phase
                  ScalerSetByte(P4_22_TX2_CLK_DLY, 0x00);
              #endif
 463   1      
 464   1          // Enable Tx Clk Calibration Circuit
 465   1          ScalerDDR1TxClkCalibrationEnable(_ON);
 466   1      
 467   1          for(ucCount = 0; ucCount <= (BYTE)(g_pucDDR1DelayChain[0] * 2); ucCount++)
 468   1          {
 469   2              ScalerSetByte(P4_C1_TX_CLK_DLY2, ucCount);
 470   2      
 471   2      #if(_MEMORY_SIZE_CONFIG == _4M_16BIT_DDR1_2PCS)
                      ScalerSetByte(P4_22_TX2_CLK_DLY, ucCount);
              #endif
 474   2              ScalerSetBit(P4_BE_SDR_RX_PHASE_CALIBRATION, ~_BIT6, _BIT6);
 475   2      
