 446          void ScalerDDR1TxClkSearchPhase(void)
 447          {
 448   1          BYTE ucCount = 0;
 449   1          BYTE ucInitialPhase = 0;
 450   1          BYTE ucPhase0 = _FALSE;
 451   1          BYTE ucEndPhase = 0;
 452   1          BYTE ucTempDiffPhase = 0;
