  46          //--------------------------------------------------
  47          // Description  : Set PCM(Input Gamma, Output Gamma, Color Matrix)
  48          // Input Value  : PCM Type --> sRGB / AdobeRGB
  49          //                Input Gamma Table  & its bank number
  50          //                Output Gamma Table & its bank number
C51 COMPILER V8.12   RL6449_SERIES_COLORPCM                                                03/11/2025 19:56:08 PAGE 2   

  51          //                Color Matrix       & its bank number
  52          // Output Value : None
  53          //--------------------------------------------------
  54          void ScalerColorPCMLoadTable(EnumPCMType enumPCMMode, BYTE *pucIGammaTableArray, BYTE *pucOGammaTableArray
             -, BYTE *pucColorMatrixArray, BYTE ucBankNum, WORD usLength, BYTE ucGammaBankNum)
  55          {
  56   1          ScalerColorSRGBSwap(_SRGB_BEFORE_OG);
  57   1      
  58   1          // Set InputGamma LUT
  59   1          if((enumPCMMode == _PCM_USER_MODE) || (enumPCMMode == _PCM_HDR_2084) || (enumPCMMode == _PCM_BYPASS))
  60   1          {
  61   2              ScalerColorPCMInputGammaAdjust(pucIGammaTableArray, ucBankNum);
  62   2          }
  63   1          else
  64   1          {
  65   2              ScalerColorPCMInputGammaAdjust((BYTE *)ScalerColorPCMGetTableAddress(enumPCMMode), ScalerColorPCMG
             -etTableBank());
  66   2          }
  67   1      
  68   1          // Load Gamma table
  69   1          ScalerColorPCMOutputGammaAdjust(pucOGammaTableArray, ucGammaBankNum);
  70   1      
  71   1          // Set color Matrix
  72   1          if((enumPCMMode == _PCM_SOFT_PROFT) || (enumPCMMode == _PCM_HDR_2084))
  73   1          {
  74   2              ScalerColorPCMSRGBAdjust(_SRGB_1_BIT_SHIFT_LEFT, pucColorMatrixArray, ucBankNum, usLength);
  75   2          }
  76   1          else if(enumPCMMode == _PCM_BYPASS)
  77   1          {
  78   2              // do nothing
  79   2          }
  80   1          else
  81   1          {
  82   2              ScalerColorPCMSRGBAdjust(_SRGB_0_BIT_SHIFT_LEFT, pucColorMatrixArray, ucBankNum, usLength);
  83   2          }
  84   1      }
