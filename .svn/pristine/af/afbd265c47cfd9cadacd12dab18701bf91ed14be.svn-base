  41          void ScalerOsdWindowGrayLevel(bit bEnable, EnumOsdWindowsType enumOsdWindowsType, BYTE ucPixelStep, BYTE u
             -cDecimalPart);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Set precise gradient level
  49          // Input Value  : bEnable            -> _ENABLE or _DISABLE
  50          //                enumOsdWindowsType -> _OSD_WINDOW_0, _OSD_WINDOW_5, _OSD_WINDOW_6, _OSD_WINDOW_7, _OSD_W
C51 COMPILER V8.12   OSDWINDOWGRAYLEVEL                                                    03/11/2025 19:56:01 PAGE 2   

             -INDOW_8, _OSD_WINDOW_9
  51          //                ucPixelStep        -> Pixel Step for toggle/incremental, can not be 0 (1 ~ 255)
  52          //                ucDecimalPart      -> Decimal part for Pixel-step (0~7)
  53          // Output Value :
  54          //--------------------------------------------------
  55          void ScalerOsdWindowGrayLevel(bit bEnable, EnumOsdWindowsType enumOsdWindowsType, BYTE ucPixelStep, BYTE u
             -cDecimalPart)
  56          {
  57   1          WORD usTempWindowNumber = 0;
  58   1          BYTE ucTemp = 0;
  59   1      
  60   1          usTempWindowNumber = 0x177 + (enumOsdWindowsType * 7);
  61   1      
  62   1          ucTemp = ScalerOsdFrameControlByteGet(usTempWindowNumber, _OSD_BYTE0);
  63   1          ucTemp = ((ucTemp & ~_BIT1) | ((BYTE)bEnable << 1));
  64   1      
  65   1          ScalerOsdFrameControlAllByte(usTempWindowNumber, _OSD_WITHOUT_DB, ucTemp, ucPixelStep, ucDecimalPart);
  66   1      }
