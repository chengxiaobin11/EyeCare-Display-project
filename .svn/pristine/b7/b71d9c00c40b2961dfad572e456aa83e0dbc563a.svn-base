                  // Set no repeat start
                  MCU_FF58_I2CM_CR3 &= ~(_BIT4 | _BIT3);
              
                  // Wait I2C Fifo Clk Switch to Mcu Clk
                  while((MCU_FF5D_I2CM_SR & _BIT5) != _BIT5)
                  {
                      if(usTimeOutCnt == 0)
                      {
