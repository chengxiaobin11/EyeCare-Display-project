                      default:
              
                          break;
                  }
              
                  // IIC command Start
                  MCU_FF55_I2CM_CR0 |= _BIT6;
              
                  // Wait until Master Transmit Complete
                  ucTimeOutCnt = _IIC_POLLING_TIME;
              
                  while((MCU_FF5D_I2CM_SR & 0x01) != 0x01)
