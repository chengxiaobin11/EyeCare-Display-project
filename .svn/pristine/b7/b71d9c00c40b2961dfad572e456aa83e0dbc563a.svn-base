                  else
                  {
                      pData[0] = ucDataLength;
                  }
              
                  switch(ucSubAddrLength)
                  {
                      case 0:
              
                          // Set data length
                          ucTempLength = ((pData[0] - 1) << 1);
              
                          break;
              
                      case 1:
              
                          // Load Sub-Address to IIC Buffer
                          MCU_FF5E_I2CM_TD = (BYTE)(usSubAddr);
              
                          // Set data length
                          ucTempLength = (pData[0] << 1);
