  47          //--------------------------------------------------
  48          // Description  : Set window gradient saturated color
  49          // Input Value  : enumOsdWindowsType -> _OSD_WINDOW_0, _OSD_WINDOW_5, _OSD_WINDOW_6, _OSD_WINDOW_7, _OSD_W
             -INDOW_8, _OSD_WINDOW_9
C51 COMPILER V8.12   OSDWINDOWSATURATEDCOLORSELECT                                         03/11/2025 19:56:01 PAGE 2   

  50          //                bversedGradient    -> _ENABLE or _DISABLE
  51          //                ucColorR           -> window RED saturated color (0 ~ 255)
  52          //                ucColorG           -> window GRN saturated color (0 ~ 255)
  53          //                ucColorB           -> window BLU saturated color (0 ~ 255)
  54          // Output Value :
  55          //--------------------------------------------------
  56          void ScalerOsdWindowSaturatedColorSelect(EnumOsdWindowsType enumOsdWindowsType, BYTE ucColorR, BYTE ucColo
             -rG, BYTE ucColorB)
  57          {
  58   1          WORD usTempWindowNumber = 0;
  59   1      
  60   1          usTempWindowNumber = 0x150 + (enumOsdWindowsType * 2);
  61   1          ScalerOsdWriteAllByte((_OSD_WIN_CONTROL), usTempWindowNumber, ucColorR, ucColorG, ucColorB);
  62   1      }
  63          
