 117          //--------------------------------------------------
 118          // Description  : Decide which scaling up function should be performed
 119          // Input Value  : Input/Output H/V Active Region
 120          // Output Value : None
 121          //--------------------------------------------------
 122          void ScalerScalingSetScalingUp(const StructSDRAMDataInfo *pstFIFOScaling)
 123          {
 124   1          CLR_V_SCALE_UP();
 125   1          CLR_H_SCALE_UP();
 126   1      
 127   1          // Disable Scale Up
 128   1          ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~(_BIT1 | _BIT0), 0x00);
 129   1      
 130   1      #if(_SHARPNESS_SUPPORT == _OFF)
                  // Disable Scale Up FixCoef
                  ScalerSetBit(P0_37_SCALE_UP_FOR_LINE_INTERLEAVE, ~(_BIT5 | _BIT4), 0x00);
              #endif
 134   1      
 135   1          //===============================
 136   1          // Decide V direction scaling up
 137   1          //===============================
 138   1          // Set V Scaling Up Factor
 139   1          if(pstFIFOScaling->usOutputVHeight < g_stMDomainOutputData.usVHeight)
 140   1          {
 141   2              SET_V_SCALE_UP();
 142   2      
 143   2              // Calculate Scaling Factor
 144   2              PDATA_DWORD(0) = GET_DWORD_MUL_DIV((1UL << (_VSU_FACTOR_BIT + 1)), pstFIFOScaling->usOutputVHeight
             -, g_stMDomainOutputData.usVHeight);
 145   2              PDATA_DWORD(0) = (PDATA_DWORD(0) + 1) >> 1;
 146   2      
 147   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_03_VER_SCALE_FACTOR_H, ((PDATA_DWORD(0) >> 16)
             - & 0x0F));
 148   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_04_VER_SCALE_FACTOR_M, ((PDATA_DWORD(0) >> 8) 
             -& 0xFF));
 149   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_05_VER_SCALE_FACTOR_L, (PDATA_DWORD(0) & 0xFF)
             -);
 150   2      
 151   2              // Set V Initial Phase
 152   2              // R = Input Height /Output Height
 153   2              // ideal initial phase: for 4line SU = (1+R)*16*8
 154   2              PDATA_DWORD(0) = (DWORD)(pstFIFOScaling->usOutputVHeight + g_stMDomainOutputData.usVHeight) * 16 *
             - 8 / g_stMDomainOutputData.usVHeight;
 155   2      
 156   2              // Check for enabling video compensation
 157   2              if((GET_INTERLACED_MODE() == _FALSE) ||
 158   2                 (ScalerFmtCnvGetSourceType() == _FC_SOURCE_ADC) ||
 159   2                 (BYPASS_VIDEO_COMPENSATION(pstFIFOScaling->usOutputVHeight, g_stMDomainOutputData.usVHeight) ==
             - _TRUE))
 160   2              {
 161   3                  ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_11_VER_FILTER_COEF_INI, pData[3]);
 162   3              }
 163   2              else
 164   2              {
 165   3                  if(pData[3] > 0xBF)
C51 COMPILER V9.60.0.0   RL6432_SERIES_SCALING                                             08/21/2025 10:45:14 PAGE 4   

 166   3                  {
 167   4                      pData[3] = 0xFF;
 168   4                  }
 169   3                  else
 170   3                  {
 171   4                      pData[3] = pData[3] + 0x40;
 172   4                  }
 173   3      
 174   3                  ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_11_VER_FILTER_COEF_INI, pData[3]);
 175   3              }
 176   2          }
 177   1          else
 178   1          {
 179   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_03_VER_SCALE_FACTOR_H, 0x0F);
 180   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_04_VER_SCALE_FACTOR_M, 0xFF);
 181   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_05_VER_SCALE_FACTOR_L, 0xFF);
 182   2      
 183   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_11_VER_FILTER_COEF_INI, 0xFF);
 184   2      
 185   2      #if(_SHARPNESS_SUPPORT == _OFF)
                      // Enable V Scale Up FixCoef
                      ScalerSetBit(P0_37_SCALE_UP_FOR_LINE_INTERLEAVE, ~_BIT4, _BIT4);
              #endif
 189   2          }
 190   1      
 191   1          if(GET_V_SCALE_UP() == _TRUE)
 192   1          {
 193   2              // Enable V Scale Up
 194   2              ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~_BIT1, _BIT1);
 195   2      
 196   2              if(GET_INTERLACED_MODE() == _TRUE)
 197   2              {
 198   3                  // VGA Input or Prefered Timing
 199   3                  if((ScalerFmtCnvGetSourceType() == _FC_SOURCE_ADC) ||
 200   3                     (BYPASS_VIDEO_COMPENSATION(pstFIFOScaling->usOutputVHeight, g_stMDomainOutputData.usVHeight
             -) == _TRUE))
 201   3                  {
 202   4                      // Disable Video Compensation
 203   4                      ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~_BIT7, 0x00);
 204   4                  }
 205   3                  else
 206   3                  {
 207   4                      // Enable Video Compensation According to Odd Field Delay One Line
 208   4                      ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~_BIT7, _BIT7);
 209   4                  }
 210   3      
 211   3      #if(_DISPLAY_ROTATION_SUPPORT == _ON)
 212   3                  // Check video compensation polarity for rotation
 213   3                  ScalerRotationCheckVideoCompensation();
 214   3      #endif
 215   3              }
 216   2              else
 217   2              {
 218   3                  // Disable Video Compensation
 219   3                  ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~_BIT7, 0x00);
 220   3              }
 221   2          }
 222   1          else
 223   1          {
 224   2              // Disable Video Compensation
 225   2              ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~_BIT7, 0x00);
 226   2          }
