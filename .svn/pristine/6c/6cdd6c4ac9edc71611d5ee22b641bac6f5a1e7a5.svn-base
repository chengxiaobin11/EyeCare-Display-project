 293          //--------------------------------------------------
 294          // Description  : Decide which scaling down function should be performed
 295          // Input Value  : Input/Output H/V Active Region
 296          // Output Value : None
 297          //--------------------------------------------------
 298          void ScalerScalingSetScalingDown(const StructSDRAMDataInfo *pstFIFOScaling)
 299          {
 300   1          CLR_V_SCALE_DOWN();
 301   1          CLR_H_SCALE_DOWN();
 302   1      
 303   1          // Disable Scale Down
 304   1          // M1
 305   1      #if(_FREESYNC_SUPPORT == _ON)
 306   1          if((GET_FREESYNC_ENABLED() == _ENABLE) && (ScalerGlobalGetDBStatus() == _FALSE))
 307   1          {
 308   2              // Keep VSD enabled under free-sync
 309   2              ScalerSetBit(P0_23_SCALE_DOWN_CTRL_M1, ~(_BIT3 | _BIT2 | _BIT1), 0x00);
 310   2          }
 311   1          else
 312   1      #endif
 313   1          {
 314   2              ScalerSetBit(P0_23_SCALE_DOWN_CTRL_M1, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 315   2          }
 316   1      
 317   1          //===============================
 318   1          // Decide H direction scaling down
 319   1          //===============================
 320   1          // Set H Scaling Down Factor
 321   1          if(g_stMDomainInputData.usHWidth > pstFIFOScaling->usInputHWidth)
 322   1          {
 323   2              SET_H_SCALE_DOWN();
 324   2      
 325   2              // Calculate Scaling Factor
 326   2              PDATA_DWORD(0) = GET_DWORD_MUL_DIV((1UL << (_HSD_FACTOR_BIT)), g_stMDomainInputData.usHWidth, pstF
             -IFOScaling->usInputHWidth);
 327   2      
 328   2              // The rounding of hsd factor may cause frame sync line buffer error under specific resolution
 329   2              if(((((1UL << _HSD_FACTOR_BIT) % pstFIFOScaling->usInputHWidth) *
 330   2                   (g_stMDomainInputData.usHWidth % pstFIFOScaling->usInputHWidth)) % pstFIFOScaling->usInputHWi
             -dth) != 0)
 331   2              {
 332   3                  PDATA_DWORD(0) += 1;
 333   3              }
 334   2      
 335   2              // M1
 336   2              ScalerSetDataPortByte(P0_24_SD_ADDRESS_PORT_M1, _P0_25_PT_05_H_SD_FACTOR_H_M1, ((PDATA_DWORD(0) >>
             - 16) & 0xFF));
 337   2              ScalerSetDataPortByte(P0_24_SD_ADDRESS_PORT_M1, _P0_25_PT_06_H_SD_FACTOR_M_M1, ((PDATA_DWORD(0) >>
             - 8) & 0xFF));
 338   2              ScalerSetDataPortByte(P0_24_SD_ADDRESS_PORT_M1, _P0_25_PT_07_H_SD_FACTOR_L_M1, (PDATA_DWORD(0) & 0
             -xFF));
C51 COMPILER V9.60.0.0   RL6432_SERIES_SCALING                                             08/21/2025 10:45:14 PAGE 7   

 339   2      
 340   2              // Calculate Initial Phase
