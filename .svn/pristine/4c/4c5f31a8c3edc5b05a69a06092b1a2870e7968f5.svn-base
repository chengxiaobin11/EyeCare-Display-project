  54          void ScalerColorDDitherLoadSeqTable(BYTE code *pucSeqTable, BYTE ucSeqLength, BYTE ucBankAddress)
  55          {
  56   1          if(pucSeqTable != _NULL_POINTER)
  57   1          {
  58   2              ScalerSetBit(P0_6A_D_DITHER_COMMON_CTRL1, ~(_BIT7 | _BIT6), 0x40);
  59   2              ScalerBurstWrite(pucSeqTable, ucSeqLength, ucBankAddress, P0_69_D_DITHER_DATA_ACCESS, _BURSTWRITE_
             -DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  60   2              ScalerSetBit(P0_6A_D_DITHER_COMMON_CTRL1, ~(_BIT7 | _BIT6), 0x00);
  61   2          }
  62   1      }
