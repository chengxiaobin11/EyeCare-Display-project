 896   1        if(GET_OSD_DCR_STATUS() == 0)
 897   1          return;
 898   1      
 899   1      #if(_MPRT_SUPPORT == _ON)
                if(GET_OSD_MPRT() != _OFF /*&& ucVFreq > _DEF_OSD_OVER_VFREQ*/)
