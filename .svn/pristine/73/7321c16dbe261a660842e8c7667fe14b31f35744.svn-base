 947   3                  SET_DCR_TARGET_VALUE(100);
 948   3          }
 949   2              else if((GET_DCR_RGB_INFORMATION() >= _DCR_ACTIVE_VALUE_MIN) && (GET_DCR_RGB_INFORMATION() <= _DCR
             -_ACTIVE_VALUE_MAX))
 950   2              {
 951   3                  SET_DCR_TARGET_VALUE((WORD)GET_DCR_RGB_INFORMATION() * 100 / _DCR_ACTIVE_VALUE_MAX);
 952   3              }
 953   2              else if((GET_DCR_RGB_INFORMATION() < _DCR_ACTIVE_VALUE_MIN) && (!GET_Y_MAX_UNDER_LABEL_STATUS()))
 954   2              {
 955   3                  if(ScalerOsdGetOsdEnable())
 956   3                  {
 957   4                      if(GET_DCR_RGB_INFORMATION() < _DCR_ACTIVE_VALUE_MIN)
 958   4                      {
