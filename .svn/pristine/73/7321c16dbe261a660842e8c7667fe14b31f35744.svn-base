                  switch(GET_OSD_LATENCY())
                  {
                      default:
                          break;
              
                      case _LATENCY_L:
                          return 0;   // 0%
              #if(_LATENCY_3_LEVEL_SUPPORT == _ON)
                      case _LATENCY_M:
                          return 50;  // 50%
              #endif
                      case _LATENCY_H:
                          return 100; // 100%
                  }
              
                  return 0;
              }
