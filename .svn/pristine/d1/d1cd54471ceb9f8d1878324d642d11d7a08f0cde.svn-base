 991          void UserInterfaceTimerEventProc(EnumScalerTimerEventID enumEventID)
 992          {
 993   1      
 994   1          switch(enumEventID)
 995   1          {
 996   2              case _USER_TIMER_EVENT_KEY_REPEAT_ENABLE:
 997   2                  SET_KEYREPEATSTART();
 998   2                  break;
 999   2      
