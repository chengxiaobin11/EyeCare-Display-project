 845          // Description  : Step by step adjust the backlight
 846          //                by control PWM
 847          // Input Value  : ucValue
 848          // Output Value : None
 849          // Return Value : None
 850          //--------------------------------------------------
 851          #define _DEF_DCR_BACK_TIME_ON                                   (1)
 852          #define _DCR_ACTIVE_VALUE_MIN                   4
 853          #define _DCR_ACTIVE_VALUE_MAX                   255
 854          
 855          #if(_DCR_BIT_MODE == _DCR_GEN_1_0_10BIT)
 856          #define _DCR_LEVEL_LOW                          (8 * 4)
 857          #else
              #define _DCR_LEVEL_LOW                          8
              #endif
 860          #define _BACKLIGHT_MIN_HIGH_DCR                 0
 861          
 862          void CDcrSlowAdjust(void)
 863          {
 864   1          if(GET_DCR_HOLD_STATUS() == _TRUE)
 865   1              {
 866   2                      if((abs(GET_DCR_PreRGB_INFORMATION() - GET_DCR_RGB_INFORMATION()) > 10)&&(ScalerOsdGetOsdEnable() == 0x0
             -0)) // original range is 20
 867   2                      {
 868   3                              SET_DCR_HOLD_STATUS(_FALSE);
 869   3                      }
 870   2              }
 871   1              else
 872   1          {
 873   2             //DebugMessageOsd("####9.GET_DCR_RGB_INFORMATION  ######",  GET_DCR_RGB_INFORMATION() );
 874   2      
 875   2                      if(GET_DCR_RGB_INFORMATION() >= 254)    //Č«°×łˇ+Ęó±ę = 254  xwei
 876   2                      {
 877   3                  SET_DCR_TARGET_VALUE(100);
 878   3                      }
 879   2              else if((GET_DCR_RGB_INFORMATION() >= _DCR_ACTIVE_VALUE_MIN) && (GET_DCR_RGB_INFORMATION() <= _DCR
             -_ACTIVE_VALUE_MAX))
 880   2              {
 881   3                  SET_DCR_TARGET_VALUE((WORD)GET_DCR_RGB_INFORMATION() * 100 / _DCR_ACTIVE_VALUE_MAX);
 882   3              }
 883   2              else if((GET_DCR_RGB_INFORMATION() < _DCR_ACTIVE_VALUE_MIN) && (!GET_Y_MAX_UNDER_LABEL_STATUS()))
 884   2              {
 885   3                  if(ScalerOsdGetOsdEnable())
 886   3                  {
 887   4                      if(GET_DCR_RGB_INFORMATION() < _DCR_ACTIVE_VALUE_MIN)
 888   4                      {
 889   5                          GET_DCR_RGB_INFORMATION() = _DCR_ACTIVE_VALUE_MIN;
 890   5                      }
 891   4      
 892   4                      g_stDcrInfo.ucRGBInfo -= _DCR_ACTIVE_VALUE_MIN;
 893   4                      SET_DCR_TARGET_VALUE((WORD)GET_DCR_RGB_INFORMATION() * 100 / (_DCR_ACTIVE_VALUE_MAX - _DCR
             -_ACTIVE_VALUE_MIN));
 894   4      
 895   4                          CLR_L4_PATTEN_TIMER();
 896   4                                      ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_DCR_BACKLIGHT_OFF);
 897   4                  }
 898   3                  else
 899   3                  {
 900   4                      SET_DCR_TARGET_VALUE(0);
 901   4      
 902   4                      if(GET_PANELPOWERSTATUS() == _PANEL_BACKLIGHT_OFF)
 903   4                      {
C51 COMPILER V8.12   RTD2014USERINTERFACE                                                  01/02/2025 16:32:17 PAGE 16  

 904   5                          //UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
 905   5                           ScalerTimerActiveTimerEvent(SEC(_DEF_DCR_BACK_TIME_ON), _USER_TIMER_EVENT_DCR_BACKLIG
             -HT_ON);
 906   5                      }
 907   4                  }
 908   3              }
 909   2              else if(GET_Y_MAX_UNDER_LABEL_STATUS())
 910   2              {
 911   3                  if(!ScalerOsdGetOsdEnable())
 912   3                  {
 913   4                      if(GET_HIGH_DCR_STATUS())
 914   4                      {
 915   5                          SET_DCR_TARGET_VALUE(0);
 916   5                          CLR_HIGH_DCR_STATUS();
 917   5                          CLR_Y_MAX_UNDER_LABEL_STATUS();
 918   5                                              CLR_L4_PATTEN_TIMER();
 919   5                      }
 920   4                      else
 921   4                      {
 922   5      //                    PCB_BACKLIGHT_PWM(_BACKLIGHT_MIN_HIGH_DCR);
 923   5                          #if(_BACKLIGHT_PWM_INVERSE == _ON)
                                  PCB_BACKLIGHT_PWM(UserGetBacklightRealValue(255 - _BACKLIGHT_MIN));
                                  #else
 926   5                          PCB_BACKLIGHT_PWM(UserGetBacklightRealValue(_BACKLIGHT_MIN));
 927   5                          #endif      
 928   5      
 929   5                          PCB_BACKLIGHT_POWER(_LIGHT_CONTROL_OFF);
 930   5      
 931   5                          if(GET_PANELPOWERSTATUS() != _PANEL_POWER_OFF_STATE)
 932   5                                      {
 933   6                              SET_PANELPOWERSTATUS(_PANEL_BACKLIGHT_OFF);
 934   6                          }
 935   5      
 936   5                          SET_DCR_ADJUST_VALUE(1);
 937   5                          return;
 938   5                      }
 939   4                  }
 940   3                  else
 941   3                  {
 942   4                      SET_DCR_TARGET_VALUE(GET_OSD_BACKLIGHT());
 943   4      
 944   4                      
 945   4                                      //UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
 946   4                                       ScalerTimerActiveTimerEvent(SEC(_DEF_DCR_BACK_TIME_ON), _USER_TIMER_EVENT_DCR_BACKLIGHT_ON);
 947   4                      
 948   4      
 949   4                      SET_HIGH_DCR_STATUS();
 950   4                  }
 951   3              }
 952   2                      else
 953   2                      {
 954   3                      SET_DCR_TARGET_VALUE(100);
 955   3                      }
 956   2      
 957   2              if(GET_DCR_ADJUST_VALUE() != GET_DCR_TARGET_VALUE())
 958   2              {
 959   3                  if(GET_DCR_ADJUST_VALUE() > GET_DCR_TARGET_VALUE())
 960   3                  {
 961   4                      g_stDcrInfo.ucDcrAdjustValue --;
 962   4                  }
 963   3                  else //if(GET_DCR_ADJUST_VALUE() < GET_DCR_TARGET_VALUE())
 964   3                              {
C51 COMPILER V8.12   RTD2014USERINTERFACE                                                  01/02/2025 16:32:17 PAGE 17  

 965   4                      g_stDcrInfo.ucDcrAdjustValue ++;
 966   4      
 967   4                      if(GET_PANELPOWERSTATUS() != _BACKLIGHT_ON_ALREADY)
 968   4                      {
 969   5                          
 970   5                          //UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
 971   5                           ScalerTimerActiveTimerEvent(SEC(_DEF_DCR_BACK_TIME_ON), _USER_TIMER_EVENT_DCR_BACKLIG
             -HT_ON);
 972   5                          
 973   5                      }
 974   4                  }
 975   3                              UserAdjustDCRBacklight(GET_DCR_ADJUST_VALUE());
 976   3              }
 977   2          }
 978   1      }
