  59          //                 ucBankNum: Bank Number
  60          //                 ucCMSel: ICM Select
  61          // Output Value  : None
  62          //--------------------------------------------------
  63          void ScalerColorICMUVOffsetLoadTable(BYTE code *pucICMTable, BYTE ucBankNum)
  64          {
  65   1          BYTE ucI = 0;
  66   1          BYTE ucCMSel = 0;
  67   1          BYTE ucTemp = 0;
  68   1      
  69   1          if(pucICMTable != NULL)
  70   1          {
  71   2              for(ucI = 0; ucI < 7; ucI++)
  72   2              {
  73   3                  ScalerFlashRead(ucBankNum, (WORD)(&pucICMTable[_CMN_INDEX_OFFSET + ucI * _ONE_CM_TABLE_SIZE]),
             - 1, &ucTemp);
  74   3      
  75   3                  switch(ucTemp)
  76   3                  {
  77   4                      case _ICM_0:
  78   4                          ucCMSel = 0;
  79   4                          break;
  80   4      
  81   4                      case _ICM_1:
  82   4                          ucCMSel = 1;
  83   4                          break;
  84   4      
  85   4                      case _ICM_2:
  86   4                          ucCMSel = 2;
  87   4                          break;
  88   4      
  89   4                      case _ICM_3:
  90   4                          ucCMSel = 3;
  91   4                          break;
  92   4      
  93   4                      case _ICM_4:
  94   4                          ucCMSel = 4;
  95   4                          break;
  96   4      
  97   4                      case _ICM_5:
  98   4                          ucCMSel = 5;
  99   4                          break;
 100   4      
 101   4                      default:
 102   4                          return;
 103   4                  }
 104   3      
 105   3                  ScalerSetBit(P7_D1_ICM_SEL, ~(_BIT2 | _BIT1 | _BIT0), ucCMSel);
 106   3                  ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_03_PORT_CMN_MST_00_DU_H);
 107   3                  ScalerBurstWrite(&pucICMTable[_CMN_UV_TABLE_OFFSET + ucI * _ONE_CM_TABLE_SIZE], _ICM_UVOFFSET_
             -TABLE_SIZE, ucBankNum, P7_D3_ICM_DATA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
 108   3                  ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_6F_PORT_CMN_MST_00_01_UV_OFFSET_L);
 109   3                  ScalerBurstWrite(&pucICMTable[_CMN_UV_LSB_TABLE_OFFSET + ucI * _ONE_CM_TABLE_SIZE], _ICM_UVOFF
