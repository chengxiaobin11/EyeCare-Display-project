  41          BYTE ScalerOsdFrameControlByteGet(WORD usAddr, EnumOsdWriteType enumOsdWriteType);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Get OSD Frame Control Byte
  49          // Input Value  : usAddr           -> WindowControl address
  50          //                enumOsdWriteType -> _OSD_BYTE0 or _OSD_BYTE1 or _OSD_BYTE2
  51          // Output Value : FrameControl Value
C51 COMPILER V8.12   OSDFRAMECONTROLBYTEGET                                                03/11/2025 19:55:50 PAGE 2   

  52          //--------------------------------------------------
  53          BYTE ScalerOsdFrameControlByteGet(WORD usAddr, EnumOsdWriteType enumOsdWriteType)
  54          {
  55   1          ScalerSetBit(P0_94_OSD_WRITE_OPTION, ~(_BIT7 | _BIT6 | _BIT5), enumOsdWriteType);
  56   1          ScalerSetBit(P0_94_OSD_WRITE_OPTION, ~(_BIT3 | _BIT2), _OSD_WIN_CONTROL);
  57   1      
  58   1          ScalerSetByte(P0_90_OSD_ADR_PORT_MSB, (HIBYTE(usAddr) & 0x7F));
  59   1          ScalerSetByte(P0_91_OSD_ADR_PORT_LSB, LOBYTE(usAddr));
  60   1      
  61   1          return ScalerGetByte(P0_92_OSD_DATA_PORT);
  62   1      }


