 290          EnumAudioSamplingFreqPacket ScalerAudioGetSamplingFreqPacket(EnumAudioSamplingFreqType enumSamplingFreqTyp
             -e)
 291          {
 292   1          switch(enumSamplingFreqType)
 293   1          {
 294   2              case _AUDIO_FREQ_32K:
 295   2                  return _AUDIO_FREQ_PACKET_32K;
 296   2      
 297   2              case _AUDIO_FREQ_44_1K:
 298   2                  return _AUDIO_FREQ_PACKET_44_1K;
 299   2      
 300   2              case _AUDIO_FREQ_48K:
 301   2                  return _AUDIO_FREQ_PACKET_48K;
 302   2      
 303   2              case _AUDIO_FREQ_64K:
 304   2                  return _AUDIO_FREQ_PACKET_64K;
 305   2      
 306   2              case _AUDIO_FREQ_88_2K:
 307   2                  return _AUDIO_FREQ_PACKET_88_2K;
 308   2      
 309   2              case _AUDIO_FREQ_96K:
 310   2                  return _AUDIO_FREQ_PACKET_96K;
 311   2      
 312   2              case _AUDIO_FREQ_128K:
 313   2                  return _AUDIO_FREQ_PACKET_128K;
 314   2      
 315   2      #if(_HW_HDMI_AUDIO_AFD_MODE_FOR_176P4_192 == _AUDIO_AFD_FW_MODE)
                      case _AUDIO_FREQ_176_4K:
                      case _AUDIO_FREQ_192K:
              
                          if(GET_REG_D0_MAC_SWITCH_TO_HDMI() == _TRUE)
                          {
                              ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_8C_PORT_PAGE2_AUDIO_FREQ_RESULT_M, ~_BIT4, _
             -BIT4);
              
                              ScalerGetDataPortByte(P2_C9_HDMI_AP, _P2_CA_PT_8C_PORT_PAGE2_AUDIO_FREQ_RESULT_M, 2, &pDat
             -a[2], _AUTOINC);
              
                              if((PDATA_WORD(1) & 0xFFF) < 0x171)
                              {
                                  DebugMessageAudio("Fs = 176.4kHz", (PDATA_WORD(1) & 0xFFF));
                                  return _AUDIO_FREQ_PACKET_176_4K;
                              }
                              else
                              {
                                  DebugMessageAudio("Fs = 192kHz", (PDATA_WORD(1) & 0xFFF));
                                  return _AUDIO_FREQ_PACKET_192K;
                              }
                          }
                          else
                          {
                              if(enumSamplingFreqType == _AUDIO_FREQ_176_4K)
                              {
                                  return _AUDIO_FREQ_PACKET_176_4K;
                              }
                              else
                              {
                                  return _AUDIO_FREQ_PACKET_192K;
                              }
                          }
              #else
 348   2              case _AUDIO_FREQ_176_4K:
C51 COMPILER V9.60.0.0   SCALERAUDIO                                                       09/09/2025 14:03:42 PAGE 7   

 349   2                  return _AUDIO_FREQ_PACKET_176_4K;
 350   2      
 351   2              case _AUDIO_FREQ_192K:
 352   2                  return _AUDIO_FREQ_PACKET_192K;
 353   2      #endif
 354   2      
 355   2              default:
 356   2                  break;
 357   2          }
 358   1      
 359   1          return _AUDIO_FREQ_PACKET_NO_AUDIO;
 360   1      }
