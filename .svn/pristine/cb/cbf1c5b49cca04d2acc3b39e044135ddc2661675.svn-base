1803          void ScalerAudioDVCResetProc(void)
1804          {
1805   1      #if(_EMBEDDED_DAC_SUPPORT == _ON)
1806   1          if(ScalerAudioDACGetState() == _AUDIO_DAC_READY)
1807   1          {
