 176          //--------------------------------------------------
 177          // Description  : Transfer depop mode to Normal mode
 178          // Input Value  : None
 179          // Output Value : None
 180          //--------------------------------------------------
 181          void ScalerAudioDisable(void)
 182          {
 183   1      #if(_EMBEDDED_DAC_SUPPORT == _ON)
 184   1      
 185   1          ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_AUDIO_DAC_WAIT_VCM_INITIAL);
 186   1          ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_AUDIO_DAC_WAIT_DEPOP_TO_NORMAL);
 187   1          ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_AUDIO_DAC_WAIT_VCM_CHARGE);
 188   1      
 189   1          ScalerAudioDACNormalToDepop();
 190   1      
 191   1          ScalerAudioDACSetVcmReady(_OFF);
 192   1      
 193   1          // Power Down Depop CLK
 194   1          ScalerSetBit(P6_D4_DA_CLK_CTRL, ~_BIT4, 0x00);
 195   1      
 196   1          // Power Down DAC
 197   1          ScalerSetByte(P6_C0_REG_DAC_POWER0, 0x00);
 198   1          ScalerSetBit(P6_C1_REG_DAC_POWER1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), 0x00);
 199   1      
 200   1          SET_AUDIO_DAC_STATE(_AUDIO_DAC_OFF);
 201   1      
 202   1      #endif
 203   1      
 204   1      #if(_LINE_IN_SUPPORT == _ON)
              
              #if(_HW_AUDIO_LINE_IN_AFE_POWER_TYPE == _ADC_AFE_POWER_CONTROL_GEN_1)
                  // Power Down ADC
                  ScalerSetBit(P6_B0_REG_ADC_POWER, ~_BIT7, 0x00);
              #else
                  // Power Down ADC
                  ScalerSetBit(P6_B0_REG_ADC_POWER, ~(_BIT7 | _BIT6), 0x00);
              #endif
              
                  // Power Down Input Buffer and Mbias
                  ScalerSetBit(P6_C0_REG_DAC_POWER0, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
              #endif
 217   1      
 218   1          // Disable DVC counter for power saving
 219   1          ScalerSetBit(P8_A0_DVC_EN, ~_BIT6, _BIT6);
 220   1      
 221   1          // Power Down DPLL
 222   1          ScalerAudioDisableAudioPLL();
 223   1      }
