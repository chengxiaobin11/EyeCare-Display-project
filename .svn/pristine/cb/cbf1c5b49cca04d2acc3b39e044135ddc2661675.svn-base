 251          //--------------------------------------------------
 252          // Description  : Get Current Audio Port For Output Type
 253          // Input Value  : None
 254          // Output Value : audio port
 255          //--------------------------------------------------
 256          BYTE ScalerAudioGetDigitalAudioPort(EnumAudioOutputType enumAudioOutput)
 257          {
 258   1          switch(enumAudioOutput)
 259   1          {
 260   2              case _AUDIO_DAC_OUT:
 261   2      
 262   2                  return (ScalerGetBit(P6F_01_MUX_DA_DVC_IN, (_BIT2 | _BIT1 | _BIT0)));
 263   2      
 264   2              case _AUDIO_I2S_OUT:
 265   2      
 266   2                  return (ScalerGetBit(P6F_00_MUX_DIG_OUT, (_BIT6 | _BIT5 | _BIT4)) >> 4);
 267   2      
 268   2              case _AUDIO_SPDIF_OUT:
 269   2      
 270   2                  return (ScalerGetBit(P6F_00_MUX_DIG_OUT, (_BIT2 | _BIT1 | _BIT0)));
 271   2      
 272   2      #if(_DP_TX_SUPPORT == _ON)
                      case _AUDIO_DPTX_OUT:
              
                          return (ScalerGetBit(P6F_02_MUX_DP_I2S_IN, (_BIT2 | _BIT1 | _BIT0)));
              #endif
 277   2      
 278   2              default:
 279   2                  break;
 280   2          }
 281   1      
 282   1          return _AUDIO_FROM_D0_PORT;
 283   1      }
