 225          //--------------------------------------------------
 226          // Description  : Switch Audio Input Port For Each Audio Output
 227          // Input Value  : ucAudioOutput, ucAudioInput
C51 COMPILER V9.60.0.0   SCALERAUDIO                                                       09/09/2025 14:03:42 PAGE 5   

 228          // Output Value : None
 229          //--------------------------------------------------
 230          void ScalerAudioInputPortSwitch(EnumAudioInputPort enumAudioInput)
 231          {
 232   1          // Set DAC Input
 233   1          ScalerSetBit(P6F_01_MUX_DA_DVC_IN, ~(_BIT2 | _BIT1 | _BIT0), enumAudioInput);
 234   1      
 235   1      #if(_DIGITAL_AUDIO_OUTPUT_ADJUST_VOLUME_SUPPORT == _OFF)
 236   1          // Set IIS Input
 237   1          ScalerSetBit(P6F_00_MUX_DIG_OUT, ~(_BIT6 | _BIT5 | _BIT4), (enumAudioInput << 4));
 238   1      
 239   1          // Set SPDIF Input
 240   1          ScalerSetBit(P6F_00_MUX_DIG_OUT, ~(_BIT2 | _BIT1 | _BIT0), enumAudioInput);
 241   1      #endif
 242   1      
 243   1      #if(_DP_TX_SUPPORT == _ON)
              #if(_LINE_IN_AUDIO_DP_TX_CLONE_SUPPORT == _ON)
                  // Set DP Tx Input
                  ScalerSetBit(P6F_02_MUX_DP_I2S_IN, ~(_BIT2 | _BIT1 | _BIT0), enumAudioInput);
              #endif
              #endif
 249   1      }
