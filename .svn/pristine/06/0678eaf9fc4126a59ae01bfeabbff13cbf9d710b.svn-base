 260          void ScalerSyncHdcpDownLoadBKsv(BYTE ucSubAddr, BYTE ucLength, BYTE *pucReadArray)
 261          {
 262   1          for(pData[0] = ucSubAddr; pData[0] < ucLength; pData[0]++)
 263   1          {
 264   2      #if((_D1_TMDS_SUPPORT == _ON) || (_D2_TMDS_SUPPORT == _ON))
 265   2              ScalerSetDataPortByte(P71_C3_HDCP_AP, pData[0], pucReadArray[pData[0]]);
 266   2      #endif
 267   2      
 268   2      #if(_D3_TMDS_SUPPORT == _ON)
 269   2              ScalerSetDataPortByte(P72_C3_HDCP_AP, pData[0], pucReadArray[pData[0]]);
 270   2      #endif
 271   2      
 272   2      #if(_DP_SUPPORT == _ON)
 273   2      #if(_D0_DP_EXIST == _ON)
 274   2              ScalerDpRx0SetDpcdValue(0x06, 0x80, (0x00 | pData[0]), pucReadArray[pData[0]]);
 275   2      #endif
 276   2      
 277   2      #if(_D1_DP_EXIST == _ON)
                      ScalerDpRx1SetDpcdValue(0x06, 0x80, (0x00 | pData[0]), pucReadArray[pData[0]]);
              #endif
 280   2      
 281   2      #if(_D0_DP_EXIST == _ON)
 282   2              // Enable DP Link Integrity Enable
 283   2              ScalerSetBit(PB_1B_HDCP_INTGT_VRF, ~_BIT7, _BIT7);
 284   2      #endif
 285   2      
 286   2      #if(_D1_DP_EXIST == _ON)
                      // Enable DP Link Integrity Enable
                      ScalerSetBit(PB0_1B_HDCP_INTGT_VRF, ~_BIT7, _BIT7);
              #endif
 290   2      #endif
 291   2              g_pucHdcpBksvBackup[pData[0]] = pucReadArray[pData[0]];
 292   2          }
 293   1      
 294   1          DebugMessageDigital("8. HDCP Bksv Backup", g_pucHdcpBksvBackup[0]);
C51 COMPILER V9.60.0.0   RL6432_SERIES_SYNC                                                09/09/2025 18:04:24 PAGE 6   

 295   1          DebugMessageDigital("8. HDCP Bksv Backup", g_pucHdcpBksvBackup[1]);
