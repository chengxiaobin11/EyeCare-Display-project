  48          // Output Value : None
C51 COMPILER V8.12   RL6463_SERIES_EFUSE                                                   03/10/2025 13:50:44 PAGE 2   

  49          //--------------------------------------------------
  50          void ScalerEfuseGetData(EnumEfuseDataState enumEfuseDataState, BYTE ucEfuseLength, BYTE *pucEfuseData)
  51          {
  52   1          BYTE ucEfuseAddress = 0;
  53   1      
  54   1          switch(enumEfuseDataState)
  55   1          {
  56   2              case _EFUSE_LC_TANK_CURRENT:
  57   2                  ucEfuseAddress = 0xA6;
  58   2                  break;
  59   2      
  60   2              case _EFUSE_M2PLL_N_F_CODE:
  61   2                  ucEfuseAddress = 0xA7;
  62   2                  break;
  63   2      
  64   2              case _EFUSE_THERMAL_SENSOR:
  65   2                  ucEfuseAddress = 0xAB;
  66   2                  break;
  67   2      
  68   2              case _EFUSE_LVDS_DRIV:
  69   2                  ucEfuseAddress = 0xAF;
  70   2                  break;
  71   2      
  72   2              case _EFUSE_LC_TANK_FREQ_FOR_APLL:
  73   2                  ucEfuseAddress = 0xB0;
  74   2                  break;
  75   2      
  76   2              case _EFUSE_CP_WAFER_INFO:
  77   2                  ucEfuseAddress = 0xB3;
  78   2                  break;
  79   2      
  80   2              default:
  81   2                  return;
  82   2          }
  83   1      
  84   1          // Enable eFuse Module Clk
  85   1          ScalerSetBit(P24_A3_EFUSE_CTRL_0, ~_BIT0, 0x00);
  86   1      
  87   1          // Set eFuse Read Start Address
  88   1          ScalerSetByte(P24_A1_EFUSE_BURN_IN_1, (ucEfuseAddress - _EFUSE_INITIAL_ADDRESS));
  89   1      
  90   1          // Enable Read eFuse
  91   1          ScalerSetBit(P24_A3_EFUSE_CTRL_0, ~(_BIT7 | _BIT6 | _BIT5), _BIT6);
  92   1      
  93   1          // Delay Time us [10,x] for eFuse ready
  94   1          DELAY_10US();
  95   1      
  96   1          // Load eFuse data
  97   1          memcpy(pucEfuseData, (volatile BYTE xdata *)P24_A6_EFUSE_DATA0, ucEfuseLength);
  98   1      
  99   1          // Disable eFuse Module Clk
 100   1          ScalerSetBit(P24_A3_EFUSE_CTRL_0, ~_BIT0, _BIT0);
 101   1      }
