  47          //--------------------------------------------------
  48          // Description  : Wait D-Domain double buffer Ready
  49          // Input Value  : None
  50          // Output Value : _TRUE or _FALSE
  51          //--------------------------------------------------
C51 COMPILER V8.12   SCALERCOLORWAITDDOMAINDBAPPLY                                         03/11/2025 19:55:49 PAGE 2   

  52          bit ScalerColorWaitDDomainDBApply(void)
  53          {
  54   1      #if(_HW_GLOBAL_DB_TYPE == _GLOBAL_DB_GEN_I)
                  if(ScalerGetBit(P31_B0_D_DB_CTRL0, (_BIT7 | _BIT6)) == (_BIT7 | _BIT6))
                  {
                      // Check D domain status
                      if((ScalerGetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, _BIT0) == 0x00) ||
                         (GET_DPLL_POWER_STATUS() == _FALSE))
                      {
                          return _FALSE;
                      }
              
                      // Wait D double buffer
                      return ScalerTimerPollingFlagProc(_DOUBLE_BUFFER_WAIT_TIME, P31_B0_D_DB_CTRL0, (_BIT6), 0);
                  }
              #endif
  68   1      
  69   1          return _TRUE;
  70   1      }


