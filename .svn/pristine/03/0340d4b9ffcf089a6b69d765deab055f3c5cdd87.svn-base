C51 COMPILER V8.12   RL6449_SERIES_COLORDCCGETSCENECHANGESTATU                             03/11/2025 19:56:14 PAGE 2   

  52          // Description  : Get Scene Change Status
  53          // Input Value  : None
  54          // Output Value : None
  55          //--------------------------------------------------
  56          bit ScalerColorDCCGetSceneChangeStatus(BYTE ucSceneChangeTHD)
  57          {
  58   1          ScalerSetBit(P7_C7_DCC_CTRL_0, ~(_BIT1 | _BIT0), _PAGE0);
  59   1          ScalerSetByte(P7_C9_DCC_ADDRESS_PORT, _P7_CA_PT_0D_PORT_PAGE0_SCG_DIFF);
  60   1      
  61   1          if(ScalerGetByte(P7_CA_DCC_DATA_PORT) > ucSceneChangeTHD)
  62   1          {
  63   2              return _TRUE;
  64   2          }
  65   1          else
  66   1          {
  67   2              return _FALSE;
  68   2          }
  69   1      }


