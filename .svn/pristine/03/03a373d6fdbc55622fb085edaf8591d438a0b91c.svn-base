                   11349     ;------------------------------------------------------------------------------
                   11350     ;  This file is part of the C51 Compiler package
                   11351     ;  Copyright (c) 1988-2002 Keil Elektronik GmbH and Keil Software, Inc.
                   11352     ;------------------------------------------------------------------------------
                   11353     ;  STARTUP.A51:  This code is executed after processor reset.
                   11354     ;
                   11355     ;  To translate this file use A51 with the following invocation:
                   11356     ;
                   11357     ;     A51 STARTUP.A51
                   11358     ;
                   11359     ;  To link the modified STARTUP.OBJ file to your application use the following
                   11360     ;  BL51 invocation:
                   11361     ;
                   11362     ;     BL51 <your object file list>, STARTUP.OBJ <controls>
                   11363     ;
                   11364     ;------------------------------------------------------------------------------
                   11365     ;
                   11366     ;  User-defined Power-On Initialization of Memory
                   11367     ;
                   11368     ;  With the following EQU statements the initialization of memory
                   11369     ;  at processor reset can be defined:
                   11370     ;
                   11371     ;               ; the absolute start-address of IDATA memory is always 0
  0100             11372     IDATALEN        EQU     0100H     ; the length of IDATA memory in bytes.
                   11373     ;
                   11374     ; the absolute start-address of XDATA memory
  D700             11375     XDATASTART      EQU     (0xD700)
                   11376     ; the length of XDATA memory in bytes.
  2000             11377     XDATALEN        EQU     ((0xF6FF) - (0xD700) + 1)
                   11378     ;
  0000             11379     PDATASTART      EQU     0H      ; the absolute start-address of PDATA memory
  0000             11380     PDATALEN        EQU     0H      ; the length of PDATA memory in bytes.
                   11381     ;
                   11382     ;  Notes:  The IDATA space overlaps physically the DATA and BIT areas of the
                   11383     ;          8051 CPU. At minimum the memory space occupied from the C51
                   11384     ;          run-time routines must be set to zero.
                   11385     ;------------------------------------------------------------------------------
                   11386     ;
                   11387     ;  Reentrant Stack Initilization
                   11388     ;
                   11389     ;  The following EQU statements define the stack pointer for reentrant
                   11390     ;  functions and initialized it:
                   11391     ;
                   11392     ;  Stack Space for reentrant functions in the SMALL model.
  0000             11393     IBPSTACK        EQU     0       ; set to 1 if small reentrant is used.
  0100             11394     IBPSTACKTOP     EQU     0FFH+1  ; set top of stack to highest location+1.
                   11395     ;
                   11396     ;  Stack Space for reentrant functions in the LARGE model.
  0000             11397     XBPSTACK        EQU     0       ; set to 1 if large reentrant is used.
  0000             11398     XBPSTACKTOP     EQU     0FFFFH+1; set top of stack to highest location+1.
                   11399     ;
                   11400     ;  Stack Space for reentrant functions in the COMPACT model.
  0000             11401     PBPSTACK        EQU     0       ; set to 1 if compact reentrant is used.
  0000             11402     PBPSTACKTOP     EQU     0FFFFH+1; set top of stack to highest location+1.
                   11403     ;
                   11404     ;------------------------------------------------------------------------------
                   11405     ;
                   11406     ;  Page Definition for Using the Compact Model with 64 KByte xdata RAM
                   11407     ;
                   11408     ;  The following EQU statements define the xdata page used for pdata
A51 MACRO ASSEMBLER  STARTUP                                                              08/21/2025 10:43:51 PAGE   174

                   11409     ;  variables. The EQU PPAGE must conform with the PPAGE control used
                   11410     ;  in the linker invocation.
                   11411     ;
  0000             11412     PPAGEENABLE     EQU     0       ; set to 1 if pdata object are used.
                   11413     ;
  0000             11414     PPAGE           EQU     0       ; define PPAGE number.
                   11415     ;
  00A0             11416     PPAGE_SFR       DATA    0A0H    ; SFR that supplies uppermost address byte
                   11417     ;               (most 8051 variants use P2 as uppermost address byte)
                   11418     ;
                   11419     ;------------------------------------------------------------------------------
                   11420     
                   11421     ; Standard SFR Symbols
  00E0             11422     ACC     DATA    0E0H
  00F0             11423     B       DATA    0F0H
  0081             11424     SP      DATA    81H
  0082             11425     DPL     DATA    82H
  0083             11426     DPH     DATA    83H
