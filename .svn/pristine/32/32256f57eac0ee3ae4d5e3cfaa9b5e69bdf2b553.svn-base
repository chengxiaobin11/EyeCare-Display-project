 110          //--------------------------------------------------
 111          // Description  : Show format conversion input source
 112          // Input Value  : NONE
 113          // Output Value : Current format conversino source
 114          //--------------------------------------------------
 115          EnumFormatConversionSourceType ScalerFmtCnvGetSourceType(void)
 116          {
 117   1          return (EnumFormatConversionSourceType)(ScalerGetBit(P31_00_FC_INPUT_SEL_P01, (_BIT7 | _BIT6 | _BIT5 |
             - _BIT4)) >> 4);
 118   1      }
