  48          // Description  : Initialize for format conversion
  49          // Input Value  : enumSourceSearchPort --> input port
  50          // Output Value : None
  51          //--------------------------------------------------
  52          void ScalerFmtCnvInitialSetting(EnumSourceSearchPort enumSourceSearchPort)
  53          {
  54   1          switch(enumSourceSearchPort)
  55   1          {
  56   2              case _A0_INPUT_PORT:
  57   2      
  58   2                  // Set source index to A0
  59   2                  ScalerSetBit(P31_00_FC_INPUT_SEL_P01, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_FC_SOURCE_ADC << 4))
             -;
  60   2                  break;
  61   2      
  62   2              case _D0_INPUT_PORT:
  63   2      
  64   2      #if((_D6_INPUT_PORT_TYPE != _D6_NO_PORT) && (_D6_INPUT_PORT_SWITCH_FROM == _SWITCH_FROM_D0))
                      case _D6_INPUT_PORT:
              #endif
  67   2                  // Set source index to D0
  68   2                  ScalerSetBit(P31_00_FC_INPUT_SEL_P01, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_FC_SOURCE_D0 << 4));
  69   2                  break;
  70   2      
  71   2              case _D1_INPUT_PORT:
  72   2      
  73   2      #if(_D1_DP_EXIST == _ON)
                          // Set source index to D1
                          ScalerSetBit(P31_00_FC_INPUT_SEL_P01, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_FC_SOURCE_D1 << 4));
              #else
  77   2                  // Set source index to D2
  78   2                  ScalerSetBit(P31_00_FC_INPUT_SEL_P01, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_FC_SOURCE_D2 << 4));
  79   2      #endif
  80   2                  break;
  81   2      
  82   2              case _D2_INPUT_PORT:
  83   2      
  84   2      #if(_D2_INPUT_PORT_TYPE == _D2_DUAL_DVI_PORT)
                          if(ScalerDualLinkDVIRx2GetDualDVIMode() == _TRUE)
                          {
                              // Set source index to DUAL DVI
                              ScalerSetBit(P31_00_FC_INPUT_SEL_P01, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_FC_SOURCE_DUAL_D
             -VI << 4));
                          }
                          else
              #endif
  92   2                  {
  93   3                      // Set source index to D2
  94   3                      ScalerSetBit(P31_00_FC_INPUT_SEL_P01, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_FC_SOURCE_D2 << 
             -4));
  95   3                  }
  96   2      
  97   2                  break;
  98   2      
  99   2              case _D3_INPUT_PORT:
 100   2      
 101   2                  // Set source index to D3
 102   2                  ScalerSetBit(P31_00_FC_INPUT_SEL_P01, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_FC_SOURCE_D3 << 4));
 103   2                  break;
 104   2      
 105   2              default:
 106   2                  break;
C51 COMPILER V9.60.0.0   RL6432_SERIES_FORMATCONVERSION                                    08/21/2025 10:45:03 PAGE 3   

 107   2          }
 108   1      }
