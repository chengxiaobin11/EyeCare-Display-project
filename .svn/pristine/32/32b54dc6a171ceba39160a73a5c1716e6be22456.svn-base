 594          void ScalerMeasureSetAuto(EnumMeasureFieldSelect enumFieldSelect)
 595          {
 596   1          // Disable auto-function
 597   1          ScalerSetBit(P0_7D_AUTO_ADJ_CTRL1, ~_BIT0, 0x00);
 598   1      
 599   1          // Set auto VS delay to 0
 600   1          ScalerSetBit(P0_1E_M1_VGIP_HV_DELAY, ~(_BIT5 | _BIT4), 0x00);
 601   1      
 602   1          if(enumFieldSelect == _EVEN_FIELD_MEASURE)
 603   1          {
 604   2              // Field Select to Even, Disable LPF, Disable Accelecration Mode, Vertical Boundary Search 1 pixel
             -, Select B channel
 605   2              ScalerSetByte(P0_7A_AUTO_ADJ_CTRL0, 0x80);
 606   2          }
 607   1          else if(enumFieldSelect == _ODD_FIELD_MEASURE)
 608   1          {
 609   2              // Field Select to Odd, Disable LPF, Disable Accelecration Mode, Vertical Boundary Search 1 pixel,
             - Select B channel
 610   2              ScalerSetByte(P0_7A_AUTO_ADJ_CTRL0, 0xC0);
 611   2          }
 612   1          else
 613   1          {
 614   2              // Disable Field Select, Disable LPF, Disable Accelecration Mode, Vertical Boundary Search 1 pixel
             -, Select B channel
 615   2              ScalerSetByte(P0_7A_AUTO_ADJ_CTRL0, 0x00);
 616   2          }
 617   1      
 618   1          // Set HW auto-phase: step = 31
 619   1          ScalerSetByte(P0_7B_HW_AUTO_PHASE_CTRL0, 0xF8);
 620   1      
 621   1          // Set H boundary
 622   1          ScalerMeasureAutoFuncHBoundInitial(0x0002, 0x1FFF);
 623   1      
 624   1          // Set V Boundary
 625   1          ScalerMeasureAutoFuncVBoundInitial(0x0000, 0x0FFF);
 626   1      
 627   1          // Digital Measure Mode, Select Auto Balance, Start Auto Function Measure; Start auto-function measure
 628   1          ScalerSetBit(P0_7D_AUTO_ADJ_CTRL1, ~(_BIT7 | _BIT6 | _BIT1 | _BIT0), (_BIT7 | _BIT6 | _BIT0));
