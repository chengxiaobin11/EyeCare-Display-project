  41          void ScalerOsdRotationWindowSize(EnumOsdMapType enumOsdMapType, WORD usLength, WORD usWidth);
  42          
  43          //****************************************************************************
  44          // FUNCTION DEFINITIONS
  45          //****************************************************************************
  46          //--------------------------------------------------
  47          // Description  : Set window rotate reference size
  48          // Input Value  : enumOsdMapType -> _OSD_A or _OSD_B
  49          //                usLength       -> Horizontal max size
  50          //                Width          -> Vertical max size
  51          // Output Value :
C51 COMPILER V8.12   OSDROTATIONWINDOWSIZE                                                 03/11/2025 19:55:59 PAGE 2   

  52          //--------------------------------------------------
  53          void ScalerOsdRotationWindowSize(EnumOsdMapType enumOsdMapType, WORD usLength, WORD usWidth)
  54          {
  55   1          if(enumOsdMapType == _OSD_A)
  56   1          {
  57   2              // First OSD Width
  58   2              ScalerSetBit(P3A_38_FRAME_CTRL_38, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), ((usWidth & 0x0F00) >> 8));
  59   2              ScalerSetByte(P3A_3A_FRAME_CTRL_3A, (usWidth & 0xFF));
  60   2      
  61   2              // First OSD Length
  62   2              ScalerSetBit(P3A_38_FRAME_CTRL_38, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), ((usLength & 0x0F00) >> 4));
  63   2              ScalerSetByte(P3A_39_FRAME_CTRL_39, (usLength & 0xFF));
  64   2          }
  65   1          else
  66   1          {
  67   2              // Second OSD Width
  68   2              ScalerSetBit(P3A_3B_FRAME_CTRL_3B, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), ((usWidth & 0x0F00) >> 8));
  69   2              ScalerSetByte(P3A_3D_FRAME_CTRL_3D, (usWidth & 0xFF));
  70   2      
  71   2              // Second OSD Length
  72   2              ScalerSetBit(P3A_3B_FRAME_CTRL_3B, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), ((usLength & 0x0F00) >> 4));
  73   2              ScalerSetByte(P3A_3C_FRAME_CTRL_3C, (usLength & 0xFF));
  74   2          }
  75   1      }
  76          
  77          /*
  78          //--------------------------------------------------
  79          // example
  80          //--------------------------------------------------
  81              ScalerOsdRotationWindowSize(_OSD_A, XEND(400), YEND(500));
  82          */
