4195   3              }
4196   2      
4197   2              return _FALSE;
4198   2          }
4199   1      #if(_TMDS_HDCP_2_2_SUPPORT == _ON)
4200   1          else if((ScalerGetBit(P71_C0_HDCP_CR, _BIT0) == 0x00) && (ScalerGetBit(P2D_26_HDCP_I2C_CTRL_0, _BIT7) 
