3231   1          PDATA_WORD(1) = ((DWORD)usM * 700UL * 2 * 314UL * 20) / _PLL_VCO_BAND_10 / ((7 + (ScalerGetBit(P2D_BE_
             -MN_SCLKG_PLL_CHP, (_BIT7 | _BIT6 | _BIT5)) >> 5) * 2) * 100);
3232   1          pData[5] = (PDATA_WORD(1) + 25) / 50;
3233   1          pData[5] -= ((pData[5] == 0) ? 0 : 1);
3234   1      
3235   1          if(pData[5] > 0x07)
3236   1          {
C51 COMPILER V8.12   RL6449_SERIES_TMDSRX2                                                 01/02/2025 16:31:56 PAGE 55  

3237   2              pData[5] = 0x07;
