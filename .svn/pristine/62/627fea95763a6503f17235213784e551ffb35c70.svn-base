3077          // Description  : Set Deep Color PLL
3078          // Input Value  : usTMDSClkCount, ucColorDepth
3079          // Output Value : None
3080          //--------------------------------------------------
3081          bit ScalerTMDSRx2HdmiSetDeepColorPll(WORD usTMDSClkCount, BYTE ucColorDepth)
3082          {
3083   1          DWORD ulTMDSClkValue = 0;
3084   1          WORD usM = 0;
3085   1          BYTE ucN = 0;
3086   1          BYTE ucDivS = 0;
3087   1          BYTE ucFactor = 0;
3088   1      
3089   1      #if((_D2_HDMI_2_0_SUPPORT == _ON) && (_HDMI_2_0_YCBCR420_SUPPORT == _ON))
3090   1          BYTE ucRatio = 1;
3091   1      #endif
3092   1      
3093   1          ////////////////////////////////////////////////////////////////////////////////////////////////
3094   1          // Fin = TMDS_clk
3095   1          // Fref = Fin / N
3096   1          // Fvco = Fin * M / N
3097   1          // Freq = Fvco / Divs
3098   1          //
3099   1          // Restriction
3100   1          // A. BW = Kvco * Icp * R / (M * 2pi) = 700k (Band10 Kvco = 1880), R = 13k)
3101   1          // B. 300MHz < Fvco < 600MHz
3102   1          // C. (Fin / N) >= 10 * BW --> (Fin / N) >= 7MHz
3103   1          // D. YCbCr 420, Ratio = 2, other case Ratio = 1
3104   1          //
3105   1          // note 1.   According A, Icp = 2.5 ~ 20 --> 14 <= M <= 111
3106   1          // note 2.   According B and note 1. --> 3 <= (Fin / N) <= 42
3107   1          // note 3.   According C and note 2. --> 7 <= (Fin / N) <= 42
3108   1          // note 4_a. 10bit : (M / N / Divs) = (4 / 5 * Ratio) --> M = N * Divs * (4 / 5 * Ratio), N or Divs: m
             -ultiple of 5
3109   1          // note 4_b. 12bit : (M / N / Divs) = (2 / 3 * Ratio) --> M = N * Divs * (2 / 3 * Ratio), N or Divs: m
             -ultiple of 3
3110   1          // note 4_b. 16bit : (M / N / Divs) = (1 / 2 * Ratio) --> M = N * Divs * (1 / 2 * Ratio), N or Divs: m
             -ultiple of 2
3111   1          ////////////////////////////////////////////////////////////////////////////////////////////////
3112   1      
3113   1          // If Measure Divider = /2 then TMDS_CLK x 2, unit:kHz
3114   1          if(ScalerGetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0, _BIT6) == _BIT6)
C51 COMPILER V8.12   RL6449_SERIES_TMDSRX2                                                 01/02/2025 16:31:56 PAGE 53  

3115   1          {
3116   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 * 2 / usTMDSClkCount;
3117   2          }
3118   1          else
3119   1          {
3120   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 / usTMDSClkCount;
3121   2          }
3122   1      
3123   1      #if(_D2_HDMI_2_0_SUPPORT == _ON)
3124   1      
3125   1          if(GET_TMDS_RX2_HIGH_SPEED_MODE() == _TRUE)
3126   1          {
3127   2              ulTMDSClkValue = (ulTMDSClkValue << 2);
3128   2          }
3129   1      
3130   1      #if(_HDMI_2_0_YCBCR420_SUPPORT == _ON)
3131   1          if(GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR420)
3132   1          {
3133   2              ucRatio = 2;
3134   2          }
3135   1      #endif
3136   1      
3137   1      #endif
3138   1      
3139   1          DebugMessageRx2("TMDS clk", ulTMDSClkValue);
3140   1          DebugMessageRx2("Color Depth", ucColorDepth);
3141   1      
3142   1          switch(ucColorDepth)
3143   1          {
3144   2              case _COLOR_DEPTH_10_BITS:
3145   2      
3146   2                  ucFactor = 5;
3147   2      
3148   2                  break;
3149   2      
3150   2              case _COLOR_DEPTH_12_BITS:
3151   2      
3152   2                  ucFactor = 3;
3153   2      
3154   2                  break;
3155   2      
3156   2              case _COLOR_DEPTH_16_BITS:
3157   2      
3158   2                  ucFactor = 2;
3159   2      
3160   2                  break;
3161   2      
3162   2              default:
3163   2      
3164   2                  return _FALSE;
3165   2          }
3166   1      
3167   1          // N <= (Fin / 7)
3168   1          PDATA_WORD(0) = (ulTMDSClkValue / 7000);
3169   1      
3170   1          if(PDATA_WORD(0) < 2)
3171   1          {
3172   2              return _FALSE;
3173   2          }
3174   1          else if(PDATA_WORD(0) >= ucFactor)
3175   1          {
3176   2              // N: Multiple of factor
C51 COMPILER V8.12   RL6449_SERIES_TMDSRX2                                                 01/02/2025 16:31:56 PAGE 54  

3177   2              PDATA_WORD(0) -= (PDATA_WORD(0) % ucFactor);
3178   2          }
3179   1          else if(PDATA_WORD(0) > 255)
3180   1          {
3181   2              // N: Multiple of factor
3182   2              PDATA_WORD(0) = 255 - (255 % ucFactor);
3183   2          }
3184   1      
3185   1          ucN = PDATA_WORD(0);
3186   1      
3187   1          // for differenct Divs, find suitable Divs and M
3188   1          for(pData[15] = 0; pData[15] <= 254; pData[15] += 2)
3189   1          {
3190   2              // N or Divs: Multiple of factor
3191   2              if(((ucN % ucFactor) == 0x00) || ((pData[15] % ucFactor) == 0x00))
3192   2              {
3193   3      #if((_D2_HDMI_2_0_SUPPORT == _ON) && (_HDMI_2_0_YCBCR420_SUPPORT == _ON))
3194   3                  usM = (WORD)ucN * ((pData[15] == 0) ? 1 : pData[15]) * (ucFactor - 1) / ucFactor * ucRatio;
3195   3      #else
                          usM = (WORD)ucN * ((pData[15] == 0) ? 1 : pData[15]) * (ucFactor - 1) / ucFactor;
              #endif
3198   3      
3199   3                  // Fvco = Fin * M / N
3200   3                  PDATA_DWORD(0) = (ulTMDSClkValue * usM / ucN);
3201   3      
3202   3                  if((PDATA_DWORD(0) >= 300000) && (PDATA_DWORD(0) <= 600000))
3203   3                  {
3204   4                      ucDivS = ((pData[15] == 0) ? 1 : pData[15]);
3205   4                      break;
3206   4                  }
3207   3              }
3208   2      
3209   2              if((pData[15] == 254) && (ucDivS == 0))
3210   2              {
3211   3                  DebugMessageRx2("4. PLL Setting Error", 0);
3212   3                  return _FALSE;
3213   3              }
3214   2          }
3215   1      
3216   1          //////////////////////////////////////////////////////////////////////////////////////////////////
3217   1          // Precise formula of Chrage Pump Current depends on DPM, resistor, and band.                   //
3218   1          // If VCO band = 'b00, Icp = (700 * M * 2 * pi) / (778 * 0x01C1[7:5]).                          //
3219   1          // If VCO band = 'b01, Icp = (700 * M * 2 * pi) / (1340 * 0x01C1[7:5]).                         //
3220   1          // If VCO band = 'b10, Icp = (700 * M * 2 * pi) / (1880 * 0x01C1[7:5]).                         //
3221   1          // If VCO band = 'b11, Icp = (700 * M * 2 * pi) / (2340 * 0x01C1[7:5]).                         //
3222   1          // 700: DPLL max frequency design target is 700MHz; 778: Frequency curve in band00 is 778MHz.   //
3223   1          // Assume DPLL_M=0x13, DPM=0x13+2=21; DPN=2; reg_dpll_vcomd='b01; reg_dpll_rs[2:0]='b011;       //
3224   1          // Icp = (700 * 21 * 2 * 3.14) / (1340 * 13)                                                    //
3225   1          //////////////////////////////////////////////////////////////////////////////////////////////////
