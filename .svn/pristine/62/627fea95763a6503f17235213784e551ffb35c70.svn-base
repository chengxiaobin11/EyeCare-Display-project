2918          // Description  : Measure Clk
2919          // Input Value  : Clk Source to be measured
2920          // Output Value : Measured Clk Count
2921          //--------------------------------------------------
2922          WORD ScalerTMDSRx2MeasureClk(BYTE ucMeasureClk)
2923          {
2924   1          BYTE ucDelayCount = 0;
2925   1      
2926   1      #if(_D2_INPUT_PORT_TYPE == _D2_MHL_PORT)
                  if(GET_D2_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
                      // Enable Rx_EN (Lane0,3)
                      ScalerSetBit(P7B_1A_CMU_00, ~(_BIT7 | _BIT4), (_BIT7 | _BIT4));
                  }
C51 COMPILER V8.12   RL6449_SERIES_TMDSRX2                                                 01/02/2025 16:31:56 PAGE 50  

                  else
              #endif
2934   1          {
2935   2              // Enable Rx_EN (Lane3)
2936   2              ScalerSetBit(P7B_1A_CMU_00, ~_BIT7, _BIT7);
2937   2          }
2938   1      
2939   1          // Disable Measure for Reset Measure Window
2940   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
2941   1          ScalerSetBit(P71_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), 0x00);
2942   1      
2943   1          // Select reference clk to Xtal Clk and measure clk
2944   1          ScalerSetBit(P71_AD_TMDS_CPS, ~(_BIT6 | _BIT5 | _BIT4), ((ucMeasureClk << 5) | _BIT4));
2945   1      
2946   1          // Start Measure
2947   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
2948   1          ScalerSetBit(P71_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), _BIT3);
2949   1      
2950   1          // Delay at least 40us at Xtal = 27MHz
2951   1          for(ucDelayCount = 0; ucDelayCount <= 8; ucDelayCount++)
2952   1          {
2953   2              DELAY_5US();
2954   2      
2955   2              ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
2956   2              if(ScalerGetBit(P71_CA_HDMI_DP, _BIT3) == 0x00)
2957   2              {
2958   3                  break;
2959   3              }
2960   2          }
2961   1      
2962   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
2963   1          pData[0] = ScalerGetByte(P71_CA_HDMI_DP);
2964   1      
2965   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_29_PORT_PAGE71_HDMI_NTX1024TR1);
2966   1          pData[1] = ScalerGetByte(P71_CA_HDMI_DP);
2967   1      
2968   1          return ((WORD)(pData[0] & 0x07) << 8) | pData[1];
2969   1      }
