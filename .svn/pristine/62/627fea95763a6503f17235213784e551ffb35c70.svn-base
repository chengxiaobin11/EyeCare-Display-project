3395   4                  }
3396   3                  // Only GCP Packet have been received
3397   3                  else if(ScalerGetBit(P71_CC_HDMI_GPVS, (_BIT6 | _BIT5)) == _BIT6)
3398   3                  {
3399   4                      SET_HDMI_RX2_GCP_RECEIVED();
3400   4      
3401   4                      // Polling more time to wait AVI IF when GCP has been received.
3402   4                      if(ScalerTimerPollingFlagProc(180, P71_CC_HDMI_GPVS, _BIT5, _TRUE) == _TRUE)
3403   4                      {
3404   5                          SET_HDMI_RX2_AVI_INFO_FRAME_RECEIVED();
3405   5                      }
3406   4                      else
3407   4                      {
3408   5                          CLR_HDMI_RX2_AVI_INFO_FRAME_RECEIVED();
3409   5                      }
3410   4                  }
3411   3              }
3412   2              // Neither AVI infoframe nor GCP packet received
3413   2              else
3414   2              {
3415   3                  CLR_HDMI_RX2_GCP_RECEIVED();
3416   3      
