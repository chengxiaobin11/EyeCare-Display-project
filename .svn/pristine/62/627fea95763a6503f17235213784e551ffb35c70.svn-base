 304          //--------------------------------------------------
 305          // Description  : Initialize TMDS Interrupt Required Settings
 306          // Input Value  : None
 307          // Output Value : None
 308          //--------------------------------------------------
 309          void ScalerTMDSRx2InterruptInitial(void)
 310          {
 311   1          if(ScalerGetBit(P71_E6_HDMI_FREQDET_CTRL, _BIT1) == 0x00)
 312   1          {
 313   2              CLR_TMDS_RX2_PHY_SET();
 314   2          }
 315   1      
 316   1          // Enable Rx_En for Clk pair Z0
 317   1          ScalerSetBit(P7B_1A_CMU_00, ~_BIT7, _BIT7);
 318   1      
 319   1          // Choose Measure Clk to TMDS Clk
 320   1          ScalerSetBit(P71_E6_HDMI_FREQDET_CTRL, ~(_BIT7 | _BIT5 | _BIT4), 0x00);
 321   1      
 322   1          // Set Freq. Reference Counter = 2000
 323   1          ScalerSetBit(P71_F6_HDMI_FREQDET_BOUND_H, ~(_BIT1 | _BIT0), _BIT0);
 324   1      
 325   1          // Set Online Measure Input Clock Divider = /2 (No Matter if Input Clock >300Mhz or <=300Mhz)
 326   1          ScalerSetBit(P71_E7_HDMI_FREQDET_OFFSET, ~_BIT6, _BIT6);
 327   1      
 328   1          // Settings for IRQ set PHY
 329   1          // Consider using table to fill all required initial settings
 330   1          // Set pre-set threshold (225MHz * 0.01 / 26.8KHz = 0x54)
 331   1      
 332   1      #if(_D2_INPUT_PORT_TYPE == _D2_MHL_PORT)
                  if(GET_D2_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
                      // Set TMDS Offset = 1/32
                      ScalerSetBit(P71_E7_HDMI_FREQDET_OFFSET, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
              
                      // Set Upper Bound
                      ScalerSetByte(P71_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_MHL_FREQ_NORMAL_UPPER_BOUND));
                      ScalerSetByte(P71_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_MHL_FREQ_NORMAL_UPPER_BOUND));
                  }
                  else
              #endif
 344   1          {
C51 COMPILER V8.12   RL6449_SERIES_TMDSRX2                                                 01/02/2025 16:31:56 PAGE 7   

 345   2              // Set TMDS Offset = 1/32
 346   2              ScalerSetBit(P71_E7_HDMI_FREQDET_OFFSET, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
 347   2      
 348   2              // Set Upper Bound
 349   2              ScalerSetByte(P71_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
 350   2              ScalerSetByte(P71_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
 351   2          }
 352   1      
 353   1          // Set Lower Bound
 354   1          ScalerSetByte(P71_EA_HDMI_FREQDET_LOWER_M, HIBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 355   1          ScalerSetByte(P71_EB_HDMI_FREQDET_LOWER_L, LOBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 356   1      
 357   1          // Set Stable Time (0x3F = about 5ms)
 358   1          ScalerSetByte(P71_EC_HDMI_FREQDET_STABLE, 0x3F);
 359   1      
 360   1          // Disable Freq. Unstable IRQ
 361   1          ScalerSetBit(P71_E6_HDMI_FREQDET_CTRL, ~_BIT1, 0x00);
 362   1      
 363   1          // Enable Freq. Stable IRQ
 364   1          ScalerSetBit(P71_EF_HDMI_ERROR_TH, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 365   1      
 366   1      #if(_D2_HDMI_2_0_SUPPORT == _ON)
 367   1          // Enable SCDC 0x20 Change IRQ
 368   1          ScalerSetBit(P71_26_HDMI_CTRL_26, ~_BIT4, _BIT4);
 369   1      #endif
 370   1      
 371   1          // Clear IRQ Pending Flag
 372   1          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_60_PORT_PAGE71_HDMI_INTCR, ~_BIT7, _BIT7);
 373   1      
 374   1          // Internal IRQ Enable (Global)
 375   1          ScalerGlobalIRQControl(_ENABLE);
 376   1      
 377   1          EX0 = 1;
 378   1      
 379   1          // Start Freq. Detection
 380   1          ScalerSetBit(P71_E6_HDMI_FREQDET_CTRL, ~_BIT7, _BIT7);
 381   1      }
