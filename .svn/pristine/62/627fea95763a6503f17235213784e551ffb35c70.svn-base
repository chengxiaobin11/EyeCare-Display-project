4105          BYTE ScalerTMDSRx2FormatDetect(void)
4106          {
4107   1          // Polling at least 3 frame for HW auto detect TMDS format
4108   1          if(ScalerTimerPollingFlagProc(130, P71_CB_HDMI_SR, _BIT0, _TRUE) == _TRUE)
4109   1          {
4110   2              ScalerSetBit(P71_AF_TMDS_WDC, ~_BIT0, 0x00);
4111   2      
4112   2      #if(_D2_HDMI_2_0_SUPPORT == _ON)
4113   2              if(GET_D2_TMDS_MODE() == _TMDS_HDMI_MODE)
4114   2              {
4115   3                  // Check if HDMI 2.0 ON
4116   3                  if(ScalerGetBit(P71_00_HDMI_CTRL_00, _BIT0) == _BIT0)
4117   3                  {
4118   4                      // Set Manual Format to HDMI
4119   4                      ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_00_PORT_PAGE71_HDMI_SCR, ~(_BIT7 | _BIT6 |
             - _BIT3 | _BIT2), (_BIT3 | _BIT2));
4120   4      
4121   4                      // Toggle HW Format Detect Flag Reset
4122   4                      ScalerSetBit(P71_01_HDMI_CTRL_01, ~(_BIT7 | _BIT3), _BIT7);
4123   4                      ScalerSetBit(P71_01_HDMI_CTRL_01, ~(_BIT7 | _BIT3), 0x00);
4124   4      
4125   4                      SET_TMDS_RX2_HDMI_2_0_FORMAT_RESET_WAITING();
4126   4      
4127   4                      ScalerTimerReactiveTimerEvent(130, _SCALER_TIMER_EVENT_RX2_HDMI2_FORMAT_RESET_WAIT);
4128   4                  }
4129   3              }
4130   2      #endif
4131   2      
4132   2      #if(_D2_INPUT_PORT_TYPE == _D2_MHL_PORT)
              
                      if(GET_D2_TMDS_MODE() == _TMDS_MHL_MODE)
                      {
                          // Set Manual Format to HDMI
                          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_00_PORT_PAGE71_HDMI_SCR, ~(_BIT7 | _BIT6 | _BI
             -T3 | _BIT2), (_BIT3 | _BIT2));
C51 COMPILER V8.12   RL6449_SERIES_TMDSRX2                                                 01/02/2025 16:31:56 PAGE 70  

                      }
              #endif
4140   2              return _SOURCE_HDMI;
4141   2          }
4142   1          else
4143   1          {
4144   2              ScalerSetBit(P71_AF_TMDS_WDC, ~_BIT0, _BIT0);
4145   2      
4146   2              if(GET_D2_TMDS_MODE() == _TMDS_HDMI_MODE)
4147   2              {
4148   3      #if(_D2_HDMI_2_0_SUPPORT == _ON)
4149   3                  if(ScalerGetBit(P71_00_HDMI_CTRL_00, _BIT0) == _BIT0)
4150   3                  {
4151   4                      ScalerTimerCancelTimerEvent(_SCALER_TIMER_EVENT_RX2_HDMI2_FORMAT_RESET_WAIT);
4152   4                  }
4153   3      #endif
