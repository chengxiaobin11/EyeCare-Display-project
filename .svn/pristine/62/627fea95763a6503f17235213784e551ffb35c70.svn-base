4219          //--------------------------------------------------
4220          // Description  : DFE Adaptation in Normal Signal
4221          // Input Value  : None
4222          // Output Value : True --> DFE Normal
4223          //                False --> DFE Abnormal
4224          //--------------------------------------------------
4225          bit ScalerTMDSRx2CheckDataDFE(void)
4226          {
4227   1          BYTE ucTemp = 0;
4228   1          BYTE ucCnt = 0;
4229   1      
4230   1          // DFE Check only under HDMI Mode.
4231   1          // MHL has only 1 data Lane --> Skip DFE Check Process and Function return True!
4232   1          if(ScalerGetBit(P7B_17_BANDGAP_03, _BIT1) != _BIT1)
4233   1          {
4234   2              for(pData[0] = 0; pData[0] <= 2; pData[0]++)
4235   2              {
4236   3                  // Sel lane
4237   3                  ScalerSetBit(P7B_F2_COEF_3, ~(_BIT7 | _BIT6), pData[0] << 6);
4238   3      
4239   3                  // Read VTH
