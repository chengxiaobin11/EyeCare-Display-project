                  CLR_DP_RX_UP_REQUEST_BYPASS_DONE();
                  CLR_DP_RX_UP_REQUEST_RETRY_NUM();
                  CLR_DP_RX_UP_REQUEST_CRC_FAIL_RETRY_NUM();
