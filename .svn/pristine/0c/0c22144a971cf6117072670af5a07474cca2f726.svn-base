  49          //--------------------------------------------------
  50          // Description  : Adjust Input gamma
  51          // Input Value  : IG Gamma Table Bank and IG Gamma table and Table Length
C51 COMPILER V8.12   RL6449_SERIES_COLORPCMINPUTGAMMAADJUST                                03/11/2025 19:56:08 PAGE 2   

  52          // Output Value : None
  53          //--------------------------------------------------
  54          void ScalerColorPCMInputGammaAdjust(BYTE *pucGammaTableArray, BYTE ucBankNum)
  55          {
  56   1          // Set Input Gamma to Old Mode (One Channel)
  57   1          ScalerSetBit(P9_A1_INPUT_GAMMA_CTRL, ~_BIT0, 0x00);
  58   1      
  59   1          // Enable Input Gamma Port Access
  60   1          ScalerSetBit(P9_A1_INPUT_GAMMA_CTRL, ~_BIT7, _BIT7);
  61   1      
  62   1          // Load Input Gamma Table
  63   1          ScalerBurstWrite(pucGammaTableArray, _PCM_INPUTGAMMA_TABLE_SIZE, ucBankNum, P9_A0_INPUT_GAMMA_PORT, _B
             -URSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  64   1      
  65   1          // Load Threshold
  66   1          ScalerBurstWrite(pucGammaTableArray + _PCM_INPUTGAMMA_TABLE_SIZE, 1, ucBankNum, P9_A2_INPUT_GAMMA_LOW_
             -THRE, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  67   1          ScalerBurstWrite(pucGammaTableArray + _PCM_INPUTGAMMA_TABLE_SIZE + 1, 1, ucBankNum, P9_A3_INPUT_GAMMA_
             -HIGH_THRE, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  68   1      
  69   1          // Disable Input Gamma Port Access
  70   1          ScalerSetBit(P9_A1_INPUT_GAMMA_CTRL, ~_BIT7, 0x00);
  71   1      }
  72          


