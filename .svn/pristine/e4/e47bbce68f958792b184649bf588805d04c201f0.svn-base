  48          //--------------------------------------------------
  49          // Description  : Get Time Cursor Difference for US
  50          // Input Value  : Debug Time Cursor
  51          // Output Value : Time Difference for Us
C51 COMPILER V8.12   SCALERCOMMONDEBUGTIMERCURSORUS                                        03/11/2025 19:55:37 PAGE 2   

  52          //--------------------------------------------------
  53          WORD ScalerDebugGetTimerCursorUSDifference(EnumDebugTimeCursor enumIndex)
  54          {
  55   1          // Check if cursor is used
  56   1          if(((g_ucTimerCursorUsedUS >> enumIndex) & _BIT0) == _DISABLE)
  57   1          {
  58   2              return 0xFFFF;
  59   2          }
  60   1          else
  61   1          {
  62   2              // Calculate timter counter difference
  63   2              WORD usStartTimeUS = g_pstTimerCursorUS[enumIndex].ucTH_Start * 0x100 + g_pstTimerCursorUS[enumInd
             -ex].ucTL_Start;
  64   2              WORD usEndTimeUS = g_pstTimerCursorUS[enumIndex].ucTH_End * 0x100 + g_pstTimerCursorUS[enumIndex].
             -ucTL_End;
  65   2      
  66   2              if(usStartTimeUS <= usEndTimeUS)
  67   2              {
  68   3                  // Convert to us
  69   3                  WORD usRCAP2 = g_pstTimerCursorUS[enumIndex].ucRCAP2H * 0x100 + g_pstTimerCursorUS[enumIndex].
             -ucRCAP2L;
  70   3                  return (WORD)((DWORD)(usEndTimeUS - usStartTimeUS) * 1000 / (0xFFFF - usRCAP2));
  71   3              }
  72   2              else
  73   2              {
  74   3                  return 0xFFFF;
  75   3              }
  76   2          }
  77   1      }
  78          


