extern BYTE xdata OSD_ITEM_BASE[_MENU_NULL - _OSD_FUN_START];
extern BYTE xdata OSD_ITEM_MASK[12];
// OSD_ITEM_MASK????hotkey??,??????????,6??????48???

/****************************OSD_MASK[]?????********************************/
#define OSD_ITEM_MASK_SET(x)  (OSD_ITEM_MASK[(x - _OSD_FUN_START)/8] |= (0x01<<((x - _OSD_FUN_START)%8)))
#define OSD_ITEM_MASK_CLR(x)  (OSD_ITEM_MASK[(x - _OSD_FUN_START)/8] &= ~(0x01<<((x - _OSD_FUN_START)%8)))
#define OSD_ITEM_MASK_GET(x)  (OSD_ITEM_MASK[(x - _OSD_FUN_START)/8]&(0x01<<((x - _OSD_FUN_START)%8)))

/****************************OSD_ITEM_BASE[]?????****************************/
#define OSD_ITEM(x)         OSD_ITEM_BASE[x - _OSD_FUN_START]
#define OSD_MASK_SET(x)     (OSD_ITEM(x) == 0xff)?0:(OSD_MASK[OSD_ITEM(x)>>4] |= (0x01<<(OSD_ITEM(x)&0x0f))); (OSD_ITEM(x) == 0xff)?0: OSD_ITEM_MASK_SET(x)
#define OSD_MASK_CLR(x)     (OSD_ITEM(x) == 0xff)?0:(OSD_MASK[OSD_ITEM(x)>>4] &= ~(0x01<<(OSD_ITEM(x)&0x0f)));(OSD_ITEM(x) == 0xff)?0: OSD_ITEM_MASK_CLR(x)
#define OSD_MASK_GET(x)     (OSD_MASK[OSD_ITEM(x)>>4] & (0x01<<(OSD_ITEM(x)&0x0f)))
#define OSD_MASK(x,y)  		(OSD_MASK[x] &  (0x01<<y))
#define OSD_MASKSET(x,y)    (OSD_MASK[x] |= (0x01<<y))
/*OSD_MASK_SET ? OSD_MASK ?????:
* OSD_MASK_SET?????????,??_MENU_FUN_BACKLIGHT
* OSD_MASK???????OSD????,???????????
*/

