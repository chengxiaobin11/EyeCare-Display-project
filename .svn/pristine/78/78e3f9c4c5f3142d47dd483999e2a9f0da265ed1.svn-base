// extern BYTE code OsdStateDefineDefault2[6][6];

extern BYTE xdata OsdStateDefine[_OSD_MAIN_LENGTH][12]; // _OSD_ITEM_LENGTH
extern WORD xdata OSD_MASK[_OSD_MAIN_LENGTH];  

