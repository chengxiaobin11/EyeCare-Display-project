             -Q_32K_GROUP_S_CODE);
              
                      // Set D code for auto load mode
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_99_PORT_PAGE71_PRESET_D_CODE_0, HIBYTE(_HDMI_SAMP
             -LING_FREQ_32K_GROUP_D_CODE));
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_9A_PORT_PAGE71_PRESET_D_CODE_1, LOBYTE(_HDMI_SAMP
             -LING_FREQ_32K_GROUP_D_CODE));
              
                      // Enable Auto Load S Code and D Code
                      ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_8A_PORT_PAGE71_AUDIO_FREQDET, ~_BIT6, _BIT6);
              
                      // Set Double Buffer bit
                      ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_10_PORT_PAGE71_HDMI_CMCR, ~_BIT4, _BIT4);
                  }
                  else
                  {
                      // Disable Auto Load S Code
                      ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_8A_PORT_PAGE71_AUDIO_FREQDET, ~_BIT6, 0x00);
              
                      // Set S code User Define
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_12_PORT_PAGE71_HDMI_SCAPR, ScalerAudioGetUserSamp
             -lingFreqSCode(_PORT_HDMI, GET_D2_SAMPLING_FREQ_USER_DEFINE()));
              
                      // Set D code User Define
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_13_PORT_PAGE71_HDMI_DCAPR0, HIBYTE(ScalerAudioGet
             -UserSamplingFreqDCode(_PORT_HDMI, GET_D2_SAMPLING_FREQ_USER_DEFINE())));
                      ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_14_PORT_PAGE71_HDMI_DCAPR1, LOBYTE(ScalerAudioGet
             -UserSamplingFreqDCode(_PORT_HDMI, GET_D2_SAMPLING_FREQ_USER_DEFINE())));
              
                      // Set Double Buffer bit
                      ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_10_PORT_PAGE71_HDMI_CMCR, ~_BIT4, _BIT4);
              
                      // Load D code
                      ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, ~_BIT6, _BIT6);
                      ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, ~_BIT6, 0x00);
                  }
              }
