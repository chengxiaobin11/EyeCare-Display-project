              #if(_INTERNAL_AUDIO_TEST_SUPPORT == _ON)
              //--------------------------------------------------
              // Description  : Get Whether Internal Audio Pattern Gen is Enabled
              // Input Value  : None
              // Output Value : _ENABLE or _DISABLE
              //--------------------------------------------------
              bit ScalerAudioD4GetInternalAudioGenEnable(void)
              {
                  if(ScalerGetDataPortBit(P73_C9_HDMI_AP, _P73_CA_PT_03_PORT_PAGE73_HDMI_AFCR, _BIT4) == _BIT4)
                  {
                      return _ENABLE;
                  }
                  else
                  {
                      return _DISABLE;
                  }
              }
              //--------------------------------------------------
              // Description  : D4 Auido Speaker Testing Process
              // Input Value  : Enable or Disable
              // Output Value : None
              //--------------------------------------------------
              void ScalerAudioD4InternalAudioGenSwitch(bit bOn, EnumAudioLeftRightChannelSelect enumAudioLeftRightChanne
             -lSelect)
              {
                  enumAudioLeftRightChannelSelect = enumAudioLeftRightChannelSelect;
              
                  if(bOn == _ON)
                  {
                      DebugMessageAudio("D4 Audio Test On", ScalerGetDataPortBit(P73_C9_HDMI_AP, _P73_CA_PT_03_PORT_PAGE
             -73_HDMI_AFCR, _BIT4));
              
                      // Disable audio FIFO and Enable audio internal generator
