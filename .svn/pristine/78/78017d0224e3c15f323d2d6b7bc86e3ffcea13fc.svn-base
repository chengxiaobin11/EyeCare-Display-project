 226          //--------------------------------------------------
 227          // Description  : Get if Digital Audio Port Changed
 228          // Input Value  : ucInputPort
 229          // Output Value : _TRUE of _FALSE
 230          //--------------------------------------------------
 231          bit ScalerAudioGetAudioInputPortChanged(EnumAudioInputSource enumAudioSource, BYTE ucInputPort)
 232          {
 233   1      #if(_INTERNAL_AUDIO_TEST_SUPPORT == _ON)
                  if(ScalerAudioGetInternalAudioGenEnable(ucInputPort) == _ENABLE)
                  {
                      // Avoid Port Switching when in audio gen play
                      return _FALSE;
                  }
              #endif
 240   1      
 241   1      #if(_LINE_IN_SUPPORT == _ON)
                  if(enumAudioSource != ScalerAudioGetInputSource())
                  {
                      return _TRUE;
                  }
              #endif
 247   1      
 248   1          if(enumAudioSource == _DIGITAL_AUDIO)
 249   1          {
 250   2              return (ucInputPort != ScalerAudioGetDigitalAudioPortMapping());
 251   2          }
 252   1      
 253   1          return _FALSE;
 254   1      }
