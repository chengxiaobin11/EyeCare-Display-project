 420          //--------------------------------------------------
 421          // Description  : Initial D0 DP audio setting
 422          // Input Value  : None
 423          // Output Value : None
 424          //--------------------------------------------------
 425          void ScalerAudioD0DPAudioInitial(void)
 426          {
 427   1          ScalerAudioD0SetAudioPLL();
 428   1      
 429   1      #if(_DIGITAL_AUDIO_OUTPUT_MUTE_CONTROL_SUPPORT == _ON)
                  // Disable Audio Output
                  ScalerSetByte(PB6_B3_DP_CHANNEL_EN, 0x00);
              #endif
 433   1      
 434   1          // Disable Check VBID[4] to Mute Audio by HW and disable Audio FSM
 435   1          ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~(_BIT7 | _BIT1), 0x00);
 436   1      
 437   1          // Disable AFD, set 2ms for auto freq. detect and disable 44.1kHz as 48kHz
 438   1          ScalerSetBit(PB6_50_AUD_FREQUENY_DET_0, ~(_BIT7 | _BIT3 | _BIT2 | _BIT0), _BIT2);
 439   1      
 440   1          // Set threshold to separate sampling frequency
 441   1          ScalerSetByte(PB6_52_AUD_FREQUENY_TH_0, 0x00);
 442   1          ScalerSetByte(PB6_53_AUD_FREQUENY_TH_1, 0x00);
 443   1          ScalerSetByte(PB6_54_AUD_FREQUENY_TH_2, 0x28);
 444   1          ScalerSetByte(PB6_55_AUD_FREQUENY_TH_3, 0x4C);
 445   1          ScalerSetByte(PB6_56_AUD_FREQUENY_TH_4, 0x5C);
 446   1          ScalerSetByte(PB6_57_AUD_FREQUENY_TH_5, 0x70);
 447   1      
 448   1          // Enable RS Decode
 449   1          ScalerSetBit(PB6_2B_MN_RS_DEC_CTRL, ~(_BIT7 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | _BIT3 | _BIT2 |
             - _BIT1 | _BIT0));
 450   1      
 451   1          // Set xtal divider for sampling freq. detection
 452   1          ScalerSetByte(PB6_51_AUD_FREQUENY_DET_1, _AUTO_FREQ_DETECT_XTAL_DIV);
 453   1      
 454   1          // Enable SDM control
 455   1          ScalerSetBit(PB6_80_AUD_PS_CTRL_0, ~_BIT7, _BIT7);
 456   1      
 457   1          // Disable Boundary Tracking Method
 458   1          ScalerSetBit(PB6_81_AUD_BDRY_0, ~_BIT7, 0x00);
 459   1      
 460   1          // Set I code of boundary tracking
 461   1          ScalerSetByte(PB6_83_AUD_BDRY_2, HIBYTE(_INITIAL_I_CODE));
 462   1          ScalerSetByte(PB6_84_AUD_BDRY_3, LOBYTE(_INITIAL_I_CODE));
 463   1      
 464   1          // Set P code of boundary tracking
 465   1          ScalerSetByte(PB6_85_AUD_BDRY_4, 0x7F);
 466   1          ScalerSetByte(PB6_86_AUD_BDRY_5, 0xFF);
 467   1      
 468   1          // Disable Trend Tracking Method
 469   1          ScalerSetBit(PB6_92_AUD_TRND_0, ~_BIT7, 0x00);
 470   1      
 471   1          // Set I code of trend tracking
 472   1          ScalerSetByte(PB6_99_AUD_TRND_7, 0x00);
C51 COMPILER V9.60.0.0   SCALERAUDIO_SEPTPHY                                               09/09/2025 14:04:04 PAGE 9   

 473   1          ScalerSetByte(PB6_9A_AUD_TRND_8, 0x02);
 474   1      
 475   1          // Set P code of trend tracking
 476   1          ScalerSetByte(PB6_9B_AUD_TRND_9, 0x7F);
 477   1          ScalerSetByte(PB6_9C_AUD_TRND_10, 0xFF);
