 598          //--------------------------------------------------
 599          // Description  : Set ZCD Timeout for DP Audio
 600          // Input Value  : bAdjustType, enumSamplingFreqPacket
 601          // Output Value : None
 602          //--------------------------------------------------
 603          void ScalerAudioD0DPSetDVCWindowSize(bit bAdjustType, EnumAudioSamplingFreqPacket enumSamplingFreqPacket)
 604          {
 605   1          if(enumSamplingFreqPacket == _AUDIO_FREQ_PACKET_NO_AUDIO)
 606   1          {
 607   2              enumSamplingFreqPacket = _AUDIO_FREQ_PACKET_48K;
 608   2          }
 609   1      
 610   1          if(bAdjustType == _DB_GAIN)
 611   1          {
 612   2              // Get numbers of the volume step for mute or unmute
 613   2              PDATA_WORD(0) = _DVC_DB_STEP_NUMBER << 3;
 614   2          }
 615   1          else
 616   1          {
 617   2              // Volume Max = 0x3FFF
 618   2              PDATA_WORD(0) = 0x3FFF / _DP_VOLUME_STEP_SIZE_VALUE + 1;
 619   2          }
 620   1      
 621   1          // Calculate samples of ZCD timeout
 622   1          PDATA_DWORD(1) = (DWORD)enumSamplingFreqPacket * _DP_DVC_VOLUME_MUTE_TIMER / PDATA_WORD(0);
 623   1      
 624   1          // Avoid Overflow
 625   1          if(PDATA_DWORD(1) > 0x0FFF)
 626   1          {
 627   2              PDATA_WORD(0) = 0x0FFF;
 628   2          }
 629   1          else
 630   1          {
 631   2              PDATA_WORD(0) = (WORD)PDATA_DWORD(1);
 632   2          }
 633   1      
 634   1          // Set DVC ZCD window size
 635   1          ScalerSetBit(PB6_78_DVC_WINDOW_CONTROL_0, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), HIBYTE(PDATA_WORD(0)));
 636   1          ScalerSetByte(PB6_79_DVC_WINDOW_CONTROL_1, LOBYTE(PDATA_WORD(0)));
 637   1      }
