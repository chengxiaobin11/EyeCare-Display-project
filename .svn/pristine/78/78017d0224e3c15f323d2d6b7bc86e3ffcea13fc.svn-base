2447   1          ScalerSetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_10_PORT_PAGE72_HDMI_CMCR, ~(_BIT4 | _BIT3 | _BIT2 | _B
             -IT1 | _BIT0), (_BIT4 | ((_AUDIO_PLL_K - 2) & 0x0F)));
2448   1      
2449   1          // Initial VCO Band = 10
