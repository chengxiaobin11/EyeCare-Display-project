                  ScalerGetDataPortByte(P73_C9_HDMI_AP, _P73_CA_PT_3C_PORT_PAGE73_HDMI_SUMCM, 2, &pData[0], _AUTOINC);
                  usbackupSumc = (((WORD)pData[0] << 8) | pData[1]);
              
