C51 COMPILER V9.60.0.0   SCALERAUDIO_SEPTPHY                                               09/09/2025 14:04:04 PAGE 72  

             -mc));
                          ScalerSetDataPortByte(P73_C9_HDMI_AP, _P73_CA_PT_13_PORT_PAGE73_HDMI_DCAPR0, HIBYTE(usbackupSu
