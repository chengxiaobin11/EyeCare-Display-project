             -PLING_FREQ_USER_DEFINE())));
                      ScalerSetByte(PB9_A0_AUD_D_CODE_1, LOBYTE(ScalerAudioGetUserSamplingFreqDCode(_PORT_DP, GET_D1_SAM
             -PLING_FREQ_USER_DEFINE())));
              
                      // D code Double Buffer
                      ScalerSetBit(PB9_7C_AUD_FSM_CTRL_1, ~_BIT7, _BIT7);
