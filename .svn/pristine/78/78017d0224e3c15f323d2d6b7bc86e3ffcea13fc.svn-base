2388          // Description  : Detect D3 Audio Sampling Freq
2389          // Input Value  : None
2390          // Output Value : Audio Sampling Freq
2391          //--------------------------------------------------
2392          EnumAudioSamplingFreqType ScalerAudioD3SamplingFreqDetect(void)
2393          {
2394   1          EnumAudioSamplingFreqType enumAudioFreq = _AUDIO_FREQ_NO_AUDIO;
2395   1      
2396   1      #if(_INTERNAL_AUDIO_TEST_SUPPORT == _ON)
                  if(ScalerAudioD3GetInternalAudioGenEnable() == _ENABLE)
                  {
                      // For Audio test pattern
                      SET_AUDIO_D3_SAMPLING_FREQ(_AUDIO_FREQ_48K);
                      return _AUDIO_FREQ_48K;
                  }
              #endif
2404   1      
2405   1          enumAudioFreq = ScalerGetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_8B_PORT_PAGE72_AUDIO_FREQ_RESULT, (_BI
             -T3 | _BIT2 | _BIT1 | _BIT0));
2406   1      
2407   1      #if(_EMBEDDED_DAC_SUPPORT == _ON)
2408   1          if(enumAudioFreq != GET_AUDIO_D3_SAMPLING_FREQ())
2409   1          {
2410   2              if(enumAudioFreq <= _AUDIO_FREQ_64K)
2411   2              {
2412   3                  ScalerSetBit(P6_D4_DA_CLK_CTRL, ~(_BIT7 | _BIT6), 0x00);
2413   3              }
2414   2              else if(enumAudioFreq <= _AUDIO_FREQ_128K)
2415   2              {
2416   3                  ScalerSetBit(P6_D4_DA_CLK_CTRL, ~(_BIT7 | _BIT6), _BIT6);
2417   3              }
2418   2              else
2419   2              {
C51 COMPILER V9.60.0.0   SCALERAUDIO_SEPTPHY                                               09/09/2025 14:04:04 PAGE 43  

2420   3                  ScalerSetBit(P6_D4_DA_CLK_CTRL, ~(_BIT7 | _BIT6), _BIT7);
2421   3              }
2422   2          }
2423   1      #endif
2424   1      
2425   1          SET_AUDIO_D3_SAMPLING_FREQ(enumAudioFreq);
2426   1      
2427   1          return enumAudioFreq;
2428   1      }
