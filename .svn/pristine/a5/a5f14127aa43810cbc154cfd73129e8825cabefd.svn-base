  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Set window 7 Special function
  49          // Input Value  : enumOsdWindow7FunctionType   -> _OSD_WINDOW_7_FUNCTION_DISABLE                        or
             - _OSD_WINDOW_7_FUNCTION_NO_BLENDING_BOTH                  or
  50          //                                                _OSD_WINDOW_7_FUNCTION_NO_BLENDING_FOREGROUND         or
C51 COMPILER V8.12   OSDWINDOW7SPECIALFUNCTION                                             03/11/2025 19:56:00 PAGE 2   

             - _OSD_WINDOW_7_FUNCTION_NO_BLENDING_BACKGROUND            or
  51          //                                                _OSD_WINDOW_7_FUNCTION_BLENDING_BOTH                  or
             - _OSD_WINDOW_7_FUNCTION_MASK_REGION_APPEAR                or
  52          //                                                _OSD_WINDOW_7_FUNCTION_MASK_REGION_TRANSPARENT_ALL    or
             - _OSD_WINDOW_7_FUNCTION_MASK_REGION_TRANSPARENT_FONT
  53          // Output Value :
  54          //--------------------------------------------------
  55          void ScalerOsdWindow7SpecialFunction(EnumOsdWindow7FunctionType enumOsdWindow7FunctionType)
  56          {
  57   1          if((enumOsdWindow7FunctionType == _OSD_WINDOW_7_FUNCTION_NO_BLENDING_BOTH) ||
  58   1             (enumOsdWindow7FunctionType == _OSD_WINDOW_7_FUNCTION_NO_BLENDING_FOREGROUND) ||
  59   1             (enumOsdWindow7FunctionType == _OSD_WINDOW_7_FUNCTION_NO_BLENDING_BACKGROUND) ||
  60   1             (enumOsdWindow7FunctionType == _OSD_WINDOW_7_FUNCTION_BLENDING_BOTH))
  61   1          {
  62   2              ScalerSetBit(P3A_09_FRAME_CTRL_09, ~(_BIT6 | _BIT5), _BIT5);  // 01: Blending (blending type 3)
  63   2              ScalerSetBit(P3A_21_FRAME_CTRL_21, ~(_BIT5 | _BIT4), ((enumOsdWindow7FunctionType - _OSD_WINDOW_7_
             -FUNCTION_NO_BLENDING_BOTH) << 4));
  64   2          }
  65   1          else if(enumOsdWindow7FunctionType == _OSD_WINDOW_7_FUNCTION_MASK_REGION_APPEAR)
  66   1          {
  67   2              ScalerSetBit(P3A_09_FRAME_CTRL_09, ~(_BIT6 | _BIT5), _BIT6);  // 10: Window 7 mask region appear
  68   2          }
  69   1          else if((enumOsdWindow7FunctionType == _OSD_WINDOW_7_FUNCTION_MASK_REGION_TRANSPARENT_ALL) || (enumOsd
             -Window7FunctionType == _OSD_WINDOW_7_FUNCTION_MASK_REGION_TRANSPARENT_FONT))
  70   1          {
  71   2              ScalerSetBit(P3A_09_FRAME_CTRL_09, ~(_BIT6 | _BIT5), (_BIT6 | _BIT5));  // 11: Window 7 mask regio
             -n transparent
  72   2              ScalerSetBit(P3A_07_FRAME_CTRL_07, ~_BIT3, ((enumOsdWindow7FunctionType - _OSD_WINDOW_7_FUNCTION_M
             -ASK_REGION_TRANSPARENT_ALL) << 3));
  73   2          }
  74   1          else
  75   1          {
  76   2              ScalerSetBit(P3A_09_FRAME_CTRL_09, ~(_BIT6 | _BIT5), 0x00);
  77   2          }
  78   1      }
