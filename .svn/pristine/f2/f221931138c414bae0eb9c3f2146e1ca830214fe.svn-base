 173   2      
 174   2              // Clear DEN_START IRQ flag
 175   2              ScalerSetBit_EXINT(P0_05_IRQ_CTRL1, ~(_BIT6 | _BIT4 | _BIT2), _BIT2);
 176   2      
 177   2              //=======================================================
 178   2              // Get current serial number in repeated frame sequence
 179   2              //=======================================================
 180   2              // Backup data port address
 181   2              ucBackupDataPortAddr = ScalerGetByte_EXINT(P0_2A_DISPLAY_FORMAT_ADDR_PORT);
