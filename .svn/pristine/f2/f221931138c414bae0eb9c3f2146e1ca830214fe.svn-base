  52          //--------------------------------------------------
  53          // Description  : OD on/off
  54          // Input Value  : enumOn --> _FUNCTION_ON/_FUNCTION_OFF
  55          // Output Value : None
  56          //--------------------------------------------------
  57          void ScalerODEnable(EnumFunctionOnOFF enumOn)
  58          {
  59   1          //=================
  60   1          // Enable OD
  61   1          //=================
  62   1          DebugMessageOsd("GET_OD_USE_BIT()", GET_OD_USE_BIT());
  63   1          if((enumOn == _FUNCTION_ON) && (GET_OD_USE_BIT() != _OFF))
  64   1          {
  65   2              // Enable OD clock
  66   2              ScalerSetBit(P1_DC_DCLK_GATED_CTRL2, ~_BIT2, _BIT2);
  67   2      
  68   2      #if(_FRC_SUPPORT == _ON)
  69   2              DebugMessageFRC("OD_ON", 0);
  70   2      
  71   2      #if(_MEMORY_TYPE_CONFIG == _MEMORY_DDR1)
  72   2              ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  73   2              ScalerDDR1SetFRCDisplayTokenRing(enumOn);
  74   2      #endif
  75   2              if(GET_DYNAMIC_OD_STATUS() == _ENABLE)
  76   2              {
  77   3                  DebugMessageFRC("Dynamic OD", GET_MEMORY_DVF_SELECT());
  78   3      
  79   3                  // Enable DEN_START IRQ
  80   3                  SET_OD_CURR_DYNAMIC_STATUS(_ENABLE);
  81   3                  ScalerGlobalSetInterrupt(_IRQ_DEN_START, _ENABLE);
  82   3              }
  83   2              else
  84   2              {
  85   3                  DebugMessageFRC("Static OD", 0);
  86   3      
  87   3                  // Enable OD function, disable DEN_START IRQ
  88   3                  SET_OD_CURR_DYNAMIC_STATUS(_DISABLE);
  89   3                  ScalerGlobalSetInterrupt(_IRQ_DEN_START, _DISABLE);
  90   3                  ScalerSetBit(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
  91   3              }
  92   2      #else
                      // Enable OD function
                      ScalerSetBit(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
              #endif
  96   2          }
  97   1          //=================
  98   1          // Disable OD
  99   1          //=================
 100   1          else
 101   1          {
 102   2              // Enable OD clock
 103   2              ScalerSetBit(P1_DC_DCLK_GATED_CTRL2, ~_BIT2, _BIT2);
 104   2      
 105   2      #if(_FRC_SUPPORT == _ON)
 106   2              DebugMessageFRC("OD_OFF", 0);
 107   2      
 108   2              SET_OD_CURR_DYNAMIC_STATUS(_DISABLE);
 109   2              ScalerGlobalSetInterrupt(_IRQ_DEN_START, _DISABLE);
C51 COMPILER V9.01   RL6432_SERIES_OD                                                      08/18/2025 18:01:58 PAGE 3   

 110   2      #endif
 111   2              // Disable OD function
 112   2              ScalerSetBit(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), 0x00);
 113   2      
 114   2      #if(_MEMORY_TYPE_CONFIG == _MEMORY_DDR1)
 115   2      #if(_FRC_SUPPORT == _ON)
 116   2              ScalerTimerWaitForEvent(_EVENT_DVS);
 117   2      
