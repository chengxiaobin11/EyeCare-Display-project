 209   4                              ScalerSetBit_EXINT(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), 0x00);
 210   4                              break;
 211   4      
 212   4                          case 1:
 213   4                              // Enable OD
 214   4                              ScalerSetBit_EXINT(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 215   4                              break;
 216   4      
