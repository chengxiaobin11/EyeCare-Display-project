 136          //--------------------------------------------------
 137          // Description  : Initialize OD memory start address
 138          // Input Value  : None
 139          // Output Value : None
 140          //--------------------------------------------------
 141          void ScalerODSetMemoryStartAddress(void)
 142          {
 143   1          // Calculate OD memory use space, unit:row
 144   1          PDATA_WORD(0) = ((((DWORD)CEILING(_PANEL_DH_WIDTH, _OD_PIXEL_PER_COMP)) * _PANEL_DV_HEIGHT * GET_OD_US
             -E_BIT() / _MEMORY_BIT_NUM) /
 145   1                           (_MEMORY_COL_PER_BANK * _MEMORY_BANK) / 10 + 1);
 146   1      
 147   1          // Set Memory Start Address
 148   1          PDATA_WORD(0) = ((DWORD)_MEMORY_ROW - PDATA_WORD(0)) << 2;
 149   1      
 150   1          ScalerSetByte(P3_DB_LS_DDR_START_ADDR_H, pData[0]);
 151   1          ScalerSetByte(P3_DC_LS_DDR_START_ADDR_M, pData[1]);
 152   1          ScalerSetByte(P3_DD_LS_DDR_START_ADDR_L, 0x00);
 153   1      }
