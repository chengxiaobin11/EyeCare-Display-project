 424          void ScalerGDIPhyDigitalPhySwitch(BYTE ucInputPort)
 425          {
 426   1          ScalerGDIPhy2DSwitch(ucInputPort);
 427   1      
 428   1          // remove Z0 always enable due to version-C solve interference
 429   1          if(ScalerGlobalGetIDCode() < _RL6463_VER_C_ID_CODE)
 430   1          {
 431   2              // RL6463 DP/HDMI has interference issue, need turn on another port's Z0.
 432   2              switch(ucInputPort)
 433   2              {
 434   3      #if(_D1_INPUT_PORT_TYPE != _D1_NO_PORT)
 435   3                  case _D0_INPUT_PORT:
 436   3      
 437   3                      // Enable Port 1 Z0
 438   3                      ScalerSetBit(PB_B9_IMPEDANCE_02, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT2 | _BIT1 
             -| _BIT0));
 439   3                      break;
 440   3      #endif
 441   3      
 442   3      #if(_D0_INPUT_PORT_TYPE != _D0_NO_PORT)
                          case _D1_INPUT_PORT:
                              // Enable Port 0 Z0
                              ScalerSetBit(PB_B7_IMPEDANCE_00, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT2 | _BIT1 
             -| _BIT0));
                              break;
              #endif
 448   3      
 449   3                  default:
 450   3                      break;
 451   3              }
 452   2          }
 453   1      
 454   1      
 455   1          /////////////////
 456   1          // DP --> TMDS //
 457   1          /////////////////
 458   1      
 459   1      #if((_DVI_SUPPORT == _ON) || (_HDMI_SUPPORT == _ON))
 460   1          if(((_D0_INPUT_PORT_TYPE != _D0_DP_PORT) && (ucInputPort == _D0_INPUT_PORT)) ||
 461   1             ((_D1_INPUT_PORT_TYPE != _D1_DP_PORT) && (ucInputPort == _D1_INPUT_PORT)))
 462   1          {
 463   2              // Current SI at DP
 464   2              if(ScalerGetBit(PB_B6_BANDGAP_02, _BIT5) != 0x00)
 465   2              {
 466   3                  // Disable Rx_En and CMU_En
 467   3                  ScalerSetByte(PB_C0_CMU_03, 0x00);
 468   3      
 469   3                  // Disable CMU PLL
 470   3                  ScalerSetBit(PB_C1_CMU_04, ~_BIT7, 0x00);
 471   3      
 472   3                  // Disable Auto K-offset
 473   3                  // Disable Auto K-offset Auto Mode
 474   3                  ScalerSetBit(PB_CA_KOFFSET_04, ~(_BIT7 | _BIT6), 0x00);
C51 COMPILER V8.12   RL6463_SERIES_GDIPHY                                                  03/10/2025 13:50:45 PAGE 9   

 475   3      
 476   3                  switch(ucInputPort)
 477   3                  {
 478   4                      case _D0_INPUT_PORT:
 479   4      
 480   4                          CLR_DIGITAL_PORT_SWITCH_TO_D0();
 481   4      
 482   4                          // Disable Port 0 Z0
 483   4                          ScalerSetBit(PB_B7_IMPEDANCE_00, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 484   4      
 485   4                          break;
 486   4      
 487   4                      case _D1_INPUT_PORT:
 488   4      
 489   4                          CLR_DIGITAL_PORT_SWITCH_TO_D1();
 490   4      
 491   4                          // Disable Port 1 Z0
 492   4                          ScalerSetBit(PB_B9_IMPEDANCE_02, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 493   4      
 494   4                          break;
 495   4      
 496   4                      default:
 497   4      
 498   4                          break;
 499   4                  }
 500   3      
 501   3                  // Analog Select to HDMI
 502   3                  ScalerSetBit(PB_B6_BANDGAP_02, ~_BIT5, 0x00);
 503   3      
 504   3                  // Termination to VDD
