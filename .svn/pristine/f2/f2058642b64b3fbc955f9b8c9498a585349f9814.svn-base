  60          //--------------------------------------------------
  61          // Description  : GDI Bandgap Power On/Off
  62          // Input Value  : On/Off
  63          // Output Value : None
  64          //--------------------------------------------------
  65          void ScalerGDIPhyBandgap(bit bSelect)
  66          {
  67   1          // [5] EN_ENHANCE_BIAS = 1 --> Enhance Clock Lane Input Buffer Bias Current
  68   1          ScalerSetBit(PB_B5_BANDGAP_01, ~_BIT5, _BIT5);
  69   1      
  70   1          // [0] en_clkdetect = 0 --> from hysteresis
  71   1          ScalerSetBit(PB_B3_CLK_DET, ~_BIT0, 0x00);
  72   1      
  73   1          if(bSelect == _ON)
  74   1          {
  75   2              ////////////////
  76   2              // BangGap EN //
  77   2              ////////////////
  78   2      
  79   2              // [7] EN_GDI_BG = 1'b1 --> GDI BG Power On
  80   2              // [6:5] RBG = 2'b00 --> BG = 1.245V
  81   2              ScalerSetBit(PB_B4_BANDGAP_00, ~(_BIT6 | _BIT5), 0x00);
  82   2              ScalerSetBit(PB_B4_BANDGAP_00, ~_BIT7, _BIT7);
  83   2      
  84   2              // [3] Always Set to 1 for PFD Deglitch Function Bug
  85   2              ScalerSetBit(PB_C1_CMU_04, ~_BIT3, _BIT3);
  86   2      
  87   2              // HDMI Clock Gating to Measure Block
  88   2              ScalerSetBit(P2_E1_AUX_PS_REPLY, ~_BIT7, _BIT7);
  89   2      
  90   2              // [4] sel_bgr_bias = 1 --> Vref = VBG
  91   2              ScalerSetBit(PB_B4_BANDGAP_00, ~_BIT4, _BIT4);
  92   2      
  93   2      #if(_D0_INPUT_PORT_TYPE == _D0_DP_PORT)
                      // Enable Z0
                      ScalerSetBit(PB_B7_IMPEDANCE_00, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT2 | _BIT1 | _BIT0)
             -);
              #endif
  97   2      
  98   2      #if(_D1_INPUT_PORT_TYPE == _D1_DP_PORT)
                      // Enable Z0
                      ScalerSetBit(PB_B9_IMPEDANCE_02, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT2 | _BIT1 | _BIT0)
             -);
              #endif
 102   2          }
 103   1          else
 104   1          {
 105   2              // [7] EN_GDI_BG = 1'b0 --> GDI BG Power Off
 106   2              ScalerSetBit(PB_B4_BANDGAP_00, ~_BIT7, 0x00);
 107   2          }
 108   1      }
