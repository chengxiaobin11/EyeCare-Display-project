7218   3                  if((ScalerDpRx0AuxChSourcePowerCheck() == _OFF) &&
7219   3                     (GET_DP_RX0_CHECK_AUX_CH_NO_POWER_DEBOUNCE() == _FALSE) &&
7220   3                     (GET_DP_RX0_CHECK_AUX_CH_POWER_STATUS() == _DP_RX_AUX_POWER_STATUS_ON))
