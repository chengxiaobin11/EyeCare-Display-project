 510          //--------------------------------------------------
 511          // Description  : DP BS to VS Delay Calculation
 512          // Input Value  : None
 513          // Output Value : BS to VS Delay
 514          //--------------------------------------------------
 515          DWORD ScalerDpRx0GetBStoVSDelay(void)
 516          {
 517   1          DWORD ulVFrontPorch = 0;
 518   1          DWORD ulHFrontPorch = 0;
 519   1          WORD usFifoOffset = 0;
 520   1      
 521   1          // Get Htotal
 522   1          ScalerRead(PB6_08_MSA_HTT_0, 2, &pData[2], _AUTOINC);
 523   1      
 524   1          // VFrontPorch = 3 * Htotal * (Link Clk / Stream CLK)
 525   1          ulVFrontPorch = ((DWORD)GET_DP_RX0_VFRONT_PORCH()) * ((DWORD)PDATA_WORD(1) * 256) / ((DWORD)GET_INPUT_
             -PIXEL_CLK()) *
 526   1                          ((DWORD)ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00) * 270) / 256;
 527   1      
 528   1          // Get Hactive
 529   1          ScalerRead(PB6_0C_MSA_HWD_0, 2, pData, _AUTOINC);
 530   1      
 531   1          // Get HSW
 532   1          pData[4] = ScalerGetBit(PB6_0E_MSA_HSW_0, (_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0));
 533   1          pData[5] = ScalerGetByte(PB6_0F_MSA_HSW_1);
 534   1      
 535   1          // Get HSW min by Measure clock
 536   1          PDATA_WORD(3) = ((DWORD) _DP_HSYNC_WIDTH_MEASURE_COUNTER * GET_INPUT_PIXEL_CLK() * 100) / _MEASURE_CLK
C51 COMPILER V9.60.0.0   SCALERDPRX0_SEPTPHY                                               08/21/2025 10:44:22 PAGE 10  

             - + 1;
 537   1      
 538   1          // Check HSW <= HSW min
 539   1          if(PDATA_WORD(2) <= PDATA_WORD(3))
 540   1          {
 541   2              // Check if H porch is more than HSW min
 542   2              if((PDATA_WORD(1) - PDATA_WORD(0)) >= PDATA_WORD(3))
 543   2              {
 544   3                  // HSW = HSW min
 545   3                  PDATA_WORD(2) = PDATA_WORD(3);
 546   3              }
 547   2              else
 548   2              {
 549   3                  // HSW = Max H Porch
 550   3                  PDATA_WORD(2) = (PDATA_WORD(1) - PDATA_WORD(0));
 551   3              }
 552   2          }
 553   1      
 554   1          // DPF H Front Porch must not be less than 8 (HW constraint)
 555   1          // Check if H porch is more than 8
 556   1          if((PDATA_WORD(1) - PDATA_WORD(0) - PDATA_WORD(2)) <= _DP_HSYNC_FRONT_PORCH)
 557   1          {
 558   2              // HSW < HSW min
 559   2              if(PDATA_WORD(2) < PDATA_WORD(3))
 560   2              {
 561   3                  // Hstart = HSW
 562   3                  PDATA_WORD(4) = PDATA_WORD(2);
 563   3              }
 564   2              else if((PDATA_WORD(1) - PDATA_WORD(0) - PDATA_WORD(3) >= _DP_HSYNC_FRONT_PORCH))
 565   2              {
 566   3                  // HSW = H porch - _DP_HSYNC_FRONT_PORCH
 567   3                  PDATA_WORD(2) = PDATA_WORD(1) - PDATA_WORD(0) - _DP_HSYNC_FRONT_PORCH;
 568   3      
 569   3                  // Hstart = HSW
 570   3                  PDATA_WORD(4) = PDATA_WORD(2);
 571   3              }
 572   2              else
 573   2              {
 574   3                  // HSW = HSW min
 575   3                  PDATA_WORD(2) = PDATA_WORD(3);
 576   3      
 577   3                  // Hstart = HSW min
 578   3                  PDATA_WORD(4) = PDATA_WORD(3);
 579   3              }
 580   2          }
 581   1          else
 582   1          {
 583   2              // Hstart = Htotal - Hactive - _DP_HSYNC_FRONT_PORCH
 584   2              PDATA_WORD(4) = PDATA_WORD(1) - PDATA_WORD(0) - _DP_HSYNC_FRONT_PORCH;
 585   2          }
 586   1      
 587   1          // HFrontPorch = (Htotal - Hactive - Hstart) * (Link Clk / Stream CLK)
 588   1          ulHFrontPorch = (((DWORD)(PDATA_WORD(1) - PDATA_WORD(0) - PDATA_WORD(4))) * (((DWORD)ScalerDpRx0GetDpc
             -dInfo(0x00, 0x01, 0x00)) * 270) / ((DWORD)GET_INPUT_PIXEL_CLK()));
 589   1      
 590   1          pData[15] = GET_COLOR_DEPTH();
 591   1      
 592   1          // DP fifo size = 256 x 96bit
 593   1          if(GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR422)
 594   1          {
 595   2              // FifoOffset = (1/2 * (256 * 96) / (2 * depth per color)), color format is YCbCr 4:2:2
 596   2              usFifoOffset = _HW_DP_RX_VIDEO_FIFO_SIZE / (4 * (WORD)pData[15]);
C51 COMPILER V9.60.0.0   SCALERDPRX0_SEPTPHY                                               08/21/2025 10:44:22 PAGE 11  

 597   2          }
 598   1          else
 599   1          {
 600   2              // FifoOffset = (1/2 * (256 * 96) / (3 * depth per color)), color format is RGB or YCbCr 4:4:4 or 
             -others
 601   2              usFifoOffset = _HW_DP_RX_VIDEO_FIFO_SIZE / (6 * (WORD)pData[15]);
 602   2          }
 603   1      
 604   1          // FifoOffset = (1/2 * (256 * 96) / (3 * depth per color)) * (Link Clk / Stream CLK))
 605   1          usFifoOffset = (WORD)(((DWORD)usFifoOffset) * (((DWORD)ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00)) * 270
             -) / ((DWORD)GET_INPUT_PIXEL_CLK()));
 606   1      
 607   1          return ((ulVFrontPorch + ulHFrontPorch + (DWORD)usFifoOffset) / 2);
 608   1      }
