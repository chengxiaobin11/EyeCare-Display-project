 219          #if(_D0_DP_EXIST == _ON)
 220          //--------------------------------------------------
 221          // Description  : DP Adjust Vsync Delay
 222          // Input Value  : None
 223          // Output Value : None
 224          //--------------------------------------------------
 225          void ScalerDpRx0AdjustVsyncDelay(void)
 226          {
 227   1          DWORD ulBStoVSDelayDeltaOverflow = 0;
 228   1          DWORD ulBStoVSDelayDeltaUnderflow = 0;
 229   1      
 230   1          if(ScalerGetBit(PB5_21_PG_CTRL_1, (_BIT1 | _BIT0)) == 0x00)// Fifo Ok
C51 COMPILER V9.60.0.0   SCALERDPRX0_SEPTPHY                                               08/21/2025 10:44:22 PAGE 5   

 231   1          {
 232   2              return;
 233   2          }
 234   1          else if(ScalerGetBit(PB5_21_PG_CTRL_1, _BIT0) == _BIT0) // Fifo Overflow
 235   1          {
 236   2              // Get Htotal
 237   2              ScalerRead(PB6_08_MSA_HTT_0, 2, &pData[0], _AUTOINC);
 238   2      
 239   2              // ((Link Clk * 256)/ Stream CLK) * Htotal / 256 --> 1 Line
 240   2              ulBStoVSDelayDeltaOverflow = (((DWORD)ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00) * 270UL) * 256) / (
             -(DWORD)GET_INPUT_PIXEL_CLK()) * ((DWORD)PDATA_WORD(0)) / 256;
 241   2      
 242   2              DebugMessageRx0("7. Fifo Overflow --> nVidia Case", ulBStoVSDelayDeltaOverflow);
 243   2          }
 244   1          else if(ScalerGetBit(PB5_21_PG_CTRL_1, _BIT1) == _BIT1) // Fifo Underflow
 245   1          {
 246   2              // Get Hactive
 247   2              ScalerRead(PB6_0C_MSA_HWD_0, 2, &pData[0], _AUTOINC);
 248   2      
 249   2              if(PDATA_WORD(0) != 1366)
 250   2              {
 251   3                  return;
 252   3              }
 253   2      
 254   2              PDATA_WORD(0) = PDATA_WORD(0) - 2;
 255   2      
 256   2              // Set Hactive
 257   2              ScalerSetByte(PB5_45_MN_DPF_HWD_M, pData[0]);
 258   2              ScalerSetByte(PB5_46_MN_DPF_HWD_L, pData[1]);
 259   2      
 260   2              // ((Link Clk * 2)/ Stream CLK) --> 2 pixels
 261   2              ulBStoVSDelayDeltaUnderflow = (((DWORD)ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00) * 270) * 2) / ((DW
             -ORD)GET_INPUT_PIXEL_CLK());
 262   2      
 263   2              DebugMessageRx0("7. Fifo Underflow --> QD882 Case", ulBStoVSDelayDeltaUnderflow);
 264   2          }
 265   1      
 266   1          // For Initial Value Before Use PDATA_DWORD(0)
 267   1          pData[0] = 0;
 268   1      
 269   1          // Get BStoVSDelay Even
 270   1          ScalerRead(PB5_32_EVBLK2VS_H, 3, &pData[1], _AUTOINC);
 271   1      
 272   1          // For Initial Value Before Use PDATA_DWORD(1)
 273   1          pData[4] = 0;
 274   1      
 275   1          // Get BStoVSDelay Odd
 276   1          ScalerRead(PB5_35_OVBLK2VS_H, 3, &pData[5], _AUTOINC);
 277   1      
 278   1          // BStoVSDelay = BStoVSDelay + (Nvid * 256 / Mvid) * ((DWORD)Htotal) / 256;
 279   1          PDATA_DWORD(0) = PDATA_DWORD(0) - ((ulBStoVSDelayDeltaOverflow + ulBStoVSDelayDeltaUnderflow) / 2);
 280   1      
 281   1          // BStoVSDelay = BStoVSDelay + (Nvid * 256 / Mvid) * ((DWORD)Htotal) / 256;
 282   1          PDATA_DWORD(1) = PDATA_DWORD(1) - ((ulBStoVSDelayDeltaOverflow + ulBStoVSDelayDeltaUnderflow) / 2);
 283   1      
 284   1          // Set Even Field BS to VS Delay
 285   1          ScalerSetByte(PB5_32_EVBLK2VS_H, pData[1]);
 286   1          ScalerSetByte(PB5_33_EVBLK2VS_M, pData[2]);
 287   1          ScalerSetByte(PB5_34_EVBLK2VS_L, pData[3]);
 288   1      
 289   1          // Set Odd Field BS to VS Delay
 290   1          ScalerSetByte(PB5_35_OVBLK2VS_H, pData[5]);
C51 COMPILER V9.60.0.0   SCALERDPRX0_SEPTPHY                                               08/21/2025 10:44:22 PAGE 6   

 291   1          ScalerSetByte(PB5_36_OVBLK2VS_M, pData[6]);
 292   1          ScalerSetByte(PB5_37_OVBLK2VS_L, pData[7]);
 293   1      
 294   1          // Enable Double Buffer
 295   1          ScalerSetBit(PB5_30_DPF_CTRL_0, ~_BIT6, _BIT6);
 296   1      
 297   1          // Reset Display Format Gen
 298   1          ScalerSetBit(PB5_30_DPF_CTRL_0, ~_BIT7, 0x00);
 299   1          ScalerSetBit(PB5_30_DPF_CTRL_0, ~_BIT7, _BIT7);
 300   1      
 301   1          // Polling Vertical BS
 302   1          if(ScalerDpRx0PollingFlagLinkCheck(50, PB6_01_DP_VBID, _BIT0, _TRUE) == _FALSE)
 303   1          {
 304   2              return;
 305   2          }
 306   1      
 307   1          // Delay for PG Stable
 308   1          if(ScalerDpRx0TimerDelayXmsLinkCheck(_DP_ONE_FRAME_TIME_MAX) == _FALSE)
 309   1          {
 310   2              return;
 311   2          }
 312   1      }
 313          
 314          #if(_FORMAT_CONVERSION_SUPPORT == _ON)
              //--------------------------------------------------
              // Description  : Check VGIP VS bypass for DP
              // Input Value  : None
              // Output Value : _TRUE / _FALSE
              //--------------------------------------------------
              bit ScalerDpRx0CheckVgipVsBypass(void)
              {
                  // Get Hstart
                  ScalerRead(PB5_43_MN_DPF_HST_M, 2, &pData[0], _AUTOINC);
              
                  // Get Vstart
                  ScalerRead(PB5_4B_MN_DPF_VST_M, 2, &pData[2], _AUTOINC);
              
                  // Check for nVedia 2560x1440@144Hz timing (reduced blanking)
                  if((PDATA_WORD(0) < _VGIP_IH_CAPTURE_MIN_VALUE) ||
                     (PDATA_WORD(1) <= _VGIP_IV_CAPTURE_MIN_VALUE))
                  {
                      DebugMessageRx0("DP RX0 VGIP VS Bypass Mode", PDATA_WORD(0));
              
                      return _TRUE;
                  }
              
                  return _FALSE;
              }
              #endif
 340          
 341          //--------------------------------------------------
 342          // Description  : Dp Set Branch Device Specific Field 00500h - 005FFh
 343          // Input Value  : _DP_VERSION_1_1 or _DP_VERSION_1_2 or _DP_VERSION_1_4
 344          // Output Value : None
 345          //--------------------------------------------------
