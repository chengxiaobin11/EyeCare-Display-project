             -);
7225   4                  }
7226   3      
7227   3                  // Debouncing
7228   3                  if(GET_DP_RX0_CHECK_AUX_CH_NO_POWER_DEBOUNCE() == _TRUE)
7229   3                  {
7230   4                      if(ScalerDpRx0AuxChSourcePowerCheck() == _ON)
7231   4                      {
