  48          // Description  :
  49          // Input Value  : ucRow, ucCol -> 1-bit font position
  50          //                ucWidth      -> font width
  51          //                ucLength     -> number of 1-bit font to be changed
C51 COMPILER V8.12   OSDCHARACTERWIDTH                                                     03/11/2025 19:55:55 PAGE 2   

  52          // Output Value :
  53          //--------------------------------------------------
  54          void ScalerOsdCharacterWidth(BYTE ucRow, BYTE ucCol, BYTE ucWidth, BYTE ucLength)
  55          {
  56   1          BYTE ucIdx = 0;
  57   1          bit bOSDOn = _OFF;
  58   1      
  59   1          // Get OSD Status for Write-Protection Function setting OSD circuit enable.
  60   1          bOSDOn = ScalerGetBit(P3A_02_FRAME_CTRL_02, _BIT0);
  61   1      
  62   1          ScalerOsdWriteProtection(_ENABLE, _OSD_BYTE0, (_BIT7 | _BIT6 | _BIT5));
  63   1          ScalerOsdSramAddressCount(ucRow, ucCol, _OSD_BYTE0);
  64   1      
  65   1          for(ucIdx = 0; ucIdx < ucLength; ucIdx++)
  66   1          {
  67   2              ScalerOsdDataPort(ucWidth);
  68   2          }
  69   1      
  70   1          ScalerOsdWriteProtection(_DISABLE, _OSD_BYTE0, (_BIT7 | _BIT6 | _BIT5));
  71   1      
  72   1          // Recovery OSD Status
  73   1          if(bOSDOn == _OFF)
  74   1          {
  75   2              ScalerOsdCircuitActivated(bOSDOn);
  76   2          }
  77   1      }
  78          
