 158   2          }
 159   1      
 160   1          // LVDS data rate = ((Pixel Clk) / (LVDS Outport)) * 7
 161   1          PDATA_DWORD(1) = ((PDATA_DWORD(0) << _D_DOMAIN_PATH) / (1 << _LVDS_OUTPUT_PORT)) * 7;
C51 COMPILER V9.60.0.0   RL6432_SERIES_PLL                                                 08/27/2025 11:01:40 PAGE 4   

 162   1      
