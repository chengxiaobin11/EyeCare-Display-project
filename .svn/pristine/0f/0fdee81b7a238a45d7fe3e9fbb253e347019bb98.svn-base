             -_PORT_CD) || (_LVDS_PORT_SEL == _LVDS_4_PORT_ABCD))
 190   1      
 191   1          // Set CMU: LVDS Mode
 192   1          ScalerSetBit(P55_73_DPTX_CMU3, ~_BIT0, 0x00);
 193   1      
 194   1          // Set CMU Referenced Clk: From Dpll Clk
 195   1          ScalerSetBit(P55_73_DPTX_CMU3, ~_BIT7, _BIT7);
 196   1      
 197   1          // Enable N.F Set By FW
 198   1          ScalerSetBit(P38_D6_DPTX_CMU6, ~_BIT5, _BIT5);
 199   1      
 200   1          // Divider for Postdivider of CMU and Pre-divder of CMU
 201   1          ScalerSetBit(P55_72_DPTX_CMU2, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 202   1      
 203   1          // LDO voltage Setting
 204   1          ScalerSetBit(P55_0E_LVDS_COMMON_AB_CTRL14, ~0xFC, 0xFC);
 205   1      
 206   1          // Setting 16 Phase when N.PI Manual
 207   1          ScalerSetBit(P38_D7_DPTX_CMU7, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 208   1      
 209   1          // CLKRD duty set to 4'b1111 @0638 as AMlee suggests.
 210   1          // Good Phase setting H/L = 4/6
 211   1          ScalerSetBit(P55_5D_DPTX_CKRDDUTY_SPD_SEL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), (_BIT7 | _BIT6 | 
             -_BIT5 | _BIT4 | _BIT3));
 212   1      
 213   1          // [7] 0:CCO Mode, 1:VCO Mode
 214   1          // [6] 0:Small Kvco, 1:Big Kvco
 215   1          // [5] 0:3rd LPF, 1:2nd LPF
 216   1          // [4] 0:1pF, 1:2pF (CMU'S LPF Cp)
 217   1          // [3] 0:Use PI, 1:Bypass PI
 218   1          // [2:0] PI Current setting
 219   1          // ScalerSetBit(P38_D0_DPTX_CMU0, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_
             -BIT6 | _BIT5 | _BIT4 | _BIT1 | _BIT0));
C51 COMPILER V9.60.0.0   RL6432_SERIES_PLL                                                 08/27/2025 11:01:40 PAGE 5   

 220   1      
 221   1          // [2] 0:Small Kvco, 1:Big Kvco
 222   1          // [1] 0:CCO Mode, 1:VCO Mode
 223   1          ScalerSetBit(P55_03_LVDS_COMMON_AB_CTRL3, ~(_BIT2 | _BIT1), _BIT2);
 224   1      
 225   1          // [0] 0:3rd LPF, 1:2nd LPF
 226   1          ScalerSetBit(P55_0F_LVDS_COMMON_AB_CTRL15, ~_BIT0, _BIT0);
 227   1      
 228   1          // [3] 0:Bypass PI, 1:Use PI
 229   1          // [2:0] PI Current setting
 230   1          ScalerSetBit(P55_70_DPTX_CMU0, ~0x0F, (_BIT1 | _BIT0));
 231   1      
 232   1          if(ulCMUFreq > _DPTX_PLL_BOUNDRY_3)
 233   1          {
 234   2              // VCO = 1.5~3 GHz, Phy range = 1.5~3 GHz, Freq_band = div1
 235   2              ScalerSetBit(P55_0F_LVDS_COMMON_AB_CTRL15, ~(_BIT3 | _BIT2 | _BIT1), 0x00);
 236   2          }
 237   1          else if(ulCMUFreq > _DPTX_PLL_BOUNDRY_2)
 238   1          {
 239   2              // VCO = 1.5~3 GHz, Phy range = 0.75~1.5 GHz, Freq_band = div2
 240   2              ScalerSetBit(P55_0F_LVDS_COMMON_AB_CTRL15, ~(_BIT3 | _BIT2 | _BIT1), _BIT1);
 241   2          }
 242   1          else if(ulCMUFreq > _DPTX_PLL_BOUNDRY_1)
 243   1          {
 244   2              // VCO = 1.5~3 GHz, Phy range = 375~750 MHz, Freq_band = div4
 245   2              ScalerSetBit(P55_0F_LVDS_COMMON_AB_CTRL15, ~(_BIT3 | _BIT2 | _BIT1), _BIT2);
 246   2          }
 247   1          else if(ulCMUFreq > _DPTX_PLL_BOUNDRY_0)
 248   1          {
 249   2              // VCO = 1.5~3 GHz, Phy range = 187.5~375 MHz, Freq_band = div4
 250   2              ScalerSetBit(P55_0F_LVDS_COMMON_AB_CTRL15, ~(_BIT3 | _BIT2 | _BIT1), (_BIT2 | _BIT1));
 251   2          }
 252   1          else
 253   1          {
 254   2              // VCO = 1.5~3 GHz, Phy range = 93.75~187.5 MHz, Freq_band = div8
 255   2              ScalerSetBit(P55_0F_LVDS_COMMON_AB_CTRL15, ~(_BIT3 | _BIT2 | _BIT1), _BIT3);
 256   2          }
 257   1      
 258   1          // Count N.F Code
 259   1          usNCode = (7 - 2);
 260   1      
 261   1          // N Code = 9 bit
 262   1          usNCode &= 0x1FF;
 263   1      
 264   1          ScalerSetBit(P38_D6_DPTX_CMU6, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (BYTE)(usNCode >> 4));
 265   1          ScalerSetBit(P38_D7_DPTX_CMU7, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (BYTE)(usNCode << 4));
 266   1      #endif // End of #if((_LVDS_PORT_SEL == _LVDS_1_PORT_C) || (_LVDS_PORT_SEL == _LVDS_1_PORT_D) || (_LVDS_PO
             -RT_SEL == _LVDS_2_PORT_CD) || (_LVDS_PORT_SEL == _LVDS_4_PORT_ABCD))
 267   1      }
