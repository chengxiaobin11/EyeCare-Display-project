 184   1      
 185   1          // Set LVDS PI Operation band
 186   1          ScalerDisplayLvdsSetPhaseBand(((ucDispPllParam & 0x0C) >> 2) << 5);
 187   1      #endif // End of #if((_LVDS_PORT_SEL == _LVDS_1_PORT_A) || (_LVDS_PORT_SEL == _LVDS_1_PORT_B) || (_LVDS_PO
