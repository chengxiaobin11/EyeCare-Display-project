 675   2      #if(_SOURCE_BACKGROUND_DETECT_SUPPORT == _ON)
                          CLR_SOURCE_BG_JUDGE(g_ucBgDetectIndex);
              #endif
 678   2      
 679   2                  // Clear Measure Ready Flag
 680   2                  CLR_MODE_TIMING_CONFIRM();
 681   2      
 682   2                  // Clear M Domain Ready Flag
 683   2                  CLR_MODE_DISPLAY_SETTING_READY();
 684   2      
 685   2                  // Clear No Wait For Active Flag
 686   2                  CLR_MODE_NO_WAIT_FOR_ACTIVE();
 687   2      
 688   2                  // Clear Mode Active Ready Flag
 689   2                  CLR_MODE_ACTIVE_READY();
 690   2      
 691   2                  ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_JUDGE_ACTIVE_STATE);
 692   2                  ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_JUDGE_NOSIGNAL_STATE);
 693   2                  ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_JUDGE_NOSUPPORT_STATE);
 694   2      
 695   2                  break;
 696   2      
 697   2              case _MODE_ACTION_RESET_TO_POWER_OFF:
