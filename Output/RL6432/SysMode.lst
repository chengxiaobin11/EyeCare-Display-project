              #elif(_PANEL_STYLE == _PANEL_DPTX)
              #if(_PANEL_POW_SEQ_FAST_MODE == _ON)
                      // Turn off backlight to prevent garbage
                      
                      UserCommonInterfacePanelPowerAction(_BACKLIGHT_OFF);
