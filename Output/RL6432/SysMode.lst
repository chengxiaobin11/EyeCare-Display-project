 598          void SysModeResetState(BYTE ucResetTarget)
 599          {
 600   1          DebugMessageSystem("SysModeResetState!!", ucResetTarget);
 601   1      
 602   1          switch(ucResetTarget)
 603   1          {
 604   2              case _MODE_ACTION_RESET_TO_SEARCH:
 605   2      
 606   2                  // User Reset Process
 607   2                  UserCommonInterfaceOsdResetProc();
 608   2      
 609   2                  // Clear Source Ready Flag
 610   2                  SysSourceInfoReset();
 611   2      
 612   2                  // Clear Measure Ready Flag
 613   2                  CLR_MODE_TIMING_CONFIRM();
 614   2      
 615   2                  // Clear M Domain Ready Flag
 616   2                  CLR_MODE_DISPLAY_SETTING_READY();
 617   2      
 618   2                  // Clear No Wait For Active Flag
 619   2                  CLR_MODE_NO_WAIT_FOR_ACTIVE();
 620   2      
 621   2                  // Clear Mode Active Ready Flag
 622   2                  CLR_MODE_ACTIVE_READY();
 623   2      
 624   2                  SysModeSetFreeRun();
 625   2      
 626   2                  ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_JUDGE_ACTIVE_STATE);
 627   2                  ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_JUDGE_NOSIGNAL_STATE);
 628   2                  ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_JUDGE_NOSUPPORT_STATE);
 629   2      
 630   2                  break;
 631   2      
 632   2              case _MODE_ACTION_RESET_TO_DISPLAY_SETTING_WITHOUT_FORCETOBG:
 633   2              case _MODE_ACTION_RESET_TO_DISPLAY_SETTING:
 634   2      
 635   2                  if(GET_MODE_STATE() != _MODE_STATUS_ACTIVE)
 636   2                  {
 637   3                      // User Reset Process
 638   3                      UserCommonInterfaceOsdResetProc();
 639   3                  }
 640   2      
 641   2                  // Clear M Domain Ready Flag
 642   2                  CLR_MODE_DISPLAY_SETTING_READY();
 643   2      
 644   2                  // Set No Wait For Active Flag
 645   2                  SET_MODE_NO_WAIT_FOR_ACTIVE();
 646   2      
 647   2                  // Clear Mode Active Ready Flag
 648   2                  CLR_MODE_ACTIVE_READY();
 649   2      
 650   2                  break;
 651   2      
 652   2              case _MODE_ACTION_RESET_TO_NOSUPPORT:
 653   2      
 654   2                  if(GET_MODE_STATE() == _MODE_STATUS_DISPLAY_SETTING)
 655   2                  {
 656   3                      // Clear M Domain Ready Flag
 657   3                      CLR_MODE_DISPLAY_SETTING_READY();
 658   3      
 659   3                      SysModeSetFreeRun();
C51 COMPILER V9.00   SYSMODE                                                               02/26/2026 13:41:42 PAGE 12  

 660   3                  }
 661   2      
 662   2                  break;
 663   2      
 664   2              case _MODE_ACTION_RESET_TO_POWER_SAVING:
 665   2      
 666   2                  // User Reset Process
 667   2                  UserCommonInterfaceOsdResetProc();
 668   2      
 669   2                  // Clear Source Ready Flag
 670   2                  SET_SOURCE_TYPE(g_ucSearchIndex, _SOURCE_NONE);
 671   2      
 672   2                  // Clear Source Judge
 673   2                  CLR_SOURCE_JUDGE(g_ucSearchIndex);
