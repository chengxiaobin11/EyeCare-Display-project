 701   2      
 702   2                  // Clear Source Ready Flag
 703   2                  SysSourceInfoReset();
 704   2      
 705   2                  CLR_SOURCE_HP_SOURCE_JUDGE();
 706   2      
 707   2                  // Clear Measure Ready Flag
 708   2                  CLR_MODE_TIMING_CONFIRM();
 709   2      
 710   2                  // Clear M Domain Ready Flag
 711   2                  CLR_MODE_DISPLAY_SETTING_READY();
 712   2      
 713   2                  // Clear No Wait For Active Flag
 714   2                  CLR_MODE_NO_WAIT_FOR_ACTIVE();
 715   2      
 716   2                  // Clear Mode Active Ready Flag
 717   2                  CLR_MODE_ACTIVE_READY();
 718   2      
 719   2                  // Judge Reset Process
 720   2                  ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_JUDGE_ACTIVE_STATE);
 721   2      
C51 COMPILER V9.00   SYSMODE                                                               02/26/2026 13:41:42 PAGE 13  

 722   2                  break;
 723   2      
