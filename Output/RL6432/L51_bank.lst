                   11342     $nomod51  NOLINES
                   11343     $nocond 
                   11344     ;------------------------------------------------------------------------------
                   11345     ;  This file is part of the BL51 / LX51 Banked Linker/Locater package
                   11346     ;  Copyright (c) 1988 - 2001 Keil Elektronik GmbH and Keil Software, Inc.
                   11347     ;  Version 2.21 (Code and Variable Banking for Classic 8051 Derivatives)
                   11348     ;------------------------------------------------------------------------------
                   11349     ;************************ Configuration Section *******************************
                   11350     ; Define maximum Number of Banks                                              *
  0010             11351     ?B_NBANKS       EQU  0x10;                  *
                   11352     ;                         ; following values are allowed: 2, 4, 8, 16, 32, 64 *
                   11353     ;                         ; for BL51 the maximum value for ?B_BANKS is 32     *
                   11354     ;                         ; for LX51 the maximum value for ?B_BANKS is 64     *
                   11355     ;                                                                             *
  0001             11356     ?B_MODE         EQU  1    ; 0 for Bank-Switching via 8051 Port                *
                   11357     ;                         ; 1 for Bank-Switching via XDATA Port               *
                   11358     ;                         ; 4 for user-provided bank switch code              *
                   11359     ;                                                                             *
  0000             11360     ?B_RTX          EQU  0    ; 0 for applications without real-time OS           *
                   11361     ;                         ; 1 for applications using the RTX-51 real-time OS  *
                   11362     ;                                                                             *
  0000             11363     ?B_VAR_BANKING  EQU  0    ; Variable Banking via L51_BANK (far memory support)*
                   11364     ;                         ; 0 Variable Banking does not use L51_BANK.A51      *
                   11365     ;                         ; 1 Variable Banking uses this L51_BANK.A51 module  *
                   11366     ; Notes: ?B_VAR_BANKING uses the 'far' and 'far const' C51 memory types to    *
                   11367     ;        extent the space for variables in RAM and/or ROM of classic 8051     *
A51 MACRO ASSEMBLER  L51_BANK                                                             02/26/2026 13:41:35 PAGE    49

                   11368     ;        device.  The same hardware as for code banking is used.  Program     *
                   11369     ;        code banking and variable banking share the same hardware I/O pins.  *
                   11370     ;        The C51 Compiler must be used with the VARBANKING directive.         *
                   11371     ;        Variable Banking is only supported with the LX51 linker/locater.     *
                   11372     ;                                                                             *
  00FF             11373     ?B_RST_BANK     EQU  0xFF ; specifies the active code bank number after CPU   *
                   11374     ;                         ; Reset.  Used to reduce the entries in the         *
                   11375     ;                         ; INTERBANK CALL TABLE.  The value 0xFF disables    *
                   11376     ;                         ; this LX51 linker/locater optimization.            *
                   11377     ; Note:  Interbank Call Table optimization is only possible with LX51.        *
                   11378     ;                                                                             *
                   11379     ;-----------------------------------------------------------------------------*
                   11380     ;                                                                             *
                             ENDIF;                                                                        *
                   11393     ;                                                                             *
                   11394     IF  ?B_MODE = 1;                                                              *
                   11395     ;-----------------------------------------------------------------------------*
                   11396     ; if ?BANK?MODE is 1 define the following values                              *
                   11397     ; For Bank-Switching via XDATA Port define XDATA Port Address / Bits          *
  FFFF             11398     ?B_XDATAPORT    EQU     0FFFFH   ; default is XDATA Port Address 0FFFFH       *
  0000             11399     ?B_FIRSTBIT     EQU     0        ; default is Bit 0                           *
                   11400     ;-----------------------------------------------------------------------------*
                   11401     ENDIF;                                                                        *
                   11402     ;                                                                             *
                             ENDIF;                                                                        *
                   11461     ;                                                                             *
                             ENDIF;                                                                        *
                   11482     ;                                                                             *
                   11483     ;******************************************************************************
                   11484     ;                                                                             *
                   11485     ; THEORY OF OPERATION                                                         *
                   11486     ; -------------------                                                         *
                   11487     ; The section below describes the code generated by BL51 or LX51 and the      *
                   11488     ; operation of the L51_BANK.A51 module.  BL51/LX51 generates for each         *
                   11489     ; function that is located in a code memory bank and called from the common   *
                   11490     ; area or a different code bank and entry into the INTRABANK CALL TABLE.  The *
                   11491     ; INTRABANK CALL TABLE is located in the SEGMENT ?BANK?SELECT and listed in   *
                   11492     ; the Linker MAP file. The entries in that TABLE have the following format:   *
                   11493     ;                                                                             *
                   11494     ;   ?FCT?1:  MOV  DPTR,#FCT     ; Load Address of target FCT                  *
                   11495     ;            JMP  ?B_BANKn      ; Switch to Bank and Jump to Target Code      *
                   11496     ;                                                                             *
                   11497     ; Instead of directly calling the function FCT, the Linker changes the entry  *
                   11498     ; to ?FCT?1.  This entry selects the bank where the function FCT is located   *
                   11499     ; and calls that function via the routines defined in this L51_BANK.A51 file. *
                   11500     ; The L51_BANK.A51 file contains two sets of functions for each bank:         *
                   11501     ;                                                                             *
                   11502     ; ?B_BANKn    is a routine which saves the entry of the ?B_SWITCHn function   *
                   11503     ;             for the current active bank on the STACK and switches to the    *
                   11504     ;             bank 'n'.  Then it jumps to the address specified by the DPTR   *
                   11505     ;             register.  It is allowed to modify the following registers in   *
                   11506     ;             the ?B_BANKn routine:  A, B, R0, DPTR, PSW                      *
                   11507     ;                                                                             *
                   11508     ; ?B_SWITCHn  is a function which selects the bank 'n'.  This function is     *
                   11509     ;             used at the end of a user function to return to the calling     *
                   11510     ;             code bank.  Only the following registers may be altered in the  *
                   11511     ;             ?B_SWITCHn function:  R0, DPTR                                  *
                   11512     ;                                                                             *
                   11513     ; The current active bank is stored in ?B_CURRENTBANK.  RTX-51 uses this      *
                   11514     ; variable to restore the code bank after a task switch.  To get correct      *
                   11515     ; results, ?B_CURRENTBANK must be set to the code bank before the hardware    *
                   11516     ; switch is done, or the code banking sequences must be interrupt protected.  *
                   11517     ;******************************************************************************
                   11518     
                   11519                     NAME    ?BANK?SWITCHING
                   11520     
A51 MACRO ASSEMBLER  L51_BANK                                                             02/26/2026 13:41:35 PAGE    50

                   11521                     PUBLIC  ?B_NBANKS, ?B_MODE, ?B_CURRENTBANK, ?B_MASK
                   11522                     PUBLIC  ?B_FACTOR, ?B_RST_BANK
                             ENDIF
                   11526     
                   11527     ; Standard SFR Symbols required in L51_BANK.A51
  00E0             11528     ACC     DATA    0E0H
  00F0             11529     B       DATA    0F0H
  0082             11530     DPL     DATA    82H
  0083             11531     DPH     DATA    83H
  00A8             11532     IE      DATA    0A8H
  00AF             11533     EA      BIT     IE.7
                   11534     
                   11535     
                   11536     ; generate Mask and Bank Number Information
                             ELSEIF  ?B_NBANKS <= 16
  000F             11544       MASK          EQU     00001111B
                             ENDIF
                   11550     
                             ENDIF  ; close block IF ?B_MODE = 0 *******************************************
                   11804     
                   11805     
                   11806     IF ?B_MODE = 1 ;***************************************************************
                   11807     
  0001             11808     ?B_FACTOR       EQU     1 SHL ?B_FIRSTBIT
                   11809     
  000F             11810     ?B_MASK         EQU     MASK SHL ?B_FIRSTBIT
                   11811     
                   11812     BANKN           MACRO   N
                   11813     BANK&N          EQU     N SHL ?B_FIRSTBIT
                   11814                     ENDM
                   11815     
  0000             11816     CNT             SET     0
                   11817     
                   11818                     REPT    ?B_NBANKS
                   11819                     BANKN   %CNT
                   11820     CNT             SET     CNT+1
                   11821                     ENDM
                   11822+1                   BANKN   %CNT
                   11825+1                   BANKN   %CNT
                   11828+1                   BANKN   %CNT
                   11831+1                   BANKN   %CNT
                   11834+1                   BANKN   %CNT
                   11837+1                   BANKN   %CNT
                   11840+1                   BANKN   %CNT
                   11843+1                   BANKN   %CNT
                   11846+1                   BANKN   %CNT
                   11849+1                   BANKN   %CNT
                   11852+1                   BANKN   %CNT
                   11855+1                   BANKN   %CNT
                   11858+1                   BANKN   %CNT
                   11861+1                   BANKN   %CNT
                   11864+1                   BANKN   %CNT
                   11867+1                   BANKN   %CNT
                   11870     
                   11871     
                   11872     ?C_INITSEG      SEGMENT CODE            ; Segment for Variable Initialization
----               11873                     RSEG    ?C_INITSEG
0000 01            11874                     DB      01H             ; IData
0001 00       F    11875                     DB      ?B_CURRENTBANK  ; Init Current Bank
0002 00            11876                     DB      0               ; Set to Zero
                   11877     
                   11878     
                   11879     
                   11880     
                   11881     
                   11882     ;User/both Code don't do this for use relocte function 30H
A51 MACRO ASSEMBLER  L51_BANK                                                             02/26/2026 13:41:35 PAGE    51

                   11883     ;Boot Code and No Dual bank case do this.
0003 41            11884                     DB      41H                        ; XData
0004 FFFF          11885                     DW      ?B_XDATAPORT               ; Init XDATA Port
0006 00            11886                     DB      0 ; Set to intial bank
                   11887     
                   11888     
                   11889                     PUBLIC  ?B_XDATAPORT
                   11890     
