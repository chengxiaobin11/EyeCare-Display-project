                   11975       ; Convert Bank No in Accu to Address * 16
                   11976       IF  ?B_FIRSTBIT = 0
                   11977       CONVBANKNO    MACRO
                   11978                     SWAP    A
                   11979                     ENDM
                   11980       ENDIF
