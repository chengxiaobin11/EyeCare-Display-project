                   12027       SWITCH        MACRO   N
                   12028                     ORG     N * 16
                   12029                     PUBLIC  ?B_SWITCH&N
                   12030       ?B_SWITCH&N:
                   12031                     MOV     R0,A
                   12032                     MOV     A,#BANK&N
