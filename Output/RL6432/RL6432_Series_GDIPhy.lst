1636          //--------------------------------------------------
1637          // Description  : GDI Bandgap Power On/Off
1638          // Input Value  : On/Off
1639          // Output Value : None
1640          //--------------------------------------------------
1641          void ScalerGDIPhyRx3Power(EnumPowerAction enumPowerAction)
1642          {
1643   1          switch(enumPowerAction)
1644   1          {
1645   2              case _POWER_ACTION_AC_ON_TO_NORMAL:
1646   2              case _POWER_ACTION_OFF_TO_NORMAL:
1647   2              case _POWER_ACTION_PS_TO_NORMAL:
1648   2      
1649   2                  ////////////////////////
1650   2                  // Clock Lane Enhance //
1651   2                  ////////////////////////
1652   2      
1653   2                  // [5:4] reg_rxvcom_sel = 2'b01 --> VDD - 0.3V
1654   2                  ScalerSetBit(P7C_17_BANDGAP_03, ~(_BIT5 | _BIT4), _BIT4);
1655   2      
1656   2      
1657   2                  ////////////////////////
1658   2                  // Offset Calibration //
1659   2                  ////////////////////////
1660   2      
1661   2                  // [7] EN_BACK_OFFSET = 1'b1 --> Enable Background Offset Calibration
1662   2                  // [6] EN_FORE_OFFSET = 1'b0 --> Disable Auto K-offset
1663   2                  // [5] FORE_OFF_AUTOK = 1'b0 --> Disable Auto K-offset Auto Mode
1664   2                  ScalerSetBit(P7C_24_KOFFSET_00, ~(_BIT7 | _BIT6 | _BIT5), _BIT7);
1665   2      
1666   2      
1667   2                  //////////////
1668   2                  // Z0 AutoK //
1669   2                  //////////////
1670   2      
1671   2                  // [0] Z0_manual = 1 --> Port2 50ohm Auto Mode
1672   2                  ScalerSetBit(P7C_17_BANDGAP_03, ~_BIT0, _BIT0);
1673   2      
1674   2      #if(_D3_TMDS_Z0_IMPEDANCE_OPTION == _LG_90_OHM)
                          // [3:0] Z0_ADJR = 6 --> Z0 Differential Impedance = level 6
                          ScalerSetBit(P7C_18_IMPEDANCE_00, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT2 | _BIT1));
              #else
1678   2                  // [3:0] Z0_ADJR = 9 --> Z0 Differential Impedance = level 9
C51 COMPILER V9.00   RL6432_SERIES_GDIPHY                                                  02/26/2026 13:42:51 PAGE 29  

1679   2                  ScalerSetBit(P7C_18_IMPEDANCE_00, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT0));
1680   2      #endif
1681   2                  // [2:0] Z0_CM_ADJR = 6 --> Z0 Common Mode Impedance = level 6
1682   2                  ScalerSetBit(P7C_19_IMPEDANCE_01, ~(_BIT2 | _BIT1 | _BIT0), (_BIT2 | _BIT1));
1683   2      
1684   2                  // [7] p_channel_en = 1 --> Switch p Channel 50ohm Z0
1685   2                  // [6] n_channel_en = 1 --> Switch n Channel 50ohm Z0
1686   2                  ScalerSetBit(P7C_17_BANDGAP_03, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
1687   2      
1688   2      
1689   2                  ///////////////
1690   2                  // Reset PHY //
1691   2                  ///////////////
1692   2      
1693   2                  // [2:0] phy_si_reset_n = 4'b1111 --> Normal Digital PHY
1694   2                  ScalerSetBit(P7C_00_DIG_00, ~(_BIT2 | _BIT1 | _BIT0), (_BIT2 | _BIT1 | _BIT0));
1695   2      
1696   2                  // [1] bypass_clk_rdy = 1 --> Manual Mode
1697   2                  ScalerSetBit(P7C_0E_SDM_03, ~_BIT1, _BIT1);
1698   2      
1699   2                  // [1] bypass_eqen_rdy = 1 --> Manual Mode
1700   2                  ScalerSetBit(P7C_10_EQEN_TIMER, ~_BIT1, _BIT1);
1701   2      
1702   2                  // [1] bypass_data_rdy = 1 --> Manual Mode
1703   2                  ScalerSetBit(P7C_11_DATA_TIMER, ~_BIT1, _BIT1);
1704   2      
1705   2      
1706   2                  ////////////////////
1707   2                  // HDMI Interface //
1708   2                  ////////////////////
1709   2      
1710   2                  // Digital PHY Lane Swap Setting
1711   2                  ScalerSetByte(P7C_01_DIG_01, 0x24);
1712   2      
1713   2                  // Digital PHY P/N Swap Setting
1714   2                  ScalerSetBit(P7C_03_DIG_03, ~(_BIT6 | _BIT5 | _BIT4), 0x00);
1715   2      
1716   2                  // Digital PHY Select to HDMI
1717   2                  ScalerSetBit(P7C_05_DIG_05, ~_BIT7, _BIT7);
1718   2      
1719   2                  break;
1720   2      
1721   2              case _POWER_ACTION_NORMAL_TO_PS:
1722   2      
1723   2      #if(_D3_TMDS_SUPPORT == _ON)
1724   2                  ScalerTMDSRx3PowerSavingProc();
1725   2      #endif
1726   2      
1727   2      #if(_SOURCE_BACKGROUND_DETECT_SUPPORT == _OFF)
1728   2                  // Disable R/G/B RX_EN, Disable R/G/B/Clock CDR_EN
1729   2                  ScalerSetByte(P7C_1A_CMU_00, 0x80);
1730   2      
1731   2                  // [7] Disable CMU PLL
1732   2                  ScalerSetBit(P7C_1B_CMU_01, ~_BIT7, 0x00);
1733   2      #endif
1734   2                  // Disable Auto k-offset(foreground)
1735   2                  // Disable Auto k-offset auto mode (foreground)
1736   2                  ScalerSetBit(P7C_24_KOFFSET_00, ~(_BIT6 | _BIT5), 0x00);
1737   2      
1738   2      #if((_D3_TMDS_SUPPORT == _ON) && (_TMDS_Z0_POWER_SAVING_OPTION == _ONLY_CLK_CHANNEL_CONNECTED_FOR_PS))
              
              #if(_D3_INPUT_PORT_TYPE == _D3_MHL_PORT)
C51 COMPILER V9.00   RL6432_SERIES_GDIPHY                                                  02/26/2026 13:42:51 PAGE 30  

                          if(GET_D3_TMDS_MODE() == _TMDS_HDMI_MODE)
                          {
                              // Disable RGB Z0
                              ScalerSetBit(P7C_18_IMPEDANCE_00, ~(_BIT6 | _BIT5 | _BIT4), 0x00);
                          }
              #else
                          // Disable RGB Z0
                          ScalerSetBit(P7C_18_IMPEDANCE_00, ~(_BIT6 | _BIT5 | _BIT4), 0x00);
              #endif
              
              #endif
1752   2                  break;
1753   2      
1754   2              case _POWER_ACTION_NORMAL_TO_OFF:
1755   2              case _POWER_ACTION_SWITCH_INTERFACE_TO_OFF:
1756   2              case _POWER_ACTION_AC_ON_TO_OFF:
1757   2              case _POWER_ACTION_PS_TO_OFF:
1758   2      
