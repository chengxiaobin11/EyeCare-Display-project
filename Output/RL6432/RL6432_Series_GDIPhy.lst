 368          void ScalerGDIPhyDigitalPhySwitch(BYTE ucInputPort)
 369          {
 370   1          switch(ucInputPort)
 371   1          {
 372   2      #if((_D1_INPUT_PORT_TYPE != _D1_NO_PORT) && (_D1_INPUT_PORT_TYPE != _D1_DP_PORT))
 373   2              case _D1_INPUT_PORT:
 374   2                  if(ScalerGetBit(P7B_30_ANA_CDR_06, _BIT3) == 0x00)
 375   2                  {
 376   3                      // [3] Ana_HDMI_DP_Sel = 1 --> Data from D1 PHY to D2 MAC
 377   3                      ScalerSetBit(P7B_30_ANA_CDR_06, ~_BIT3, _BIT3);
 378   3      
 379   3                      // clear HDCP key ready bit
 380   3                      ScalerSetBit(P71_AE_TMDS_RPS, ~_BIT1, 0x00);
 381   3                  }
 382   2                  break;
 383   2      
 384   2              case _D2_INPUT_PORT:
 385   2                  if(ScalerGetBit(P7B_30_ANA_CDR_06, _BIT3) == _BIT3)
 386   2                  {
 387   3                      // [3] Ana_HDMI_DP_Sel = 0 --> Data from D2 PHY to D2 MAC
 388   3                      ScalerSetBit(P7B_30_ANA_CDR_06, ~_BIT3, 0x00);
 389   3      
 390   3                      // clear HDCP key ready bit
 391   3                      ScalerSetBit(P71_AE_TMDS_RPS, ~_BIT1, 0x00);
 392   3                  }
 393   2      
 394   2                  break;
 395   2      #endif
 396   2      
 397   2              default:
 398   2      
 399   2                  break;
 400   2          }
 401   1      }
