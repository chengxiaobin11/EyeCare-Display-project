 456          //--------------------------------------------------
 457          // Description  : GDI Z0 Switch
 458          // Input Value  : D0/D0 Port ; Z0 ON/OFF
 459          // Output Value : None
 460          //--------------------------------------------------
 461          void ScalerGDIPhyRx0Z0Switch(bit bSelect)
 462          {
 463   1          if(bSelect == _ON)
 464   1          {
 465   2              SET_DIGITAL_PORT_SWITCH_TO_D0();
 466   2      
 467   2      #if((_D6_INPUT_PORT_TYPE == _D6_DP_PORT) && (_D6_INPUT_PORT_SWITCH_FROM == _SWITCH_FROM_D0))
                      SET_DIGITAL_PORT_SWITCH_TO_D6();
              #endif
 470   2      
 471   2      #if(_MHL_SUPPORT == _ON)
              #if((_D1_INPUT_PORT_TYPE == _D1_MHL_PORT) || (_D2_INPUT_PORT_TYPE == _D2_MHL_PORT))
                      // GPIO Select to CBUS
