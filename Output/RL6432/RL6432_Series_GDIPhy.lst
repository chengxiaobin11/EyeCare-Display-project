  87          void ScalerGDIPhyBandgap(bit bSelect)
  88          {
  89   1          // [4] reg_en_vtest_hiz = 0 --> Enable Vtest HIZ Mode
  90   1          ScalerSetBit(P1D_1C_CMU_02, ~_BIT4, 0x00);
