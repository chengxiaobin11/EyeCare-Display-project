  96   1          ScalerSetBit(P1D_26_KOFFSET_02, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
  97   1          ScalerSetBit(P7A_26_KOFFSET_02, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
