 106   1      
 107   1          // [7:5] reg_adp_time = 3'b010 --> DP PHY DFE delay_time = 16*(1/14.318)*(reg_adp_time[2:0]+1) = 3.35u
             -s
 108   1          ScalerSetBit(P1D_2D_ANA_CDR_02, ~(_BIT7 | _BIT6 | _BIT5), _BIT6);
