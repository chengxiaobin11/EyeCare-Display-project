1502          // Description  : GDI Z0 Switch
1503          // Input Value  : D3/D3 Port ; Z0 ON/OFF
1504          // Output Value : None
1505          //--------------------------------------------------
1506          void ScalerGDIPhyRx3Z0Switch(bit bSelect)
1507          {
1508   1          if(bSelect == _ON)
1509   1          {
1510   2              SET_DIGITAL_PORT_SWITCH_TO_D3();
1511   2          }
1512   1          else
1513   1          {
1514   2              CLR_DIGITAL_PORT_SWITCH_TO_D3();
1515   2          }
1516   1      
1517   1      #if(_D3_INPUT_PORT_TYPE == _D3_MHL_PORT)
              
                  if(GET_D3_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
                      if(bSelect == _ON)
                      {
              #if(_MHL_DEBUG_WITHOUT_CBUS_MODE == _ON)
                          // Enable Z0
                          ScalerSetBit(P7C_18_IMPEDANCE_00, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_BIT7 | _BIT6 | _BIT5 | _
             -BIT4));
              #endif
                      }
                      else
                      {
                          if((ScalerGetBit(P7C_18_IMPEDANCE_00, (_BIT7 | _BIT6 | _BIT5 | _BIT4)) == (_BIT7 | _BIT6 | _BI
             -T5 | _BIT4)) &&
                             (GET_MHL_RX3_PROCESS_STATE() >= _MHL_STATE_SET_DEV_CAP_DONE))
                          {
                              // Reset D3 CBUS While Switch Port
                              ScalerMHLCBUSResetProc(_D3_INPUT_PORT);
                          }
                      }
                  }
                  else
                  {
                      ScalerMHLCBUSPhySwitch(_D3_INPUT_PORT, _OFF);
              
                      if(bSelect == _ON)
                      {
                          if(ScalerGetBit(P7C_18_IMPEDANCE_00, _BIT7) == 0x00)
                          {
                              SET_TMDS_RX3_Z0_ASSERTED();
              
              #if(_DP_HDMI_COMPATIBLE_MODE == _ON)
                              CLR_D3_HDMI_PS_WAKEUP();
              #endif
                              // Clear HDCP Flag
                              ScalerSetBit(P72_A9_TMDS_ABC0, ~(_BIT7 | _BIT6 | _BIT5 | _BIT2), (_BIT6 | _BIT5));
              
                              // Initialize DDC Detection Process
                              CLR_TMDS_RX3_DDC_DETECTED();
              
                              // Enable DDC Toggle IRQ
C51 COMPILER V9.00   RL6432_SERIES_GDIPHY                                                  02/26/2026 13:42:51 PAGE 27  

                              MCU_FE72_DDC3_EDID_IRQ |= _BIT2;
                              MCU_FE72_DDC3_EDID_IRQ |= _BIT3;
              
                              // Enable Z0
                              ScalerSetBit(P7C_18_IMPEDANCE_00, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_BIT7 | _BIT6 | _BIT5
             - | _BIT4));
                          }
                      }
                      else
                      {
                          // Disable DDC Toggle IRQ
                          MCU_FE72_DDC3_EDID_IRQ &= ~(_BIT3 | _BIT1);
              
                          // Disable Z0
                          ScalerSetBit(P7C_18_IMPEDANCE_00, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), 0x00);
              
              #if((_HDCP_2_2_SUPPORT == _ON) && (_TMDS_HDCP_2_2_SUPPORT == _ON))
                          // Reset Hdcp2 Proc
                          ScalerHdcp2ResetTMDSProc(_D3_INPUT_PORT);
              #endif
                      }
                  }
              
              #else // Else of #if(_D3_INPUT_PORT_TYPE == _D3_MHL_PORT)
1581   1      
1582   1          if(bSelect == _ON)
1583   1          {
1584   2              // [1] MHL_Mode = 1'b0 --> Disable MHL Mode
1585   2              ScalerSetBit(P7C_17_BANDGAP_03, ~_BIT1, 0x00);
1586   2      
1587   2              // [4] Disable MHL OP
1588   2              ScalerSetBit(P7C_1B_CMU_01, ~_BIT4, 0x00);
1589   2      
1590   2              if(ScalerGetBit(P7C_18_IMPEDANCE_00, _BIT7) == 0x00)
1591   2              {
1592   3      #if((_D3_TMDS_SUPPORT == _ON) && (_D2_INPUT_PORT_TYPE != _D2_DUAL_DVI_PORT))
1593   3      
1594   3                  SET_TMDS_RX3_Z0_ASSERTED();
1595   3      
1596   3      #if(_DP_HDMI_COMPATIBLE_MODE == _ON)
                          CLR_D3_HDMI_PS_WAKEUP();
              #endif
1599   3                  // Clear HDCP Flag
1600   3                  ScalerSetBit(P72_A9_TMDS_ABC0, ~(_BIT7 | _BIT6 | _BIT5 | _BIT2), (_BIT6 | _BIT5));
1601   3      
1602   3                  // Initialize DDC Detection Process
1603   3                  CLR_TMDS_RX3_DDC_DETECTED();
1604   3      
1605   3                  // Enable DDC Toggle IRQ
1606   3                  MCU_FE72_DDC3_EDID_IRQ |= _BIT2;
1607   3                  MCU_FE72_DDC3_EDID_IRQ |= _BIT3;
1608   3      
1609   3      #endif // End of #if((_D3_TMDS_SUPPORT == _ON) && (_D2_INPUT_PORT_TYPE != _D2_DUAL_DVI_PORT))
1610   3      
1611   3                  // Enable Z0
1612   3                  ScalerSetBit(P7C_18_IMPEDANCE_00, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_BIT7 | _BIT6 | _BIT5 | _
             -BIT4));
1613   3              }
1614   2          }
1615   1          else
1616   1          {
1617   2      #if(_D3_TMDS_SUPPORT == _ON)
C51 COMPILER V9.00   RL6432_SERIES_GDIPHY                                                  02/26/2026 13:42:51 PAGE 28  

1618   2      
1619   2              // Disable DDC Toggle IRQ
1620   2              MCU_FE72_DDC3_EDID_IRQ &= ~(_BIT3 | _BIT1);
1621   2      
1622   2              // Disable Z0
1623   2              ScalerSetBit(P7C_18_IMPEDANCE_00, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), 0x00);
1624   2      
1625   2      #endif
1626   2      
1627   2      #if((_D3_INPUT_PORT_TYPE == _D3_HDMI_PORT) && (_TMDS_HDCP_2_2_SUPPORT == _ON) && (_HDCP_2_2_SUPPORT == _ON
