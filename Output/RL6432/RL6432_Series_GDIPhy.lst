 100   1      
 101   1          // [0] PLL_WD_EN = 1'b0 --> Disable WD
 102   1          ScalerSetBit(P1D_0F_WD, ~_BIT0, 0x00);
 103   1          ScalerSetBit(P7A_0F_WD, ~_BIT0, 0x00);
 104   1          ScalerSetBit(P7B_0F_WD, ~_BIT0, 0x00);
