1763   2      #if(_SOURCE_BACKGROUND_DETECT_SUPPORT == _OFF)
1764   2                  // Disable R/G/B RX_EN, Disable R/G/B/Clock CDR_EN
1765   2                  ScalerSetByte(P7C_1A_CMU_00, 0x00);
1766   2      
1767   2                  // [7] Disable CMU PLL
1768   2                  ScalerSetBit(P7C_1B_CMU_01, ~_BIT7, 0x00);
1769   2      #endif
1770   2                  // Disable Auto k-offset(foreground)
1771   2                  // Disable Auto k-offset auto mode (foreground)
1772   2                  ScalerSetBit(P7C_24_KOFFSET_00, ~(_BIT6 | _BIT5), 0x00);
1773   2      
1774   2                  break;
1775   2      
1776   2              default:
