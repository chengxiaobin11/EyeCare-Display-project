 907          void CDcrSlowAdjust(void)
 908          {
 909   1      
 910   1              static BYTE ucECOBackup = _ECO_DEFAULT;
 911   1              static BYTE ucCount = 0;
 912   1      
 913   1              if(GET_OSD_DCR_STATUS() == 0)
 914   1                      return;
 915   1      
 916   1      #if(_MPRT_SUPPORT == _ON)
                      if(GET_OSD_MPRT() != _OFF /*&& ucVFreq > _DEF_OSD_OVER_VFREQ*/)
                              return;
              #endif
 920   1      
 921   1              ucCount++;
 922   1      
 923   1      
 924   1              if(GET_OSD_DCR_STATUS() == _DCR_Level_1)
 925   1              {
 926   2                      if(ucCount>2)
 927   2                              ucCount = 1;
 928   2                      if(ucCount ==1)
 929   2                      return;
 930   2              }
 931   1              else if(GET_OSD_DCR_STATUS() == _DCR_Level_2)
 932   1              {
 933   2                      if(ucCount>5)
 934   2                              ucCount = 1;
 935   2                      if(ucCount ==2||ucCount ==4)
 936   2                      return;
 937   2              }
 938   1              else if(GET_OSD_DCR_STATUS() == _DCR_Level_3)
 939   1              {
 940   2                      if(ucCount>4)
 941   2                              ucCount = 1;
 942   2                      if(ucCount ==4)
 943   2                      return;
 944   2              }
 945   1              else if(GET_OSD_DCR_STATUS() == _DCR_Level_4)
 946   1              {
 947   2      
 948   2              }
 949   1      
 950   1      
 951   1          if(GET_DCR_HOLD_STATUS() == _TRUE)
 952   1              {
 953   2                      if((abs(GET_DCR_PreRGB_INFORMATION() - GET_DCR_RGB_INFORMATION()) > 10)&&(ScalerOsdGetOsdEnable() == 0x0
             -0)) // original range is 20
 954   2                      {
 955   3                              SET_DCR_HOLD_STATUS(_FALSE);
 956   3                      }
 957   2              }
 958   1              else
 959   1          {
 960   2              //DebugMessageOsd("####9.GET_DCR_RGB_INFORMATION  ######",  GET_DCR_RGB_INFORMATION() );
 961   2      
 962   2                      if(GET_DCR_RGB_INFORMATION() >= 254)    //ȫ�׳�+��� = 254  xwei
 963   2                      {
 964   3                  SET_DCR_TARGET_VALUE(100);
 965   3                      }
 966   2              else if((GET_DCR_RGB_INFORMATION() >= _DCR_ACTIVE_VALUE_MIN) && (GET_DCR_RGB_INFORMATION() <= _DCR
             -_ACTIVE_VALUE_MAX))
C51 COMPILER V9.00   RTD2014USERINTERFACE                                                  02/26/2026 13:43:21 PAGE 17  

 967   2              {
 968   3                  SET_DCR_TARGET_VALUE((WORD)GET_DCR_RGB_INFORMATION() * 100 / _DCR_ACTIVE_VALUE_MAX);
 969   3              }
 970   2              else if((GET_DCR_RGB_INFORMATION() < _DCR_ACTIVE_VALUE_MIN) && (!GET_Y_MAX_UNDER_LABEL_STATUS()))
 971   2              {
 972   3                  if(ScalerOsdGetOsdEnable())
 973   3                  {
 974   4                      if(GET_DCR_RGB_INFORMATION() < _DCR_ACTIVE_VALUE_MIN)
 975   4                      {
 976   5                          GET_DCR_RGB_INFORMATION() = _DCR_ACTIVE_VALUE_MIN;
 977   5                      }
 978   4      
 979   4                      g_stDcrInfo.ucRGBInfo -= _DCR_ACTIVE_VALUE_MIN;
 980   4                      SET_DCR_TARGET_VALUE((WORD)GET_DCR_RGB_INFORMATION() * 100 / (_DCR_ACTIVE_VALUE_MAX - _DCR
             -_ACTIVE_VALUE_MIN));
 981   4      
 982   4                          CLR_L4_PATTEN_TIMER();
 983   4                                      ScalerTimerCancelTimerEvent(_USER_TIMER_EVENT_DCR_BACKLIGHT_OFF);
 984   4                  }
 985   3                  else
 986   3                  {
 987   4                      SET_DCR_TARGET_VALUE(0);
 988   4      
 989   4                      if(GET_PANELPOWERSTATUS() == _PANEL_BACKLIGHT_OFF)
 990   4                      {
 991   5                          //UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
 992   5                           ScalerTimerActiveTimerEvent(SEC(_DEF_DCR_BACK_TIME_ON), _USER_TIMER_EVENT_DCR_BACKLIG
             -HT_ON);
 993   5                      }
 994   4                  }
 995   3              }
 996   2              else if(GET_Y_MAX_UNDER_LABEL_STATUS())
 997   2              {
 998   3                  if(!ScalerOsdGetOsdEnable())
 999   3                  {
1000   4                      if(GET_HIGH_DCR_STATUS())
1001   4                      {
1002   5                          SET_DCR_TARGET_VALUE(0);
