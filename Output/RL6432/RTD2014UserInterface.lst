              // Input Value  : EDID Index
              // Output Value : External/ Embedded Edid
              //--------------------------------------------------
              EnumHdmiEdidLocation UserInterfaceGetMultiHdmiEdidLocated(BYTE ucInputport, BYTE ucEdidIndex)
              {
