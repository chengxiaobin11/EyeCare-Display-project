4701   2      
4702   2              ScalerGetDataPortByte(P71_C3_HDCP_AP, _P71_C4_PT_C0_PORT_PAGE71_HDCP_FCR, 1, &pucHDCPFrameCount[1]
             -, _NON_AUTOINC);
4703   2      
4704   2              if(pucHDCPFrameCount[0] != pucHDCPFrameCount[1])
4705   2              {
4706   3                  return _TRUE;
4707   3              }
4708   2      
4709   2              return _FALSE;
4710   2          }
4711   1      #if(_TMDS_HDCP_2_2_SUPPORT == _ON)
4712   1          else if((ScalerGetBit(P71_C0_HDCP_CR, _BIT0) == 0x00) && (ScalerGetBit(P2D_26_HDCP_I2C_CTRL_0, _BIT7) 
             -== _BIT7))
4713   1          {
4714   2              if(ScalerGetByte(P2D_2C_HDCP_I2C_CTRL_6) == 0x10)
4715   2              {
4716   3                  return _TRUE;
4717   3              }
4718   2              else
4719   2              {
4720   3                  return _FALSE;
4721   3              }
4722   2          }
4723   1          else
4724   1          {
4725   2              return _FALSE;
4726   2          }
4727   1      #endif
4728   1      }
