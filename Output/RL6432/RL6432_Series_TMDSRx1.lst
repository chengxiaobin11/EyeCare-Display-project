3216   1          ScalerSetBit_EXINT(P71_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), _BIT3);
3217   1      
3218   1          // Delay at least 40us at Xtal = 27MHz
3219   1          for(ucDelayCount = 0; ucDelayCount <= 8; ucDelayCount++)
3220   1          {
3221   2              DELAY_5US_EXINT();
3222   2      
3223   2              if((ScalerGetBit_EXINT(P71_CA_HDMI_DP, _BIT3)) == 0x00)
3224   2              {
3225   3                  break;
3226   3              }
3227   2          }
