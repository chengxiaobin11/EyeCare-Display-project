4800          // Description  : DFE Adaptation in Normal Signal
C51 COMPILER V9.00   RL6432_SERIES_TMDSRX1                                                 02/26/2026 13:43:03 PAGE 81  

4801          // Input Value  : None
4802          // Output Value : True --> DFE Normal
4803          //                False --> DFE Abnormal
4804          //--------------------------------------------------
4805          bit ScalerTMDSRx1CheckDataDFE(void)
4806          {
4807   1          BYTE ucTemp = 0;
4808   1          BYTE ucCnt = 0;
4809   1      
4810   1          // DFE Check only under HDMI Mode.
4811   1          // MHL has only 1 data Lane --> Skip DFE Check Process and Function return True!
4812   1          if(ScalerGetBit(P7A_17_BANDGAP_03, _BIT1) != _BIT1)
4813   1          {
4814   2              for(pData[0] = 0; pData[0] <= 2; pData[0]++)
4815   2              {
4816   3                  // Sel lane
4817   3                  ScalerSetBit(P7A_F2_COEF_3, ~(_BIT7 | _BIT6), pData[0] << 6);
4818   3      
4819   3                  // Read VTH
4820   3                  ScalerSetBit(P7A_F0_COEF_1, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
4821   3      
4822   3                  if((ScalerGetByte(P7A_F1_COEF_2) & 0x1F) == 0)
4823   3                  {
4824   4                      for(ucCnt = 0; ucCnt < 3; ucCnt++)
4825   4                      {
4826   5                          // Read TAP0
4827   5                          ScalerSetBit(P7A_F0_COEF_1, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT0);
4828   5      
4829   5                          ucTemp = (ScalerGetByte(P7A_F1_COEF_2) & 0x1F);
4830   5      
4831   5                          if(ucTemp < 21)
4832   5                          {
4833   6                              return _TRUE;
4834   6                          }
4835   5                          else if(ucCnt == 2)
4836   5                          {
4837   6                              DebugMessageRx1("DFE Abnormal ", 0);
4838   6                              return _FALSE;
4839   6                          }
4840   5                      }
4841   4                  }
4842   3              }
4843   2          }
4844   1      
4845   1          return _TRUE;
4846   1      }
