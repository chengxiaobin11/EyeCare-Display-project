3296          // Output Value : None
C51 COMPILER V9.00   RL6432_SERIES_TMDSRX1                                                 02/26/2026 13:43:03 PAGE 56  

3297          //--------------------------------------------------
3298          bit ScalerTMDSRx1HdmiSetDeepColorPll(WORD usTMDSClkCount, BYTE ucColorDepth)
3299          {
3300   1          DWORD ulTMDSClkValue = 0;
3301   1          WORD usM = 0;
3302   1          BYTE ucN = 0;
3303   1          BYTE ucDivS = 0;
3304   1          BYTE ucFactor = 0;
3305   1      
3306   1          ////////////////////////////////////////////////////////////////////////////////////////////////
3307   1          // Fin = TMDS_clk
3308   1          // Fref = Fin / N
3309   1          // Fvco = Fin * M / N
3310   1          // Freq = Fvco / Divs
3311   1          //
3312   1          // Restriction
3313   1          // A. BW = Kvco * Icp * R / (M * 2pi) = 700k (Band10 Kvco = 1880), R = 13k)
3314   1          // B. 300MHz < Fvco < 600MHz
3315   1          // C. (Fin / N) >= 10 * BW --> (Fin / N) >= 7MHz
3316   1          // D. YCbCr 420, Ratio = 2, other case Ratio = 1
3317   1          //
3318   1          // note 1.   According A, Icp = 2.5 ~ 20 --> 14 <= M <= 111
3319   1          // note 2.   According B and note 1. --> 3 <= (Fin / N) <= 42
3320   1          // note 3.   According C and note 2. --> 7 <= (Fin / N) <= 42
3321   1          // note 4_a. 10bit : (M / N / Divs) = (4 / 5 * Ratio) --> M = N * Divs * (4 / 5 * Ratio), N or Divs: m
             -ultiple of 5
3322   1          // note 4_b. 12bit : (M / N / Divs) = (2 / 3 * Ratio) --> M = N * Divs * (2 / 3 * Ratio), N or Divs: m
             -ultiple of 3
3323   1          // note 4_b. 16bit : (M / N / Divs) = (1 / 2 * Ratio) --> M = N * Divs * (1 / 2 * Ratio), N or Divs: m
             -ultiple of 2
3324   1          ////////////////////////////////////////////////////////////////////////////////////////////////
3325   1      
3326   1          // If Measure Divider = /2 then TMDS_CLK x 2, unit:kHz
3327   1          if(ScalerGetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0, _BIT6) == _BIT6)
3328   1          {
3329   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 * 2 / usTMDSClkCount;
3330   2          }
3331   1          else
3332   1          {
3333   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 / usTMDSClkCount;
3334   2          }
3335   1      
3336   1      #if(_D1_HDMI_2_0_SUPPORT == _ON)
3337   1          if(GET_TMDS_RX1_HIGH_SPEED_MODE() == _TRUE)
3338   1          {
3339   2              ulTMDSClkValue = (ulTMDSClkValue << 2);
3340   2          }
3341   1      #endif
3342   1      
3343   1          DebugMessageRx1("TMDS clk", ulTMDSClkValue);
3344   1          DebugMessageRx1("Color Depth", ucColorDepth);
3345   1      
3346   1          switch(ucColorDepth)
3347   1          {
3348   2              case _COLOR_DEPTH_10_BITS:
3349   2      
3350   2                  ucFactor = 5;
3351   2      
3352   2                  break;
3353   2      
3354   2              case _COLOR_DEPTH_12_BITS:
3355   2      
C51 COMPILER V9.00   RL6432_SERIES_TMDSRX1                                                 02/26/2026 13:43:03 PAGE 57  

3356   2                  ucFactor = 3;
3357   2      
3358   2                  break;
3359   2      
3360   2              case _COLOR_DEPTH_16_BITS:
3361   2      
3362   2                  ucFactor = 2;
3363   2      
3364   2                  break;
3365   2      
3366   2              default:
3367   2      
3368   2                  return _FALSE;
3369   2          }
3370   1      
3371   1          // N <= (Fin / 7)
3372   1          PDATA_WORD(0) = (ulTMDSClkValue / 7000);
3373   1      
3374   1          if(PDATA_WORD(0) < 2)
3375   1          {
3376   2              return _FALSE;
3377   2          }
3378   1          else if(PDATA_WORD(0) >= ucFactor)
3379   1          {
3380   2              // N: Multiple of factor
3381   2              PDATA_WORD(0) -= (PDATA_WORD(0) % ucFactor);
3382   2          }
3383   1          else if(PDATA_WORD(0) > 255)
3384   1          {
3385   2              // N: Multiple of factor
3386   2              PDATA_WORD(0) = 255 - (255 % ucFactor);
3387   2          }
3388   1      
3389   1          ucN = PDATA_WORD(0);
3390   1      
3391   1          // for differenct Divs, find suitable Divs and M
3392   1          for(pData[15] = 0; pData[15] <= 254; pData[15] += 2)
3393   1          {
3394   2              // N or Divs: Multiple of factor
3395   2              if(((ucN % ucFactor) == 0x00) || ((pData[15] % ucFactor) == 0x00))
3396   2              {
3397   3                  usM = (WORD)ucN * ((pData[15] == 0) ? 1 : pData[15]) * (ucFactor - 1) / ucFactor;
3398   3      
3399   3                  // Fvco = Fin * M / N
3400   3                  PDATA_DWORD(0) = (ulTMDSClkValue * usM / ucN);
3401   3      
3402   3                  if((PDATA_DWORD(0) >= 300000) && (PDATA_DWORD(0) <= 600000))
3403   3                  {
3404   4                      ucDivS = ((pData[15] == 0) ? 1 : pData[15]);
3405   4                      break;
3406   4                  }
3407   3              }
3408   2      
3409   2              if((pData[15] == 254) && (ucDivS == 0))
3410   2              {
3411   3                  DebugMessageRx1("4. PLL Setting Error", 0);
3412   3                  return _FALSE;
3413   3              }
3414   2          }
3415   1      
3416   1          //////////////////////////////////////////////////////////////////////////////////////////////////
3417   1          // Precise formula of Chrage Pump Current depends on DPM, resistor, and band.                   //
C51 COMPILER V9.00   RL6432_SERIES_TMDSRX1                                                 02/26/2026 13:43:03 PAGE 58  

3418   1          // If VCO band = 'b00, Icp = (700 * M * 2 * pi) / (778 * 0x01C1[7:5]).                          //
3419   1          // If VCO band = 'b01, Icp = (700 * M * 2 * pi) / (1340 * 0x01C1[7:5]).                         //
3420   1          // If VCO band = 'b10, Icp = (700 * M * 2 * pi) / (1880 * 0x01C1[7:5]).                         //
3421   1          // If VCO band = 'b11, Icp = (700 * M * 2 * pi) / (2340 * 0x01C1[7:5]).                         //
3422   1          // 700: DPLL max frequency design target is 700MHz; 778: Frequency curve in band00 is 778MHz.   //
3423   1          // Assume DPLL_M=0x13, DPM=0x13+2=21; DPN=2; reg_dpll_vcomd='b01; reg_dpll_rs[2:0]='b011;       //
3424   1          // Icp = (700 * 21 * 2 * 3.14) / (1340 * 13)                                                    //
3425   1          //////////////////////////////////////////////////////////////////////////////////////////////////
3426   1      
3427   1          // Set VCO resister = 3b'011(13K), Capacitor = 2b'11(66pF) (Analog DIC suggust)
3428   1          ScalerSetBit(P2D_BE_MN_SCLKG_PLL_CHP, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), (_BIT6 | _BIT5 | _BIT4
             - | _BIT3));
3429   1      
3430   1          // BW = Kvco * Icp * R / (M * 2pi) = 700k --> Icp = M * BW * 2pi / Kvco / R
3431   1          PDATA_WORD(1) = ((DWORD)usM * 700UL * 2 * 314UL * 20) / _PLL_VCO_BAND_10 / ((7 + (ScalerGetBit(P2D_BE_
             -MN_SCLKG_PLL_CHP, (_BIT7 | _BIT6 | _BIT5)) >> 5) * 2) * 100);
