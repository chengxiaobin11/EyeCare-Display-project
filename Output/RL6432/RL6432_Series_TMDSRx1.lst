3125          // Description  : Measure Clk
3126          // Input Value  : Clk Source to be measured
3127          // Output Value : Measured Clk Count
3128          //--------------------------------------------------
3129          WORD ScalerTMDSRx1MeasureClk(BYTE ucMeasureClk)
3130          {
3131   1          BYTE ucDelayCount = 0;
3132   1      
3133   1      #if(_D1_INPUT_PORT_TYPE == _D1_MHL_PORT)
                  if(GET_D1_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
                      // Enable Rx_EN (Lane0,3)
                      ScalerSetBit(P7A_1A_CMU_00, ~(_BIT7 | _BIT4), (_BIT7 | _BIT4));
                  }
                  else
              #endif
3141   1          {
3142   2              // Enable Rx_EN (Lane3)
3143   2              ScalerSetBit(P7A_1A_CMU_00, ~_BIT7, _BIT7);
3144   2          }
3145   1      
3146   1          // Disable Measure for Reset Measure Window
3147   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
3148   1          ScalerSetBit(P71_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), 0x00);
3149   1      
3150   1          // Select reference clk to Xtal Clk and measure clk
3151   1          ScalerSetBit(P71_AD_TMDS_CPS, ~(_BIT6 | _BIT5 | _BIT4), ((ucMeasureClk << 5) | _BIT4));
3152   1      
3153   1          // Start Measure
3154   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
3155   1          ScalerSetBit(P71_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), _BIT3);
3156   1      
3157   1          // Delay at least 40us at Xtal = 27MHz
3158   1          for(ucDelayCount = 0; ucDelayCount <= 8; ucDelayCount++)
3159   1          {
3160   2              DELAY_5US();
3161   2      
3162   2              ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
3163   2              if(ScalerGetBit(P71_CA_HDMI_DP, _BIT3) == 0x00)
3164   2              {
3165   3                  break;
3166   3              }
3167   2          }
3168   1      
3169   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
3170   1          pData[0] = ScalerGetByte(P71_CA_HDMI_DP);
3171   1      
3172   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_29_PORT_PAGE71_HDMI_NTX1024TR1);
3173   1          pData[1] = ScalerGetByte(P71_CA_HDMI_DP);
3174   1      
C51 COMPILER V9.00   RL6432_SERIES_TMDSRX1                                                 02/26/2026 13:43:03 PAGE 54  

3175   1          return ((WORD)(pData[0] & 0x07) << 8) | pData[1];
3176   1      }
