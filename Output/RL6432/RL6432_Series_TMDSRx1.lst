 132          void ScalerTMDSRx1Initial(void)
 133          {
 134   1          // Disable TMDS output
 135   1          ScalerSetBit(P71_A6_TMDS_OUTCTL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), 0x00);
 136   1      
 137   1          // Set HS Width(DE only) and HDCP Reference VS
 138   1          ScalerSetBit(P71_AB_TMDS_ACC2, ~(_BIT7 | _BIT6), 0x00);
 139   1      
 140   1          // Set TMDS Hsync/Vsync Polarity as Input Raw Polarity
 141   1          ScalerSetBit(P71_AF_TMDS_WDC, ~(_BIT3 | _BIT2), 0x00);
 142   1      
 143   1          // Disable C9/CA Port Auto-Inc
 144   1          ScalerSetBit(P71_C8_HDMI_APC, ~_BIT0, 0x00);
 145   1      
 146   1      #if(_D1_HDMI_SUPPORT == _ON)
 147   1      
 148   1          ScalerTMDSRx1HdmiWatchDog((_HDMI_AVI_INFO_VARIATION_WD | _HDMI_AV_MUTE_WD), _DISABLE);
 149   1      
 150   1          // Deep Color Mode clock and detection auto
 151   1          ScalerSetBit(P71_B8_TMDS_DPC1, ~(_BIT3 | _BIT2), _BIT2);
 152   1      
 153   1          // Enable BCH Detection
 154   1          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_02_PORT_PAGE71_HDMI_BCHCR, ~(_BIT6 | _BIT3 | _BIT2 | _
             -BIT1), (_BIT6 | _BIT3 | _BIT2 | _BIT1));
 155   1      
 156   1          // DVI mode don't disable Audio Clk
 157   1          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_00_PORT_PAGE71_HDMI_SCR, ~(_BIT7 | _BIT6 | _BIT5), _BI
             -T5);
 158   1      
 159   1          // Set Video Watch Dog New Mode
 160   1          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_32_PORT_PAGE71_HDMI_WDCR1, ~_BIT5, _BIT5);
 161   1      
 162   1          // Specify Packet Detect Type
 163   1          ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_43_PORT_PAGE71_HDMI_PTRSV0, _HDMI_AVI_INFO_TYPE);
 164   1          ScalerSetDataPortByte(P71_C9_HDMI_AP, _P71_CA_PT_44_PORT_PAGE71_HDMI_PTRSV1, _HDMI_GENERAL_CONTROL_TYP
             -E);
 165   1      
