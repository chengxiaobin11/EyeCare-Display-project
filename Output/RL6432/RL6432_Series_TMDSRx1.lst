 322          //--------------------------------------------------
 323          // Description  : Initialize TMDS Interrupt Required Settings
 324          // Input Value  : None
 325          // Output Value : None
 326          //--------------------------------------------------
 327          void ScalerTMDSRx1InterruptInitial(void)
 328          {
 329   1          if(ScalerGetBit(P71_E6_HDMI_FREQDET_CTRL, _BIT1) == 0x00)
 330   1          {
 331   2              CLR_TMDS_RX1_PHY_SET();
 332   2          }
 333   1      
 334   1          // Enable Rx_En for Clk pair Z0
 335   1          ScalerSetBit(P7A_1A_CMU_00, ~_BIT7, _BIT7);
 336   1      
 337   1          // Choose Measure Clk to TMDS Clk
 338   1          ScalerSetBit(P71_E6_HDMI_FREQDET_CTRL, ~(_BIT7 | _BIT5 | _BIT4), 0x00);
 339   1      
 340   1          // Set Freq. Reference Counter = 2000
 341   1          ScalerSetBit(P71_F6_HDMI_FREQDET_BOUND_H, ~(_BIT1 | _BIT0), _BIT0);
 342   1      
 343   1          // Set Online Measure Input Clock Divider = /2 (No Matter if Input Clock >300Mhz or <=300Mhz)
 344   1          ScalerSetBit(P71_E7_HDMI_FREQDET_OFFSET, ~_BIT6, _BIT6);
 345   1      
C51 COMPILER V9.00   RL6432_SERIES_TMDSRX1                                                 02/26/2026 13:43:03 PAGE 7   

 346   1          // Settings for IRQ set PHY
 347   1          // Consider using table to fill all required initial settings
 348   1          // Set pre-set threshold (225MHz * 0.01 / 26.8KHz = 0x54)
 349   1      
 350   1      #if(_D1_INPUT_PORT_TYPE == _D1_MHL_PORT)
                  if(GET_D1_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
                      // Set TMDS Offset = 1/32
                      ScalerSetBit(P71_E7_HDMI_FREQDET_OFFSET, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
              
                      // Set Upper Bound
                      ScalerSetByte(P71_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_MHL_FREQ_NORMAL_UPPER_BOUND));
                      ScalerSetByte(P71_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_MHL_FREQ_NORMAL_UPPER_BOUND));
                  }
                  else
              #endif
 362   1          {
 363   2              // Set TMDS Offset = 1/32
 364   2              ScalerSetBit(P71_E7_HDMI_FREQDET_OFFSET, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
 365   2      
 366   2              // Set Upper Bound
 367   2              ScalerSetByte(P71_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
 368   2              ScalerSetByte(P71_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
 369   2          }
 370   1      
 371   1          // Set Lower Bound
 372   1          ScalerSetByte(P71_EA_HDMI_FREQDET_LOWER_M, HIBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 373   1          ScalerSetByte(P71_EB_HDMI_FREQDET_LOWER_L, LOBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 374   1      
 375   1          // Set Stable Time (0x3F = about 5ms)
 376   1          ScalerSetByte(P71_EC_HDMI_FREQDET_STABLE, 0x3F);
 377   1      
 378   1          // Disable Freq. Unstable IRQ
