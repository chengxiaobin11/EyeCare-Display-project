                              OsdDispSetPosition(_POS_PERCENT, _OSD_POSITION_GLOBAL_A, 98, 2);
                              OsdFuncEnableOsd();
                      
                              ScalerTimerActiveTimerEvent(SEC(0.5), _USER_TIMER_EVENT_UPDATE_VFREQ);
                      
                              //SET_OSD_FRONT_SIGHT(_ON);
                              //RTDNVRamSaveOsdUserData();
                      }
                              
