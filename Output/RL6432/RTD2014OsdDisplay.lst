              void OsdDispAutoConfigProc(void)
              {
                  OsdDispOsdMessage(_OSD_DISP_AUTO_CONFIG_MSG);
                      //ScalerDDomainBackgroundSetColor(0x00, 0x00, 0x00);
                      //ScalerDDomainBackgroundEnable(_ENABLE);
                  UserCommonAutoConfig();
