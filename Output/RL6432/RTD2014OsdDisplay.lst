                  // OsdFuncChangeColor1Bit(ROW(12), COL(0), WIDTH(30), HEIGHT(4), 0, 3);
              
                  OsdTableFuncPutIcon1BitLogo(ROW(0), COL(0), tiOSD_THREE_BIRDS_1BIT);
