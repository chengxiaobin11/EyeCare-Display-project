 211          //--------------------------------------------------
 212          // Description  : Cache Control
 213          // Input Value  : bControl
 214          // Output Value : None
 215          //--------------------------------------------------
 216          void ScalerMcuCacheControl(bit bControl)
 217          {
 218   1          if(bControl == _ENABLE)
 219   1          {
 220   2              // Enable Cache
 221   2              MCU_FDA0_CACHE_FUNCTION |= _BIT0;
 222   2          }
 223   1          else
 224   1          {
 225   2              // Disable Cache
 226   2              MCU_FDA0_CACHE_FUNCTION &= ~_BIT0;
 227   2          }
 228   1      }
 229          
C51 COMPILER V9.00   SCALERCOMMONMCU                                                       04/02/2026 14:20:49 PAGE 5   

 230          //--------------------------------------------------
 231          // Description  : Send DDC Data
 232          // Input Value  : pWriteArray --> Data to be sent
 233          //                usTimeOutCnt --> Timeout
 234          // Output Value : None
 235          //--------------------------------------------------
 236          
 237          
 238          void ScalerMcuDdcciSendData(BYTE *pucWriteArray)
 239          {
 240   1          WORD usTimeOutCnt = _DDCCI_TIMEOUT_LIMIT;
 241   1          BYTE ucDdcciCount = 0;
 242   1      
 243   1      
 244   1          if((MCU_FF27_IIC_STATUS & _BIT0) == _BIT0)
 245   1          {
 246   2              g_bSrcReadDdcciAlready = _TRUE;
 247   2      
 248   2              // Clear Flag
 249   2              MCU_FF27_IIC_STATUS &= ~_BIT0;
 250   2          }
 251   1      
 252   1          // Enable mcu write
 253   1          MCU_FF2A_IIC_IRQ_CONTROL2 |= (_BIT6 | _BIT5);
 254   1      
 255   1      #if(_SMBUS_BLOCK_READ_WRITE_COMMAND_SUPPORT == _ON)
                  if(GET_SMBUS_BLOCK_RW_STATUS() == _TRUE)
                  {
                      MCU_FF26_IIC_DATA_OUT = g_stSmbusBlockRWCmd.ucDataLen;
                  }
              #endif
 261   1      
 262   1          while(ucDdcciCount < ((pucWriteArray[_DDCCI_LENGTH] & 0x7F) + 3))
 263   1          {
 264   2              // Load data to DDC-CI buffer until buffer full
 265   2              if((MCU_FF29_IIC_STATUS2 & _BIT2) == 0)
 266   2              {
 267   3                  MCU_FF26_IIC_DATA_OUT = pucWriteArray[ucDdcciCount++];
 268   3      
 269   3                  usTimeOutCnt = _DDCCI_TIMEOUT_LIMIT;
 270   3              }
 271   2              else
 272   2              {
 273   3                  ScalerTimerDelayXms(2);
 274   3      
 275   3                  usTimeOutCnt--;
 276   3              }
 277   2      
 278   2              if(usTimeOutCnt == 0)
 279   2              {
 280   3                  break;
 281   3              }
 282   2          }
 283   1      
 284   1          // Disable mcu write
 285   1          MCU_FF2A_IIC_IRQ_CONTROL2 &= ~_BIT5;
 286   1      }
 287          
 288          #if((_DP_MST_SUPPORT == _ON) && (_DP_TX_SUPPORT == _ON))
              //--------------------------------------------------
              // Description  : Set DDC Data
              // Input Value  : *pucReadArray, ucLength, enumDdcciCmdSrc
C51 COMPILER V9.00   SCALERCOMMONMCU                                                       04/02/2026 14:20:49 PAGE 6   

              // Output Value : None
              //--------------------------------------------------
              void ScalerMcuDdcciSetData(BYTE *pucReadArray, BYTE ucLength, EnumDdcciCmdSrc enumDdcciCmdSrc)
              {
                  memcpy(g_pucDdcciRxBuf, pucReadArray, ucLength);
              
                  SET_RUN_DDCCI_COMMAND(_SUCCESS);
                  SET_RUN_DDCCI_COMMAND_SRC(enumDdcciCmdSrc);
              }
              #endif
