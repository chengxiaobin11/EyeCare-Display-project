 115          void OsdFuncApplyMapOsdAB(BYTE ucWidthA, BYTE ucHeightA, BYTE ucColorA, BYTE ucWidthB, BYTE ucHeightB, BYT
             -E ucColorB)
 116          {
 117   1          BYTE ucI = 0;
 118   1          BYTE ucTmp = 17; // Row Height = 18
 119   1         // BYTE ucMapBRowCommandBaseAddr = (ucHeightA + 1);
 120   1      
 121   1      ////////// OSD A Row command
 122   1      #if(_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE)
