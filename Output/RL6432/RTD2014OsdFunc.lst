                     (GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_270))
                  {
                      ucI = ucWidthA;
                      ucWidthA = ucHeightA;
                      ucHeightA = ucI;
                      ucTmp = 11;  // Row Height = 12
                  }
              #endif
 132   1          // Row Command
 133   1          for(ucI = 0; ucI < ucHeightA; ucI++)
 134   1          {
 135   2              ScalerOsdCommandAllByte(ucI, 0x80, ucTmp, ucWidthA);
 136   2          }
 137   1      
 138   1      
 139   1          // Row Command end
