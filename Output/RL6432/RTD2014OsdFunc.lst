 427   3              }
 428   2              else
 429   2      #endif
 430   2              {
 431   3                  if((enumWinIndex >= _OSD_WINDOW_4_1) && (enumWinIndex <= _OSD_WINDOW_4_8))
 432   3                  {
 433   4                       usWinTemp = (0x2230 >> 4) + ((enumWinIndex - _OSD_WINDOW_4_1) * 4);
 434   4                  }
 435   3                  else if(enumWinIndex <= _OSD_WINDOW_9)
 436   3                  {
 437   4                      usWinTemp = (0x1030 >> 4) + (enumWinIndex * 4);
 438   4                  }
 439   3              }
 440   2      
 441   2              ScalerOsdWriteByte((_OSD_WIN_CONTROL | _OSD_BYTE2), _OSD_WITHOUT_DB, usWinTemp, 0x00);
