 412   4                      ScalerOsdWriteByte((_OSD_WIN_CONTROL | _OSD_BYTE2), _OSD_WITHOUT_DB, ((0x2030 >> 4) + usWi
             -nTemp * 4), 0x00);  // _OSD_WINDOW_4_1 ~ _OSD_WINDOW_4_8
 413   4      
 414   4      #if(_OSD_WINDOW_5_1_5_8_SUPPORT == _ON)
 415   4                      // Window 5-1~5-8
 416   4                      ScalerOsdWriteByte((_OSD_WIN_CONTROL | _OSD_BYTE2), _OSD_WITHOUT_DB, ((0x2230 >> 4) + usWi
             -nTemp * 4), 0x00);  // _OSD_WINDOW_5_1 ~ _OSD_WINDOW_5_8
 417   4      #endif
 418   4                  }
 419   3              }
 420   2          }
 421   1          else
 422   1          {
 423   2      #if(_OSD_WINDOW_5_1_5_8_SUPPORT == _ON)
 424   2              if((enumWinIndex >= _OSD_WINDOW_5_1) && (enumWinIndex <= _OSD_WINDOW_5_8))
 425   2              {
