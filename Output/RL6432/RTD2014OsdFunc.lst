              #endif
 154   1      
 155   1          // Row Command
 156   1          // MapB Row Command address must be multiple of 4
 157   1              for(ucI = (ucHeightA + 1); ucI < (ucHeightA + 1 + ucHeightB); ucI++)
 158   1              {
 159   2                      ScalerOsdCommandAllByte(ucI, 0x80, ucTmp, ucWidthB);    // 0x80 ÄŹïżœïżœpage0/1 0xA0 page2
 160   2              }
 161   1      
 162   1              
 163   1              // Row Command end
