 392          void OsdFuncCloseWindow(EnumOsdWindowsType enumWinIndex)
 393          {
 394   1      
 395   1          // ScalerSetByte(0x3A57, 0x00);//WIN0-7
 396   1          // ScalerSetByte(0x3A59, 0x00);//WIN4-1~4-8
 397   1          // ScalerSetByte(0x3A5A, 0x00);//WIN5-1~5-8
 398   1      
 399   1          // ScalerOsdWindowDisable(enumWinIndex);
 400   1          WORD usWinTemp = 0;
 401   1      
 402   1          if(enumWinIndex == _OSD_WINDOW_ALL)
 403   1          {
 404   2              for(usWinTemp = 0; usWinTemp < 10; usWinTemp++)
 405   2              {
 406   3                  // Window 0~9
 407   3                  ScalerOsdWriteByte((_OSD_WIN_CONTROL | _OSD_BYTE2), _OSD_WITHOUT_DB, ((0x1030 >> 4) + usWinTem
             -p * 4), 0x00);
 408   3      
 409   3                  if(usWinTemp < 8)
C51 COMPILER V9.00   RTD2014OSDFUNC                                                        02/26/2026 13:43:34 PAGE 8   

 410   3                  {
