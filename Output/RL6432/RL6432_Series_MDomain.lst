  48          // Input Value  : None
  49          // Output Value : None
  50          // Note : Only for Frame Sync case
  51          //--------------------------------------------------
  52          void ScalerMDomainControlDBApply(void)
  53          {
  54   1          bit bFreeRunEn = _FALSE;
  55   1      
  56   1          // Enable double buffer
  57   1          if((GET_MEMORY_SELECT() == _FRAME_SYNC_LINE_BUFFER) || (GET_MEMORY_SELECT() == _FRAME_SYNC_MEMORY) || 
             -(GET_MEMORY_SELECT() == _MN_FRAME_SYNC_MEMORY))
  58   1          {
  59   2              if(ScalerGetBit(P0_10_M1_VGIP_CTRL, _BIT1) == _BIT1)
  60   2              {
  61   3                  // Avoid (Current_IVStart + IVHeight) > IVToal + New_IVSDelay in digital capture
  62   3                  PDATA_WORD(0) = (g_stInputTimingData.usVStart + ScalerVgipGetCaptureVStartPosition() + g_stMDo
             -mainInputData.usVHeight);
  63   3              }
  64   2              else
  65   2              {
  66   3                  // Avoid (Current_IVSDelay + IVStart + IVHeight) > IVToal + New_IVSDelay in analog capture
  67   3                  PDATA_WORD(0) = (ScalerVgipGetCaptureVDelay() + ScalerVgipGetCaptureVStartPosition() + g_stMDo
             -mainInputData.usVHeight);
  68   3              }
  69   2      
  70   2              bFreeRunEn = (PDATA_WORD(0) > g_stMDomainInputData.usVTotal) ? (_TRUE) : (_FALSE);
  71   2      
  72   2              if(bFreeRunEn == _TRUE)
  73   2              {
  74   3                  ScalerTimerWaitForEvent(_EVENT_DEN_START);
  75   3      
  76   3                  // Set Free run
  77   3                  ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT3, 0x00);
  78   3      
  79   3                  ScalerSetDataPortBit(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_25_MN_FRAME_RATE_EN, ~_BIT7, 0x
             -00);
  80   3              }
  81   2      
  82   2              ScalerGlobalIDomainDBApply(_DB_APPLY_POLLING);
  83   2      
  84   2              if(bFreeRunEn == _TRUE)
  85   2              {
  86   3                  switch(GET_MEMORY_DVF_SELECT())
  87   3                  {
  88   4                      case _1_IVF:
  89   4                          ScalerTimerWaitForEvent(_EVENT_IVS);
  90   4                          ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  91   4      
  92   4                          // Set Frame sync
  93   4                          ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT3, _BIT3);
  94   4                          break;
  95   4      
  96   4                      case _6_5_IVF:
  97   4                      case _5_4_IVF:
  98   4                          ScalerTimerWaitForEvent(_EVENT_IVS);
  99   4                          ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
 100   4      
 101   4                          ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT3, _BIT3);
 102   4                          ScalerSetDataPortBit(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_25_MN_FRAME_RATE_EN, ~_
             -BIT7, _BIT7);
 103   4                          break;
 104   4      
C51 COMPILER V9.00   RL6432_SERIES_MDOMAIN                                                 02/26/2026 13:42:53 PAGE 3   

 105   4                      case _2_IVF:
 106   4                      case _3_IVF:
 107   4                          ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_27_N_FOR_MN_FRAME_RATE
             -, 1, &pData[15], _NON_AUTOINC);
 108   4      
 109   4                          ScalerTimerWaitForEvent(_EVENT_IEN_STOP);
 110   4                          ScalerTimerWaitForEvent(_EVENT_IVS);
 111   4      
 112   4                          while(pData[15] > 0)
 113   4                          {
 114   5                              pData[15] --;
 115   5                              ScalerTimerWaitForEvent(_EVENT_DEN_START);
 116   5                          }
 117   4                          ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
 118   4      
 119   4                          ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT3, _BIT3);
 120   4                          ScalerSetDataPortBit(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_25_MN_FRAME_RATE_EN, ~_
             -BIT7, _BIT7);
 121   4                          break;
 122   4      
 123   4                      case _2_5_IVF:
 124   4                          // Measure DVtotal in current mode
 125   4                          ScalerSetBit(P0_43_FS_DELAY_FINE_TUNE, ~_BIT5, _BIT5);
 126   4                          ScalerSetBit(P0_44_LAST_LINE_H, ~_BIT7, _BIT7);
 127   4      
 128   4                          // Get N frame
 129   4                          ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_27_N_FOR_MN_FRAME_RATE
             -, 1, &pData[15], _NON_AUTOINC);
 130   4      
 131   4                          // Get free run DVtotal
 132   4                          PDATA_WORD(6) = GET_FREE_RUN_DVTOTAL();
 133   4      
 134   4                          ScalerTimerWaitForEvent(_EVENT_IEN_STOP);
 135   4                          ScalerTimerWaitForEvent(_EVENT_IVS);
 136   4      
 137   4                          GET_DVTOTAL_LASTLINE(PDATA_WORD(0));
 138   4      
 139   4                          if(PDATA_WORD(0) < (PDATA_WORD(6) * 7 / 10))
 140   4                          {
 141   5                              while(pData[15] > 0)
 142   5                              {
 143   6                                  pData[15] --;
 144   6                                  ScalerTimerWaitForEvent(_EVENT_DEN_START);
 145   6                              }
 146   5                          }
 147   4                          else
 148   4                          {
 149   5                              ScalerTimerWaitForEvent(_EVENT_DEN_START);
 150   5                          }
 151   4      
 152   4                          ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
 153   4      
 154   4                          ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT3, _BIT3);
 155   4                          ScalerSetDataPortBit(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_25_MN_FRAME_RATE_EN, ~_
             -BIT7, _BIT7);
 156   4                          ScalerSetBit(P0_43_FS_DELAY_FINE_TUNE, ~_BIT5, 0x00);
 157   4                          break;
 158   4      
 159   4                      default:
 160   4                          break;
 161   4                  }
 162   3              }
