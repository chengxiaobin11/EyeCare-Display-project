 171          //--------------------------------------------------
 172          // Description  : Check memory
 173          // Input Value  : None
 174          // Output Value : Memory check pass or fail
 175          //--------------------------------------------------
 176          bit ScalerMDomainMemoryCheck(void)
 177          {
 178   1          // Check fifo underflow & overflow and Input HVsync error flag, Display Vsync timeout flag
 179   1          if((ScalerGetBit(P0_02_STATUS0, (_BIT6 | _BIT5 | _BIT1 | _BIT0)) != 0x00) || (ScalerGetBit(P0_0C_WATCH
             -_DOG_CTRL0, _BIT0) != 0x00))
 180   1          {
 181   2              return _FALSE;
 182   2          }
 183   1      
 184   1          return _TRUE;
 185   1      }
