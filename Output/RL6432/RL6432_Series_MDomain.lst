 163   2          }
 164   1          else
 165   1          {
 166   2              ScalerGlobalIDomainDBApply(_DB_APPLY_POLLING);
 167   2          }
 168   1          ScalerGlobalDDomainDBApply(_DB_APPLY_POLLING);
 169   1      }
