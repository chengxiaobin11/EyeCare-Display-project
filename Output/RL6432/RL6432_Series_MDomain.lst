 187          //--------------------------------------------------
 188          // Description  : Apply Display Timing Gen Double Buffer
 189          // Input Value  : None
 190          // Output Value : None
 191          //--------------------------------------------------
 192          void ScalerMDomainDisplayTimingGenDBApply(EnumDBApply enumDBApply)
 193          {
 194   1          if(enumDBApply != _DB_APPLY_NONE)
 195   1          {
 196   2              // Check if Display Timing Gen DB is enabled
 197   2              if(ScalerGetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, _BIT7) == 0x00)
 198   2              {
 199   3                  return;
 200   3              }
 201   2      
 202   2              // Check D domain status
 203   2              if((ScalerGetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, _BIT0) == 0x00) ||
 204   2                 (GET_DPLL_POWER_STATUS() == _FALSE))
 205   2              {
 206   3                  // Disable Double Buffer
 207   3                  ScalerSetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, ~_BIT7, 0x00);
 208   3                  return;
 209   3              }
 210   2      
 211   2              // Apply Display Timing Gen Double Buffer
 212   2              ScalerSetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, ~_BIT6, _BIT6);
 213   2      
 214   2              if(enumDBApply == _DB_APPLY_POLLING)
 215   2              {
 216   3                  // Wait Display Timing Gen double buffer
 217   3                  if(ScalerTimerPollingFlagProc(_DOUBLE_BUFFER_WAIT_TIME, P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, _B
             -IT6, 0) == _FALSE)
 218   3                  {
 219   4                      // Disable Double Buffer
 220   4                      ScalerSetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, ~_BIT7, 0x00);
 221   4                  }
 222   3              }
