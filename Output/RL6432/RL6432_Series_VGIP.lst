  48          //****************************************************************************
  49          //--------------------------------------------------
  50          // Description  : Initial for VGIP Input
  51          // Input Value  : Input Source Type
  52          // Output Value : None
  53          //--------------------------------------------------
  54          void ScalerVgipInputInitial(EnumSourceTypeDef enumSourceType, EnumSourceSearchPort enumSourceSearchPort)
  55          {
  56   1          enumSourceType = enumSourceType;
  57   1      
  58   1          // Initial format conversion
  59   1          ScalerFmtCnvInitialSetting(enumSourceSearchPort);
  60   1      
  61   1          // Set Input Pixel Format, Disable Double buffer, Analog Capture, and Start generate DE
  62   1          ScalerSetBit(P0_10_M1_VGIP_CTRL, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT2));
  63   1      
  64   1          // HS Sync Edge select to Positive, Disable 1 clock Delay Mode
  65   1          ScalerSetBit(P0_12_M1_VGIP_DELAY_CTRL, ~(_BIT4 | _BIT3 | _BIT2), 0x00);
  66   1      
  67   1          // Reset field detect edge
  68   1          ScalerSetBit(P0_11_M1_VGIP_SIGINV, ~(_BIT5 | _BIT3), 0x00);
  69   1      
  70   1      #if(_FREESYNC_SUPPORT == _ON)
  71   1          if((GET_FREESYNC_ENABLED() == _TRUE) && (enumSourceType == _SOURCE_DP))
  72   1          {
  73   2              // Enable bypass Vsync
  74   2              ScalerVgipVsBypassEnable(_ENABLE);
  75   2          }
  76   1          else
  77   1          {
  78   2              // Disable bypass Vsync
  79   2              ScalerVgipVsBypassEnable(_DISABLE);
  80   2          }
  81   1      #else
                  // Disable bypass Vsync
                  ScalerVgipVsBypassEnable(_DISABLE);
              #endif
  85   1      
  86   1      #if((_MEASURE_ADJUSTED_IHF_SUPPORT == _ON) || (_MEASURE_ADJUSTED_IVF_SUPPORT == _ON))
  87   1          // Set to analog measure
  88   1          ScalerVgipSetDigitalCaptureStatus(_DISABLE);
  89   1      #endif
  90   1      
  91   1          // Initial IVS/IHS Delay for Capture and Auto
  92   1          ScalerVgipSetCaptureHDelay(0x00);
  93   1          ScalerVgipSetCaptureVDelay(0x00);
  94   1      
  95   1      #if((_MEASURE_ADJUSTED_IHF_SUPPORT == _ON) || (_MEASURE_ADJUSTED_IVF_SUPPORT == _ON))
  96   1          ScalerVgipSetCaptureHStartPosition(0x00);
  97   1          ScalerVgipSetCaptureVStartPosition(0x00);
  98   1      
  99   1          // Set to digital measure
 100   1          ScalerVgipSetDigitalCaptureStatus(_ENABLE);
 101   1      #endif
 102   1      }


