             -_BUS_WIDTH / 10) * g_usDVFreq / 100) +
1931   1                            (((DWORD)g_stMDomainOutputData.usVTotal * usHWidth * GET_MEMORY_DATA_BIT() / _MEMORY
             -_BUS_WIDTH / 100) * g_usDVFreq * ((_DCLK_SPREAD_RANGE / _DPLL_SSCG_DIV_MODE) + _DCLK_SPREAD_RANGE_MARGIN) / 4 / 100 / 10
