1568   2              {
1569   3                  usIvDelay = ScalerVgipGetCaptureVDelay();
1570   3              }
1571   2      
1572   2              // Check IVS_Delay change from larger to smaller
1573   2              if((GET_INPUT_TIMING_VTOTAL() - usIvDelay) < (usIvs2dvsDelay + 4)) // 4 line margin
1574   2              {
