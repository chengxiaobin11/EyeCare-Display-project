 556          //--------------------------------------------------
 557          // Description  : If Dclk over panel spec, finetune DHtotal
 558          // Input Value  : current Dclk/ Dclk max boundary/ Dclk min boundary
 559          // Output Value : Fine tune status/ DHtotal
 560          //--------------------------------------------------
 561          StructDHtotalFTStatus ScalerMDomainDHtotalFinetune(DWORD ulDclk, DWORD ulDclkMaxBoundary, DWORD ulDclkMinB
             -oundary)
 562          {
 563   1          StructDHtotalFTStatus stDHtotalFTStatus;
 564   1      
 565   1          stDHtotalFTStatus.b1DHtotalFineTuneStatus = _TRUE;
 566   1          stDHtotalFTStatus.usDHtotal = GET_MDOMAIN_OUTPUT_HTOTAL();
 567   1      
 568   1          if(ulDclk > ulDclkMaxBoundary)
 569   1          {
 570   2              // Calculate target DHTotal
 571   2              stDHtotalFTStatus.usDHtotal = GET_DWORD_MUL_DIV(GET_MDOMAIN_OUTPUT_HTOTAL(), ulDclkMaxBoundary, ul
             -Dclk);
 572   2              stDHtotalFTStatus.usDHtotal -= (stDHtotalFTStatus.usDHtotal % _DHTOTAL_MULTIPLE);
 573   2      
 574   2              if(stDHtotalFTStatus.usDHtotal < _PANEL_DH_TOTAL_MIN)
 575   2              {
 576   3                  DebugMessageSystem("_DHTotal_over_panel", stDHtotalFTStatus.usDHtotal);
 577   3      
 578   3                  stDHtotalFTStatus.b1DHtotalFineTuneStatus = _FALSE;
 579   3                  stDHtotalFTStatus.usDHtotal = _PANEL_DH_TOTAL_MIN;
 580   3              }
 581   2      
 582   2              DebugMessageSystem("FS fine tune, Dclk larger than panel spec => Modify Htotal'", stDHtotalFTStatu
             -s.usDHtotal);
 583   2          }
 584   1          else if(ulDclk < ulDclkMinBoundary)
 585   1          {
 586   2              // Calculate target DHTotal
 587   2              stDHtotalFTStatus.usDHtotal = GET_DWORD_MUL_DIV(GET_MDOMAIN_OUTPUT_HTOTAL(), ulDclkMinBoundary, ul
             -Dclk);
 588   2              stDHtotalFTStatus.usDHtotal = stDHtotalFTStatus.usDHtotal + _DHTOTAL_MULTIPLE - (stDHtotalFTStatus
             -.usDHtotal % _DHTOTAL_MULTIPLE);
 589   2      
 590   2              if(stDHtotalFTStatus.usDHtotal > _PANEL_DH_TOTAL_MAX)
 591   2              {
 592   3                  DebugMessageSystem("_DHTotal_over_panel", stDHtotalFTStatus.usDHtotal);
 593   3      
 594   3                  stDHtotalFTStatus.b1DHtotalFineTuneStatus = _FALSE;
 595   3                  stDHtotalFTStatus.usDHtotal = _PANEL_DH_TOTAL_MAX;
 596   3              }
C51 COMPILER V9.00   SCALERMDOMAIN                                                         02/26/2026 13:42:02 PAGE 11  

 597   2      
 598   2              DebugMessageSystem("FS fine tune, Dclk smaller than panel spec => Modify Htotal'", stDHtotalFTStat
             -us.usDHtotal);
 599   2          }
 600   1      
 601   1          return stDHtotalFTStatus;
 602   1      }
