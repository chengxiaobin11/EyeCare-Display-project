1490   1          {
1491   2              if(GET_INPUT_TIMING_VTOTAL() > (GET_INPUT_TIMING_VHEIGHT() + ScalerVgipGetCaptureVStartPosition() 
             -+ 3))
1492   2              {
1493   3                  usAdjustLimit = (GET_INPUT_TIMING_VTOTAL() - (GET_INPUT_TIMING_VHEIGHT() + ScalerVgipGetCaptur
             -eVStartPosition() + 3));
1494   3              }
1495   2          }
1496   1      
1497   1      #if((_PANEL_STYLE == _PANEL_DPTX) || (_PANEL_STYLE == _PANEL_VBO))
              
