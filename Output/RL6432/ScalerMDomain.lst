 433          EnumMemoryWorkMode ScalerMDomainMemoryConfig(void)
 434          {
 435   1      #if(_FRC_SUPPORT == _ON)
 436   1          if(g_stDisplayCustomizedData.stDVCustomizedFreq.b1DecideMemoryConfig == _FORCE_FRAME_BUFFER_MODE)
 437   1          {
 438   2              return _MEMORY_WORK_MODE;
 439   2          }
 440   1      #endif
 441   1      
 442   1      #if(_FREESYNC_SUPPORT == _ON)
 443   1          if((GET_FREESYNC_ENABLED() == _TRUE) && (_FREESYNC_LINEBUFFER_PRIORITY == _ON))
 444   1          {
 445   2      #if(_DISPLAY_ROTATION_SUPPORT == _ON)
 446   2              if(ScalerRotationCheckStatus() == _TRUE)
 447   2              {
 448   3                  return _MEMORY_WORK_MODE;
 449   3              }
 450   2      #endif
 451   2      
 452   2              if(_LAST_LINE_FINETUNE_ENABLE == _DISABLE)
 453   2              {
 454   3                  return _MEMORY_WORK_MODE;
 455   3              }
 456   2              else
 457   2              {
 458   3      #if(_FRC_SUPPORT == _ON)
 459   3                  if((g_stMDomainOutputData.usVBackHeight > g_stMDomainOutputData.usVHeight) ||
 460   3                     (ScalerMDomainFSLineBufferDclkDvtotalCheck() == _FALSE))
 461   3                  {
 462   4                      return _MEMORY_WORK_MODE;
 463   4                  }
 464   3      #endif
 465   3              }
 466   2      
 467   2              return _LINE_BUFFER_MODE;
 468   2          }
 469   1          else
 470   1      #endif // End of #if(_FREESYNC_SUPPORT == _ON)
 471   1          {
 472   2      #if(_FRAME_SYNC_LINE_BUFFER_SUPPORT == _OFF)
                      return _MEMORY_WORK_MODE;
              #else
 475   2              BYTE ucMemoryConfig = _LINE_BUFFER_MODE;
 476   2      
 477   2      #if(_FRC_SUPPORT == _ON)
 478   2              g_stDisplayCustomizedData.stDVCustomizedFreq.usMaxFreq += _FRAME_SYNC_MARGIN;
 479   2              g_stDisplayCustomizedData.stDVCustomizedFreq.usMinFreq -= _FRAME_SYNC_MARGIN;
C51 COMPILER V9.00   SCALERMDOMAIN                                                         02/26/2026 13:42:02 PAGE 9   

 480   2      
 481   2              if((GET_MEMORY_DVF_SELECT() != _1_IVF) ||
 482   2                 (g_stMDomainOutputData.usVBackHeight > g_stMDomainOutputData.usVHeight) ||
 483   2                 (ScalerMDomainFSLineBufferDclkDvtotalCheck() == _FALSE))
 484   2              {
 485   3                  ucMemoryConfig = _MEMORY_WORK_MODE;
 486   3              }
 487   2      
 488   2              if(GET_MEMORY_DVF_SELECT() == _PANEL_TYP_FRAME_RATE_FREE_RUN)
 489   2              {
 490   3                  ucMemoryConfig = _MEMORY_WORK_MODE;
 491   3              }
 492   2      
 493   2      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
                      if(ScalerFmtCnvFtoPGetStatus() == _FALSE)
                      {
                          ucMemoryConfig = _MEMORY_WORK_MODE;
                      }
              #endif
 499   2      
 500   2      #if(_DISPLAY_ROTATION_SUPPORT == _ON)
 501   2              if(ScalerRotationCheckStatus() == _TRUE)
 502   2              {
 503   3                  ucMemoryConfig = _MEMORY_WORK_MODE;
 504   3              }
 505   2      #endif
 506   2      
 507   2      #if(_DISP_LATENCY_ADJUST_SUPPORT == _ON)
                      // if display latency != faster, then change to _MEMORY_WORK_MODE
                      if((GET_DISP_LATENCY_RATIO() != 0x00) && (ucMemoryConfig == _LINE_BUFFER_MODE))
                      {
                          PDATA_WORD(0) = MINOF(GET_MDOMAIN_INPUT_HWIDTH(), GET_MDOMAIN_OUTPUT_HWIDTH());
                          if((ScalerMDomainGetFRCMemorySpace() < _MEMORY_ROW) && (ScalerMDomainGetFRCMemoryBW(_FRC_BW_AC
             -TUAL_USAGE, PDATA_WORD(0)) < _MEMORY_TOTAL_BW))
                          {
                              ucMemoryConfig = _MEMORY_WORK_MODE;
