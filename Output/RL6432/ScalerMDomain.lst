1576   3      
1577   3                  if(usIvDelay > usIvs2dvsDelayLimit)
1578   3                  {
1579   4                      usIvs2dvsDelayLimit = usIvDelay - usIvs2dvsDelayLimit;
1580   4      
1581   4                      if(usIvs2dvsDelayLimit < usAdjustLimit)
1582   4                      {
