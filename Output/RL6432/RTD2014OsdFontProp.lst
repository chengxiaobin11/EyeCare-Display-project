              void OsdPropGetShowDpInfoStringAddress(BYTE Index)
              {
                  BYTE ucI = 0;
                  BYTE ucIndex = 0;
                  EnumSourceSearchPort ucPortSel = SysSourceGetInputPort();
                  if(SysModeGetModeState() != _MODE_STATUS_ACTIVE)
                  {
                      ucPortSel = GET_OSD_POWER_SAVING_SHOW_DP_INFO_PORT();
              
