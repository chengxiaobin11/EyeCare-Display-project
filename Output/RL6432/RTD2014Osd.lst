              void MENU_FUN_MSG_BOOT_UP(void)
              {
                  switch(GET_KEYMESSAGE())
                  {
                      case _MENU_KEY_MESSAGE:
                                      if(OSD_SubMenuCur == 0) // Boot up Screen
                                      {
                                              SET_FACTORY_FORCE_LOGO_OFF(!GET_FACTORY_FORCE_LOGO_OFF());
                                              OsdPropPutString(ROW(2), COL(19), _PFONT_PAGE_2, STRING(_STRING_ON_OFF), GET_FACTORY_FORCE_LOGO_OFF(),
             - COLOR(_CP_WHITE, _CP_DARKGRAY), GET_OSD_LANGUAGE());
                                              TPVNVRamSaveFactoryDate();
              
                                      }
                                      else    // Mode Message
                                      {
                                              SET_OSD_Message_Info_Eanble(!GET_OSD_Message_Info_Eanble());
                                              OsdPropPutString(ROW(4), COL(19), _PFONT_PAGE_2, STRING(_STRING_ON_OFF), GET_OSD_Message_Info_Eanble()
             -, COLOR(_CP_WHITE, _CP_DARKGRAY), GET_OSD_LANGUAGE());
                                              RTDNVRamSaveOSDData();
                                              //SET_OSD_EVENT_MESSAGE(_OSDEVENT_SAVE_NVRAM_OSDUSERDATA_MSG);
                                      }
                                      break;
                                      
                      case _EXIT_KEY_MESSAGE:
                                      OsdDispDisableOsd();
                                      break;
                                      
                      case _RIGHT_KEY_MESSAGE:
                      case _LEFT_KEY_MESSAGE:         
                              case _UP_KEY_MESSAGE:
                      case _DOWN_KEY_MESSAGE:
                                      OSD_SubMenuCur = OsdDisplayDetOverRange(OSD_SubMenuCur, 1, 0, _ON);
                                      OsdWindowDrawingHighlight(WINNO(_MAIN_WIN_3RD_CURSOR), XSTART(0), YSTART(2*18+(OSD_SubMenuCur*2)*18), X
             -END(_OSD_MSG_COL_NUM_23*12), YEND(3*18+(OSD_SubMenuCur*2)*18),        _CP_BLUE, _CP_WHITE, _CP_BLUE);
                          break;
              
                      default:
                          break;
                  }
              }
              #endif
