                  UserCommonEepromRead(_COLORTEMP_DATA_ADDRESS + (ucColorTempType) * sizeof(StructColorProcDataType), si
             -zeof(StructColorProcDataType), (BYTE *)(&g_stColorProcData.usColorTempR));
              
                  /*
                  else
