C51 COMPILER V9.00   RTD2014NVRAMOSD                                                       02/26/2026 13:43:28 PAGE 24  

              {
              #if(_OGC_SUPPORT == _ON)
                  if(GET_OSD_GAMMA() != _GAMMA_OFF)
