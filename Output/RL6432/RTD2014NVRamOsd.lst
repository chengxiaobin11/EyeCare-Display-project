1560          //--------------------------------------------------
1561          // Description  : Get the free page number of flash
1562          // Input Value  : None
1563          // Output Value : Free page index
1564          //--------------------------------------------------
1565          BYTE RTDFlashGetFreePage(void)
1566          {
1567   1          BYTE ucPageID = _START_OF_PAGEID;
1568   1          BYTE ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1569   1      
1570   1          // If the _END_PAGE page has the biggest move count, suppose first page is free page
1571   1          if(g_ulFlashMoveCount > 0)
1572   1          {
1573   2              if(g_ucFlashLastPage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1574   2              {
1575   3                  ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1576   3              }
1577   2              else
1578   2              {
1579   3                  ucFreePage = g_ucFlashLastPage + 1;
1580   3              }
1581   2          }
1582   1      
1583   1          // Check the supposed free page is actual free page which has not been used ever
1584   1          do
C51 COMPILER V9.00   RTD2014NVRAMOSD                                                       02/26/2026 13:43:28 PAGE 27  

1585   1          {
1586   2              if(ucFreePage == g_pucFlashPageArr[ucPageID])
1587   2              {
1588   3                  if(ucFreePage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1589   3                  {
1590   4                      ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1591   4                  }
1592   3                  else
1593   3                  {
1594   4                      ucFreePage += 1;
1595   4                  }
1596   3      
1597   3                  ucPageID = _START_OF_PAGEID;
1598   3              }
1599   2              else
1600   2              {
1601   3                  ucPageID++;
1602   3              }
1603   2          }
1604   1          while(ucPageID <= _END_OF_PAGEID);
1605   1      
1606   1          return ucFreePage;
1607   1      }
1608          
1609          //--------------------------------------------------
1610          // Description  : Check the page is vaild or not
1611          // Input Value  : ucPage: The page to be check, must between 0 and (_END_PAGE - _START_PAGE)
1612          // Output Value : _TRUE means the page is valid, _FLASE is invalid
1613          //--------------------------------------------------
1614          bit RTDFlashIsPageInfoValid(BYTE ucPage)
1615          {
1616   1          WORD usPageInfoAddr = ucPage * _FLASH_PAGE_SIZE;
1617   1          BYTE ucPageInfoChecksum = 0;
1618   1          BYTE pucPageInfo[5] = {0};
1619   1          BYTE pucPageInfoTemp[4] = {0};
1620   1      
1621   1          UserCommonFlashRead(_SYSTEM_EEPROM_EMULATION_FLASH_BANK, usPageInfoAddr + _PAGEINFO_CHECKSUM_ADDR, 5, 
             -pucPageInfo);
1622   1          pucPageInfoTemp[0] = pucPageInfo[1];
1623   1          pucPageInfoTemp[1] = pucPageInfo[2];
1624   1          pucPageInfoTemp[2] = pucPageInfo[3];
1625   1          pucPageInfoTemp[3] = pucPageInfo[4];
1626   1          ucPageInfoChecksum = UserCommonFlashCalculateCheckSumData(pucPageInfoTemp, 4);
1627   1          ucPageInfoChecksum = (ucPageInfoChecksum & 0x7F);
1628   1      
1629   1          if(ucPageInfoChecksum == pucPageInfo[0])
1630   1          {
1631   2              return _TRUE;
1632   2          }
1633   1      
1634   1          return _FALSE;
1635   1      }
