                      UserCommonAdjustOGCColorTempGain(ucColorTempType, (GET_OSD_GAMMA() - 1), pData, _OGC_NORMAL_TYPE);
              
              #if(_CTS_TYPE == _CTS_GEN_1_12BIT)
                      g_stColorProcData.usColorTempR = PDATA_WORD(0);
