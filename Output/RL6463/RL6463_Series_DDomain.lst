  46          // Description  : Display Force to Background Enable
  47          // Input Value  : _ENABLE or _DISABLE
  48          // Output Value : None
C51 COMPILER V8.12   RL6463_SERIES_DDOMAIN                                                 03/10/2025 13:50:43 PAGE 2   

  49          //--------------------------------------------------
  50          void ScalerDDomainBackgroundEnable(bit bEnable)
  51          {
  52   1          if(bEnable == _ENABLE)
  53   1          {
  54   2              // Enable Force to Back Ground
  55   2              ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT5, _BIT5);
  56   2          }
  57   1          else
  58   1          {
  59   2              // Disable Force to Back Ground
  60   2              ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT5, 0x00);
  61   2          }
  62   1      }
  63          
  64          //--------------------------------------------------
  65          // Description  : Set Display Background Color
  66          // Input Value  : RGB Color
  67          // Output Value : None
  68          //--------------------------------------------------
  69          void ScalerDDomainBackgroundSetColor(BYTE ucRed, BYTE ucGreen, BYTE ucBlue)
  70          {
  71   1          // Reset Port index
  72   1          ScalerSetBit(P0_6C_OVERLAY_CTRL, ~_BIT5, 0x00);
  73   1          ScalerSetBit(P0_6C_OVERLAY_CTRL, ~_BIT5, _BIT5);
  74   1      
  75   1          // 8bits RGB color
  76   1          ScalerSetByte(P0_6D_BG_COLOR_DATA_PORT_M1, ucRed);
  77   1          ScalerSetByte(P0_6D_BG_COLOR_DATA_PORT_M1, ucGreen);
  78   1          ScalerSetByte(P0_6D_BG_COLOR_DATA_PORT_M1, ucBlue);
  79   1      
  80   1          ScalerSetBit(P0_6C_OVERLAY_CTRL, ~_BIT5, 0x00);
  81   1      }
