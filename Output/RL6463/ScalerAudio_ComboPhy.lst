 176          //--------------------------------------------------
 177          // Description  : Switch Digital Audio Output Mute
 178          // Input Value  : _ON => Mute On
 179          // Output Value : None
 180          //--------------------------------------------------
 181          void ScalerAudioDigitalOutputMute(bit bMute)
 182          {
 183   1          if(GET_REG_D0_MAC_SWITCH_TO_HDMI() == _TRUE)
 184   1          {
 185   2              ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_07_PORT_PAGE2_HDMI_MAG_M_FINAL, ~(_BIT1 | _BIT0), ((
             -(!bMute) == _ENABLE) ? (_BIT1 | _BIT0) : 0x00));
 186   2              ScalerSetDataPortByte(P2_C9_HDMI_AP, _P2_CA_PT_08_PORT_PAGE2_HDMI_MAG_L_FINAL, 0x00);
 187   2              ScalerSetDataPortByte(P2_C9_HDMI_AP, _P2_CA_PT_09_PORT_PAGE2_HDMI_MAG_R_FINAL, 0x00);
 188   2          }
 189   1          else
 190   1          {
 191   2      #if(_DP_SUPPORT == _ON)
                      ScalerAudioDPDigitalOutputProc(~bMute, _D0_INPUT_PORT);
              #endif
 194   2          }
 195   1      }
