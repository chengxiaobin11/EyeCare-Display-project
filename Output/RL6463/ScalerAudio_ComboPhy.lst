1401          // Output Value : None
1402          //--------------------------------------------------
1403          void ScalerAudioD0HbrAudioDetect(void)
1404          {
1405   1          // Check Input Port Type
1406   1          if(GET_REG_D0_MAC_SWITCH_TO_HDMI() == _FALSE)
1407   1          {
1408   2              // Check HBR Audio Receive
1409   2              if(ScalerGetBit(PB6_B0_DP_AUD_CTRL, (_BIT3 | _BIT2 | _BIT1 | _BIT0)) == _BIT0)
1410   2              {
1411   3                  // Check Current Detect Mode
1412   3                  if(ScalerGetBit(PB6_B0_DP_AUD_CTRL, _BIT6) != _BIT6)
1413   3                  {
