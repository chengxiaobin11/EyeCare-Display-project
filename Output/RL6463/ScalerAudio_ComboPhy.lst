1341          // Description  : D0 Audio Watch Dog Proc
1342          // Input Value  : bOn
1343          // Output Value : None
1344          //--------------------------------------------------
1345          void ScalerAudioD0WatchDogProc(bit bOn)
1346          {
1347   1          if(bOn == _ON)
1348   1          {
1349   2              if(GET_REG_D0_MAC_SWITCH_TO_HDMI() == _TRUE)
1350   2              {
1351   3                  // Clear audio FIFO overflow and underflow status
1352   3                  ScalerSetBit(P2_CB_HDMI_SR, ~(_BIT2 | _BIT1), (_BIT2 | _BIT1));
1353   3      
1354   3                  // Enable Audio Watch Dog for FIFO Overflow/Underflow
1355   3                  ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_31_PORT_PAGE2_HDMI_WDCR0, ~(_BIT2 | _BIT1), (_BI
             -T2 | _BIT1));
1356   3              }
1357   2              else
1358   2              {
1359   3                  // Clear audio buffer overflow and underflow status
1360   3                  ScalerSetBit(PB6_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
1361   3      
1362   3                  // Enable Audio Watch Dog for Buffer Overflow/Underflow
1363   3                  ScalerSetBit(PB6_39_DP_AWD_CTRL, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
1364   3              }
1365   2          }
C51 COMPILER V8.12   SCALERAUDIO_COMBOPHY                                                  03/10/2025 13:50:29 PAGE 24  

1366   1          else
1367   1          {
1368   2              if(GET_REG_D0_MAC_SWITCH_TO_HDMI() == _TRUE)
1369   2              {
1370   3                  // Disable Audio Watch Dog for FIFO Overflow/Underflow
1371   3                  ScalerSetDataPortBit(P2_C9_HDMI_AP, _P2_CA_PT_31_PORT_PAGE2_HDMI_WDCR0, ~(_BIT2 | _BIT1), 0x00
             -);
1372   3              }
1373   2              else
1374   2              {
1375   3                  // Disable Audio Watch Dog for Buffer Overflow/Underflow
1376   3                  ScalerSetBit(PB6_39_DP_AWD_CTRL, ~(_BIT7 | _BIT6), 0x00);
1377   3      
1378   3                  if(ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0, (_BIT1 | _BIT0)) != 0x00)
1379   3                  {
1380   4                      DebugMessageAudio("WD : D0 DP Audio Over/Underflow", ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0
             -, (_BIT1 | _BIT0)));
1381   4      
1382   4                      // Reset Audio FSM
1383   4                      ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~_BIT7, 0x00);
1384   4      
1385   4                      // Clear audio FIFO overflow and underflow status
1386   4                      ScalerSetBit(PB6_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
1387   4      
1388   4                      // Enable Audio FSM
1389   4                      ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~_BIT7, _BIT7);
1390   4      
1391   4                      // Waiting for 2ms(Audio Freq. Detect || Audio FIFO Write (1/2 FIFO depth = 64 packet)) + 
             -1ms(Audio Stable Time Count = 5 x 200us)
1392   4                      ScalerTimerDelayXms(3);
1393   4                  }
1394   3              }
1395   2          }
1396   1      }
