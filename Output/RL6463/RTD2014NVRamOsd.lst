                  BYTE ucTemp = 0;
                  for(ucTemp = _CT_9300; ucTemp < _CT_USER; ucTemp++)
                  {
                      g_stColorProcData = tColorTempDefaultData[ucTemp];
                      RTDEepromSaveColorSetting(ucTemp);
                  }
              }
              
