              void RTDFlashLoadPanelIndex(void)
              {
                  if(UserCommonFlashLoadItem(_FLASH_ITEMID_PANEL_INDEX, pData, 1) == _TRUE)
                  {
                      SET_MDOMAIN_PANEL_INDEX(pData[0]);
                  }
                  else
                  {
                      SET_MDOMAIN_PANEL_INDEX(0);
