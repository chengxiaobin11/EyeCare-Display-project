                      stUserColorTemp = tColorTempDefaultData[ucIndex];
                      UserCommonEepromWrite(_COLORTEMP_DATA_ADDRESS + (ucIndex) * sizeof(StructColorProcDataType), sizeo
             -f(StructColorProcDataType), (BYTE *)(&stUserColorTemp));
