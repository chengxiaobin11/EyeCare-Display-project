1588          //--------------------------------------------------
1589          // Description  : Check the page is vaild or not
1590          // Input Value  : ucPage: The page to be check, must between 0 and (_END_PAGE - _START_PAGE)
1591          // Output Value : _TRUE means the page is valid, _FLASE is invalid
1592          //--------------------------------------------------
1593          bit RTDFlashIsPageInfoValid(BYTE ucPage)
1594          {
1595   1          WORD usPageInfoAddr = ucPage * _FLASH_PAGE_SIZE;
1596   1          BYTE ucPageInfoChecksum = 0;
1597   1          BYTE pucPageInfo[5] = {0};
1598   1          BYTE pucPageInfoTemp[4] = {0};
1599   1      
1600   1          UserCommonFlashRead(_SYSTEM_EEPROM_EMULATION_FLASH_BANK, usPageInfoAddr + _PAGEINFO_CHECKSUM_ADDR, 5, 
             -pucPageInfo);
1601   1          pucPageInfoTemp[0] = pucPageInfo[1];
1602   1          pucPageInfoTemp[1] = pucPageInfo[2];
1603   1          pucPageInfoTemp[2] = pucPageInfo[3];
1604   1          pucPageInfoTemp[3] = pucPageInfo[4];
1605   1          ucPageInfoChecksum = UserCommonFlashCalculateCheckSumData(pucPageInfoTemp, 4);
1606   1          ucPageInfoChecksum = (ucPageInfoChecksum & 0x7F);
1607   1      
1608   1          if(ucPageInfoChecksum == pucPageInfo[0])
1609   1          {
1610   2              return _TRUE;
1611   2          }
1612   1      
1613   1          return _FALSE;
1614   1      }
