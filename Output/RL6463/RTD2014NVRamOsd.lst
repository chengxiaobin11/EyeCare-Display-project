1539          //--------------------------------------------------
1540          // Description  : Get the free page number of flash
1541          // Input Value  : None
1542          // Output Value : Free page index
1543          //--------------------------------------------------
1544          BYTE RTDFlashGetFreePage(void)
1545          {
1546   1          BYTE ucPageID = _START_OF_PAGEID;
1547   1          BYTE ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1548   1      
1549   1          // If the _END_PAGE page has the biggest move count, suppose first page is free page
1550   1          if(g_ulFlashMoveCount > 0)
1551   1          {
1552   2              if(g_ucFlashLastPage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1553   2              {
1554   3                  ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1555   3              }
1556   2              else
1557   2              {
1558   3                  ucFreePage = g_ucFlashLastPage + 1;
1559   3              }
1560   2          }
1561   1      
1562   1          // Check the supposed free page is actual free page which has not been used ever
1563   1          do
1564   1          {
1565   2              if(ucFreePage == g_pucFlashPageArr[ucPageID])
1566   2              {
1567   3                  if(ucFreePage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1568   3                  {
1569   4                      ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1570   4                  }
1571   3                  else
1572   3                  {
1573   4                      ucFreePage += 1;
1574   4                  }
1575   3      
1576   3                  ucPageID = _START_OF_PAGEID;
1577   3              }
1578   2              else
1579   2              {
1580   3                  ucPageID++;
1581   3              }
1582   2          }
1583   1          while(ucPageID <= _END_OF_PAGEID);
1584   1      
1585   1          return ucFreePage;
C51 COMPILER V8.12   RTD2014NVRAMOSD                                                       03/10/2025 13:51:03 PAGE 27  

1586   1      }
