3107   1      
3108   1          ///////////////////////////////////////////////////////////////////////////////
3109   1          // Formula :                                                                 //
3110   1          //                                                                           //
3111   1          //  I_gain       Ths                    PE(UNIT)                   1         //
3112   1          // --------- x  ------- = ------------------------------------ x  -----      //
3113   1          //   2^22        Tbck        Txclk x 16N / (16M +- K) x 1/16       8         //
3114   1          //                                                                           //
3115   1          //  I_gain         Ths                      PE(UNIT)                   1     //
3116   1          // --------- x  ----------- = ------------------------------------ x  -----  //
3117   1          //   2^22       Tclk x N         Txclk x N / (M +- K/16) x 1/16        8     //
3118   1          //                                                                           //
3119   1          //                                                                           //
3120   1          //           2^22 x PE_U x (M +- K/16) x 2^4        1                        //
3121   1          // I_gain = ----------------------------------- x ------                     //
3122   1          //                        Ths                      2^3                       //
3123   1          //                                                                           //
3124   1          //           2^23 x PE_U x (M +- K/16)                                       //
3125   1          //       = -----------------------------                                     //
3126   1          //                      Ths                                                  //
3127   1          //                                                                           //
3128   1          //                                                                           //
3129   1          //       = IHF x 2^23 x PE_U x (M +- K/16)                                   //
3130   1          //                                                                           //
3131   1          //                                                                           //
3132   1          // I_gain = IHF x 2^23 x PE_U x (M +- K/16)                                  //
3133   1          // IHFreq/10 UNIT is KHz, so result has to multiply 10^2          //
3134   1          // (PE Value UNIT is ps, so result has to multiply 10^-12)                   //
3135   1          //                                                                           //
3136   1          // I_gain = 10^2 x 2^23 x 10^-12 x 2^-10 => 10^10 / 2^13 = 1220703           //
3137   1          //                                                                           //
3138   1          ///////////////////////////////////////////////////////////////////////////////
3139   1      
3140   1          // Calculate I code
3141   1          usIcode = (WORD)(((DWORD)usCurrHFreq * g_stApllData.usPEValue * (ulOldPllDivider >> 10)) / 1192);
3142   1      
3143   1          // Total gain = 3 / 8
3144   1          usIcode = (usIcode / 64) & 0x00007fff; // n = 64 x 8 = 512
3145   1      
3146   1          // The minimum value of I code is 1.
3147   1          if(usIcode < 1)
3148   1          {
3149   2              usIcode = 1;
3150   2          }
3151   1      
3152   1          // Set I code
C51 COMPILER V8.12   SCALERPLL                                                             03/10/2025 13:50:26 PAGE 54  

3153   1          ScalerSetByte(P1_A1_I_CODE_M, (BYTE)(usIcode >> 8));
3154   1          ScalerSetByte(P1_A2_I_CODE_L, (BYTE)usIcode);
3155   1      
3156   1          // Calculate P code
