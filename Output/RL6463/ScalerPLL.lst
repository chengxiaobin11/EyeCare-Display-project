 278          //--------------------------------------------------
 279          // Description  : M2PLL Power COntrol.
 280          // Input Value  : ucOn    --> ON/OFF.
 281          // Output Value : None
 282          //--------------------------------------------------
 283          void ScalerPLLM2PLLPower(BYTE ucOn)
 284          {
 285   1      #if(_M2PLL_STRUCT_TYPE == _M2PLL_STRUCT_M_N)
                  if(ucOn == _ON)
                  {
                      // Power Off M2PLL
                      ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT0, _BIT0);
              
                      // In fact, we can move the m/n code setting to scaler initial
                      // Set M2PLL M Code
                      ScalerSetByte(P1_E0_M2PLL_M, (_M2PLL_PLL_M - 2));
              
                      // Set M2PLL N Code
C51 COMPILER V8.12   SCALERPLL                                                             03/10/2025 13:50:26 PAGE 6   

                      ScalerSetByte(P1_E1_M2PLL_N, (((_M2PLL_PLL_O >> 1) << 4) | (_M2PLL_PLL_N - 2)));
              
                      // Set Rs, Cs, Icp
                      ScalerSetByte(P1_E4_M2PLL_CRNT, 0x73);
              
                      // DPLL VCORSTB Set to Normal
                      ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT1, (_DPLL_VCORSTB_NORMAL_VALUE << 1));
              
                      // Power On M2PLL
                      ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT0, 0x00);
                      DELAY_XUS(150);
              
                      // Reset PFD, LPF
                      ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT5, _BIT5);
                      DELAY_5US();
                      ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT5, 0x00);
              
                      // Wait for M2PLL Stable (1ms)
                      DELAY_XUS(1000);
                  }
                  else
                  {
                      // Power Off M2PLL
                      ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT0, _BIT0);
                  }
              
              #elif(_M2PLL_STRUCT_TYPE == _M2PLL_STRUCT_N_F)
 323   1      
 324   1          DWORD ulNFcode = _M2PLL_DEFAULT_N_F_CODE;
 325   1          BYTE pucNFvalue[4];
 326   1          memset(pucNFvalue, 0, sizeof(pucNFvalue));
 327   1      
 328   1          if(ucOn == _ON)
 329   1          {
 330   2      #if(_LC_TANK_SUPPORT == _ON)
 331   2              // M2PLL clock selection from LC tank or Xtal
 332   2              ScalerSetBit(P41_03_PLL_IN_CONTROL, ~(_BIT7 | _BIT6), ((_XTALESS_SUPPORT == _ON) ? 0x00 : _BIT6));
 333   2      
 334   2      #if((_XTALESS_SUPPORT == _ON) && (_EFUSE_SUPPORT == _ON))
                      // Read Out eFuse Data
                      ScalerEfuseGetData(_EFUSE_M2PLL_N_F_CODE, 4, pucNFvalue);
              
                      ulNFcode = (((DWORD)pucNFvalue[0] << 24) | ((DWORD)pucNFvalue[1] << 16) | ((DWORD)pucNFvalue[2] <<
             - 8) | pucNFvalue[3]);
                      ulNFcode = (ulNFcode == 0) ? _M2PLL_DEFAULT_N_F_CODE : ulNFcode;
              #endif
 341   2      #endif
 342   2      
 343   2              // Dobule Buffer for Prediv, Outputdiv, Bpn
 344   2              ScalerSetBit(P41_03_PLL_IN_CONTROL, ~_BIT0, _BIT0);
 345   2      
 346   2              // Power On LDO
 347   2              ScalerSetBit(P41_09_M2PLL_LDO, ~_BIT7, _BIT7);
 348   2      
 349   2              // Set Icp = 5uA
 350   2              ScalerSetByte(P41_06_M2PLL_0, 0x79);
 351   2      
 352   2              // Set PI current 3.33uA
 353   2              ScalerSetByte(P41_07_M2PLL_1, 0x26);
 354   2      
 355   2              // Set NF code
 356   2              ScalerSetDWord(P41_0D_N_F_CODE_1, ulNFcode);
C51 COMPILER V8.12   SCALERPLL                                                             03/10/2025 13:50:26 PAGE 7   

 357   2      
 358   2              // N.F double buffer
 359   2              ScalerSetBit(P41_0C_N_F_CODE_0, ~_BIT0, _BIT0);
 360   2      
 361   2              // DPLL VCORSTB Set to Normal
 362   2              ScalerSetBit(P41_08_M2PLL_CONTROL, ~_BIT1, (_DPLL_VCORSTB_NORMAL_VALUE << 1));
 363   2      
 364   2              // Disable PI Bypass
 365   2              ScalerSetBit(P41_07_M2PLL_1, ~_BIT2, 0x00);
 366   2      
 367   2              // Power On M2PLL
 368   2              ScalerSetBit(P41_08_M2PLL_CONTROL, ~_BIT0, 0x00);
 369   2      
 370   2              // Wait for M2PLL Stable (1ms)
 371   2              DELAY_XUS(1000);
 372   2          }
 373   1          else
 374   1          {
 375   2              // Power Off M2PLL
