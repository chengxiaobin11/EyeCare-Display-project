 560   1          ScalerTimerPollingFlagProc(2, _REG_DPLL_SSCG_0, _BIT7, 0x00);
 561   1      
 562   1          if((ucSpreadRange != _OFF) &&
 563   1             ((ucDclkSpreadSpeed == _SPEED_33K) || (ucDclkSpreadSpeed == _SPEED_66K)))
 564   1          {
 565   2              // Set SSCG speed
 566   2              BYTE ucSpreadSpeed = (ucDclkSpreadSpeed == _SPEED_33K) ? 33 : 66;
 567   2      
 568   2              // calculate TBase with constant Fref
 569   2              usTBase = (ScalerGetBit(_REG_DPLL_ANALOG_SETTING_0, _BIT4) == _BIT4) ? _EXT_XTAL : (_EXT_XTAL / GE
             -T_N_F_PLL_PREDIVIDER());
