3180   1          // Check PLL lock already
3181   1          if(ScalerTimerPollingFlagProc(150, P1_B8_DDS_MIX_1, _BIT0, _TRUE) == _FALSE)
3182   1          {
3183   2              DebugMessageAnalog("5. APLL Unlock", 0);
3184   2          }
3185   1      
3186   1          return _TRUE;
3187   1      }
