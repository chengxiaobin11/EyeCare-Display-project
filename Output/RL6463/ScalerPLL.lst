 551   1      
 552   1          DWORD ulSSCGStep = 0;
 553   1          WORD usTBase = 0;
 554   1          BYTE ucStepWeighting = 0;
 555   1      
 556   1          // Disable SSCG, Disable SSCG_TBASE_CAL_EN
 557   1          ScalerSetBit(_REG_DPLL_SSCG_0, ~(_BIT7 | _BIT2), 0x00);
