3161   1      
3162   1          // Set G value
3163   1          ScalerSetByte(P1_B6_P_CODE_MAPPING_METHOD, (pucData[0] << 2));
3164   1      
3165   1          // Set P code
3166   1          ScalerSetByte(P1_A3_P_CODE, (BYTE)usPcode);
3167   1      
3168   1          // Intial Phase
3169   1          ScalerSetByte(P1_B4_PLLPHASE_CTRL1, 0x00);
3170   1      
3171   1          // Apply phase write port for phase DB
3172   1          ScalerSetByte(P1_B3_PLLPHASE_CTRL0, ScalerGetByte(P1_B3_PLLPHASE_CTRL0));
3173   1      
