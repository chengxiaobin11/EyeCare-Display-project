 571   2              usTBase = usTBase / ucSpreadSpeed;
 572   2      
 573   2              // TBase must be a multiple of 4
 574   2              usTBase = ((usTBase + 2) >> 2) << 2;
 575   2      
 576   2              // SSCG_TBASE_CAL_EN set manual mode
 577   2              ScalerSetBit(_REG_DPLL_SSCG_0, ~_BIT2, 0x00);
 578   2      
 579   2              ///////////////////////////////////////////////////////////////////////////
 580   2              //
 581   2              // Calculate SSCG range step
 582   2              //
 583   2              // N.F * range = step * (TBASE / 2)
 584   2              // Step = SSCG_step * SSCG_weight, SSCG_step unit: 2^8, SSCG_weight min:1/8
 585   2              // Setp calculate use min unit: 2^8 / 8 = 2^5
