 589   2              ulSSCGStep = ((((DWORD)(ScalerGetDWord(_REG_DPLL_N_F_CODE_0) & 0x0FFFFFFF) >> 5) * 5 * ucSpreadRan
             -ge * 2) / 1000 + (usTBase / 2)) / usTBase;
 590   2      
 591   2              if((ulSSCGStep >> 8) < 1)
 592   2              {
 593   3                  ucStepWeighting = 0;
 594   3              }
 595   2              else if((ulSSCGStep >> 8) < 2)
 596   2              {
 597   3                  ucStepWeighting = 1;
 598   3              }
 599   2              else if((ulSSCGStep >> 8) < 4)
C51 COMPILER V8.12   SCALERPLL                                                             03/10/2025 13:50:26 PAGE 11  

 600   2              {
 601   3                  ucStepWeighting = 2;
 602   3              }
 603   2              else if((ulSSCGStep >> 8) < 8)
 604   2              {
 605   3                  ucStepWeighting = 3;
 606   3              }
 607   2              else if((ulSSCGStep >> 8) < 16)
 608   2              {
 609   3                  ucStepWeighting = 4;
 610   3              }
 611   2              else if((ulSSCGStep >> 8) < 32)
 612   2              {
 613   3                  ucStepWeighting = 5;
