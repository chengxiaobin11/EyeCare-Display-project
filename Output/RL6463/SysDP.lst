              void SysDpMstHandler(void)
              {
                  if(GET_POWER_STATUS() == _POWER_STATUS_NORMAL)
                  {
                      ScalerDpRxMstHandler();
              
                      ScalerDpRxMstStreamsHandler();
              
                      ScalerSyncDpSourceWritePowerUpProc();
              
