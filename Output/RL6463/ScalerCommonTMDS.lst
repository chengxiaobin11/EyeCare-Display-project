              //--------------------------------------------------
              // Description  : TMDS Reset Scdc Info
              // Input Value  : ucInputPort
              // Output Value : None
              //--------------------------------------------------
              void ScalerTMDSHdmiResetScdcInfo(BYTE ucInputPort)
              {
