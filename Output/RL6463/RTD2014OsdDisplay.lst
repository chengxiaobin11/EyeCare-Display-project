4401          WORD OsdDisplayDetOverRange(WORD usValue, WORD usMax, WORD usMin, bit bCycle)
4402          {
4403   1      //if(_OSD_FUN_START<=GET_OSD_STATE() && GET_OSD_STATE()< _OSD_FUN_END)
4404   1      {
4405   2          switch(GET_KEYMESSAGE())
4406   2          {
4407   3              case _RIGHT_KEY_MESSAGE:
4408   3                      case _DOWN_KEY_MESSAGE:
4409   3                  if(usValue >= usMax)
4410   3                  {
4411   4                      if(bCycle == _ON)
4412   4                      {
4413   5                          return usMin;
4414   5                      }
4415   4                      else
4416   4                      {
4417   5                          return usMax;
4418   5                      }
4419   4                  }
4420   3                  else
4421   3                  {
4422   4                      usValue++;
4423   4                  }
4424   3      
4425   3                  break;
4426   3      
4427   3              case _LEFT_KEY_MESSAGE:
4428   3                      case _UP_KEY_MESSAGE:
4429   3                  if (usValue <= usMin)
4430   3                  {
4431   4                      if(bCycle == _ON)
4432   4                      {
4433   5                          return usMax;
4434   5                      }
4435   4                      else
4436   4                      {
4437   5                          return usMin;
4438   5                      }
4439   4                  }
4440   3                  else
4441   3                  {
4442   4                      usValue--;
4443   4                  }
4444   3                  break;
4445   3      
4446   3              default:
4447   3                  break;
C51 COMPILER V8.12   RTD2014OSDDISPLAY                                                     03/10/2025 13:51:05 PAGE 82  

4448   3          }
4449   2      }
4450   1          return usValue;
4451   1      }
