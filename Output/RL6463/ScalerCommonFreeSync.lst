 414          //--------------------------------------------------
 415          // Description  : EDID Analysis Get Ref Timing Info
 416          // Input Value  : usPixelClk/ pstHtotalInfo(Htotal & Htotal margin)
 417          // Output Value : pstEdidRefInfo
 418          //--------------------------------------------------
 419          void ScalerFreeSyncEdidAnalysisGetRefInfo(StructFreeSyncEdidRefInfo *pstEdidRefInfo, WORD usPixelClk, cons
             -t StructFreeSyncSourceInfo *pstSourceInfo)
 420          {
 421   1          WORD usClkMargin = ((DWORD)usPixelClk * _EDID_ANALYSIS_CLK_MARGIN / 100);
 422   1      
 423   1          pstEdidRefInfo->b1RefInterlace = GET_INPUT_TIMING_INTERLACE_FLG();
 424   1          pstEdidRefInfo->usRefHwidth = GET_INPUT_TIMING_HWIDTH();
 425   1          pstEdidRefInfo->usRefVheight = GET_INPUT_TIMING_VHEIGHT();
 426   1          pstEdidRefInfo->usRefHblankHBound = (pstSourceInfo->usHtotal - GET_INPUT_TIMING_HWIDTH() + pstSourceIn
             -fo->usHtotalMargin);
 427   1          pstEdidRefInfo->usRefHblankLBound = (pstSourceInfo->usHtotal - GET_INPUT_TIMING_HWIDTH() - pstSourceIn
             -fo->usHtotalMargin);
 428   1          pstEdidRefInfo->usPixelClkHBound = (usPixelClk + usClkMargin);
 429   1          pstEdidRefInfo->usPixelClkLBound = (usPixelClk - usClkMargin);
 430   1      }
