 305          bit ScalerFreeSyncVfreqMaxInfoEnable(EnumSourceSearchPort enumInputPort, BYTE ucPortType)
 306          {
 307   1          // AMD ver 1 & 2
 308   1          if((ScalerSyncGetAmdVsdbVer(enumInputPort) == _AMD_VER1) ||
 309   1             (ScalerSyncGetAmdVsdbVer(enumInputPort) == _AMD_VER2))
 310   1          {
 311   2              if(GET_FREESYNC_SPD_INFO_FRAME_RECEIVED() == _TRUE)
 312   2              {
 313   3      #if(_HDMI_FREESYNC_SUPPORT == _ON)
 314   3                  if((ucPortType == _PORT_HDMI) || (ucPortType == _PORT_DVI))
 315   3                  {
 316   4                      return GET_HDMI_FREESYNC_ENABLED();
 317   4                  }
 318   3                  else
 319   3      #endif
 320   3                  {
 321   4      #if(_DP_FREESYNC_SUPPORT == _ON)
              #if(_DP_DRR_GET_IVF_TYPE == _DP_DRR_SPD_INFO)
                              if(ucPortType == _PORT_DP)
                              {
                                  return GET_DP_FREESYNC_ENABLED();
                              }
              #endif
              #endif
 329   4                  }
 330   3              }
 331   2              else
 332   2              {
 333   3                  // Gsync
 334   3              }
 335   2          }
 336   1          else
 337   1          {
 338   2              // Version 3 or _AMD_VER_NONE
 339   2          }
 340   1      
 341   1          return _FALSE;
 342   1      }
