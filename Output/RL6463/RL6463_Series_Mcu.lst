 584          //--------------------------------------------------
 585          // Description  : MCU memory init in startup
 586          // Input Value  : None
 587          // Output Value : None
 588          //--------------------------------------------------
 589          #pragma save
 590          #pragma OT(8)
 591          void ScalerMcuMemoryZeroInit(void)
 592          {
 593   1          // Initialize data/idata to 0 in [8 : (SP + 1 - 2)]
 594   1      #if(_DUAL_BANK_SUPPORT == _ON)
              #if((_DUAL_BANK_FLASH_PARTITION_SUPPORT == _ON) && (_DUAL_BANK_FLASH_PARTITION_BOOT_USER_SEL == _DUAL_BANK
             -_FLASH_PARTITION_BOTH))
                  if(GET_CURRENT_BANK_NUMBER() != 0)
                  {
                      memset((volatile BYTE data *)0x08, 0, (0x30 - 0x08));
                      memset((volatile BYTE data *)(0x30 + 1), 0, ((SP - 0x01) - (0x30 + 1)));
                  }
                  else
                  {
                      memset((volatile BYTE data *)0x08, 0, ((SP - 0x01) - 0x08));
                  }
              #elif((_DUAL_BANK_FLASH_PARTITION_SUPPORT == _ON) && (_DUAL_BANK_FLASH_PARTITION_BOOT_USER_SEL == _DUAL_BA
C51 COMPILER V8.12   RL6463_SERIES_MCU                                                     03/10/2025 13:50:46 PAGE 11  

             -NK_FLASH_PARTITION_BOOT))
                  memset((volatile BYTE data *)0x08, 0, ((SP - 0x01) - 0x08));
              #else
                  // for Diff /Copy Bank / Flash Partition User
                  // skip address for _BOOT_BANK_OFFSET_ADDR
                  memset((volatile BYTE data *)0x08, 0, (0x30 - 0x08));
                  memset((volatile BYTE data *)(0x30 + 1), 0, ((SP - 0x01) - (0x30 + 1)));
              #endif
              #else
 614   1          memset((volatile BYTE data *)0x08, 0, ((SP - 0x01) - 0x08));
 615   1      #endif
 616   1      
 617   1      #if(_HW_PC99_SUPPORT == _ON)
 618   1      
 619   1      #if((_A0_EMBEDDED_DDCRAM_LOCATION == _EDID_TABLE_LOCATION_PC99) ||\
 620   1          (_D0_EMBEDDED_DDCRAM_LOCATION == _EDID_TABLE_LOCATION_PC99) ||\
 621   1          (_D1_EMBEDDED_DDCRAM_LOCATION == _EDID_TABLE_LOCATION_PC99))
              
              #if(_A0_EMBEDDED_DDCRAM_MAX_SIZE == _EDID_SIZE_NONE)
                  // A0 Port Xdata Init to 0
                  memset((volatile BYTE xdata *)_EMBEDDED_DDCRAM_VGA_DDC_ADDRESS, 0, 0x80);
              #endif
              
              #if(_D0_EMBEDDED_DDCRAM_MAX_SIZE == _EDID_SIZE_NONE)
                  // D0 Port Xdata Init to 0
                  memset((volatile BYTE xdata *)_EMBEDDED_DDCRAM_DDC0_ADDRESS, 0, 0x100);
              #endif
              
              
              #if(_D1_EMBEDDED_DDCRAM_MAX_SIZE == _EDID_SIZE_NONE)
                  // D1 Port Xdata Init to 0
                  memset((volatile BYTE xdata *)_EMBEDDED_DDCRAM_DDC1_ADDRESS, 0, 0x100);
              #endif
              
                  memset((volatile BYTE xdata *)(_XRAM_ADDR_START + 0x280), 0, (_XRAM_ADDR_END - (_XRAM_ADDR_START + 0x2
             -80) + 1));
              
              #else
 642   1      
 643   1          // Initialize all xdata to 0
 644   1          memset((volatile BYTE xdata *)_XRAM_ADDR_START, 0, (_XRAM_ADDR_END - _XRAM_ADDR_START + 1));
 645   1      
 646   1      #endif
 647   1      
 648   1      #endif // End of #if(_HW_PC99_SUPPORT == _ON)
 649   1      
 650   1      }
