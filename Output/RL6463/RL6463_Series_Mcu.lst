                  BYTE ucDdcChannel = ScalerMcuGetDdcChannelFromInputPort(ucInputPort);
              
                  if(bEn == _DISABLE)
                  {
                      switch(ucDdcChannel)
                      {
                          case _VGA_DDC:
                              MCU_FF1D_ADC_DDC_CONTROL_2 &= ~_BIT4;
                              break;
              
              #if(_D0_DDC_CHANNEL_SEL != _NO_DDC)
                          case _D0_DDC_CHANNEL_SEL:
                              if(_D0_DDC_CHANNEL_SEL == _DDC0)
                              {
                                  MCU_FF20_DDC0_DDC_CONTROL_2 &= ~_BIT4;
                              }
              
                              if(_D0_DDC_CHANNEL_SEL == _DDC1)
                              {
                                  MCU_FF2E_DDC1_DDC_CONTROL_2 &= ~_BIT4;
                              }
              
                              break;
              #endif
              
              #if(_D1_DDC_CHANNEL_SEL != _NO_DDC)
                          case _D1_DDC_CHANNEL_SEL:
                              if(_D1_DDC_CHANNEL_SEL == _DDC0)
                              {
                                  MCU_FF20_DDC0_DDC_CONTROL_2 &= ~_BIT4;
                              }
              
                              if(_D1_DDC_CHANNEL_SEL == _DDC1)
                              {
                                  MCU_FF2E_DDC1_DDC_CONTROL_2 &= ~_BIT4;
                              }
              
                              break;
              #endif
              
                          default:
                              break;
                      }
                  }
                  else
                  {
                      switch(ucDdcChannel)
                      {
                          case _VGA_DDC:
                              MCU_FF1D_ADC_DDC_CONTROL_2 |= _BIT4;
                              break;
              
              #if(_D0_DDC_CHANNEL_SEL != _NO_DDC)
                          case _D0_DDC_CHANNEL_SEL:
                              if(_D0_DDC_CHANNEL_SEL == _DDC0)
                              {
                                  MCU_FF20_DDC0_DDC_CONTROL_2 |= _BIT4;
C51 COMPILER V8.12   RL6463_SERIES_MCU                                                     03/10/2025 13:50:46 PAGE 21  

                              }
              
                              if(_D0_DDC_CHANNEL_SEL == _DDC1)
                              {
                                  MCU_FF2E_DDC1_DDC_CONTROL_2 |= _BIT4;
                              }
              
                              break;
              #endif
              
              #if(_D1_DDC_CHANNEL_SEL != _NO_DDC)
                          case _D1_DDC_CHANNEL_SEL:
                              if(_D1_DDC_CHANNEL_SEL == _DDC0)
                              {
                                  MCU_FF20_DDC0_DDC_CONTROL_2 |= _BIT4;
                              }
              
                              if(_D1_DDC_CHANNEL_SEL == _DDC1)
                              {
                                  MCU_FF2E_DDC1_DDC_CONTROL_2 |= _BIT4;
                              }
              
                              break;
              #endif
              
                          default:
                              break;
                      }
                  }
              }
