 653          //--------------------------------------------------
 654          // Description  : DDC Debounce Settings
 655          // Input Value  : Clock --> _EXT_XTAL_CLK/_IOSC_CLK
 656          // Output Value : None
 657          //--------------------------------------------------
 658          void ScalerMcuDdcDebounceSel(EnumClkSel enumClock)
 659          {
 660   1          enumClock = enumClock;
 661   1      
 662   1          // VGA_DDC De-bounce Reference Clock(IOSC = 28M) div by 4, latch 3 stages
 663   1          MCU_FF1C_ADC_DDC_CONTROL_1 |= (_BIT7 | _BIT6 | _BIT5 | _BIT4);
 664   1      
 665   1          // VGA_DDC2 De-bounce Reference Clock(IOSC = 28M) div by 4, latch 3 stages
C51 COMPILER V8.12   RL6463_SERIES_MCU                                                     03/10/2025 13:50:46 PAGE 12  

 666   1          MCU_FD33_ADC_DDC2_DDC_CONTROL_1 |= (_BIT7 | _BIT6 | _BIT5 | _BIT4);
 667   1      
 668   1      #if(((_D0_INPUT_PORT_TYPE == _D0_DP_PORT) && (_D0_DDC_CHANNEL_SEL == _DDC0)) ||\
 669   1          ((_D1_INPUT_PORT_TYPE == _D1_DP_PORT) && (_D1_DDC_CHANNEL_SEL == _DDC0)))
                  // DDC0 De-bounce Reference Clock(IOSC = 27M) div by 2, latch 1 stages
                  MCU_FF1F_DDC0_DDC_CONTROL_1 &= ~(_BIT7);
                  MCU_FF1F_DDC0_DDC_CONTROL_1 |= (_BIT6 | _BIT4);
              #elif(((_D0_TMDS_SUPPORT == _ON) && (_D0_DDC_CHANNEL_SEL == _DDC0)) ||\
                    ((_D1_TMDS_SUPPORT == _ON) && (_D1_DDC_CHANNEL_SEL == _DDC0)))
                  // DDC0 De-bounce Reference Clock(IOSC = 27M) div by 4, latch 3 stages
                  MCU_FF1F_DDC0_DDC_CONTROL_1 |= (_BIT7 | _BIT6 | _BIT5 | _BIT4);
              #endif
 678   1      
 679   1      #if(((_D0_INPUT_PORT_TYPE == _D0_DP_PORT) && (_D0_DDC_CHANNEL_SEL == _DDC1)) ||\
 680   1          ((_D1_INPUT_PORT_TYPE == _D1_DP_PORT) && (_D1_DDC_CHANNEL_SEL == _DDC1)))
                  // DDC1 De-bounce Reference Clock(IOSC = 27M) div by 2, latch 1 stages
                  MCU_FF2D_DDC1_DDC_CONTROL_1 &= ~(_BIT7);
                  MCU_FF2D_DDC1_DDC_CONTROL_1 |= (_BIT6 | _BIT4);
              #elif(((_D0_TMDS_SUPPORT == _ON) && (_D0_DDC_CHANNEL_SEL == _DDC1)) ||\
