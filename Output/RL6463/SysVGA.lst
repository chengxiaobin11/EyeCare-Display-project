  62          BYTE SysVgaScanInputPort(BYTE ucInputPort)
  63          {
  64   1          BYTE ucModeNo = 0;
  65   1      
  66   1          if(ScalerSyncProcPreDetect(ucInputPort) == _FALSE)
  67   1          {
  68   2              return _SOURCE_NONE;
  69   2          }
  70   1      
  71   1          if(ScalerSyncProcTypeAutoRun() != _NO_SYNC_STATE)
  72   1          {
  73   2              SET_SOURCE_TYPE(g_ucSearchIndex, _SOURCE_VGA);
  74   2      
  75   2              // Initial ADC Clock.
  76   2              if(ScalerSyncProcAdcClkInitial() == _FALSE)
  77   2              {
  78   3                  DebugMessageAnalog("Apll initial Fail", 0);
  79   3      
  80   3                  return _SOURCE_NONE;
  81   3              }
