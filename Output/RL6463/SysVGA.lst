 190          //--------------------------------------------------
 191          // Description  : Modify Timing For Underscan
 192          // Input Value  : None
 193          // Output Value : None
 194          //--------------------------------------------------
 195          void SysVgaAdjustUnderScan(void)
 196          {
 197   1          WORD usUnderScanVHeight = 0;
 198   1      
 199   1          if(UserInterfaceAdjustUnderScan() == _FALSE)
 200   1          {
 201   2              return;
 202   2          }
 203   1      
 204   1          if(GET_INPUT_TIMING_VHEIGHT() < GET_UNDERSCAN_VHEIGHT())
 205   1          {
 206   2              // Adjust VgaTop Vstart for underscan; Default center-positioned
 207   2              usUnderScanVHeight = (GET_UNDERSCAN_VHEIGHT() - GET_INPUT_TIMING_VHEIGHT()) / 2;
 208   2      
 209   2              if(GET_INPUT_TIMING_VSTART() < (usUnderScanVHeight + ScalerIDomainVgipGetVCaptureStartMinValue()))
 210   2              {
 211   3                  SET_INPUT_TIMING_VSTART(usUnderScanVHeight + ScalerIDomainVgipGetVCaptureStartMinValue());
 212   3              }
 213   2      
 214   2              if((GET_INPUT_TIMING_VSTART() + GET_INPUT_TIMING_VHEIGHT() + 3) > GET_INPUT_TIMING_VTOTAL())
 215   2              {
 216   3                  SET_INPUT_TIMING_VSTART(GET_INPUT_TIMING_VTOTAL() - GET_INPUT_TIMING_VHEIGHT() - 3);
 217   3              }
 218   2      
 219   2              ScalerVgaTopSetCaptureVStartPosition(GET_INPUT_TIMING_VSTART() - 2);
 220   2      
 221   2      #if(_ADCNR_SUPPORT == _ON)
 222   2              // Disable ADCNR when underscan
 223   2              ScalerADCNREn(_DISABLE);
 224   2      #endif
 225   2          }
 226   1      }
 227          #endif
