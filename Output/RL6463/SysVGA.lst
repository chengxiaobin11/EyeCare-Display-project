                      if(ucModeNo == _VGA_MODE_NOSUPPORT)
                      {
                          ucModeNo = UserInterfaceModeSearchModeVGA();
                      }
              #endif
 125   2              if(ucModeNo == _VGA_MODE_NOSUPPORT)
 126   2              {
 127   3                  SET_INPUT_TIMING_HWIDTH(0);
 128   3                  SET_INPUT_TIMING_VHEIGHT(0);
 129   3              }
 130   2              else
