 377          //--------------------------------------------------
 378          // Description  : Decide which scaling size
 379          // Input Value  : Input/Output H/V Active Region
 380          // Output Value : None
 381          //--------------------------------------------------
 382          void ScalerScalingUpdateFIFOScalingSize(StructSDRAMDataInfo *pstData)
 383          {
 384   1      #if(_FRC_SUPPORT == _ON)
                  DWORD ulHSDSpace = 0;
                  DWORD ulHSDBW = 0;
              
                  // Clear Double buffer flag
                  SET_MEMORY_FRAME_BUFFER(_MEMORY_1_FRAME_BUFFER);
              #endif // End of #if(_FRC_SUPPORT == _ON)
 391   1      
 392   1          //-----------------------------------------------
 393   1          // Consider FIFO Input / Output H width
 394   1          //-----------------------------------------------
 395   1          if(g_stMDomainInputData.usHWidth > g_stMDomainOutputData.usHWidth)
 396   1          {
 397   2              pstData->usInputHWidth = g_stMDomainOutputData.usHWidth;
C51 COMPILER V8.12   RL6463_SERIES_SCALING                                                 03/10/2025 13:50:49 PAGE 8   

 398   2              pstData->usOutputHWidth = g_stMDomainOutputData.usHWidth;
 399   2          }
 400   1          else
 401   1          {
 402   2              pstData->usInputHWidth = g_stMDomainInputData.usHWidth;
 403   2              pstData->usOutputHWidth = g_stMDomainInputData.usHWidth;
 404   2          }
 405   1      
 406   1          //-----------------------------------------------
 407   1          // Consider FIFO Input / Output V Height
 408   1          //-----------------------------------------------
 409   1          if(g_stMDomainInputData.usVHeight > g_stMDomainOutputData.usVHeight)
 410   1          {
 411   2              pstData->usInputVHeight = g_stMDomainOutputData.usVHeight;
 412   2              pstData->usOutputVHeight = g_stMDomainOutputData.usVHeight;
 413   2          }
 414   1          else
 415   1          {
 416   2              pstData->usInputVHeight = g_stMDomainInputData.usVHeight;
 417   2              pstData->usOutputVHeight = g_stMDomainInputData.usVHeight;
 418   2          }
 419   1      
 420   1      #if(_FRC_SUPPORT == _ON)
                  //-----------------------------------------------
                  // Consider FIFO Input / Output H width in FRC
                  //-----------------------------------------------
                  if(GET_MEMORY_CONFIG() == _MEMORY_WORK_MODE)
                  {
              #if(_DP_FREESYNC_SUPPORT == _ON)
                      if((GET_DP_FREESYNC_ENABLED() == _TRUE) && (GET_FREESYNC_SPD_INFO_FRAME_RECEIVED() == _FALSE))
                      {
                          ulHSDBW = (DWORD)_MEMORY_TOTAL_BW * 100000 / GET_MEMORY_DATA_BIT() * _MEMORY_BUS_WIDTH /
                                    ((((DWORD)g_stMDomainInputData.usHFreq * 1000) +
                                      ((DWORD)g_stMDomainOutputData.usVTotal * g_usDVFreq) +
                                      ((DWORD)g_stMDomainOutputData.usVTotal * g_usDVFreq * ((_DCLK_SPREAD_RANGE / _DPLL
             -_SSCG_DIV_MODE) + _DCLK_SPREAD_RANGE_MARGIN) / 4 / 100)) / 10 + 1);
                      }
                      else
              #endif
                      {
                          ulHSDBW = (DWORD)_MEMORY_TOTAL_BW * 100000 / GET_MEMORY_DATA_BIT() * _MEMORY_BUS_WIDTH /
                                    ((((DWORD)g_stMDomainInputData.usVTotal * g_stMDomainInputData.usVFreq) +
                                      ((DWORD)g_stMDomainOutputData.usVTotal * g_usDVFreq) +
                                      ((DWORD)g_stMDomainOutputData.usVTotal * g_usDVFreq * ((_DCLK_SPREAD_RANGE / _DPLL
             -_SSCG_DIV_MODE) + _DCLK_SPREAD_RANGE_MARGIN) / 4 / 100)) / 10 + 1);
                      }
              
                      ulHSDSpace = ScalerComputeDwordMulDiv(((DWORD)_MEMORY_ROW * _MEMORY_BANK), ((DWORD)_MEMORY_COL_PER
             -_BANK * _MEMORY_BIT_NUM), ((DWORD)GET_MEMORY_DATA_BIT() * pstData->usInputVHeight));
              
                      // Margin (unit: pixel)
                      ulHSDSpace -= 0x10;
              
                      ulHSDSpace = ((ulHSDSpace > ulHSDBW) ? (ulHSDBW) : (ulHSDSpace));
              
                      if(pstData->usInputHWidth > ulHSDSpace)
                      {
                          pstData->usInputHWidth = ulHSDSpace;
                      }
              
                      DebugMessageFRC("ulHSDSpace", ulHSDSpace);
                      DebugMessageFRC("ulHSDBW", ulHSDBW);
C51 COMPILER V8.12   RL6463_SERIES_SCALING                                                 03/10/2025 13:50:49 PAGE 9   

                  } // End of if(GET_MEMORY_CONFIG() == _MEMORY_WORK_MODE)
              
                  // Let HWidth be multiple of 2.
                  pstData->usInputHWidth -= (pstData->usInputHWidth % 2);
                  pstData->usOutputHWidth = pstData->usInputHWidth;
              
              #endif // End of #if(_FRC_SUPPORT == _ON)
 464   1      }
