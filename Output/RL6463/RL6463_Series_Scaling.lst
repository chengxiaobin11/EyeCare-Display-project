 467          // Description  : Decide which scaling size
 468          // Input Value  : Input/Output H/V Active Region
 469          // Output Value : None
 470          //--------------------------------------------------
 471          void ScalerScalingGetFIFOScalingSize(StructSDRAMDataInfo *pstData)
 472          {
 473   1          ScalerScalingUpdateFIFOScalingSize(pstData);
 474   1      }
