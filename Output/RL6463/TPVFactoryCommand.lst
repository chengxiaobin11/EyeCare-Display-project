1785   2          }
1786   1      
1787   1          g_pucDdcciTxBuf[_DDCCI_SOURCE] = _DDCCI_DEST_ADDRESS;
1788   1          g_pucDdcciTxBuf[_DDCCI_LENGTH] = _DDCCI_CONTROL_STATUS_FLAG | 0x03;
1789   1          g_pucDdcciTxBuf[_DDCCI_COMMAND] = ucResult;
1790   1          g_pucDdcciTxBuf[3] = (BYTE)((usCRC&0xff00)>>8);
