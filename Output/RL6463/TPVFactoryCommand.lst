1752          // Input Value  : None
1753          // Output Value : CRC
1754          //--------------------------------------------------
1755          WORD TPVFCCrc16(BYTE nData, WORD nCRC)
1756          {
1757   1          BYTE nMask;
1758   1          bit fFeedback;
1759   1          for (nMask= 0x80; nMask; nMask >>= 1)
1760   1          {
1761   2              fFeedback= (bit)(((nCRC & 0x8000) ? 1 : 0) ^ ((nMask & nData) ? 1 : 0));
1762   2              nCRC <<= 1;
1763   2              if (fFeedback)
1764   2              {
1765   3                  nCRC ^= 0x1021;
1766   3              }
1767   2          }
1768   1      
1769   1          return nCRC;
1770   1      }
