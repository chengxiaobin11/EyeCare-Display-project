              void ScalerAudioDPDigitalOutputProc(bit bEnable, BYTE ucInputPort)
              {
              #if(_LINE_IN_SUPPORT == _ON)
                  if(ScalerAudioGetDigitalAudioPort(_AUDIO_DAC_OUT) != _AUDIO_FROM_ADC_PORT)
              #endif
                  {
                      switch(ucInputPort)
                      {
