 179          //--------------------------------------------------
 180          // Description  : Check Audio whether Audio LPCM By Audio Data
 181          // Input Value  : ucSourceType
 182          // Output Value : _TRUE => LPCM
 183          //--------------------------------------------------
 184          bit ScalerAudioLPCMCheckData(void)
 185          {
 186   1          switch(ScalerAudioGetDigitalAudioPort(_AUDIO_DAC_OUT))
 187   1          {
 188   2              case _AUDIO_FROM_D0_PORT:
 189   2              case _AUDIO_FROM_D1_PORT:
 190   2      
 191   2                  if(GET_REG_D0_MAC_SWITCH_TO_HDMI() == _TRUE)
 192   2                  {
 193   3                      if(ScalerGetBit(P2_CB_HDMI_SR, _BIT4) == 0x00)
 194   3                      {
 195   4                          return _TRUE;
 196   4                      }
 197   3                      else
 198   3                      {
 199   4                          return _FALSE;
 200   4                      }
 201   3                  }
 202   2                  else
 203   2                  {
 204   3                      // Check Audio Packet
 205   3                      if(ScalerAudioD0GetAudioDetected() == _FALSE)
 206   3                      {
 207   4                          // Reset Coding Type Detect
 208   4                          SET_DP_D0_AUDIO_CODING_TYPE_FORMAT(_AUDIO_CODING_TYPE_NONE);
 209   4      
 210   4                          return _FALSE;
 211   4                      }
 212   3      
 213   3      
 214   3                      // Check First Time Check or Coding Type Change before Playback
 215   3                      if((GET_DP_D0_AUDIO_CODING_TYPE_FORMAT() == _AUDIO_CODING_TYPE_NONE) ||
 216   3                         ((ScalerGetBit(PB6_3B_DP_IRQ_CTRL1, _BIT0) == 0x00) && (ScalerGetBit(PB6_36_DP_GLB_STAT
             -US, _BIT2) == _BIT2)))
 217   3                      {
 218   4                          // =================================
 219   4                          // Flag Reset
 220   4                          // =================================
 221   4      
 222   4                          // Disable Audio Coding Type Change INT
 223   4                          ScalerSetBit(PB6_3B_DP_IRQ_CTRL1, ~_BIT0, 0x00);
 224   4      
 225   4                          // Clear Audio Coding Type Change Flag
 226   4                          ScalerSetBit(PB6_36_DP_GLB_STATUS, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _
             -BIT1), _BIT2);
 227   4      
 228   4      
 229   4                          // =================================
 230   4                          // Detect Coding Type at First Time
C51 COMPILER V8.12   RL6463_SERIES_AUDIO                                                   03/10/2025 13:50:42 PAGE 5   

 231   4                          // =================================
 232   4      
 233   4                          DebugMessageAudio("[Audio] Rx0 Coding Type First Time Detect", 0);
 234   4      
 235   4      
 236   4                          // ---------------------------------
 237   4                          // Valid_Bit Detect at First
 238   4                          // ---------------------------------
 239   4      
 240   4                          // Set Audio Coding Type Source to Valid_Bit
 241   4                          ScalerSetBit(PB6_B0_DP_AUD_CTRL, ~_BIT5, _BIT5);
 242   4      
 243   4                          // Update Detect Result
 244   4                          if(ScalerGetBit(PB6_B0_DP_AUD_CTRL, _BIT4) == 0x00)
 245   4                          {
 246   5                              DebugMessageAudio("[Audio] Rx0 initial at LPCM via Valid_Bit", 0);
 247   5      
 248   5                              SET_DP_D0_AUDIO_CODING_TYPE_FORMAT(_AUDIO_LPCM);
 249   5                          }
 250   4                          else
 251   4                          {
 252   5                              WORD usDelayTime = 12;
 253   5                              EnumAudioSamplingFreqType enumAudioFreq = ScalerAudioD0SamplingFreqDetect();
 254   5                              EnumAudioSamplingFreqPacket enumAudioPacket = ScalerAudioGetSamplingFreqPacket(enu
             -mAudioFreq);
 255   5      
 256   5                              // -----------------------------
 257   5                              // Channel Status Detect Flow
 258   5                              // -----------------------------
 259   5      
 260   5                              // Set Audio Coding Type Source to Channel_Status
 261   5                              ScalerSetBit(PB6_B0_DP_AUD_CTRL, ~_BIT5, 0x00);
 262   5      
 263   5                              // Calculate Minimum Delay for Receiving 192*2 Audio Samples
 264   5                              // Avoid 0Hz Value
 265   5                              if(enumAudioPacket == _AUDIO_FREQ_PACKET_NO_AUDIO)
 266   5                              {
 267   6                                  enumAudioPacket = _AUDIO_FREQ_PACKET_32K;
 268   6                              }
 269   5      
 270   5                              // (192Samples * 2) / AudioFreq
 271   5                              usDelayTime = (192 * 2) / enumAudioPacket;
 272   5      
 273   5                              // Delay with 2ms margin added
 274   5                              ScalerTimerDelayXms(usDelayTime + 2);
 275   5      
 276   5                              // Update Detect Result
 277   5                              if(ScalerGetBit(PB6_B0_DP_AUD_CTRL, _BIT4) == _BIT4)
 278   5                              {
 279   6                                  DebugMessageAudio("[Audio] Rx0 initial at Non-LPCM via Channel_Status", 1);
 280   6      
 281   6                                  SET_DP_D0_AUDIO_CODING_TYPE_FORMAT(_AUDIO_NON_LPCM);
 282   6                              }
 283   5                              else
 284   5                              {
 285   6                                  DebugMessageAudio("[Audio] Rx0 initial at LPCM via Channel_Status", 0);
 286   6      
 287   6                                  SET_DP_D0_AUDIO_CODING_TYPE_FORMAT(_AUDIO_LPCM);
 288   6                              }
 289   5                          }
 290   4                      }
 291   3      
C51 COMPILER V8.12   RL6463_SERIES_AUDIO                                                   03/10/2025 13:50:42 PAGE 6   

 292   3                      // =================================
 293   3                      // Return Coding Type Status
 294   3                      // =================================
 295   3                      if(GET_DP_D0_AUDIO_CODING_TYPE_FORMAT() == _AUDIO_NON_LPCM)
 296   3                      {
 297   4                          return _FALSE;
 298   4                      }
 299   3      
 300   3                      return _TRUE;
 301   3                  }
 302   2      
 303   2                  break;
 304   2      
 305   2              default:
 306   2                  break;
 307   2          }
 308   1      
 309   1          return _TRUE;
 310   1      }
