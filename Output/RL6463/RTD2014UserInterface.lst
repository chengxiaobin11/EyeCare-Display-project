                  for(ucIndex = 0; ucIndex < (sizeof(tDrrVrrHdmiTimingInfo) / sizeof(tDrrVrrHdmiTimingInfo[0])); ucIndex
             -++)
                  {
                      if((GET_HDMI_VRR_IHWIDTH(ucIndex) == GET_INPUT_TIMING_HWIDTH()) && (GET_HDMI_VRR_IVHEIGHT(ucIndex)
             - == GET_INPUT_TIMING_VHEIGHT()) &&
                         ((GET_HDMI_VRR_IHTOTAL(ucIndex) <= usRefHtotalHBound) && (GET_HDMI_VRR_IHTOTAL(ucIndex) >= usRe
             -fHtotalLBound)) &&
                         ((GET_HDMI_VRR_ICLK(ucIndex) <= usPixelClkHBound) && (GET_HDMI_VRR_ICLK(ucIndex) >= usPixelClkL
             -Bound)))
                      {
                          *pusVfreqMax = GET_HDMI_VRR_IVFREQ(ucIndex);
              
                          DebugMessageScaler("ucIndex if Drr user define timing ", ucIndex);
                          return _HDMI21_VRR_WITH_IVF_MAX;
                      }
                  }
              
                  *pusVfreqMax = 0;
                  return _HDMI21_VRR_WITHOUT_IVF_MAX;
              }
