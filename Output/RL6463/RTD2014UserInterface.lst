             -Index) == GET_INPUT_TIMING_VHEIGHT()) &&
                         ((GET_DP_FREESYNC_IHTOTAL(ucIndex) <= usRefHtotalHBound) && (GET_DP_FREESYNC_IHTOTAL(ucIndex) >
             -= usRefHtotalLBound)) &&
