  49          // Description  : Sdram ScalerSdramPowerMode
  50          // Input Value  : None
  51          // Output Value : None
  52          //--------------------------------------------------
  53          void ScalerSdramPowerEnable(bit bOn)
  54          {
  55   1          if(bOn == _ON)
  56   1          {
  57   2              // Config for SDRAM MCM Mde
  58   2              ScalerSetBit(P4_00_SDR_CTRL, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
  59   2      
  60   2              // Disable Sdram CKE force low into Power down mode
  61   2              ScalerSetBit(P4_A6_SDR_SLEW_RATE, ~_BIT1, 0x00);
  62   2      
  63   2              // Precharge power down mode select
  64   2              ScalerSetBit(P4_B7_SDR_POWER_CTRL0, ~(_BIT5 | _BIT4), 0x00);
  65   2      
  66   2              // Delay Time us [5,x] Waiting for DDR setting
  67   2              DELAY_5US();
  68   2      
  69   2              // Inactive power down
  70   2              ScalerSetBit(P4_B7_SDR_POWER_CTRL0, ~_BIT7, 0x00);
  71   2          }
  72   1          else
  73   1          {
  74   2              // Config for SDRAM MCM Mde
  75   2              ScalerSetBit(P4_00_SDR_CTRL, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
  76   2      
  77   2              // Self Refresh mode select
  78   2              ScalerSetBit(P4_B7_SDR_POWER_CTRL0, ~(_BIT5 | _BIT4), (_BIT5 | _BIT4));
  79   2      
  80   2              // Delay Time us [5,x] Waiting for DDR setting
  81   2              DELAY_5US();
  82   2      
  83   2              // Active power down
  84   2              ScalerSetBit(P4_B7_SDR_POWER_CTRL0, ~_BIT7, _BIT7);
  85   2      
  86   2              // Enable Sdram CKE force low into Power down mode
  87   2              ScalerSetBit(P4_A6_SDR_SLEW_RATE, ~_BIT1, _BIT1);
  88   2      
  89   2              // Config for Non-SDRAM MCM Mde
  90   2              ScalerSetBit(P4_00_SDR_CTRL, ~(_BIT1 | _BIT0), 0x00);
  91   2          }
  92   1      }
  93          
  94          //--------------------------------------------------
  95          // Description  : Sdram Pinshare Initial
  96          // Input Value  : None
  97          // Output Value : None
  98          //--------------------------------------------------
  99          void ScalerSdramPinshareInitial(void)
 100          {
 101   1          ScalerSetByte(P4_01_SDR_CLK_CTRL0, 0x00);
 102   1          ScalerSetByte(P4_02_SDR_CMD_CTRL, 0x00);
 103   1          ScalerSetByte(P4_03_SDR_DQ_CTRL0, 0x00);
 104   1          ScalerSetByte(P4_04_SDR_DQ_CTRL1, 0x00);
 105   1          ScalerSetByte(P4_05_SDR_ADR_CTRL, 0x00);
 106   1          ScalerSetByte(P4_06_SDR_DQM_CTRL, 0x00);
 107   1      }
