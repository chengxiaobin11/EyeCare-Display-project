             -Y_PAGE_0, tFONT_FACTORY_EUROPE, pData, _ENGLISH);
                       //Panel Size
                      // GetEDIDPanelSize(pDDCRAMData);
                      // RTDFactoryOsdFuncPutStringProp(ROW(_FACTORY_EDID_INFO_ROW), COL(_FACTORY_EDID_INFO_COL), _PFONT_FACTOR
             -Y_PAGE_0, tFONT_FACTORY_EUROPE, pData, _ENGLISH);
                       
                       //Panel Resolution
                   GetEDIDProductName(pDDCRAMData);
                       RTDFactoryOsdFuncPutStringProp(ROW(_FACTORY_EDID_INFO_ROW), COL(_FACTORY_EDID_INFO_COL), _PFONT_FACTORY_
             -PAGE_0, tFONT_FACTORY_EUROPE, pData, _ENGLISH);
