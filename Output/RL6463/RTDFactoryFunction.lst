              void GetEDIDPanelSize(BYTE *pDDCRAMData)
              {
                      BYTE idata H_Low8,V_Low8,H_high4,V_high4;
                      WORD idata inch,Hor,Ver;                
                      DWORD idata  xx;
                      
                              //------VGA------------------------------
                              H_Low8 = pDDCRAMData[0x42];
                              V_Low8 = pDDCRAMData[0x43];
                      
