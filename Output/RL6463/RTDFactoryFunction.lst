                       GetOSDEDIDResult(pDDCRAMData,PortTyp);
                       RTDFactoryOsdFuncPutStringProp(ROW(_FACTORY_EDID_INFO_ROW), COL(_FACTORY_EDID_INFO_COL), _PFONT_FACTORY_
             -PAGE_0, tFONT_FACTORY_EUROPE, pData, _ENGLISH);
                       
                       //EDID CheckSum
                       GetEDIDCheckSum(pDDCRAMData);
                       RTDFactoryOsdFuncPutStringProp(ROW(_FACTORY_EDID_INFO_ROW), COL(_FACTORY_EDID_INFO_COL), _PFONT_FACTORY_
             -PAGE_0, tFONT_FACTORY_EUROPE, pData, _ENGLISH);
