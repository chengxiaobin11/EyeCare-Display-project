                              Hor = ((H_high4 << 8) + H_Low8);
                              Ver = ((V_high4 << 8) + V_Low8);
                      
                              xx =(float)(Hor) * (float)(Hor)+(float)(Ver) * (float) (Ver);
                                 
                                      
                                 inch= sqrt(xx)/0.254;        
                      
                               if(inch%10>=5)
C51 COMPILER V8.12   RTDFACTORYFUNCTION                                                    03/10/2025 13:51:10 PAGE 73  

                                      inch=inch/10+1;
                               else
                                      inch=inch/10;           
                      
                                      if(inch==241)
                                      inch=240;
                                      
                              pData[0]=_S__;
                              pData[1]=_I__;
                              pData[2]=_Z__;
                              pData[3]=_E__;
                              pData[4]=_COLON__;
                              pData[5]=__;
                              pData[6]=inch/100+_0__;
                              pData[7]=inch%100/10+_0__;
                              pData[8]=_DOT__;
                              pData[9]=inch%10+_0__;
                              pData[10]=__;
                              pData[11]=_I__;
                              pData[12]=_n__;
                              pData[13]=_c__;
                              pData[14]=_h__;
                              pData[15]=_END_;
              
              }
              
