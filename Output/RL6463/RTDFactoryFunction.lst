                      Hactive = H_high4 ;
                      Hactive = ((Hactive *256))+ H_Low8;
              
                      Vactive = V_high4 ;
                      Vactive = ((Vactive *256))+ V_Low8;
              
                      for(i=0;i<9;i++)
                      {
                        pData[i]=__;
