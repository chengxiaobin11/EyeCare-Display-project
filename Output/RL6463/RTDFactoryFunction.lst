5304          void RTDFactoryOsdFuncShowChecksum(BYTE ucRow, BYTE ucCol, BYTE ucPar ,BYTE ucFontPoint)
5305          {
5306   1                              BYTE h,l,t,h1,l1;
5307   1                              BYTE idata ucIndex = 0;
5308   1                              BYTE idata ucTemp = 0;
5309   1                              BYTE idata i = 0;
5310   1                              // BYTE xdata pData[7] = {0};
5311   1                              WORD usValue =  0;
5312   1                              UserCommonFlashRead(1, 0xfffe, 2, (BYTE *)&usValue);
5313   1                              ucPar= ucPar;
5314   1      
5315   1                              pData[0]=_0__;
5316   1                              pData[1]=_0__;
5317   1      
5318   1                              t =(usValue & 0x0f);
5319   1                              if(t < 10)
5320   1                              l = t +_0__;
5321   1                              else
5322   1                              l = t -10+ _A__;
5323   1      
5324   1                              t = (usValue >> 4) & 0x0f;
5325   1                              if(t < 10)
5326   1                              h = t +_0__;
5327   1                              else
5328   1                              h = t -10+_A__;
5329   1      
5330   1                              t = (usValue >> 8) & 0x0f;
5331   1                              if(t < 10)
5332   1                              l1 = t +_0__;
5333   1                              else
5334   1                              l1 = t -10+_A__;
5335   1      
5336   1                              t = (usValue >> 12) & 0x0f;
5337   1                              if(t < 10)
5338   1                              h1 = t +_0__;
5339   1                              else
5340   1                              h1 = t -10+_A__;
5341   1      
5342   1                              pData[3]=l ;
5343   1                              pData[2]=h;
5344   1                              pData[1]=l1 ;
5345   1                              pData[0]=h1 ;
5346   1      
5347   1                              pData[4] = _END_;
5348   1      
5349   1                              RTDFactoryOsdFuncPutStringProp(ucRow, ucCol, ucFontPoint, tFONT_FACTORY_EUROPE, pData, _ENGLISH);       
5350   1      
5351   1                               
5352   1      }
