                          PDATA_WORD(1) = _PANEL_DH_WIDTH;
                          PDATA_WORD(2) = _PANEL_DV_START;
                          PDATA_WORD(3) = _PANEL_DV_HEIGHT;
              
                          // Calculate / Set Display Window H
