 231          //--------------------------------------------------
 232          // Description  : Check if the ADC clock (IHTotal) is out of range. Range = (BackPorch + FrontPorch) * 2 /
             - 5 .
 233          // Input Value  : usClock   --> ADC Clock (IHTotal)
 234          // Output Value : Return _TRUE if not out of range
 235          //--------------------------------------------------
 236          WORD UserCommonAdjustGetAdcClockRange(BYTE ucPar)
 237          {
 238   1          WORD usDelta1 = 0;
 239   1          WORD usDelta2 = 0;
 240   1          WORD usDelta = 0;
 241   1      
 242   1          usDelta1 = GET_ADC_LIMIT_CLOCK() - g_stVGAModeUserData.usCenterClock;
 243   1      
 244   1          usDelta2 = g_stVGAModeUserData.usCenterClock - ScalerVgaTopGetCaptureHStartPosition() - ScalerVgaTopGe
             -tCaptureHWidth();
 245   1      
 246   1          usDelta = (usDelta1 < usDelta2) ? usDelta1 : usDelta2;
 247   1      
 248   1          if(ucPar == _GET_CLOCKRANGE_MAX)
 249   1          {
 250   2              if(usDelta < _CLOCK_BIAS)
 251   2              {
 252   3                  return (g_stVGAModeUserData.usCenterClock + usDelta);
 253   3              }
 254   2              else
 255   2              {
 256   3                  return (g_stVGAModeUserData.usCenterClock + _CLOCK_BIAS);
 257   3              }
 258   2          }
 259   1          else if(ucPar == _GET_CLOCKRANGE_MIN)
 260   1          {
 261   2              if(usDelta < _CLOCK_BIAS)
 262   2              {
 263   3                  return (g_stVGAModeUserData.usCenterClock - usDelta);
 264   3              }
 265   2              else
 266   2              {
 267   3                  return (g_stVGAModeUserData.usCenterClock - _CLOCK_BIAS);
 268   3              }
 269   2          }
 270   1      
 271   1          return (g_stVGAModeUserData.usCenterClock);
 272   1      }
