C51 COMPILER V8.12   USERCOMMONADJUST                                                      03/10/2025 13:50:51 PAGE 47  

              // Input Value  : usDHStart, usDHEnd, ucColor
              // Output Value : void
              //--------------------------------------------------
              void UserCommonAdjustColorSetAutoMeasure(BYTE ucColor)
              {
                  ScalerMeasureDynamicColorSetAutoMeasure(ucColor);
              }
              
              //--------------------------------------------------
              // Description  : Get Auto measure value for dynamic crosshair color
              // Input Value  : usDHStart, usDHEnd, ucColor, bWait
              // Output Value : _TRUE if auto-function measure passed
              //--------------------------------------------------
              bit UserCommonAdjustColorGetDynamicColorMeasureResult(BYTE *pucMeasureResult, bit bWait)
              {
                  StructAutoActiveData stAutoData;
                  memset(&stAutoData, 0, sizeof(stAutoData));
              
                  if(ScalerMeasureDynamicColorGetResult(&stAutoData.ucColorAverageValue, bWait) == _FALSE)
                  {
                      return _FALSE;
                  }
              
                  *pucMeasureResult = stAutoData.ucColorAverageValue;
              
                  return _TRUE;
              }
              #endif
