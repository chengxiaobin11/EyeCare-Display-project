                  ScalerMDomainFREESYNCODSetDisplayFormat(((WORD)_PANEL_DH_TOTAL), ((DWORD)_PANEL_PIXEL_CLOCK_MAX_KHZ), 
             -((WORD)_PANEL_FREESYNC_MIN_FRAME_RATE));
              
                  while(_TRUE)
                  {
                      ScalerDebug();
                      ScalerDDomainFREESYNCODSetBackgroundGrayLevel();
                  }
              }
