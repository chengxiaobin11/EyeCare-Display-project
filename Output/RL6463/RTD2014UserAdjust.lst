                              // Display V background start setting
                              ScalerMDomainSetDisplayTimingGenBackgroundVStart(HIBYTE(usDVBGstart), LOBYTE(usDVBGstart),
             - _DB_APPLY_POLLING);
                              // Display V background end setting
