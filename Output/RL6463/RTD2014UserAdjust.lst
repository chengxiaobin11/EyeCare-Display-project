              //--------------------------------------------------
              void UserAdjustFREESYNCODMeasure(void)
              {
                  // Set Backlight
                  UserAdjustBacklight(100);
              
                  // Enable Backlight
                  UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
              
                  // Disable OSD
                  ScalerOsdDisableOsd();
              
                  // Disable D-domain Pattern Gen.
