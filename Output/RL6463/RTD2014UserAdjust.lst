             -PPLY_POLLING);
                              break;
              
                          default:
                              break;
                      }
                  }
              
                  ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
                  ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
                  ScalerMDomainSetCaptureWindowEnable(_DISABLE);
