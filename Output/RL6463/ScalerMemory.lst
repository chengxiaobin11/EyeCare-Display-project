 101          void ScalerMemorySetScalingCoef(BYTE code *pucAddress1, BYTE code *pucAddress2, BYTE ucBankNum)
 102          {
 103   1          ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
 104   1      
 105   1          // Set Coefficient table 1
 106   1          ScalerSetBit(P0_35_FILTER_CONTROL_REG, ~(_BIT7 | _BIT6), _BIT7);
 107   1          ScalerBurstWrite(pucAddress1, _SHARPNESS_TABLE_SIZE, ucBankNum, P0_36_USER_DEF_FILTER_ACCESS_PORT, _BU
             -RSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
 108   1      
C51 COMPILER V8.12   SCALERMEMORY                                                          03/10/2025 13:50:25 PAGE 3   

 109   1          // Set Coefficient table 2
 110   1          ScalerSetBit(P0_35_FILTER_CONTROL_REG, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 111   1          ScalerBurstWrite(pucAddress2, _SHARPNESS_TABLE_SIZE, ucBankNum, P0_36_USER_DEF_FILTER_ACCESS_PORT, _BU
             -RSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
 112   1      
 113   1      
 114   1          // Disable Coefficient Access, Set HSU to use coefficient table 1 & set VSU to use coefficient table 2
 115   1          ScalerSetBit(P0_35_FILTER_CONTROL_REG, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), _BIT4);
 116   1      }
