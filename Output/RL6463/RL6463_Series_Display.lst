 298          //--------------------------------------------------
 299          // Description  : Set Dual Port LVDS Clk Infomation: CLK set 80ohm as Termination On / CLK set current 2x 
             -as Termination Off
 300          // Input Value  : None
 301          // Output Value : None
 302          //--------------------------------------------------
 303          void ScalerDisplayLvdsClkInfoSelect(void)
 304          {
 305   1          // Set LVDS Output Termination 50ohm Initially
 306   1          ScalerSetByte(P15_27_LVDS_PORTA_CTRL7, 0xFF);
 307   1          ScalerSetByte(P15_28_LVDS_PORTA_CTRL8, 0xFF);
 308   1          ScalerSetByte(P15_37_LVDS_PORTB_CTRL7, 0xFF);
 309   1          ScalerSetByte(P15_38_LVDS_PORTB_CTRL8, 0xFF);
 310   1      
 311   1          // Dual Port LVDS: CLK set 80ohm as Termination on, CLK set current 2x as Termination Off
 312   1      #if(_LVDS_OUTPUT_PORT == _LVDS_2_PORT)
 313   1      #if(_LVDS_PAIR_MIRROR == _DISABLE)
 314   1      
 315   1          // Set LVDS TXBC Output Termination 80ohm
 316   1          ScalerSetBit(P15_38_LVDS_PORTB_CTRL8, ~(_BIT5 | _BIT4), 0x00);
 317   1      
 318   1          // Set LVDS TXBC Current 2x
 319   1          ScalerSetBit(P15_30_LVDS_PORTB_CTRL0, ~_BIT3, _BIT3);
 320   1      
 321   1      #else // Else of #if(_LVDS_PAIR_MIRROR == _DISABLE)
              
                  // Set LVDS TXB1 Output Termination 80ohm
                  ScalerSetBit(P15_37_LVDS_PORTB_CTRL7, ~(_BIT1 | _BIT0), 0x00);
              
                  // Set LVDS TXB1 Current 2x
                  ScalerSetBit(P15_30_LVDS_PORTB_CTRL0, ~_BIT1, _BIT1);
              
              #endif // End of #if(_LVDS_PAIR_MIRROR == _DISABLE)
 330   1      
 331   1      #if(_LVDS_TERMINATION_CONTROL == _ENABLE)
              
                  // Disable LVDS TXB Current 2x
                  ScalerSetByte(P15_30_LVDS_PORTB_CTRL0, 0x00);
              
              #endif // End of #if(_LVDS_TERMINATION_CONTROL == _DISABLE)
 337   1      #endif // End of #if(_LVDS_OUTPUT_PORT == _LVDS_2_PORT)
 338   1      
 339   1      #if(_LVDS_SETTING_CONTROL_BY_USER == _ENABLE)
              
                  // Set LVDS TXA Current 2x
                  ScalerSetBit(P15_20_LVDS_PORTA_CTRL0, ~_BIT4, (_LVDS_PORTA_DATA3_DRIV_2X_USER_CTRL) << 4);
                  ScalerSetBit(P15_20_LVDS_PORTA_CTRL0, ~_BIT2, (_LVDS_PORTA_DATA2_DRIV_2X_USER_CTRL) << 2);
                  ScalerSetBit(P15_20_LVDS_PORTA_CTRL0, ~_BIT1, (_LVDS_PORTA_DATA1_DRIV_2X_USER_CTRL) << 1);
                  ScalerSetBit(P15_20_LVDS_PORTA_CTRL0, ~_BIT0, (_LVDS_PORTA_DATA0_DRIV_2X_USER_CTRL) << 0);
C51 COMPILER V8.12   RL6463_SERIES_DISPLAY                                                 03/10/2025 13:50:43 PAGE 7   

              
                  // Set LVDS TXB Current 2x
                  ScalerSetBit(P15_30_LVDS_PORTB_CTRL0, ~_BIT4, (_LVDS_PORTB_DATA3_DRIV_2X_USER_CTRL) << 4);
                  ScalerSetBit(P15_30_LVDS_PORTB_CTRL0, ~_BIT3, (_LVDS_PORTB_CLK_DRIV_2X_USER_CTRL) << 3);
                  ScalerSetBit(P15_30_LVDS_PORTB_CTRL0, ~_BIT2, (_LVDS_PORTB_DATA2_DRIV_2X_USER_CTRL) << 2);
                  ScalerSetBit(P15_30_LVDS_PORTB_CTRL0, ~_BIT1, (_LVDS_PORTB_DATA1_DRIV_2X_USER_CTRL) << 1);
                  ScalerSetBit(P15_30_LVDS_PORTB_CTRL0, ~_BIT0, (_LVDS_PORTB_DATA0_DRIV_2X_USER_CTRL) << 0);
              
                  // Set LVDS TXA Output Termination
                  ScalerSetBit(P15_27_LVDS_PORTA_CTRL7, ~(_BIT3 | _BIT2), (_LVDS_PORTA_DATA0_TERM_USER_ADJUST & 0x03) <<
             - 2);
                  ScalerSetBit(P15_27_LVDS_PORTA_CTRL7, ~(_BIT1 | _BIT0), (_LVDS_PORTA_DATA1_TERM_USER_ADJUST & 0x03) <<
             - 0);
              
                  ScalerSetBit(P15_28_LVDS_PORTA_CTRL8, ~(_BIT7 | _BIT6), (_LVDS_PORTA_DATA2_TERM_USER_ADJUST & 0x03) <<
             - 6);
                  ScalerSetBit(P15_28_LVDS_PORTA_CTRL8, ~(_BIT3 | _BIT2), (_LVDS_PORTA_DATA3_TERM_USER_ADJUST & 0x03) <<
