 225   2              ScalerSetBit(P10_24_PIN_SHARE_CTRL64___LVDS, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT2);
 226   2      #endif
 227   2      #endif
 228   2      
 229   2              if(ScalerGlobalGetIDCode() == _RL6463_VER_A_ID_CODE)
 230   2              {
 231   3                  // Set DPLL CMU Power Down
 232   3                  ScalerPLLSetDPLLReset();
 233   3                  ScalerTimerDelayXms(2);
