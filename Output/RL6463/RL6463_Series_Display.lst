 372          //--------------------------------------------------
 373          // Description  : Set LVDS driving control
 374          // Input Value  : Driving current for Data and Clock pair
 375          // Output Value : None
 376          //--------------------------------------------------
 377          void ScalerDisplayLvdsDrivingControl(BYTE ucDriv)
 378          {
 379   1          BYTE ucEfuseDriv = 0;
 380   1          WORD usTempDriv = 0;
 381   1      
