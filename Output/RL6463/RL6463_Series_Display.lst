 669          //--------------------------------------------------
 670          // Description  : LVDS Cts Fifo Reset by Tcon
 671          // Input Value  : _ENABLE or _DISABLE
 672          // Output Value : None
 673          //--------------------------------------------------
 674          void ScalerDisplayCtsFifoRstByTcon(bit bEnable)
 675          {
 676   1          WORD usTconDVStart = 0;
 677   1          WORD usTconDHStart = 0;
 678   1      
 679   1          if(bEnable == _ON)
 680   1          {
 681   2              // Disable TCON8
 682   2              ScalerTcon8Enable(_OFF);
 683   2      
 684   2              // Disable All TCON
 685   2              // ScalerTconGlobalEnable(_OFF);
 686   2      
 687   2              // Get DHTotal (12-bit)
 688   2              ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_00_DISPLAY_HOR_TOTAL_H, 2, pData, 
             -_AUTOINC);
 689   2      
 690   2              // Get DV_ACT_End (12-bit)
 691   2              ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_12_DISPLAY_VER_ACT_END_H, 2, &pDat
             -a[2], _AUTOINC);
 692   2      
 693   2              // Get DV_BK_End (12-bit)
 694   2              ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_14_DISPLAY_VER_BG_END_H, 2, &pData
             -[4], _AUTOINC);
 695   2      
 696   2              // Calculate the Tcon8_DVStart and Tcon8_DHStart
 697   2              usTconDVStart = MAXOF(PDATA_WORD(1), PDATA_WORD(2)) + 1;
 698   2              usTconDHStart = (PDATA_WORD(0) >> 1) + 2;
 699   2      
 700   2              // Set TCON8 V start & end to [max_DV + 1: max_DV + 2]
 701   2              // Set TCON8 H start & end to [DH_total/2 + 2:DH_total/2 + 12]
 702   2              ScalerTcon8Adjust(usTconDHStart, (usTconDHStart + 10), usTconDVStart, (usTconDVStart + 1));
 703   2      
 704   2              // Enable All TCON
 705   2              ScalerTconGlobalEnable(_ON);
C51 COMPILER V8.12   RL6463_SERIES_DISPLAY                                                 03/10/2025 13:50:43 PAGE 13  

 706   2      
 707   2              // Enable TCON8
 708   2              ScalerTcon8Enable(_ON);
 709   2      
 710   2              // ctsFIFO reset by TCON8
 711   2              ScalerSetBit(P15_14_LVDS_COMMON_AB_CTRL20, ~_BIT0, _BIT0);
 712   2          }
 713   1          else
 714   1          {
 715   2              // ctsFIFO reset by force_cts_fifo_rstn
 716   2              ScalerSetBit(P15_14_LVDS_COMMON_AB_CTRL20, ~_BIT0, 0x00);
 717   2          }
 718   1      }
