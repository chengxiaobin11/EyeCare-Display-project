 585          // Input Value  : None
 586          // Output Value : None
 587          //--------------------------------------------------
 588          void ScalerDisplayLvdsPhaseConrol(void)
 589          {
 590   1          BYTE ucTxPhase = 0x00;
 591   1      
 592   1          // TXA0 Phase Select (Analog Port B)
 593   1          ucTxPhase = (_LVDS_A0_PHASE <= _LVDS_PHASE7) ? _LVDS_A0_PHASE : _LVDS_PHASE7;
 594   1          ScalerSetBit(P15_07_LVDS_COMMON_AB_CTRL7, ~(_BIT5 | _BIT4 | _BIT3), ((ucTxPhase & 0x07) << 3));
 595   1      
 596   1          // TXA1 Phase Select (Analog Port B)
 597   1          ucTxPhase = (_LVDS_A1_PHASE <= _LVDS_PHASE7) ? _LVDS_A1_PHASE : _LVDS_PHASE7;
 598   1          ScalerSetBit(P15_07_LVDS_COMMON_AB_CTRL7, ~(_BIT2 | _BIT1 | _BIT0), (ucTxPhase & 0x07));
 599   1      
 600   1          // TXA2 Phase Select (Analog Port B)
 601   1          ucTxPhase = (_LVDS_A2_PHASE <= _LVDS_PHASE7) ? _LVDS_A2_PHASE : _LVDS_PHASE7;
 602   1          ScalerSetBit(P15_08_LVDS_COMMON_AB_CTRL8, ~(_BIT5 | _BIT4 | _BIT3), ((ucTxPhase & 0x07) << 3));
 603   1      
 604   1          // TXAC Phase Select (Analog Port B)
 605   1          ucTxPhase = (_LVDS_AC_PHASE <= _LVDS_PHASE7) ? _LVDS_AC_PHASE : _LVDS_PHASE7;
 606   1          ScalerSetBit(P15_08_LVDS_COMMON_AB_CTRL8, ~(_BIT2 | _BIT1 | _BIT0), (ucTxPhase & 0x07));
 607   1      
 608   1          // TXA3 Phase Select (Analog Port B)
 609   1          ucTxPhase = (_LVDS_A3_PHASE <= _LVDS_PHASE7) ? _LVDS_A3_PHASE : _LVDS_PHASE7;
 610   1          ScalerSetBit(P15_09_LVDS_COMMON_AB_CTRL9, ~(_BIT5 | _BIT4 | _BIT3), ((ucTxPhase & 0x07) << 3));
 611   1      
 612   1          // TXB0 Phase Select (Analog Port A)
 613   1          ucTxPhase = (_LVDS_B0_PHASE <= _LVDS_PHASE7) ? _LVDS_B0_PHASE : _LVDS_PHASE7;
 614   1          ScalerSetBit(P15_04_LVDS_COMMON_AB_CTRL4, ~(_BIT5 | _BIT4 | _BIT3), ((ucTxPhase & 0x07) << 3));
 615   1      
 616   1          // TXB1 Phase Select (Analog Port A)
 617   1          ucTxPhase = (_LVDS_B1_PHASE <= _LVDS_PHASE7) ? _LVDS_B1_PHASE : _LVDS_PHASE7;
 618   1          ScalerSetBit(P15_04_LVDS_COMMON_AB_CTRL4, ~(_BIT2 | _BIT1 | _BIT0), (ucTxPhase & 0x07));
 619   1      
 620   1          // TXB2 Phase Select (Analog Port A)
 621   1          ucTxPhase = (_LVDS_B2_PHASE <= _LVDS_PHASE7) ? _LVDS_B2_PHASE : _LVDS_PHASE7;
 622   1          ScalerSetBit(P15_05_LVDS_COMMON_AB_CTRL5, ~(_BIT5 | _BIT4 | _BIT3), ((ucTxPhase & 0x07) << 3));
 623   1      
 624   1          // TXB3 Phase Select (Analog Port A)
 625   1          ucTxPhase = (_LVDS_B3_PHASE <= _LVDS_PHASE7) ? _LVDS_B3_PHASE : _LVDS_PHASE7;
 626   1          ScalerSetBit(P15_06_LVDS_COMMON_AB_CTRL6, ~(_BIT5 | _BIT4 | _BIT3), ((ucTxPhase & 0x07) << 3));
 627   1      }
