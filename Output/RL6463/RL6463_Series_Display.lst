             - (_LVDS_PORTA_STRONG_PULL_DOWN_USER_CTRL << 6)));
                  ScalerSetBit(P15_36_LVDS_PORTB_CTRL6, ~(_BIT7 | _BIT6), ((_LVDS_PORTB_WEAK_PULL_DOWN_USER_CTRL << 7) |
             - (_LVDS_PORTB_STRONG_PULL_DOWN_USER_CTRL << 6)));
              #else
 198   1      #if(_LVDS_PORT_SEL == _LVDS_1_PORT_A)
                  // Enable Weakly Pull Down, Disable Strong Pull Down
                  ScalerSetBit(P15_26_LVDS_PORTA_CTRL6, ~(_BIT7 | _BIT6), 0x00);
                  ScalerSetBit(P15_36_LVDS_PORTB_CTRL6, ~(_BIT7 | _BIT6), _BIT7);
              #elif(_LVDS_PORT_SEL == _LVDS_1_PORT_B)
                  // Enable Weakly Pull Down, Disable Strong Pull Down
                  ScalerSetBit(P15_26_LVDS_PORTA_CTRL6, ~(_BIT7 | _BIT6), _BIT7);
                  ScalerSetBit(P15_36_LVDS_PORTB_CTRL6, ~(_BIT7 | _BIT6), 0x00);
              #else
 207   1          // Enable Weakly Pull Down, Disable Strong Pull Down
 208   1          ScalerSetBit(P15_26_LVDS_PORTA_CTRL6, ~(_BIT7 | _BIT6), _BIT7);
 209   1          ScalerSetBit(P15_36_LVDS_PORTB_CTRL6, ~(_BIT7 | _BIT6), _BIT7);
 210   1      #endif
 211   1      #endif
 212   1      
 213   1          if(bOn == _ON)
 214   1          {
 215   2      #if(_LVDS_NO_VCM_LEVEL_BEFORE_DATA == _OFF)
 216   2      #if((_LVDS_PORT_SEL == _LVDS_1_PORT_B) || (_LVDS_PORT_SEL == _LVDS_2_PORT_AB))
 217   2              // Set LVDS Port B Configuration: LVDS
 218   2              ScalerSetBit(P10_1D_PIN_SHARE_CTRL55___LVDS, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT2);
 219   2              ScalerSetBit(P10_1E_PIN_SHARE_CTRL56___LVDS, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT2);
