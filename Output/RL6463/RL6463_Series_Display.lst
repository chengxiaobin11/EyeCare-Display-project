 144          //--------------------------------------------------
 145          // Description  : Set LVDS driving control
 146          // Input Value  : VCM for Data and Clock pair
 147          // Output Value : None
 148          //--------------------------------------------------
 149          void ScalerDisplayVcmControl(BYTE ucType)
 150          {
 151   1          // Set LVDS common mode Voltage
 152   1          switch(ucType)
 153   1          {
 154   2              case _LVDS_VCM_LOW:
 155   2      
 156   2                  ScalerSetBit(P15_01_LVDS_COMMON_AB_CTRL1, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _B
             -IT0), (_BIT6 | _BIT5));
 157   2      
 158   2                  break;
 159   2      
 160   2              case _LVDS_VCM_NORMAL:
 161   2      
 162   2                  ScalerSetBit(P15_01_LVDS_COMMON_AB_CTRL1, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _B
             -IT0), (_BIT6 | _BIT5 | _BIT3 | _BIT2 | _BIT0));
 163   2      
 164   2                  break;
C51 COMPILER V8.12   RL6463_SERIES_DISPLAY                                                 03/10/2025 13:50:43 PAGE 4   

 165   2      
 166   2              case _LVDS_VCM_HIGH:
 167   2      
 168   2                  ScalerSetBit(P15_01_LVDS_COMMON_AB_CTRL1, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _B
             -IT0), (_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0));
 169   2      
 170   2                  break;
 171   2      
 172   2              case _LVDS_VCM_USER:
 173   2      
 174   2                  ScalerSetBit(P15_01_LVDS_COMMON_AB_CTRL1, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _B
             -IT0), (_BIT6 | _BIT5 | (_LVDS_VCM_USER_LEVEL & 0x1F)));
 175   2      
 176   2                  break;
 177   2      
 178   2              default:
 179   2      
 180   2                  break;
 181   2          }
 182   1      }
