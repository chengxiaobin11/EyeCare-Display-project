              #elif(_LVDS_PORT_SEL == _LVDS_1_PORT_B)
                          // Power Up Port B LVDS Block
                          ScalerSetBit(P15_00_LVDS_COMMON_AB_CTRL0, ~_BIT6, _BIT6);
              #elif(_LVDS_PORT_SEL == _LVDS_2_PORT_AB)
 738   3                  // Power Up Port AB LVDS Block
