 236   3                  for(ucLvdsRstCount = 0; ucLvdsRstCount < 4; ucLvdsRstCount++)
 237   3                  {
 238   4                      // Power Up Port AB LVDS Block
 239   4                      ScalerSetBit(P15_00_LVDS_COMMON_AB_CTRL0, ~(_BIT6 | _BIT5), (_BIT6 | _BIT5));
