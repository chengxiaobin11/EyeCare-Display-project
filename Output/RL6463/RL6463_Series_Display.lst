  80          void ScalerDisplayLvdsInitialTable(void)
  81          {
  82   1      #if(_LVDS_NO_VCM_LEVEL_BEFORE_DATA == _ON)
                  // Set DISP mode is Hiz
                  ScalerSetBit(P39_00_LVDS_DISP_TYPE, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
              
                  ScalerDisplayLvdsPinshareSetting(_HIZ_TYPE);
              #else
  88   1          // Set DISP mode is LVDS
  89   1          ScalerSetBit(P39_00_LVDS_DISP_TYPE, ~(_BIT2 | _BIT1 | _BIT0), _BIT0);
  90   1      #endif
  91   1      
  92   1          // Set Panel Display Type
  93   1          ScalerSetBit(P39_01_LVDS_DISPLAY_CONV_CTRL0, ~(_BIT7 | _BIT6 | _BIT0), ((_LVDS_OUTPUT_PORT << 6) | (_L
             -VDS_TABLE_TYPE << 0)));
  94   1      
  95   1          // Display Resolution Control Settings
  96   1          ScalerSetBit(P39_01_LVDS_DISPLAY_CONV_CTRL0, ~(_BIT2 | _BIT1), (_PANEL_DISP_BIT_MODE << 1));
  97   1      
  98   1          // Set LVDS Interface Type
  99   1          ScalerSetBit(P39_06_LVDS_DISPLAY_CONV_CTRL5, ~0xFF, ((_LVDS_RB_SWAP << 7) | (_LVDS_ML_SWAP << 6) | (_L
             -VDS_PN_SWAP << 4) | (_BIT3) | (_LVDS_PAIR_MIRROR << 0)));
 100   1      
 101   1          // Set LVDS Display Content
 102   1          ScalerSetBit(P39_07_LVDS_DISPLAY_CONV_CTRL6, ~(_BIT3 | _BIT2 | _BIT1), ((_LVDS_DVS_INVERT << 3) | (_LV
             -DS_DHS_INVERT << 2) | (_LVDS_DEN_INVERT << 1)));
 103   1      
 104   1          // Set LVDS Rclk_inv: Enable
 105   1          ScalerSetBit(P15_12_LVDS_COMMON_AB_CTRL18, ~_BIT1, _BIT1);
 106   1      
 107   1          // Set OCLK: Non-inverted
