 245   4                  }
 246   3      
 247   3                  // Power Up Port AB LVDS Block
 248   3                  ScalerSetBit(P15_00_LVDS_COMMON_AB_CTRL0, ~(_BIT6 | _BIT5), (_BIT6 | _BIT5));
