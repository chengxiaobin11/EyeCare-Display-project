 124          //--------------------------------------------------
 125          // Description  : DownLoad HDCP BKsv
 126          // Input Value  : None
 127          // Output Value : None
 128          //--------------------------------------------------
 129          void ScalerSyncHdcpDownLoadBKsv(BYTE ucSubAddr, BYTE ucLength, BYTE *pucReadArray)
 130          {
 131   1          for(pData[0] = ucSubAddr; pData[0] < ucLength; pData[0]++)
 132   1          {
 133   2      #if((_DVI_SUPPORT == _ON) || (_HDMI_SUPPORT == _ON))
 134   2              ScalerSetDataPortByte(P2_C3_HDCP_AP, pData[0], pucReadArray[pData[0]]);
 135   2      #endif
 136   2      
 137   2      #if(_DP_SUPPORT == _ON)
                      ScalerDpRx0SetDpcdValue(0x06, 0x80, (0x00 | pData[0]), pucReadArray[pData[0]]);
              
                      // Enable DP Link Integrity Enable
                      ScalerSetBit(PB_1B_HDCP_INTGT_VRF, ~_BIT7, _BIT7);
              #endif
 143   2              g_pucHdcpBksvBackup[pData[0]] = pucReadArray[pData[0]];
 144   2          }
 145   1      
 146   1          DebugMessageDigital("8. HDCP Bksv Backup", g_pucHdcpBksvBackup[0]);
 147   1          DebugMessageDigital("8. HDCP Bksv Backup", g_pucHdcpBksvBackup[1]);
 148   1          DebugMessageDigital("8. HDCP Bksv Backup", g_pucHdcpBksvBackup[2]);
 149   1          DebugMessageDigital("8. HDCP Bksv Backup", g_pucHdcpBksvBackup[3]);
 150   1          DebugMessageDigital("8. HDCP Bksv Backup", g_pucHdcpBksvBackup[4]);
 151   1      }
