  69          //--------------------------------------------------
  70          // Description  : Enable/Disable DownLoad HDCP Key
  71          // Input Value  : None
  72          // Output Value : None
  73          //--------------------------------------------------
  74          void ScalerSyncHdcpEnableDownLoadKey(bit bEnable)
  75          {
  76   1          if(bEnable == _ENABLE)
  77   1          {
  78   2              // Disable HDMI Repeater Function
  79   2              ScalerSetDataPortBit(P2_C3_HDCP_AP, _P2_C4_PT_40_PORT_PAGE2_BCAPS, ~_BIT6, 0x00);
  80   2      
  81   2              // Suspend Key Calculation before load key
  82   2              ScalerSetBit(P2_AE_TMDS_RPS, ~(_BIT1 | _BIT0), _BIT0);
  83   2      
  84   2              // Manual Select Key SRAM Access Right
  85   2              ScalerSetBit(P2_A9_TMDS_ABC0, ~_BIT4, 0x00);
  86   2      
  87   2              // Switch MAC to Hdmi
  88   2              ScalerSetBit(PB_00_HD_DP_SEL, ~_BIT0, _BIT0);
  89   2      
  90   2              // Enable HDCP Block, and Key download port
  91   2              ScalerSetBit(P2_C0_HDCP_CR, ~(_BIT7 | _BIT1 | _BIT0), (_BIT7 | _BIT1 | _BIT0));
  92   2      
  93   2              // Set Km Clock to EMCU Clock
  94   2              ScalerSetBit(P2_AC_TMDS_Z0CC2, ~_BIT4, 0x00);
  95   2      
  96   2              // Disable HDCP Module Clock Gating
  97   2              ScalerSetBit(P2_C2_HDCP_PCR, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
  98   2          }
  99   1          else if(bEnable == _DISABLE)
 100   1          {
 101   2              // Disable Key download port
 102   2              ScalerSetBit(P2_C0_HDCP_CR, ~_BIT1, 0x00);
 103   2      
 104   2              // New Cipher Mode
 105   2              ScalerSetBit(P2_C0_HDCP_CR, ~_BIT7, _BIT7);
 106   2      
 107   2              // Auto Select Key SRAM Access Right
 108   2              ScalerSetBit(P2_A9_TMDS_ABC0, ~_BIT4, _BIT4);
 109   2      
 110   2              // For Chroma HDCP1.4 20k IIC r0 issue
C51 COMPILER V8.12   RL6463_SERIES_SYNC                                                    03/10/2025 13:50:49 PAGE 3   

 111   2              // Clear only AKSV IRQ Flag
 112   2              ScalerSetBit(P2_A9_TMDS_ABC0, ~(_BIT7 | _BIT6 | _BIT5 | _BIT2), (_BIT7));
 113   2      
 114   2              // Internal IRQ Enable (Global)
 115   2              ScalerGlobalIRQControl(_ENABLE);
 116   2      
 117   2              // Enable HDCP 1.4 AKSV IRQ
 118   2              ScalerSetBit(P2_AA_TMDS_ABC1, ~(_BIT4), _BIT4);
 119   2      
 120   2              EX0 = 1;
 121   2          }
 122   1      }
