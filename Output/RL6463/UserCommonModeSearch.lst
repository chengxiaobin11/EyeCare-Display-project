 148          //--------------------------------------------------
 149          BYTE UserCommonModeSearchModeVGA(void)
 150          {
 151   1          BYTE ucModeIndex = _MODE_NOSUPPORT;
 152   1      
 153   1          // Check OOR Mode By Measure Information.
 154   1          if(UserCommonModeSearchOORModeByMeasureInfo() == _TRUE)
 155   1          {
 156   2              return _MODE_NOSUPPORT;
 157   2          }
 158   1      
 159   1          // Search Preset Mode
 160   1          ucModeIndex = UserCommonModeSearchPresetMode();
 161   1      
 162   1          if((ucModeIndex < _MAX_PRESET_MODE) && (UserCommonModeSearchPresetModeCheckOOR(ucModeIndex) == _TRUE))
 163   1          {
 164   2              DebugMessageAnalog("Pixel Rate Over 220M ", GET_ADC_LIMIT_CLOCK());
 165   2      
 166   2              return _MODE_NOSUPPORT;
C51 COMPILER V8.12   USERCOMMONMODESEARCH                                                  03/10/2025 13:50:54 PAGE 4   

 167   2          }
 168   1      
 169   1          // Check Result
 170   1          if(ucModeIndex >= _MAX_PRESET_MODE)
 171   1          {
 172   2              // Search User Mode
 173   2              ucModeIndex = UserCommonModeSearchUserMode();
 174   2      
 175   2              DebugMessageAnalog("User Mode Search Mode No. ", ucModeIndex);
 176   2          }
 177   1      
 178   1          if(ucModeIndex < _MAX_PRESET_MODE)
 179   1          {
 180   2              // User Check ModeIndex
 181   2              ucModeIndex = UserInterfaceGetVGAConfuseMode(ucModeIndex);
 182   2      
 183   2              // Save FIFO Mode
 184   2              UserCommonModeSearchFIFOSaveModeInfo(ucModeIndex);
 185   2          }
 186   1      
 187   1          DebugMessageAnalog("3. ucModeIndex_FIFO", ucModeIndex);
 188   1      
 189   1          return ucModeIndex;
 190   1      }
