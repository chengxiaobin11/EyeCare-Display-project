 600          //--------------------------------------------------
 601          // Description : Get A Std Mode Height And Check Is Full
 602          // Input Value  : Measured Height
 603          // Output Value : Verified Height
 604          //--------------------------------------------------
 605          WORD UserCommonModeSearchGetHeightByGTF(WORD usVTotal, WORD usVFreq)
 606          {
 607   1          /**********************************************************************************************
 608   1          // Cminimum : minimum time of vertical sync + back porch interval, default value is 550 (us) //
 609   1          // Cfrontporch : minimum front porch in lines(vertical),default value is 3 (lines)           //
 610   1          // Height = Vtotal / (1 + (Vfreq / (20000 / 11 - Vfreq))) - 3                                //
 611   1          // Height = Vtotal - (Vtotal * 11 * Vfreq / 200000) - 3                                      //
 612   1          **********************************************************************************************/
 613   1          return (usVTotal - (WORD)((DWORD)11 * usVTotal * usVFreq / 200000) - 3);
 614   1      }
