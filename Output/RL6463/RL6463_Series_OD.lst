  53          //--------------------------------------------------
  54          // Description  : OD on/off
  55          // Input Value  : enumOn --> _FUNCTION_ON/_FUNCTION_OFF
  56          // Output Value : None
  57          //--------------------------------------------------
  58          void ScalerODEnable(EnumFunctionOnOFF enumOn)
  59          {
  60   1          //=================
  61   1          // Enable OD
  62   1          //=================
  63   1          if((enumOn == _FUNCTION_ON) && (GET_OD_USE_BIT() != _OFF) && (GET_MEMORY_CONFIG() != _MEMORY_WORK_MODE
             -))
  64   1          {
  65   2              // Set memory FIFO MUX to OD
  66   2              ScalerSetBit(P3_C9_LS_FIFO_CTRL0, ~_BIT7, 0x00);
  67   2      
  68   2      #if(_FRC_SUPPORT == _ON)
                      DebugMessageFRC("OD_ON", 0);
              
                      if(GET_DYNAMIC_OD_STATUS() == _ENABLE)
                      {
                          DebugMessageFRC("Dynamic OD", GET_MEMORY_DVF_SELECT());
              
                          // Enable DEN_START IRQ
                          SET_OD_CURR_DYNAMIC_STATUS(_ENABLE);
                          ScalerGlobalSetInterrupt(_IRQ_DEN_START, _ENABLE);
                      }
                      else
                      {
                          DebugMessageFRC("Static OD", 0);
              
                          // Enable OD function, disable DEN_START IRQ
                          SET_OD_CURR_DYNAMIC_STATUS(_DISABLE);
                          ScalerGlobalSetInterrupt(_IRQ_DEN_START, _DISABLE);
                          ScalerSetBit(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
                      }
              #else
  89   2              // Enable OD function
  90   2              ScalerSetBit(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
  91   2      #endif
  92   2          }
  93   1          //=================
  94   1          // Disable OD
  95   1          //=================
  96   1          else
  97   1          {
  98   2      #if(_FRC_SUPPORT == _ON)
                      DebugMessageFRC("OD_OFF", 0);
              
                      SET_OD_CURR_DYNAMIC_STATUS(_DISABLE);
                      ScalerGlobalSetInterrupt(_IRQ_DEN_START, _DISABLE);
              #endif
 104   2              // Disable OD function
 105   2              ScalerSetBit(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), 0x00);
 106   2      
 107   2              // After turning off OD memory access, set memory FIFO MUX to FRC
 108   2              ScalerTimerWaitForEvent(_EVENT_DVS); // OD ctrl bit DB effective at DVS falling
 109   2              ScalerTimerWaitForEvent(_EVENT_DVS); // Last OD read process is finished
C51 COMPILER V8.12   RL6463_SERIES_OD                                                      03/10/2025 13:50:47 PAGE 3   

 110   2              ScalerSetBit(P3_C9_LS_FIFO_CTRL0, ~_BIT7, _BIT7);
 111   2          }
 112   1      }
