 114          //--------------------------------------------------
 115          // Description  : Initialize OD memory start address
 116          // Input Value  : None
 117          // Output Value : None
 118          //--------------------------------------------------
 119          void ScalerODSetMemoryStartAddress(void)
 120          {
 121   1          // Calculate OD memory use space, unit:row
 122   1          PDATA_WORD(0) = ((((DWORD)CEILING(_PANEL_DH_WIDTH, _OD_PIXEL_PER_COMP)) * _PANEL_DV_HEIGHT * GET_OD_US
             -E_BIT() / _MEMORY_BIT_NUM) /
 123   1                           (_MEMORY_COL_PER_BANK * _MEMORY_BANK) / 10 + 1);
 124   1      
 125   1          // Set Memory Start Address
 126   1          PDATA_WORD(0) = ((DWORD)_MEMORY_ROW - PDATA_WORD(0)) << 2;
 127   1      
 128   1          ScalerSetByte(P3_DB_LS_DDR_START_ADDR_H, pData[0]);
 129   1          ScalerSetByte(P3_DC_LS_DDR_START_ADDR_M, pData[1]);
 130   1          ScalerSetByte(P3_DD_LS_DDR_START_ADDR_L, 0x00);
 131   1      }
