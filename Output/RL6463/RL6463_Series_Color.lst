  64          // Output Value : None
  65          //--------------------------------------------------
  66          void ScalerColorDDitherAdjust(BYTE code *pucDitherTable, BYTE code *pucSeqTable, BYTE code *pucTempoTable,
             - BYTE ucBankAddress)
  67          {
  68   1          DWORD ulSettingOption = 0x00000000;
  69   1      
  70   1          ScalerColorDDitherLoadDitherTable(pucDitherTable, ucBankAddress);
  71   1      
  72   1      #if((_D_DITHER_MULTI_SEQ_ENABLE == _ENABLE) || (_D_DITHER_SERIES_SEQ_ENABLE == _ENABLE))
                  ScalerColorDDitherLoadSeqTable(pucSeqTable, (24 * 4), ucBankAddress);
              #else
  75   1          ScalerColorDDitherLoadSeqTable(pucSeqTable, 24, ucBankAddress);
  76   1      #endif
  77   1      
  78   1          ScalerColorDDitherLoadTempoTable(pucTempoTable, ucBankAddress);
  79   1      
  80   1          ulSettingOption = (_DDITHER_TEMPORAL_ENABLE << 4) | (_D_DITHER_V_FRAME_MOD << 1) | _D_DITHER_H_FRAME_M
             -OD;
  81   1          ulSettingOption = ulSettingOption | (((DWORD)(_DDITHER_KEEP_NFRAME << 4)) << 8);
  82   1          ulSettingOption = ulSettingOption | (((DWORD)(_D_DITHER_MULTI_SEQ_ENABLE << 2)) << 16);
  83   1          ulSettingOption = ulSettingOption | (((DWORD)((_D_DITHER_SHARE_SEQ_ENABLE << 3) | (_D_DITHER_SEQ_INV_E
             -NABLE << 1) | _D_DITHER_SEQ_INV_MODE)) << 24);
  84   1      
  85   1          ScalerColorDDitherLoadSetting(ulSettingOption);
  86   1      }
