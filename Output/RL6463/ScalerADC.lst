 347          //--------------------------------------------------
 348          // Description  : ADCNR setting
 349          // Input Value  : None
 350          // Output Value : None
 351          //--------------------------------------------------
 352          void ScalerADCNRSetting(void)
 353          {
C51 COMPILER V8.12   SCALERADC                                                             03/10/2025 13:50:17 PAGE 7   

 354   1          // Tone Count Modify Type Select to High mode
 355   1          ScalerSetBit(P33_0E_ADCNR_MODIFY, ~_BIT7, _BIT7);
 356   1      
 357   1          // Total Frame Number set 1
 358   1          ScalerSetBit(P33_01_ADCNR_CTRL2, ~(_BIT5 | _BIT4), _BIT4);
 359   1      
 360   1          // Truncate LSB bit to avoid IDither Noise
 361   1          ScalerSetBit(P33_02_ADCNR_CTRL3, ~(_BIT7 | _BIT6), _BIT6);
 362   1      
 363   1      #if(_ADCNR_SUPPORT == _ON)
 364   1          // Enable ADCNR
 365   1          ScalerADCNREn(_ENABLE);
 366   1      #endif
 367   1      
 368   1          // ADC offset dither disable
 369   1          ScalerSetBit(P0_D9_ADC_REG1, ~(_BIT7 | _BIT6 | _BIT5), 0x00);
 370   1      }
