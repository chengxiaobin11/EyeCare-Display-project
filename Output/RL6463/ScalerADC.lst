 142          //--------------------------------------------------
 143          // Description  : Intial adc Bias current setting
 144          // Input Value  : None
 145          // Output Value : None
 146          //--------------------------------------------------
 147          void ScalerADCBiasCurrentSetting(void)
 148          {
 149   1          // Set bandgap voltage 1.217V, ADC Regulator 1.145V
 150   1          ScalerSetBit(P0_C7_ADC_VOLT_SEL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), (_BIT6 | _BIT4));
 151   1      
 152   1          // Set SF Bias current relation control register
 153   1          // Disable SF LPF, Enable VREF LPF
 154   1          ScalerSetBit(P0_C8_ADC_SF_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT2), (_BIT6 | _BIT2));
 155   1      
 156   1          // Enable meta-stable detect/correction, bias current of SAR Comparator pre-am = 75uA
 157   1          ScalerSetBit(P0_D5_ADC_SAR_CTRL, ~(_BIT6 | _BIT5 | _BIT4), (_BIT6 | _BIT4));
 158   1      
 159   1          // the bottom plate of sampling cap do not reset in advance
 160   1          ScalerSetBit(P0_D9_ADC_REG1, ~_BIT3, 0x00);
 161   1      }
