 163          //--------------------------------------------------
 164          // Description  : Adjust ADC gain
 165          // Input Value  : pGainMSB ---> R/G/B Gain coefficient MSB
 166          //                pGainLSB ---> R/G/B Gain coefficient LSB
 167          // Output Value : None
 168          //--------------------------------------------------
 169          void ScalerADCGainAdjust(BYTE *pucGainMSB, BYTE *pucGainLSB)
 170          {
C51 COMPILER V8.12   SCALERADC                                                             03/10/2025 13:50:17 PAGE 4   

 171   1          // Set ADC Gain High Byte Factor
 172   1          ScalerSetByte(P0_C0_ADC_GAI_RED_MSB, pucGainMSB[0]);
 173   1          ScalerSetByte(P0_C1_ADC_GAI_GRN_MSB, pucGainMSB[1]);
 174   1          ScalerSetByte(P0_C2_ADC_GAI_BLU_MSB, pucGainMSB[2]);
 175   1      
 176   1          // Set ADC Gain Low Byte Factor
 177   1          ScalerSetByte(P0_BE_ADC_GAI_LSB, ((pucGainLSB[0] & 0x03) << 4) | ((pucGainLSB[1] & 0x03) << 2) | (pucG
             -ainLSB[2] & 0x03));
 178   1      }
 179          
 180          //--------------------------------------------------
 181          // Description  : Adjust ADC offset
 182          // Input Value  : pGainMSB ---> R/G/B Offset coefficient MSB
 183          //                pGainLSB ---> R/G/B Offset coefficient LSB
 184          // Output Value : None
 185          //--------------------------------------------------
 186          void ScalerADCOffsetAdjust(BYTE *pucOffsetMSB, BYTE *pucOffsetLSB)
 187          {
 188   1          // Set ADC Gain High Byte Factor
 189   1          ScalerSetByte(P0_C3_ADC_OFF_RED_MSB, pucOffsetMSB[0]);
 190   1          ScalerSetByte(P0_C4_ADC_OFF_GRN_MSB, pucOffsetMSB[1]);
 191   1          ScalerSetByte(P0_C5_ADC_OFF_BLU_MSB, pucOffsetMSB[2]);
 192   1      
 193   1          // Set ADC Offset Low Byte Factor
 194   1          ScalerSetByte(P0_BF_ADC_OFF_LSB, ((pucOffsetLSB[0] & 0x03) << 4) | ((pucOffsetLSB[1] & 0x03) << 2) | (
             -pucOffsetLSB[2] & 0x03));
 195   1      }
