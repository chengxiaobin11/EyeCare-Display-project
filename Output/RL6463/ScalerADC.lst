 270          //--------------------------------------------------
 271          // Description  : DC restore
 272          // Input Value  : bEn---> Disable or enable dcrestore function
 273          // Output Value : None
 274          //--------------------------------------------------
 275          void ScalerADCDCRestoreEn(bit bEn)
 276          {
 277   1          if(bEn == _TRUE)
 278   1          {
 279   2              // Enable DC Restore circut
 280   2              ScalerSetBit(P0_D4_ADC_SOG_CTRL, ~_BIT4, _BIT4);
 281   2          }
 282   1          else
 283   1          {
 284   2              // Disable DC Restore circut
 285   2              ScalerSetBit(P0_D4_ADC_SOG_CTRL, ~_BIT4, 0x00);
 286   2          }
 287   1      }
 288          
 289          //--------------------------------------------------
 290          // Description  : SOG Clamp Control
 291          // Input Value  : bEn---> Disable or enable SOG clamp
 292          // Output Value : None
C51 COMPILER V8.12   SCALERADC                                                             03/10/2025 13:50:17 PAGE 6   

 293          //--------------------------------------------------
 294          void ScalerADCSOGClampEn(bit bEn)
 295          {
 296   1          if(bEn == _TRUE)
 297   1          {
 298   2              // Enable SOG Clamp, normal clamp
 299   2              ScalerSetBit(P0_D4_ADC_SOG_CTRL, ~(_BIT5 | _BIT2), _BIT5);
 300   2      
 301   2              // 0x19 * 10 = 250mV = [(100 + X) + (400 - X)] / 2;
 302   2              // 250mV is fit to Both DC Restore and Clamp Mode.
 303   2              if(ScalerGetBit(P0_D7_ADC_SOG_DAC, 0x1F) < 0x19)
 304   2              {
 305   3                  pData[0] = 0x19 - ScalerGetBit(P0_D7_ADC_SOG_DAC, 0x1F);
 306   3      
 307   3                  // Chanage SOG DAC Setting to 250mV smoothly
 308   3                  while(pData[0]--)
 309   3                  {
 310   4                      ScalerSetBit(P0_D7_ADC_SOG_DAC, ~(0x1F), (0x19 - pData[0]));
 311   4      
 312   4                      // Delay 1ms for clamp mode rising.
 313   4                      ScalerTimerDelayXms(1);
 314   4                  }
 315   3              }
 316   2          }
 317   1          else
 318   1          {
 319   2              // Disable SOG Clamp
 320   2              ScalerSetBit(P0_D4_ADC_SOG_CTRL, ~_BIT5, 0x00);
 321   2          }
 322   1      }
 323          
 324          //--------------------------------------------------
 325          // Description  : ADC Schmitt Trigger Setting
 326          // Input Value  : None
 327          // Output Value : None
 328          //--------------------------------------------------
 329          void ScalerADCSchmittTriggerSetting(void)
 330          {
 331   1          // Enable Schmitt Trigger and Select New Mode
 332   1          ScalerSetBit(P0_F4_HS_SCHMITT_TRIGGE_CTRL, ~(_BIT7 | _BIT5), (_BIT7 | _BIT5));
 333   1      
 334   1          // HS Schimmit Tigger Polarity Select
 335   1          ScalerSetBit(P0_F4_HS_SCHMITT_TRIGGE_CTRL, ~_BIT6, (_VGA_HS_SCHMITT_TRIGGER_POLARITY_SEL << 6));
 336   1      
 337   1          // HS Schimmit Tigger Vth Fine tune
 338   1          ScalerSetBit(P0_F4_HS_SCHMITT_TRIGGE_CTRL, ~_BIT4, (_VGA_HS_SCHMITT_TRIGGER_VTH_FINE_TUNE << 4));
 339   1      
 340   1          // HS Schimmit Trigger Positive Vth Setting
 341   1          ScalerSetBit(P0_F4_HS_SCHMITT_TRIGGE_CTRL, ~(_BIT3 | _BIT2), (_VGA_HS_SCHMITT_TRIGGER_POSITIVE_VTH << 
             -2));
 342   1      
 343   1          // HS Schimmit Trigger Negative Vth Setting
 344   1          ScalerSetBit(P0_F4_HS_SCHMITT_TRIGGE_CTRL, ~(_BIT1 | _BIT0), (_VGA_HS_SCHMITT_TRIGGER_NEGATIVE_VTH));
 345   1      }
