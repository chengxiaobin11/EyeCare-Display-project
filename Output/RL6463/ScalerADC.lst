 124          //--------------------------------------------------
 125          // Description  : ADC Power Setting
 126          // Input Value  : None
 127          // Output Value : None
 128          //--------------------------------------------------
 129          void ScalerADCPowerSetting(void)
 130          {
 131   1          // ADC LDO Power On, ADC Clock Power On, SOG_ADC0 Power On, R/G/B ADC Power On
 132   1          // ADC ldo Output Not Short to Ground
 133   1          ScalerSetBit(P0_C6_ADC_POWER, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | _BIT6
             - | _BIT5 | _BIT2 | _BIT1 | _BIT0));
 134   1      
 135   1          // Set internal 2.5V LDO voltage
 136   1          ScalerSetBit(P0_DA_ADC_REG2, ~(_BIT1 | _BIT0), _BIT0);
 137   1      
 138   1          // ADCNR Setting
 139   1          ScalerADCNRSetting();
 140   1      }
