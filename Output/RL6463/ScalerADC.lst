 393          //--------------------------------------------------
 394          // Description  : ADC & Apll thermal compensation
 395          // Input Value  : None
 396          // Output Value : None
 397          //--------------------------------------------------
 398          void ScalerADCThermalCompensationSetting(void)
 399          {
 400   1          // APLL & ADC Path thermal Compensation Setting
 401   1          if(ScalerGetBit(P0_47_SYNC_SELECT, _BIT4) == _BIT4) // SOG mode
 402   1          {
 403   2              // APLL thermal compensation need set by w/i extro delay path
 404   2              SET_THERMO_LONG_PATH_STATUS();
 405   2          }
 406   1          else // Separate mode
 407   1          {
 408   2              // APLL thermal compensation need set by w/o extro delay path
 409   2              CLR_THERMO_LONG_PATH_STATUS();
 410   2          }
 411   1      }
