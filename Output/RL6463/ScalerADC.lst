 247          //--------------------------------------------------
 248          // Description  : ADC bandwidth and bias current setting
 249          // Input Value  : ulAdcClock ---> ADC Clock frequency
 250          // Output Value : None
 251          //--------------------------------------------------
 252          void ScalerADCBandWidthSetting(DWORD ulAdcClock)
 253          {
 254   1          ulAdcClock = ulAdcClock;
 255   1      
 256   1      #if(_VGA_ADC_SF_SHA_LPF_UNDER_25MHZ_SUPPORT == _ON)
                  if(ulAdcClock < 26)
                  {
                      // Enable SF bandwidth & Set Bandwidth to 150MHz
                      ScalerSetBit(P0_C8_ADC_SF_CTRL, ~(_BIT5 | _BIT4 | _BIT3), (_BIT5 | _BIT3));
                  }
                  else
                  {
                      // Disable SF bandwidth
                      ScalerSetBit(P0_C8_ADC_SF_CTRL, ~(_BIT5 | _BIT4 | _BIT3), 0x00);
                  }
              #endif
 268   1      }
