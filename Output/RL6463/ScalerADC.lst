 197          //--------------------------------------------------
 198          // Description  : ADC color format setting
 199          // Input Value  : ucColorFormat ---> SOY or VGA sync type format
 200          // Output Value : None
 201          //--------------------------------------------------
 202          void ScalerADCClampMode(EnumColorSpace enumColorFormat)
 203          {
 204   1      #if(_VGA_CHROMA_PATTERN12_SUPPORT == _ON)
                  if(ScalerADCGetClampToTopStatus() == _TRUE)
                  {
                      return;
                  }
              #endif
 210   1      
 211   1          if(enumColorFormat == _COLOR_SPACE_YPBPR)
 212   1          {
 213   2              // Red Channel Set Ypbpr Clamp Mode
 214   2              ScalerSetBit(P0_CF_ADC_CTL_RED, ~_BIT7, _BIT7);
 215   2      
 216   2              // Green Channel Set RGB Clamp Mode
 217   2              ScalerSetBit(P0_D0_ADC_CTL_GRN, ~_BIT7, 0x00);
 218   2      
 219   2              // Blue Channel Set Ypbpr Clamp Mode
 220   2              ScalerSetBit(P0_D1_ADC_CTL_BLU, ~_BIT7, _BIT7);
 221   2          }
 222   1          else // RGB format
 223   1          {
 224   2              // Red Channel Set RGB Clamp Mode
 225   2              ScalerSetBit(P0_CF_ADC_CTL_RED, ~_BIT7, 0x00);
 226   2      
 227   2              // Green Channel Set RGB Clamp Mode
 228   2              ScalerSetBit(P0_D0_ADC_CTL_GRN, ~_BIT7, 0x00);
 229   2      
 230   2              // Blue Channel Set RGB Clamp Mode
C51 COMPILER V8.12   SCALERADC                                                             03/10/2025 13:50:17 PAGE 5   

 231   2              ScalerSetBit(P0_D1_ADC_CTL_BLU, ~_BIT7, 0x00);
 232   2          }
 233   1      }
 234          
 235          #if(_VGA_CHROMA_PATTERN12_SUPPORT == _ON)
              //--------------------------------------------------
              // Description  : Get clamp-to-top status
              // Input Value  : None
              // Output Value : _TRUE or _FALSE
              //--------------------------------------------------
              bit ScalerADCGetClampToTopStatus(void)
              {
                  return (ScalerGetBit(P0_D6_ADC_CLAMP_TOP, (_BIT2 | _BIT1 | _BIT0)) != 0x00);
              }
