 105          //--------------------------------------------------
 106          // Description  : Intial adc output clock setting
 107          // Input Value  : None
 108          // Output Value : None
 109          //--------------------------------------------------
 110          void ScalerADCOutputClkSetting(void)
C51 COMPILER V8.12   SCALERADC                                                             03/10/2025 13:50:17 PAGE 3   

 111          {
 112   1          // Output clock divider Polarity Normal, Output Pixel Dealy 0.56nS, divider = 1
 113   1          // ck_data polarity select normal; Clock polarity select positive
 114   1          ScalerSetBit(P0_BC_ADC_CK_OUT_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1), _BIT6);
 115   1      
 116   1          // Disable Test Output
 117   1          ScalerSetBit(P0_BD_ADC_TEST, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), 0x00);
 118   1      
 119   1          // diff clock from APLL, duty set 49.3%
 120   1          // ADC sample time duty set 400ps (default)
 121   1          ScalerSetBit(P0_BB_ADC_CK_IN_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2), (_BIT7 | _BIT5 | 
             -_BIT4));
 122   1      }
