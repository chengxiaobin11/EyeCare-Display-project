 271          //--------------------------------------------------
 272          // Description  : Group Top Power on/off
 273          // Input Value  : ON --> Group Top (Low Power)
 274          //                OFF --> Group Top (Normal Operation)
 275          // Output Value : None
 276          //--------------------------------------------------
 277          void ScalerPowerGroupTopPowerCut(BYTE ucOn)
 278          {
 279   1          if(ucOn == _ON)
 280   1          {
 281   2              // Top Power Strong power off
 282   2              ScalerSetBit(P0_09_TOP_POWER_CTRL, ~_BIT5, 0x00);
 283   2      
 284   2              // Top Power Weak power off
 285   2              ScalerSetBit(P0_09_TOP_POWER_CTRL, ~_BIT4, 0x00);
 286   2          }
 287   1          else
 288   1          {
 289   2              // Weak power on
 290   2              ScalerSetBit(P0_09_TOP_POWER_CTRL, ~_BIT4, _BIT4);
 291   2      
 292   2              // Wait for weak power on flag
 293   2              pData[0] = 50;
 294   2      
 295   2              while((ScalerGetBit(P0_09_TOP_POWER_CTRL, _BIT6) != _BIT6) && (pData[0]-- > 0))
 296   2              {
C51 COMPILER V8.12   RL6463_SERIES_POWER                                                   03/10/2025 13:50:48 PAGE 6   

 297   3                  DELAY_5US();
 298   3              }
 299   2      
 300   2              // Strong power on
 301   2              ScalerSetBit(P0_09_TOP_POWER_CTRL, ~_BIT5, _BIT5);
 302   2      
 303   2              // Wait for strong power on flag
 304   2              pData[0] = 50;
 305   2      
 306   2              while((ScalerGetBit(P0_09_TOP_POWER_CTRL, _BIT7) != _BIT7) && (pData[0]-- > 0))
 307   2              {
 308   3                  DELAY_5US();
 309   3              }
 310   2          }
 311   1      }
