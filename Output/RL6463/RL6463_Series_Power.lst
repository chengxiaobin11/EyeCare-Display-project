 151          void ScalerPowerAllGroupPowerCutReset(BYTE ucOn)
 152          {
 153   1          if(ucOn == _ON)
 154   1          {
 155   2              // Top Power Cut block Reset
 156   2              ScalerSetBit(P0_09_TOP_POWER_CTRL, ~_BIT0, _BIT0);
 157   2      
 158   2              // Audio Power Cut block Reset
 159   2              ScalerSetBit(PC0_0A_AUDIO_POWER_CTRL, ~_BIT0, _BIT0);
 160   2      
 161   2              // GDI & GDI PHY Power Cut block Reset
 162   2              ScalerSetBit(P0_0A_GDI_POWER_CTRL, ~_BIT0, _BIT0);
 163   2          }
 164   1          else
 165   1          {
 166   2              // Top Power Cut block Reset
 167   2              ScalerSetBit(P0_09_TOP_POWER_CTRL, ~_BIT0, 0x00);
 168   2      
 169   2              // Audio Power Cut block Reset
 170   2              ScalerSetBit(PC0_0A_AUDIO_POWER_CTRL, ~_BIT0, 0x00);
 171   2      
 172   2              // GDI Power Cut block Reset
C51 COMPILER V8.12   RL6463_SERIES_POWER                                                   03/10/2025 13:50:48 PAGE 4   

 173   2              ScalerSetBit(P0_0A_GDI_POWER_CTRL, ~_BIT0, 0x00);
 174   2          }
 175   1      }
