 501          //--------------------------------------------------
 502          // Description  : Recover GDI Group Power Cut Area.
 503          // Input Value  : None
 504          // Output Value : None
 505          //--------------------------------------------------
 506          void ScalerPowerRecoverGDIGroupIsolationData(void)
 507          {
 508   1          // There is no action on RL6369 IC (For Tx Block) //C Group
 509   1      
 510   1          //////////////////////// GDI power cut block start ///////////////////////////////
 511   1      #if(_DP_SUPPORT == _ON)
              
                  // Set R0' Available HW Mode
                  ScalerSetBit(PB_1A_HDCP_IRQ, ~(_BIT5 | _BIT4), _BIT5);
              
                  // Enable DP Link Integrity Enable
                  ScalerSetBit(PB_1B_HDCP_INTGT_VRF, ~_BIT7, _BIT7);
              
                  // DP Mac Clock Select to Xtal Clock
                  ScalerSetBit(PB_01_PHY_DIG_RESET_CTRL, ~_BIT6, _BIT6);
              
                  if(ScalerGetBit(PB_20_HDCP_DEBUG, _BIT7) == _BIT7)
                  {
                      // HDCP R0 Calculate
                      ScalerSetBit(PB_63_DUMMY2, ~_BIT7, _BIT7);
                      ScalerSetBit(PB_63_DUMMY2, ~_BIT7, 0x00);
                  }
              #endif
 529   1          //////////////////////// GDI power cut block End /////////////////////////////////
 530   1      
 531   1          //////////////////////// GDI_2(CBUS/ECBUS) power cut block start ///////////////////////////////
 532   1      
 533   1          //////////////////////// GDI_2(CBUS/ECBUS) power cut block End /////////////////////////////////
 534   1      
 535   1          //////////////////////// HDCP 2.2 start //////////////////////
 536   1      
 537   1      #if(_HDCP_2_2_SUPPORT == _ON)
                  ScalerHdcp2Initial();
              #endif
 540   1      
 541   1          //////////////////////// HDCP 2.2 End ////////////////////////
 542   1      
 543   1          // There is no action on RL6369 IC (For high speed port Block) //E Group
 544   1      }
