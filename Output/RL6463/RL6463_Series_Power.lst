  59          //--------------------------------------------------
  60          // Description  : Power cut block flow
  61          // Input Value  : enumSwitch    --> Power action description.
  62          // Output Value : return power group enter isolation area
  63          //--------------------------------------------------
  64          BYTE ScalerPowerIsolation(EnumPowerAction enumSwitch)
  65          {
  66   1          BYTE ucPowerIsoFlg = 0x00;
  67   1      
  68   1          switch(enumSwitch)
  69   1          {
  70   2              case _POWER_ACTION_NORMAL_TO_PS:
  71   2              case _POWER_ACTION_NORMAL_TO_OFF:
  72   2              case _POWER_ACTION_AC_ON_TO_OFF:
  73   2              case _POWER_ACTION_AC_ON_INITIAL:
  74   2      
  75   2                  // LVDS Pad Power Off
  76   2                  ScalerDisplayLvdsPadPower(_OFF);
  77   2      
  78   2                  // Group Top block isolation control
  79   2                  ScalerPowerGroupTopIsolation(_ON);
  80   2                  ucPowerIsoFlg |= _BIT0;
  81   2      
  82   2                  // Group Audio block isolation control
  83   2                  ScalerPowerGroupAudioIsolation(_ON);
  84   2                  ucPowerIsoFlg |= _BIT1;
  85   2      
  86   2                  // Group GDI & GDI PHY block isolation control
  87   2                  ScalerPowerGroupGDIIsolation(_ON);
  88   2                  ucPowerIsoFlg |= _BIT3;
  89   2      
  90   2                  // Group Top block power control
  91   2                  ScalerPowerGroupTopPowerCut(_ON);
  92   2      
  93   2                  // Group Audio block power control
  94   2                  ScalerPowerGroupAudioPowerCut(_ON);
  95   2      
  96   2                  // Group GDI & GDI PHY block power control
  97   2                  ScalerPowerGroupGDIPowerCut(_ON);
  98   2      
  99   2                  break;
 100   2      
 101   2              case _POWER_ACTION_AC_ON_TO_NORMAL:
 102   2              case _POWER_ACTION_OFF_TO_NORMAL:
 103   2              case _POWER_ACTION_PS_TO_NORMAL:
 104   2      
 105   2                  // All power group Reset
 106   2                  ScalerPowerAllGroupPowerCutReset(_ON);
 107   2      
 108   2                  // Group Top block power control
 109   2                  ScalerPowerGroupTopPowerCut(_OFF);
 110   2      
C51 COMPILER V8.12   RL6463_SERIES_POWER                                                   03/10/2025 13:50:48 PAGE 3   

 111   2                  // Group Audio block power control
 112   2                  ScalerPowerGroupAudioPowerCut(_OFF);
 113   2      
 114   2                  // Group GDI power block power control
 115   2                  ScalerPowerGroupGDIPowerCut(_OFF);
 116   2      
 117   2                  // Group Top block isolation control
 118   2                  ScalerPowerGroupTopIsolation(_OFF);
 119   2      
 120   2                  // Group Audio block isolationcontrol
 121   2                  ScalerPowerGroupAudioIsolation(_OFF);
 122   2      
 123   2                  // Group GDI & GDI PHY block isolation control
 124   2                  ScalerPowerGroupGDIIsolation(_OFF);
 125   2      
 126   2                  // All power group Relase
 127   2                  ScalerPowerAllGroupPowerCutReset(_OFF);
 128   2      
 129   2                  // LVDS Pad Power On
 130   2                  ScalerDisplayLvdsPadPower(_ON);
 131   2      
 132   2                  break;
 133   2      
 134   2              case _POWER_ACTION_NORMAL_TO_FAKE_PS:
 135   2              case _POWER_ACTION_PS_TO_OFF:
 136   2      
 137   2                  break;
 138   2      
 139   2              default:
 140   2                  break;
 141   2          }
 142   1      
 143   1          return ucPowerIsoFlg;
 144   1      }
