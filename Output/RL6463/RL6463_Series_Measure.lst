             -ScalerGetByte(P30_09_MEAS_VS_PERIOD_A_L))) + 1;
 174   2          }
 175   1      
 176   1          // VSync Pulse Width
 177   1          pstMeasureSyncHV->usVSWidth = ((((WORD)ScalerGetByte(P30_0C_MEAS_VS_PULSE_A_M) & 0xF) << 8) | (ScalerG
