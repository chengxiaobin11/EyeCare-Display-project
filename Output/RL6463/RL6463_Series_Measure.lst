 195          void ScalerMeasureSetOfflineMeasure(EnumSourceTypeDef enumSourceType, EnumSourceSearchPort enumSourcePort)
 196          {
 197   1          enumSourceType = enumSourceType;
 198   1      
 199   1          // Power up off-line measure; Measure Time Clock = 16384 Xtal; VS Measure Invert Disable; Disable HS/D
             -EN swap
 200   1          ScalerSetBit(P30_01_MEAS_CTL0, ~(_BIT7 | _BIT6 | _BIT4 | _BIT3 | _BIT0), (_BIT7 | _BIT6));
 201   1      
 202   1          // Disable off-line measure
 203   1          ScalerSetBit(P30_02_MEAS_CTL1, ~(_BIT5 | _BIT0), 0x00);
 204   1      
 205   1          if(enumSourcePort == _A0_INPUT_PORT)
 206   1          {
 207   2              // Set off line measure source; Disable clock divider
 208   2              ScalerSetBit(P30_00_SYNC_SELECT, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT2 | _BIT0));
 209   2          }
 210   1          else
 211   1          {
 212   2              switch(enumSourcePort)
 213   2              {
 214   3      #if((_D0_INPUT_PORT_TYPE != _D0_NO_PORT) || (_D1_INPUT_PORT_TYPE != _D1_NO_PORT))
 215   3      
 216   3                  case _D0_INPUT_PORT:
C51 COMPILER V8.12   RL6463_SERIES_MEASURE                                                 03/10/2025 13:50:46 PAGE 5   

 217   3                  case _D1_INPUT_PORT:
 218   3      
 219   3                      ScalerSetBit(P30_00_SYNC_SELECT, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 220   3      
 221   3                      break;
 222   3      
 223   3      #endif // End of #if(_D0_INPUT_PORT_TYPE != _D0_NO_PORT)
 224   3      
 225   3                  default:
 226   3      
 227   3                      break;
 228   3              }
 229   2          }
 230   1      
 231   1          // Delay for measure reset
 232   1          ScalerTimerDelayXms(_MEASURE_RESET_TIME);
 233   1      
 234   1          // Enable off-line measure
 235   1          ScalerSetBit(P30_02_MEAS_CTL1, ~(_BIT5 | _BIT0), (_BIT5 | _BIT0));
 236   1      }
