 115          bit ScalerMeasureGetOfflineMeasureResult(StructMeasureSyncData *pstMeasureSyncHV, EnumSourceSearchPort enu
             -mSourceSearchPort)
 116          {
 117   1          enumSourceSearchPort = enumSourceSearchPort;
 118   1      
 119   1          if(ScalerTimerPollingFlagProc(_MEASURE_TIMEOUT, P30_02_MEAS_CTL1, _BIT7, 0x00) == _FALSE)
 120   1          {
 121   2              return _FALSE;
 122   2          }
 123   1      
 124   1      #if(_FREESYNC_SUPPORT == _ON)
 125   1          if(GET_FREESYNC_ENABLED() == _TRUE)
 126   1          {
 127   2              // Check measure result status
 128   2              if(ScalerGetBit(P30_03_MEAS_ERROR_FLG0, (_BIT7 | _BIT4)) != 0x00)
 129   2              {
 130   3                  return _FALSE;
 131   3              }
 132   2          }
 133   1          else
 134   1      #endif
 135   1          {
 136   2              // Check measure result status
 137   2              if(ScalerGetBit(P30_03_MEAS_ERROR_FLG0, (_BIT7 | _BIT5 | _BIT4)) != 0x00)
 138   2              {
 139   3                  return _FALSE;
 140   3              }
 141   2          }
 142   1      
 143   1          // Pop up measurement result
 144   1          ScalerSetBit(P30_02_MEAS_CTL1, ~_BIT6, _BIT6);
 145   1      
 146   1          // Polarity
 147   1          pstMeasureSyncHV->b1HSP = (bit)ScalerGetBit(P30_04_MEAS_ERROR_FLG1, _BIT6);
 148   1          pstMeasureSyncHV->b1VSP = (bit)ScalerGetBit(P30_04_MEAS_ERROR_FLG1, _BIT7);
 149   1      
 150   1      #if(_DP_FREESYNC_SUPPORT == _ON)
                  // DP Freesync case, HSync Period, HSync Pulse Width and VSync Period use DP measure
                  if(GET_DP_FREESYNC_ENABLED() == _TRUE)
                  {
                      // HSync Period
                      pstMeasureSyncHV->usHSPeriod = ((DWORD)ScalerFreeSyncDpGetHSPeriod(enumSourceSearchPort) * _MEASUR
             -E_CLK / 1000000);
              
                      // HSync Pulse Width
                      pstMeasureSyncHV->usHSWidth = ScalerFreeSyncDpGetHSW(enumSourceSearchPort);
              
                      // VSync Period
                      pstMeasureSyncHV->usVSPeriod = ScalerFreeSyncDpGetVSPeriod(enumSourceSearchPort);
                  }
