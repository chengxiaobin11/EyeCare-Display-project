 555          bit ScalerMeasureCheckInterlaceVst(WORD usVstart, WORD usVend)
 556          {
 557   1          if(usVstart == g_stActiveRegion.usVActiveStart)
 558   1          {
 559   2              // For 1035i
 560   2              if((usVend - usVstart) == (g_stActiveRegion.usVActiveEnd - g_stActiveRegion.usVActiveStart))
 561   2              {
