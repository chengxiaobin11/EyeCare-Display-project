  65          // Description  : Initial measure interface
  66          // Input Value  : enumSourceType: source type
  67          //              : enumSourceSearchPort: port type
  68          // Output Value : None
  69          //--------------------------------------------------
  70          void ScalerMeasureInterfaceInitial(EnumSourceTypeDef enumSourceType, EnumSourceSearchPort *penumSourceSear
             -chPort)
  71          {
  72   1          penumSourceSearchPort = penumSourceSearchPort;
  73   1      
  74   1          switch(enumSourceType)
  75   1          {
  76   2      #if(_VGA_SUPPORT == _ON)
  77   2              case _SOURCE_VGA:
  78   2      
  79   2                  // Special case for small DVS width
  80   2                  if(ScalerGetDataPortBit(P0_5C_SYNC_PROC_PORT_ADDR, _P0_5D_PT_05_CLAMP_CTRL1, (_BIT7 | _BIT6)) 
             -== (_BIT7 | _BIT6))
  81   2                  {
  82   3                      if(ScalerSyncProcGetDeVsyncWidth() >= 4)
  83   3                      {
  84   4                          ScalerSetDataPortBit(P0_5C_SYNC_PROC_PORT_ADDR, _P0_5D_PT_05_CLAMP_CTRL1, ~(_BIT7 | _B
             -IT6), 0x00);
  85   4                      }
  86   3                  }
  87   2      
  88   2                  // Hsync Measure Source from SeHS or DeHS by CR49[6]
  89   2                  ScalerSetBit(P0_49_SYNC_CTRL, ~_BIT2, _BIT2);
  90   2      
  91   2                  break;
  92   2      #endif
  93   2      
  94   2      #if((_DVI_SUPPORT == _ON) || (_HDMI_SUPPORT == _ON))
  95   2              case _SOURCE_HDMI:
  96   2              case _SOURCE_DVI:
  97   2                  // Reset TMDS HS/VS polarity
  98   2                  ScalerSetBit(P2_AF_TMDS_WDC, ~(_BIT3 | _BIT2), 0x00);
  99   2      
 100   2                  // reset Tmds De only mode Hs = 72
 101   2                  ScalerTMDSSetDeOnlyModeConfig(_D0_INPUT_PORT, _DE_ONLY_HS_72T);
 102   2                  break;
C51 COMPILER V8.12   RL6463_SERIES_MEASURE                                                 03/10/2025 13:50:46 PAGE 3   

 103   2      #endif
 104   2      
 105   2              default:
 106   2                  break;
 107   2          }
 108   1      }
