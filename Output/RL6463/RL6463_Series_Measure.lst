 566   2              {
 567   3                  // For 487i
 568   3                  ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~_BIT6, (~(ScalerGetByte(P0_32_SCALE_CONTROL_REG)) & _BI
             -T6));
 569   3              }
 570   2          }
 571   1          else if(abs(usVstart - g_stActiveRegion.usVActiveStart) == 0x01)
 572   1          {
 573   2              StructAutoActiveData stAutoActiveData;
 574   2              memset(&stAutoActiveData, 0, sizeof(StructAutoActiveData));
