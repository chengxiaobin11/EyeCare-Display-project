             -;
 588   2      
 589   2              if((ScalerTimerWaitForEvent(_EVENT_IVS) == _FALSE) ||
 590   2                 (ScalerTimerWaitForEvent(_EVENT_IVS) == _FALSE) ||
 591   2                 (ScalerTimerWaitForEvent(_EVENT_IVS) == _FALSE))
 592   2              {
 593   3                  return _FALSE;
 594   3              }
 595   2      
 596   2              // Pop up auto-function result
