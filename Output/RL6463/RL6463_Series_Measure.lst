 432          //--------------------------------------------------
 433          // Description  : Initialization for Picture Position <easure by Auto Function Measure
 434          // Input Value  : EnumMeasureFieldSelect --> Measure for Even or Odd Field
 435          // Output Value : None
 436          //--------------------------------------------------
 437          void ScalerMeasureSetAuto(EnumMeasureFieldSelect enumFieldSelect)
 438          {
 439   1          // Disable auto-function
 440   1          ScalerSetBit(P0_7D_AUTO_ADJ_CTRL1, ~_BIT0, 0x00);
 441   1      
 442   1          // Set auto VS delay to 0
 443   1          ScalerSetBit(P0_1E_M1_VGIP_HV_DELAY, ~(_BIT5 | _BIT4), 0x00);
 444   1      
 445   1          if(enumFieldSelect == _EVEN_FIELD_MEASURE)
 446   1          {
 447   2              // Field Select to Even, Disable LPF, Disable Accelecration Mode, Vertical Boundary Search 1 pixel
             -, Select B channel
 448   2              ScalerSetByte(P0_7A_AUTO_ADJ_CTRL0, 0x80);
 449   2          }
 450   1          else if(enumFieldSelect == _ODD_FIELD_MEASURE)
 451   1          {
 452   2              // Field Select to Odd, Disable LPF, Disable Accelecration Mode, Vertical Boundary Search 1 pixel,
             - Select B channel
 453   2              ScalerSetByte(P0_7A_AUTO_ADJ_CTRL0, 0xC0);
 454   2          }
 455   1          else
 456   1          {
 457   2              // Disable Field Select, Disable LPF, Disable Accelecration Mode, Vertical Boundary Search 1 pixel
C51 COMPILER V8.12   RL6463_SERIES_MEASURE                                                 03/10/2025 13:50:46 PAGE 9   

             -, Select B channel
 458   2              ScalerSetByte(P0_7A_AUTO_ADJ_CTRL0, 0x00);
 459   2          }
 460   1      
 461   1          // Set HW auto-phase: step = 31
 462   1          ScalerSetByte(P0_7B_HW_AUTO_PHASE_CTRL0, 0xF8);
 463   1      
