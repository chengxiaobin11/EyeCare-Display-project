 120          //--------------------------------------------------
 121          // Description  : Apply Display Timing Gen Double Buffer
 122          // Input Value  : None
 123          // Output Value : None
 124          //--------------------------------------------------
 125          void ScalerMDomainDisplayTimingGenDBApply(EnumDBApply enumDBApply)
 126          {
 127   1          if(enumDBApply != _DB_APPLY_NONE)
 128   1          {
 129   2              // Check if Display Timing Gen DB is enabled
 130   2              if(ScalerGetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, _BIT7) == 0x00)
 131   2              {
 132   3                  return;
 133   3              }
 134   2      
 135   2              // Check D domain status
 136   2              if((ScalerGetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, _BIT0) == 0x00) ||
 137   2                 (GET_DPLL_POWER_STATUS() == _FALSE))
 138   2              {
 139   3                  // Disable Double Buffer
 140   3                  ScalerSetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, ~_BIT7, 0x00);
 141   3                  return;
 142   3              }
 143   2      
 144   2              // Apply Display Timing Gen Double Buffer
 145   2              ScalerSetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, ~_BIT6, _BIT6);
 146   2      
 147   2              if(enumDBApply == _DB_APPLY_POLLING)
 148   2              {
 149   3                  // Wait Display Timing Gen double buffer
 150   3                  if(ScalerTimerPollingFlagProc(_DOUBLE_BUFFER_WAIT_TIME, P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, _B
             -IT6, 0) == _FALSE)
 151   3                  {
 152   4                      // Disable Double Buffer
 153   4                      ScalerSetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, ~_BIT7, 0x00);
 154   4                  }
 155   3              }
 156   2          }
 157   1      }
