  48          // Output Value : None
C51 COMPILER V8.12   RL6463_SERIES_MDOMAIN                                                 03/10/2025 13:50:46 PAGE 2   

  49          // Note : Only for Frame Sync case
  50          //--------------------------------------------------
  51          void ScalerMDomainControlDBApply(void)
  52          {
  53   1          bit bFreeRunEn = _FALSE;
  54   1      
  55   1          // Enable double buffer
  56   1          if((GET_MEMORY_SELECT() == _FRAME_SYNC_LINE_BUFFER) || (GET_MEMORY_SELECT() == _FRAME_SYNC_MEMORY))
  57   1          {
  58   2              if(ScalerGetBit(P0_10_M1_VGIP_CTRL, _BIT1) == _BIT1)
  59   2              {
  60   3                  // Avoid (Current_IVStart + IVHeight) > IVToal + New_IVSDelay in digital capture
  61   3                  PDATA_WORD(0) = (g_stInputTimingData.usVStart + ScalerVgipGetCaptureVStartPosition() + g_stMDo
             -mainInputData.usVHeight);
  62   3              }
  63   2              else
  64   2              {
  65   3                  // Avoid (Current_IVSDelay + IVStart + IVHeight) > IVToal + New_IVSDelay in analog capture
  66   3                  PDATA_WORD(0) = (ScalerVgipGetCaptureVDelay() + ScalerVgipGetCaptureVStartPosition() + g_stMDo
             -mainInputData.usVHeight);
  67   3              }
  68   2      
  69   2              bFreeRunEn = (PDATA_WORD(0) > g_stMDomainInputData.usVTotal) ? (_TRUE) : (_FALSE);
  70   2      
  71   2      
  72   2              if(bFreeRunEn == _TRUE)
  73   2              {
  74   3                  ScalerTimerWaitForEvent(_EVENT_DEN_START);
  75   3      
  76   3                  // Set Free run
  77   3                  ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT3, 0x00);
  78   3      
  79   3                  ScalerSetDataPortBit(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_25_MN_FRAME_RATE_EN, ~_BIT7, 0x
             -00);
  80   3              }
  81   2      
  82   2              // I-domain & D-domain apply polling
  83   2              ScalerGlobalIDDomainDBApply(_DB_APPLY_POLLING);
  84   2      
  85   2              if(bFreeRunEn == _TRUE)
  86   2              {
  87   3                  if(GET_MEMORY_DVF_SELECT() == _1_IVF)
  88   3                  {
  89   4                      ScalerTimerWaitForEvent(_EVENT_IVS);
  90   4                      ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  91   4      
  92   4                      // Set Frame sync
  93   4                      ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT3, _BIT3);
  94   4                  }
  95   3              }
  96   2          }
  97   1          else
  98   1          {
  99   2              // I-domain & D-domain apply polling
 100   2              ScalerGlobalIDDomainDBApply(_DB_APPLY_POLLING);
 101   2          }
 102   1      }
