 108          //--------------------------------------------------
 109          bit ScalerMDomainMemoryCheck(void)
 110          {
 111   1          // Check fifo under/overflow and Input HVsync error flag, Display Vsync timeout flag
 112   1          if((ScalerGetBit(P0_02_STATUS0, (_BIT6 | _BIT5 | _BIT1 | _BIT0)) != 0x00) || (ScalerGetBit(P0_0C_WATCH
             -_DOG_CTRL0, _BIT0) != 0x00))
 113   1          {
 114   2              return _FALSE;
 115   2          }
 116   1      
 117   1          return _TRUE;
 118   1      }
