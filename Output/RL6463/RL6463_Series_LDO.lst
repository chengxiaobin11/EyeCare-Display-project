  47          
C51 COMPILER V8.12   RL6463_SERIES_LDO                                                     03/10/2025 13:50:46 PAGE 2   

  48          
  49          //****************************************************************************
  50          // FUNCTION DEFINITIONS
  51          //****************************************************************************
  52          
  53          //--------------------------------------------------
  54          // Description  : LDO Power Control.
  55          // Input Value  : ucPorStatus    --> _POWER_STATUS_NORMAL/_POWER_STATUS_SAVING/_POWER_STATUS_OFF Select.
  56          // Output Value : None
  57          //--------------------------------------------------
  58          void ScalerLDOPowerControl(EnumPowerStatus enumPorStatus)
  59          {
  60   1          bit bLDOSupport = (_IMD_DOMAIN_ULTRA_HIGH_SPEED_SUPPORT == _OFF);
  61   1      
  62   1      #ifdef _76PIN_PIN_21
  63   1          bLDOSupport = _TRUE;
  64   1      #endif
  65   1      
  66   1          if((bLDOSupport == _TRUE) &&
  67   1             ((bit)PCB_EMBEDDED_LDO_DETECT() == _EMBEDDED_LDO_ON))
  68   1          {
  69   2              switch(enumPorStatus)
  70   2              {
  71   3                  case _POWER_STATUS_NORMAL:
  72   3      
  73   3      #if(_IMD_DOMAIN_ULTRA_HIGH_SPEED_SUPPORT == _ON)
  74   3                      // Select LDO-D voltage output is 1.04V
  75   3                      ScalerSetBit(P62_03_EBD_REGLATOR_D_CTRL1, ~(_BIT2 | _BIT1 | _BIT0), (_BIT2 | _BIT0));
  76   3      #else
                              // Select LDO-D voltage output is 1.0V
                              ScalerSetBit(P62_03_EBD_REGLATOR_D_CTRL1, ~(_BIT2 | _BIT1 | _BIT0), _BIT2);
              #endif
  80   3      
  81   3                      break;
  82   3      
  83   3                  case _POWER_STATUS_OFF:
  84   3                  case _POWER_STATUS_SAVING:
  85   3      
  86   3                      // Select LDO-D voltage output is 0.96V
  87   3                      ScalerSetBit(P62_03_EBD_REGLATOR_D_CTRL1, ~(_BIT2 | _BIT1 | _BIT0), (_BIT1 | _BIT0));
  88   3      
  89   3                      break;
  90   3      
  91   3                  default:
  92   3      
  93   3                      break;
  94   3              }
  95   2          }
  96   1          else
  97   1          {
  98   2              // Avoiding Complier Error
  99   2              enumPorStatus = enumPorStatus;
 100   2      
 101   2              // Disable LDO-D
 102   2              ScalerSetBit(P62_03_EBD_REGLATOR_D_CTRL1, ~_BIT7, 0x00);
 103   2          }
 104   1      }
