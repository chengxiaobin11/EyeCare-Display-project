 157          //--------------------------------------------------
 158          // Description  : SDRAM Mclk Gen Reset
 159          // Input Value  : None
 160          // Output Value : None
 161          //--------------------------------------------------
 162          void ScalerSdramMclkGenReset(void)
 163          {
 164   1          // Set Mclk Gen Local Reset
 165   1          ScalerSetBit(P4_A8_SDR_CLK_ALIGN, ~_BIT7, _BIT7);
 166   1      
 167   1          // Delay Time us [300,x] Waiting for SDRAM Mclk Reset
 168   1          DELAY_XUS(300);
 169   1      
 170   1          // Set Mclk Gen Local Reset
 171   1          ScalerSetBit(P4_A8_SDR_CLK_ALIGN, ~_BIT7, 0x00);
 172   1      }
