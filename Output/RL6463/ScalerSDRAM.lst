                  ScalerSetByte(P4_AC_SDR_RSC_CAP1, 0x40);
                  ScalerSetByte(P4_AE_SDR_RSC_MAIN, 0x80);
                  ScalerSetByte(P4_B0_SDR_RSC_RTC_RD, 0x04);
