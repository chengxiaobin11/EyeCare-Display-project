 367          // Output Value : None
 368          //--------------------------------------------------
 369          void ScalerSdramTxClkSearchPhase(void)
 370          {
 371   1          BYTE ucCount = 0;
 372   1          BYTE ucInitialPhase = 0;
 373   1          BYTE ucPhase0 = _FALSE;
 374   1          BYTE ucEndPhase = 0;
 375   1          BYTE ucTempDiffPhase = 0;
 376   1          BYTE ucBestPhase = 0;
 377   1          BYTE ucHalfCycle = 0;
 378   1          bit bPhaseSearch = _FALSE;
 379   1      
 380   1          // Set Tx Clk Initial Phase
 381   1          ScalerSetByte(P4_C1_TX_CLK_DLY2, 0x00);
 382   1      
 383   1          // Enable Tx Clk Calibration Circuit
 384   1          ScalerSdramTxClkCalibrationEnable(_ON);
 385   1      
 386   1      #if(_SDRAM_PHASE_CALIBRATION_2T == _ON)
                  ucHalfCycle = (g_pucSdramDelayChain[0] * 4); // Test 2T
              #else
 389   1          ScalerSetBit(P4_C2_SDR_RX_CLK_DLY1, ~(_BIT6 | _BIT5), _BIT5);
 390   1          ScalerSetBit(P4_C4_SDR_RX_CLK_DLY3, ~(_BIT6 | _BIT5), _BIT5);
 391   1      
 392   1          ucHalfCycle = (g_pucSdramDelayChain[0] * 2); // Test 1T
 393   1      #endif
 394   1      
 395   1          DebugMessageMemoryPhaseCal("======================", 0x00);
 396   1          DebugMessageMemoryPhaseCal("==TX Clk Serch Phase==", 0x00);
 397   1          DebugMessageMemoryPhaseCal("===Tx phase half T====", g_pucSdramDelayChain[0]);
 398   1          DebugMessageMemoryPhaseCal("======================", 0x00);
 399   1      
 400   1          for(ucCount = 0; ucCount < ucHalfCycle; ucCount++)
 401   1          {
 402   2              ScalerSetByte(P4_C1_TX_CLK_DLY2, ucCount);
 403   2      
 404   2              ScalerSetBit(P4_BE_SDR_RX_PHASE_CALIBRATION, ~_BIT6, _BIT6);
 405   2      
 406   2              ScalerSdramControlReset();
 407   2      
 408   2              g_ucPhaseCount = ScalerSdramMcuReadWriteCheck((ucCount >> 6), ((ucCount << 2) & 0xFC), 0x00, _OFF)
             -;
 409   2      
 410   2              // avoid phase all pass case
 411   2              if(ucCount == (ucHalfCycle - 1))
 412   2              {
 413   3                  g_ucPhaseCount = _FALSE;
 414   3              }
 415   2      
 416   2              if((g_ucPhaseCount == _TRUE) && (bPhaseSearch == _FALSE))
 417   2              {
C51 COMPILER V8.12   SCALERSDRAM                                                           03/10/2025 13:50:27 PAGE 8   

 418   3                  ucInitialPhase = ucCount;
 419   3                  DebugMessageMemoryPhaseCal("ucInitialPhase", ucInitialPhase);
 420   3      
 421   3                  bPhaseSearch = _ON;
 422   3      
 423   3                  // Checking the Phase0 is good phase or not
 424   3                  if((ucCount == 0) && (ucInitialPhase == 0))
 425   3                  {
 426   4                      ucPhase0 = _TRUE;
 427   4                  }
 428   3              }
 429   2      
 430   2              if((g_ucPhaseCount == _FALSE) && (bPhaseSearch == _ON))
 431   2              {
 432   3                  ucEndPhase = ucCount;
 433   3                  DebugMessageMemoryPhaseCal("ucEndPhase", ucEndPhase);
 434   3      
 435   3                  pData[2] = ucEndPhase - ucInitialPhase;
 436   3      
 437   3                  if(pData[2] > ucTempDiffPhase)
 438   3                  {
 439   4                      ucTempDiffPhase = pData[2];
 440   4                      DebugMessageMemoryPhaseCal("ucTempDiffPhase", ucTempDiffPhase);
 441   4                      ucBestPhase = (ucInitialPhase + ucEndPhase) / 2;
 442   4                      DebugMessageMemoryPhaseCal("ucBestPhase", ucBestPhase);
 443   4      #if(_SDRAM_PHASE_CALIBRATION_2T == _ON)
                              // The parameters of oprmization
                              g_ucTempDiffPhase = ucTempDiffPhase;
                              g_ucTempBestPhase = (ucBestPhase % (g_pucSdramDelayChain[0] * 2)); // Choice midpoint of t
             -he max range
                              g_ucTempCoarseDly = ScalerGetByte(P4_C2_SDR_RX_CLK_DLY1);
                              g_ucTempCASLatn = ScalerGetByte(P4_A5_SDR_MEM_TYPE);
              #endif
 450   4                  }
 451   3      
 452   3                  bPhaseSearch = _FALSE;
 453   3              }
 454   2      
 455   2      #if(_SDRAM_MCU_ALL_PHASE_CHECK == _ON)
                      DebugMessageMemoryPhaseCal("counter", ucCount);
                      DebugMessageMemoryPhaseCal("Tx Clk ", g_ucPhaseCount);
              #endif
 459   2          }
 460   1      
 461   1          if(ucPhase0 == _TRUE)
 462   1          {
 463   2              ucBestPhase = 0;
 464   2          }
 465   1          else
 466   1          {
 467   2              ucBestPhase = ucBestPhase;
 468   2          }
 469   1      
 470   1          g_pucSdramInitialPhase[0] = ucBestPhase;
