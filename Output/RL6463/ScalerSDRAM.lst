 174          //--------------------------------------------------
 175          // Description  : Sdram system initial
 176          // Input Value  : None
 177          // Output Value : None
 178          //--------------------------------------------------
 179          void ScalerSdramSystemInitial(void)
 180          {
 181   1          // Set Sdram Pinshare Initial
 182   1          ScalerSdramPinshareInitial();
 183   1      
 184   1          // Set Sdram Module Active to Read and Write delay
 185   1          ScalerSetBit(P4_A1_SDR_CTRL0, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT4 | _BIT3 | _BIT1
             - | _BIT0));
 186   1      
 187   1          // Set Sdram Module CAS Latency
 188   1          ScalerSetBit(P4_A2_SDR_CTRL1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT3 | _BIT2 | _BIT1), (_BIT6 | _BIT5 | _BIT2
             -));
 189   1      
 190   1          // Set Sdram Auto Refresh Time
 191   1          ScalerSetByte(P4_A3_SDR_AREF_TIME, 0x0D);
 192   1      
 193   1          // Set Sdram Precharge Duty Cycle
 194   1          ScalerSetBit(P4_A4_SDR_PRCG, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT1 | _BIT0));
 195   1      
 196   1          // Set Sdram Memory Type & Control CAS Latency = 1
 197   1          ScalerSetBit(P4_A5_SDR_MEM_TYPE, ~(_BIT7 | _BIT6 | _BIT5 | _BIT2 | _BIT1 | _BIT0), (_BIT5 | _BIT1));
 198   1      
 199   1          // Set Sdram Slew Rate SDRAM mode
 200   1          ScalerSetBit(P4_A6_SDR_SLEW_RATE, ~_BIT7, _BIT7);
 201   1      
 202   1          // Set Sdram Refresh time 15.6us
 203   1          ScalerSetByte(P4_A7_SDR_AREF_CNT, 0x0D);
 204   1      
 205   1      #if(_SDRAM_PHASE_CALIBRATION == _ON)
 206   1          ScalerSdramTokenRingSet();
 207   1      #endif
 208   1      
 209   1          // Set Sdram Read SRAM Length
 210   1          ScalerSetByte(P4_BD_SDR_MCU_RD_LEN, 0x04);
 211   1      
 212   1          // Set Sdram Control Reset
 213   1          ScalerSdramControlReset();
 214   1      
 215   1          // Set Sdram Control Reset Ready
 216   1          ScalerTimerPollingFlagProc(5, P4_B5_SDR_ABTR_STATUS1, _BIT0, _TRUE);
 217   1      }
