 124          //--------------------------------------------------
 125          // Description  : DDR Power On/Off
 126          // Input Value  : None
 127          // Output Value : None
 128          //--------------------------------------------------
 129          void ScalerSdramPowerControl(bit bOn)
 130          {
 131   1      #if(_MPLL_STRUCT_TYPE != _MPLL_STRUCT_COMBO_M2PLL)
                  // Set MPLL CLK
                  ScalerPLLSetMPLLFreq((DWORD)_MEMORY_PLL_CLOCK * 1000);
              #endif
 135   1      
 136   1          // Set Mclk Gen Reset Align MPLL
 137   1          ScalerSdramMclkGenReset();
 138   1      
 139   1          if(bOn == _ON)
 140   1          {
 141   2              // Set Sdram Module Power Status
 142   2              ScalerSdramPowerEnable(_ON);
 143   2      
 144   2              // Set Sdram System Initial
 145   2              ScalerSdramSystemInitial();
 146   2          }
 147   1          else
 148   1          {
 149   2              // Set Sdram Module Power Status
 150   2              ScalerSdramPowerEnable(_OFF);
 151   2      
 152   2              // Set Sdram Module Power Status
 153   2              ScalerSdramMpllPowerDown();
 154   2          }
 155   1      }
