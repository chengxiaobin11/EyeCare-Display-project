             -otectInfo.ucOvpDebounce);
                  stTypeCUserProtectInfo.ucUvpDebounce = ((stTypeCUserProtectInfo.ucUvpDebounce > 5) ? 5 : stTypeCUserPr
             -otectInfo.ucUvpDebounce);
                  stTypeCUserProtectInfo.ucOcpDebounce = ((stTypeCUserProtectInfo.ucOcpDebounce > 5) ? 5 : stTypeCUserPr
             -otectInfo.ucOcpDebounce);
              
                  stTypeCUserProtectInfo.enumPeakCurrentProtect = _TYPE_C_PEAK_CURRENT_PROTECT_ENABLE;
              
                  *pstTypeCUserProtectInfo = stTypeCUserProtectInfo;
              }
