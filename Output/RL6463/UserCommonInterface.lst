                              {
                                  enumMstTargetPort = _DP_MST_RX6_PORT;
                              }
              
                              break;
              #endif
              
                          default:
              
                              break;
                      }
                  }
              
                  if(SysSourceGetScanType() == _SOURCE_SWITCH_FIXED_PORT)
                  {
                      if(GET_PORT_TYPE(SysSourceGetInputPortType(SysSourceGetInputPort())) == _PORT_DP)
                      {
                          return enumMstTargetPort;
