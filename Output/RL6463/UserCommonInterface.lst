                              {
                                  enumMstTargetPort = _DP_MST_RX0_PORT;
                              }
              
                              break;
              #endif
              
              #if((_D1_INPUT_PORT_TYPE == _D1_DP_PORT) && (_D1_DP_MST_PORT_SUPPORT == _ON))
                          case _D1_INPUT_PORT:
              
