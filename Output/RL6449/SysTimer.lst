                      // Timer Counter
                      g_usTimerCounter += 1;
              
              #if(_DEBUG_MESSAGE_SUPPORT == _ON)
                      g_usMeasureCounter += 1;
              #endif
                  }
                  else
                  {
                      g_ucTimerQuarterCount++;
                  }
              
                  UserInterfaceTimer2InstantAccess_EXINT();
              
              #endif
