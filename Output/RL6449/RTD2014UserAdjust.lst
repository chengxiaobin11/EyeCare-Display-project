              #if(_D2_INPUT_PORT_TYPE == _D2_DP_PORT)
                  if(ScalerSyncDpCableStatus(_D2_INPUT_PORT) == _TRUE)
                  {
                      if(GET_DP_EMBEDDED_SWITCH_SELECT() != _D2_INPUT_PORT)
