1545          
1546          //--------------------------------------------------
1547          // Description  : Get the free page number of flash
1548          // Input Value  : None
1549          // Output Value : Free page index
1550          //--------------------------------------------------
1551          BYTE RTDFlashGetFreePage(void)
1552          {
1553   1          BYTE ucPageID = _START_OF_PAGEID;
1554   1          BYTE ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1555   1      
1556   1          // If the _END_PAGE page has the biggest move count, suppose first page is free page
1557   1          if(g_ulFlashMoveCount > 0)
1558   1          {
1559   2              if(g_ucFlashLastPage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1560   2              {
1561   3                  ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1562   3              }
1563   2              else
1564   2              {
1565   3                  ucFreePage = g_ucFlashLastPage + 1;
1566   3              }
1567   2          }
1568   1      
1569   1          // Check the supposed free page is actual free page which has not been used ever
1570   1          do
1571   1          {
1572   2              if(ucFreePage == g_pucFlashPageArr[ucPageID])
1573   2              {
1574   3                  if(ucFreePage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1575   3                  {
1576   4                      ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1577   4                  }
1578   3                  else
1579   3                  {
1580   4                      ucFreePage += 1;
1581   4                  }
1582   3      
1583   3                  ucPageID = _START_OF_PAGEID;
1584   3              }
C51 COMPILER V9.01   RTD2014NVRAMOSD                                                       05/24/2025 16:34:22 PAGE 27  

1585   2              else
1586   2              {
1587   3                  ucPageID++;
1588   3              }
1589   2          }
1590   1          while(ucPageID <= _END_OF_PAGEID);
1591   1      
1592   1          return ucFreePage;
1593   1      }
1594          
1595          //--------------------------------------------------
1596          // Description  : Check the page is vaild or not
1597          // Input Value  : ucPage: The page to be check, must between 0 and (_END_PAGE - _START_PAGE)
1598          // Output Value : _TRUE means the page is valid, _FLASE is invalid
1599          //--------------------------------------------------
1600          bit RTDFlashIsPageInfoValid(BYTE ucPage)
1601          {
1602   1          WORD usPageInfoAddr = ucPage * _FLASH_PAGE_SIZE;
1603   1          BYTE ucPageInfoChecksum = 0;
1604   1          BYTE pucPageInfo[5] = {0};
1605   1          BYTE pucPageInfoTemp[4] = {0};
1606   1      
1607   1          UserCommonFlashRead(_SYSTEM_EEPROM_EMULATION_FLASH_BANK, usPageInfoAddr + _PAGEINFO_CHECKSUM_ADDR, 5, 
             -pucPageInfo);
1608   1          pucPageInfoTemp[0] = pucPageInfo[1];
1609   1          pucPageInfoTemp[1] = pucPageInfo[2];
1610   1          pucPageInfoTemp[2] = pucPageInfo[3];
1611   1          pucPageInfoTemp[3] = pucPageInfo[4];
1612   1          ucPageInfoChecksum = UserCommonFlashCalculateCheckSumData(pucPageInfoTemp, 4);
1613   1          ucPageInfoChecksum = (ucPageInfoChecksum & 0x7F);
1614   1      
1615   1          if(ucPageInfoChecksum == pucPageInfo[0])
1616   1          {
1617   2              return _TRUE;
1618   2          }
1619   1      
1620   1          return _FALSE;
1621   1      }
1622          
1623          //--------------------------------------------------
1624          // Description  : Initial data page
1625          // Input Value  : None
1626          // Output Value : None
1627          //--------------------------------------------------
1628          void RTDFlashInitialDataPage(BYTE ucPageID)
1629          {
1630   1          WORD usAddr = _SYSTEM_EEPROM_EMULATION_START_PAGE * _FLASH_PAGE_SIZE;
1631   1          BYTE ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1632   1         // BYTE ucVersionCode = 0;
1633   1         // BYTE ucChecksum = 0;
1634   1      
1635   1          ucFreePage = RTDFlashGetFreePage();
1636   1          // Initial page index
1637   1          g_pucFlashPageArr[ucPageID] = ucFreePage;
1638   1          // Initial address
1639   1          g_pusFlashAddrArr[ucPageID] = 0;
1640   1          // Initial move count
