 204          //--------------------------------------------------
 205          // Description  : IVSdelay need to setting several times
 206          // Input Value  : Initial IVS delay
 207          // Output Value : N.A.
 208          //--------------------------------------------------
 209          void ScalerIDomainVgipIVDelayIVstStepAdjust(WORD usInitialIVDelay)
 210          {
 211   1          WORD usIVDelayStep = 1;
 212   1          WORD usIVDelayTemp = 0;
 213   1          BYTE ucSettingCounter = 0;
 214   1      
 215   1          WORD usDVtotal = GET_MDOMAIN_OUTPUT_VTOTAL();
 216   1      
 217   1          // Measure DVtotal in frame sync mode
 218   1          ScalerSetBit(P0_43_FS_DELAY_FINE_TUNE, ~_BIT5, 0x00);
 219   1          ScalerSetBit(P0_44_LAST_LINE_H, ~_BIT7, _BIT7);
 220   1      
 221   1          GET_DVTOTAL_LASTLINE(usDVtotal);
 222   1          SET_MDOMAIN_OUTPUT_VTOTAL(usDVtotal);
 223   1      
 224   1          if(g_stMDomainOutputData.usVTotal > (g_stMDomainOutputData.usVBackStart + g_stMDomainOutputData.usVBac
             -kHeight + _PANEL_FRONT_PORCH_LIMIT))
C51 COMPILER V9.01   SCALERIDOMAIN                                                         05/24/2025 15:51:10 PAGE 5   

 225   1          {
 226   2              usIVDelayStep = (g_stMDomainOutputData.usVTotal - g_stMDomainOutputData.usVBackStart - g_stMDomain
             -OutputData.usVBackHeight - _PANEL_FRONT_PORCH_LIMIT);
 227   2              usIVDelayStep = GET_DWORD_MUL_DIV(usIVDelayStep, g_stMDomainInputData.usVTotal, g_stMDomainOutputD
             -ata.usVTotal);
 228   2      
 229   2              if(usIVDelayStep < 1)
 230   2              {
 231   3                  usIVDelayStep = 1;
 232   3              }
 233   2          }
 234   1          else
 235   1          {
 236   2              DebugMessageFS("warning !!! Aspect ratio/ overscan maybe have garbage", 0);
 237   2          }
 238   1      
 239   1          ucSettingCounter = (abs(usInitialIVDelay - ScalerVgipGetCaptureVDelay()) / usIVDelayStep) + 1;
 240   1      
 241   1          do
 242   1          {
 243   2              if(usInitialIVDelay > ScalerVgipGetCaptureVDelay())
 244   2              {
 245   3                  // Set VGIP V delay
 246   3                  ScalerVgipSetCaptureVDelay(usInitialIVDelay);
 247   3      
 248   3                  // Set VGIP V Capture  Start Position
 249   3                  ScalerVgipSetCaptureVStartPosition(g_stMDomainInputData.usVStart);
 250   3              }
 251   2              else
 252   2              {
 253   3                  if((ScalerVgipGetCaptureVDelay() - usInitialIVDelay) <= usIVDelayStep)
 254   3                  {
 255   4                      // Set VGIP V delay
 256   4                      ScalerVgipSetCaptureVDelay(usInitialIVDelay);
 257   4      
 258   4                      // Set VGIP V Capture  Start Position
 259   4                      ScalerVgipSetCaptureVStartPosition(g_stMDomainInputData.usVStart);
 260   4                  }
 261   3                  else
 262   3                  {
 263   4                      usIVDelayTemp = ScalerVgipGetCaptureVDelay() - usIVDelayStep;
 264   4      
 265   4                      // Step adjust IVdelay
 266   4                      ScalerVgipSetCaptureVDelay(usIVDelayTemp);
 267   4      
 268   4                      // Step adjust IVstart
 269   4                      ScalerVgipSetCaptureVStartPosition(g_stMDomainInputData.usVStart + usInitialIVDelay - usIV
             -DelayTemp);
 270   4                  }
 271   3      
 272   3                  DebugMessageFS("IVDelay step step", ScalerVgipGetCaptureVDelay());
 273   3              }
 274   2      
 275   2              ScalerGlobalIDomainDBApply(_DB_APPLY_POLLING);
 276   2      
 277   2              ucSettingCounter--;
 278   2          }
 279   1          while((usInitialIVDelay != ScalerVgipGetCaptureVDelay()) && (ucSettingCounter > 0));
 280   1      }
