 350          //--------------------------------------------------
 351          // Description  : Switch DDC pin to GPIO or viceversa
 352          // Input Value  : ucPinType -->
 353          //                PIN65-65/212-213/214-215 for GPIO/DDC
 354          // Output Value : None
 355          //--------------------------------------------------
 356          void ScalerPinshareGpioDdcPinSwitch(BYTE ucPinType)
 357          {
 358   1          switch(ucPinType)
 359   1          {
 360   2              case _DDC_VGA_SWITCH_GPIO:
 361   2                  ScalerSetBit(P10_02_PIN_SHARE_CTRL12__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_OPEN_DRAIN))); // Pin_65
 362   2                  ScalerSetByte(P10_03_PIN_SHARE_CTRL13__ADION, (BYTE)_GPIO_OPEN_DRAIN); // Pin_66
 363   2                  break;
 364   2      
 365   2              case _DDC_VGA_SWITCH_DDC:
 366   2                  ScalerSetBit(P10_02_PIN_SHARE_CTRL12__ADION, ~_BIT7, 0x00); // Pin_65-66, DDCVGA
 367   2                  break;
 368   2      
 369   2              case _DDC2_SWITCH_GPIO:
 370   2                  ScalerSetBit(P10_49_PIN_SHARE_CTRLB1__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_OPEN_DRAIN))); // Pin_212
 371   2                  ScalerSetByte(P10_4A_PIN_SHARE_CTRLB2__ADION, (BYTE)_GPIO_OPEN_DRAIN); // Pin_213
 372   2                  break;
 373   2      
 374   2              case _DDC2_SWITCH_DDC:
 375   2                  ScalerSetBit(P10_49_PIN_SHARE_CTRLB1__ADION, ~_BIT7, 0x00); // Pin_212/213, DDC2
 376   2                  break;
 377   2      
 378   2              case _DDC2_SWITCH_GPI:
 379   2                  ScalerSetBit(P10_49_PIN_SHARE_CTRLB1__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_INPUT))); // Pin_212
 380   2                  ScalerSetByte(P10_4A_PIN_SHARE_CTRLB2__ADION, (BYTE)_GPIO_INPUT); // Pin_213
 381   2                  break;
 382   2      
 383   2              case _DDC3_SWITCH_GPIO:
 384   2                  ScalerSetBit(P10_4B_PIN_SHARE_CTRLB3__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_OPEN_DRAIN))); // Pin_214
 385   2                  ScalerSetByte(P10_4C_PIN_SHARE_CTRLB4__ADION, (BYTE)_GPIO_OPEN_DRAIN); // Pin_215
 386   2                  break;
 387   2      
 388   2              case _DDC3_SWITCH_DDC:
 389   2                  ScalerSetBit(P10_4B_PIN_SHARE_CTRLB3__ADION, ~_BIT7, 0x00); // Pin_214/215, DDC3
 390   2                  break;
 391   2      
 392   2              case _DDC3_SWITCH_GPI:
 393   2                  ScalerSetBit(P10_4B_PIN_SHARE_CTRLB3__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_INPUT))); // Pin_214
 394   2                  ScalerSetByte(P10_4C_PIN_SHARE_CTRLB4__ADION, (BYTE)_GPIO_INPUT); // Pin_215
 395   2                  break;
 396   2      
 397   2              default:
 398   2                  break;
 399   2          }
 400   1      }
