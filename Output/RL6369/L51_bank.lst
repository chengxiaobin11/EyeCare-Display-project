                   10992     $nomod51  NOLINES
                   10993     $nocond 
                   10994     ;------------------------------------------------------------------------------
                   10995     ;  This file is part of the BL51 / LX51 Banked Linker/Locater package
                   10996     ;  Copyright (c) 1988 - 2001 Keil Elektronik GmbH and Keil Software, Inc.
                   10997     ;  Version 2.21 (Code and Variable Banking for Classic 8051 Derivatives)
                   10998     ;------------------------------------------------------------------------------
                   10999     ;************************ Configuration Section *******************************
                   11000     ; Define maximum Number of Banks                                              *
  0010             11001     ?B_NBANKS       EQU  0x10;                  *
                   11002     ;                         ; following values are allowed: 2, 4, 8, 16, 32, 64 *
                   11003     ;                         ; for BL51 the maximum value for ?B_BANKS is 32     *
                   11004     ;                         ; for LX51 the maximum value for ?B_BANKS is 64     *
                   11005     ;                                                                             *
  0001             11006     ?B_MODE         EQU  1    ; 0 for Bank-Switching via 8051 Port                *
                   11007     ;                         ; 1 for Bank-Switching via XDATA Port               *
                   11008     ;                         ; 4 for user-provided bank switch code              *
                   11009     ;                                                                             *
  0000             11010     ?B_RTX          EQU  0    ; 0 for applications without real-time OS           *
                   11011     ;                         ; 1 for applications using the RTX-51 real-time OS  *
                   11012     ;                                                                             *
  0000             11013     ?B_VAR_BANKING  EQU  0    ; Variable Banking via L51_BANK (far memory support)*
                   11014     ;                         ; 0 Variable Banking does not use L51_BANK.A51      *
                   11015     ;                         ; 1 Variable Banking uses this L51_BANK.A51 module  *
                   11016     ; Notes: ?B_VAR_BANKING uses the 'far' and 'far const' C51 memory types to    *
                   11017     ;        extent the space for variables in RAM and/or ROM of classic 8051     *
                   11018     ;        device.  The same hardware as for code banking is used.  Program     *
                   11019     ;        code banking and variable banking share the same hardware I/O pins.  *
                   11020     ;        The C51 Compiler must be used with the VARBANKING directive.         *
                   11021     ;        Variable Banking is only supported with the LX51 linker/locater.     *
                   11022     ;                                                                             *
  00FF             11023     ?B_RST_BANK     EQU  0xFF ; specifies the active code bank number after CPU   *
                   11024     ;                         ; Reset.  Used to reduce the entries in the         *
                   11025     ;                         ; INTERBANK CALL TABLE.  The value 0xFF disables    *
                   11026     ;                         ; this LX51 linker/locater optimization.            *
                   11027     ; Note:  Interbank Call Table optimization is only possible with LX51.        *
                   11028     ;                                                                             *
                   11029     ;-----------------------------------------------------------------------------*
                   11030     ;                                                                             *
                             ENDIF;                                                                        *
                   11043     ;                                                                             *
                   11044     IF  ?B_MODE = 1;                                                              *
                   11045     ;-----------------------------------------------------------------------------*
                   11046     ; if ?BANK?MODE is 1 define the following values                              *
                   11047     ; For Bank-Switching via XDATA Port define XDATA Port Address / Bits          *
  FFFF             11048     ?B_XDATAPORT    EQU     0FFFFH   ; default is XDATA Port Address 0FFFFH       *
  0000             11049     ?B_FIRSTBIT     EQU     0        ; default is Bit 0                           *
                   11050     ;-----------------------------------------------------------------------------*
                   11051     ENDIF;                                                                        *
                   11052     ;                                                                             *
                             ENDIF;                                                                        *
                   11111     ;                                                                             *
                             ENDIF;                                                                        *
                   11132     ;                                                                             *
                   11133     ;******************************************************************************
                   11134     ;                                                                             *
                   11135     ; THEORY OF OPERATION                                                         *
                   11136     ; -------------------                                                         *
                   11137     ; The section below describes the code generated by BL51 or LX51 and the      *
                   11138     ; operation of the L51_BANK.A51 module.  BL51/LX51 generates for each         *
                   11139     ; function that is located in a code memory bank and called from the common   *
A51 MACRO ASSEMBLER  L51_BANK                                                             09/17/2025 16:28:38 PAGE    45

                   11140     ; area or a different code bank and entry into the INTRABANK CALL TABLE.  The *
                   11141     ; INTRABANK CALL TABLE is located in the SEGMENT ?BANK?SELECT and listed in   *
                   11142     ; the Linker MAP file. The entries in that TABLE have the following format:   *
                   11143     ;                                                                             *
                   11144     ;   ?FCT?1:  MOV  DPTR,#FCT     ; Load Address of target FCT                  *
                   11145     ;            JMP  ?B_BANKn      ; Switch to Bank and Jump to Target Code      *
                   11146     ;                                                                             *
                   11147     ; Instead of directly calling the function FCT, the Linker changes the entry  *
                   11148     ; to ?FCT?1.  This entry selects the bank where the function FCT is located   *
                   11149     ; and calls that function via the routines defined in this L51_BANK.A51 file. *
                   11150     ; The L51_BANK.A51 file contains two sets of functions for each bank:         *
                   11151     ;                                                                             *
                   11152     ; ?B_BANKn    is a routine which saves the entry of the ?B_SWITCHn function   *
                   11153     ;             for the current active bank on the STACK and switches to the    *
                   11154     ;             bank 'n'.  Then it jumps to the address specified by the DPTR   *
                   11155     ;             register.  It is allowed to modify the following registers in   *
                   11156     ;             the ?B_BANKn routine:  A, B, R0, DPTR, PSW                      *
                   11157     ;                                                                             *
                   11158     ; ?B_SWITCHn  is a function which selects the bank 'n'.  This function is     *
                   11159     ;             used at the end of a user function to return to the calling     *
                   11160     ;             code bank.  Only the following registers may be altered in the  *
                   11161     ;             ?B_SWITCHn function:  R0, DPTR                                  *
                   11162     ;                                                                             *
                   11163     ; The current active bank is stored in ?B_CURRENTBANK.  RTX-51 uses this      *
                   11164     ; variable to restore the code bank after a task switch.  To get correct      *
                   11165     ; results, ?B_CURRENTBANK must be set to the code bank before the hardware    *
                   11166     ; switch is done, or the code banking sequences must be interrupt protected.  *
                   11167     ;******************************************************************************
                   11168     
                   11169                     NAME    ?BANK?SWITCHING
                   11170     
                   11171                     PUBLIC  ?B_NBANKS, ?B_MODE, ?B_CURRENTBANK, ?B_MASK
                   11172                     PUBLIC  ?B_FACTOR, ?B_RST_BANK
                             ENDIF
                   11176     
                   11177     ; Standard SFR Symbols required in L51_BANK.A51
  00E0             11178     ACC     DATA    0E0H
  00F0             11179     B       DATA    0F0H
  0082             11180     DPL     DATA    82H
  0083             11181     DPH     DATA    83H
  00A8             11182     IE      DATA    0A8H
  00AF             11183     EA      BIT     IE.7
                   11184     
                   11185     
                   11186     ; generate Mask and Bank Number Information
                             ELSEIF  ?B_NBANKS <= 16
  000F             11194       MASK          EQU     00001111B
                             ENDIF
                   11200     
                             ENDIF  ; close block IF ?B_MODE = 0 *******************************************
                   11454     
                   11455     
                   11456     IF ?B_MODE = 1 ;***************************************************************
                   11457     
  0001             11458     ?B_FACTOR       EQU     1 SHL ?B_FIRSTBIT
                   11459     
  000F             11460     ?B_MASK         EQU     MASK SHL ?B_FIRSTBIT
                   11461     
                   11462     BANKN           MACRO   N
                   11463     BANK&N          EQU     N SHL ?B_FIRSTBIT
                   11464                     ENDM
                   11465     
  0000             11466     CNT             SET     0
                   11467     
                   11468                     REPT    ?B_NBANKS
                   11469                     BANKN   %CNT
