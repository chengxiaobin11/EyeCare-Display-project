                   10997     ;  STARTUP.A51:  This code is executed after processor reset.
                   10998     ;
                   10999     ;  To translate this file use A51 with the following invocation:
                   11000     ;
                   11001     ;     A51 STARTUP.A51
                   11002     ;
                   11003     ;  To link the modified STARTUP.OBJ file to your application use the following
                   11004     ;  BL51 invocation:
                   11005     ;
                   11006     ;     BL51 <your object file list>, STARTUP.OBJ <controls>
                   11007     ;
                   11008     ;------------------------------------------------------------------------------
                   11009     ;
                   11010     ;  User-defined Power-On Initialization of Memory
                   11011     ;
                   11012     ;  With the following EQU statements the initialization of memory
A51 MACRO ASSEMBLER  STARTUP                                                              09/17/2025 16:28:38 PAGE   168

                   11013     ;  at processor reset can be defined:
                   11014     ;
                   11015     ;               ; the absolute start-address of IDATA memory is always 0
  0100             11016     IDATALEN        EQU     0100H     ; the length of IDATA memory in bytes.
                   11017     ;
                   11018     ; the absolute start-address of XDATA memory
  E000             11019     XDATASTART      EQU     (0xE000)
                   11020     ; the length of XDATA memory in bytes.
  1000             11021     XDATALEN        EQU     ((0xEFFF) - (0xE000) + 1)
                   11022     ;
  0000             11023     PDATASTART      EQU     0H      ; the absolute start-address of PDATA memory
  0000             11024     PDATALEN        EQU     0H      ; the length of PDATA memory in bytes.
                   11025     ;
                   11026     ;  Notes:  The IDATA space overlaps physically the DATA and BIT areas of the
                   11027     ;          8051 CPU. At minimum the memory space occupied from the C51
                   11028     ;          run-time routines must be set to zero.
                   11029     ;------------------------------------------------------------------------------
                   11030     ;
                   11031     ;  Reentrant Stack Initilization
                   11032     ;
                   11033     ;  The following EQU statements define the stack pointer for reentrant
                   11034     ;  functions and initialized it:
                   11035     ;
                   11036     ;  Stack Space for reentrant functions in the SMALL model.
  0000             11037     IBPSTACK        EQU     0       ; set to 1 if small reentrant is used.
  0100             11038     IBPSTACKTOP     EQU     0FFH+1  ; set top of stack to highest location+1.
                   11039     ;
                   11040     ;  Stack Space for reentrant functions in the LARGE model.
  0000             11041     XBPSTACK        EQU     0       ; set to 1 if large reentrant is used.
  0000             11042     XBPSTACKTOP     EQU     0FFFFH+1; set top of stack to highest location+1.
                   11043     ;
                   11044     ;  Stack Space for reentrant functions in the COMPACT model.
  0000             11045     PBPSTACK        EQU     0       ; set to 1 if compact reentrant is used.
  0000             11046     PBPSTACKTOP     EQU     0FFFFH+1; set top of stack to highest location+1.
                   11047     ;
                   11048     ;------------------------------------------------------------------------------
                   11049     ;
                   11050     ;  Page Definition for Using the Compact Model with 64 KByte xdata RAM
                   11051     ;
                   11052     ;  The following EQU statements define the xdata page used for pdata
                   11053     ;  variables. The EQU PPAGE must conform with the PPAGE control used
                   11054     ;  in the linker invocation.
                   11055     ;
  0000             11056     PPAGEENABLE     EQU     0       ; set to 1 if pdata object are used.
                   11057     ;
  0000             11058     PPAGE           EQU     0       ; define PPAGE number.
                   11059     ;
  00A0             11060     PPAGE_SFR       DATA    0A0H    ; SFR that supplies uppermost address byte
                   11061     ;               (most 8051 variants use P2 as uppermost address byte)
                   11062     ;
                   11063     ;------------------------------------------------------------------------------
                   11064     
                   11065     ; Standard SFR Symbols
  00E0             11066     ACC     DATA    0E0H
  00F0             11067     B       DATA    0F0H
  0081             11068     SP      DATA    81H
  0082             11069     DPL     DATA    82H
  0083             11070     DPH     DATA    83H
