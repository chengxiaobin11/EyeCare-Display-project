             - 2) | (pucEdidAddr[usHfVsdbStartAddr + 10]));
              
                              if((pucEdidAddr[usHfVsdbStartAddr] & (_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0)) >= 11)
C51 COMPILER V8.12   USERCOMMONINTERFACE                                                   01/02/2025 16:32:03 PAGE 52  

                              {
