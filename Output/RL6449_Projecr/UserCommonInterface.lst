                      memset(&stHdmi21EdidVrr, 0, sizeof(stHdmi21EdidVrr));
              
                      if((pucEdidAddr[usHfVsdbStartAddr] & (_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0)) >= 8)
                      {
