 203          //--------------------------------------------------
 204          // Description  : Cache Control
 205          // Input Value  : bControl
 206          // Output Value : None
 207          //--------------------------------------------------
 208          void ScalerMcuCacheControl(bit bControl)
 209          {
 210   1          if(bControl == _ENABLE)
 211   1          {
 212   2              // Enable Cache
 213   2              MCU_FDA0_CACHE_FUNCTION |= _BIT0;
 214   2          }
 215   1          else
 216   1          {
 217   2              // Disable Cache
 218   2              MCU_FDA0_CACHE_FUNCTION &= ~_BIT0;
 219   2          }
 220   1      }
 221          
 222          //--------------------------------------------------
 223          // Description  : Send DDC Data
 224          // Input Value  : pWriteArray --> Data to be sent
 225          //                usTimeOutCnt --> Timeout
 226          // Output Value : None
 227          //--------------------------------------------------
 228          void ScalerMcuDdcciSendData(BYTE *pucWriteArray)
 229          {
C51 COMPILER V8.12   SCALERCOMMONMCU                                                       01/02/2025 16:31:10 PAGE 5   

 230   1          WORD usTimeOutCnt = _DDCCI_TIMEOUT_LIMIT;
 231   1          BYTE ucDdcciCount = 0;
 232   1      
 233   1          if((MCU_FF27_IIC_STATUS & _BIT0) == _BIT0)
 234   1          {
 235   2              g_bSrcReadDdcciAlready = _TRUE;
 236   2      
 237   2              // Clear Flag
 238   2              MCU_FF27_IIC_STATUS &= ~_BIT0;
 239   2          }
 240   1      
 241   1          // Enable mcu write
 242   1          MCU_FF2A_IIC_IRQ_CONTROL2 |= (_BIT6 | _BIT5);
 243   1      
 244   1      #if(_SMBUS_BLOCK_READ_WRITE_COMMAND_SUPPORT == _ON)
                  if(GET_SMBUS_BLOCK_RW_STATUS() == _TRUE)
                  {
                      MCU_FF26_IIC_DATA_OUT = g_stSmbusBlockRWCmd.ucDataLen;
                  }
              #endif
 250   1      
 251   1          while(ucDdcciCount < ((pucWriteArray[_DDCCI_LENGTH] & 0x7F) + 3))
 252   1          {
 253   2              // Load data to DDC-CI buffer until buffer full
 254   2              if((MCU_FF29_IIC_STATUS2 & _BIT2) == 0)
 255   2              {
 256   3                  MCU_FF26_IIC_DATA_OUT = pucWriteArray[ucDdcciCount++];
 257   3      
 258   3                  usTimeOutCnt = _DDCCI_TIMEOUT_LIMIT;
 259   3              }
 260   2              else
 261   2              {
 262   3                  ScalerTimerDelayXms(2);
 263   3      
 264   3                  usTimeOutCnt--;
 265   3              }
 266   2      
 267   2              if(usTimeOutCnt == 0)
 268   2              {
 269   3                  break;
 270   3              }
 271   2          }
 272   1      
 273   1          // Disable mcu write
 274   1          MCU_FF2A_IIC_IRQ_CONTROL2 &= ~_BIT5;
 275   1      }
 276          
