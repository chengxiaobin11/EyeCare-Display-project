 208          void OsdPaletteLoadPigment(BYTE ucPaletteIndex, BYTE *pucColorPaletteArray)
 209          {
 210   1          BYTE ucAddr = ucPaletteIndex * 16;
 211   1          BYTE ucI = 0;
 212   1      
 213   1          for(ucI = 0; ucI < 16; ucI++)
 214   1          {
 215   2              ScalerOsdSetColorPalette(ucAddr + ucI, *(pucColorPaletteArray + (ucI * 3)), *(pucColorPaletteArray
             - + (ucI * 3) + 1), *(pucColorPaletteArray + (ucI * 3) + 2));
 216   2          }
 217   1      }
