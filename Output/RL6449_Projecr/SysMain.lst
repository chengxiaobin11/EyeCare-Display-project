             -_FLASH_PARTITION_BOTH))
                  if(GET_CURRENT_BANK_NUMBER() != 0x00)
              #endif
                  {
                      // Reset FW after switched to user code
                      ((void (*)(void))0x0000)();
                  }
              }
              #endif
