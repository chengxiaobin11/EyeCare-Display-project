1240          //****************************************************************************
1241          // FUNCTION DEFINITIONS
1242          //****************************************************************************
1243          //--------------------------------------------------
1244          // Description  : Cache Control
1245          // Input Value  : bControl
1246          // Output Value : None
1247          //--------------------------------------------------
1248          //--------------------------------------------------
1249          // Description  : DDC Debounce Settings
1250          // Input Value  : Clock --> _EXT_XTAL_CLK/_IOSC_CLK
1251          // Output Value : None
1252          //--------------------------------------------------
1253          void ScalerMcuDdcDebounceSel(EnumClkSel enumClock)
1254          {
1255   1          if(enumClock == _EXT_XTAL_CLK)
1256   1          {
1257   2              // VGA_DDC De-bounce Reference Clock(Xtal = 14.318M) div by 2, latch 3 stages
1258   2              MCU_FF1C_ADC_DDC_CONTROL_1 &= ~_BIT7;
1259   2              MCU_FF1C_ADC_DDC_CONTROL_1 |= (_BIT6 | _BIT5 | _BIT4);
1260   2      
1261   2      #if(_D0_INPUT_PORT_TYPE == _D0_DP_PORT)
                      // DDC0 De-bounce Reference Clock(Xtal = 14.318M) div by 1, latch 1 stages
                      MCU_FF1F_DDC0_DDC_CONTROL_1 &= ~(_BIT7 | _BIT6);
                      MCU_FF1F_DDC0_DDC_CONTROL_1 |= _BIT4;
              #endif
1266   2      
1267   2      #if(_D1_INPUT_PORT_TYPE == _D1_DP_PORT)
1268   2              // DDC1 De-bounce Reference Clock(Xtal = 14.318M) div by 1, latch 1 stages
1269   2              MCU_FF2D_DDC1_DDC_CONTROL_1 &= ~(_BIT7 | _BIT6);
1270   2              MCU_FF2D_DDC1_DDC_CONTROL_1 |= _BIT4;
1271   2      #endif
1272   2      
1273   2      #if((_D2_INPUT_PORT_TYPE == _D2_DVI_PORT) || (_D2_INPUT_PORT_TYPE == _D2_HDMI_PORT) || (_D2_INPUT_PORT_TYP
