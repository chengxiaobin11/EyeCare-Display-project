3590   4                      {
3591   5                          return usMax;
3592   5                      }
3593   4                  }
3594   3                  else
C51 COMPILER V8.12   RTD2014OSDDISPLAY                                                     01/02/2025 16:32:28 PAGE 66  

3595   3                  {
3596   4                      usValue++;
3597   4                  }
3598   3      
3599   3                  break;
3600   3      
3601   3              case _LEFT_KEY_MESSAGE:
3602   3                      case _UP_KEY_MESSAGE:
3603   3                  if (usValue <= usMin)
3604   3                  {
3605   4                      if(bCycle == _ON)
3606   4                      {
3607   5                          return usMax;
3608   5                      }
3609   4                      else
3610   4                      {
3611   5                          return usMin;
3612   5                      }
3613   4                  }
3614   3                  else
3615   3                  {
3616   4                      usValue--;
3617   4                  }
3618   3                  break;
3619   3      
3620   3              default:
3621   3                  break;
3622   3          }
3623   2      }
3624   1          return usValue;
3625   1      }
