6209   2                      currentOsdWidth = _NAVIGAT_FRAME_WIDTH;
6210   2                      currentOsdHeight = _NAVIGAT_FRAME_HEIGHT-4;
6211   2               }
6212   1               else if(currentOsdState == _OSD_HOTKEY_CONBRI ||currentOsdState == _OSD_HOTKEY_VOLUME )
6213   1               {
6214   2                      currentOsdWidth = _HOTKEY_FRAME_WIDTH;
6215   2                      currentOsdHeight = (HeightAmount * 2 +3);
6216   2               }
6217   1               else if(currentOsdState == _OSD_HOTKEY_VIEWMODE)
C51 COMPILER V8.12   RTD2014OSDDISPLAY                                                     01/02/2025 16:32:28 PAGE 111 

6218   1               {
6219   2                      currentOsdWidth = _HOTKEY_FRAME_WIDTH;
6220   2                      currentOsdHeight = (HeightAmount * 2-3);
6221   2               }
6222   1               else if(currentOsdState == _OSD_HOTKEY_INPUT)
6223   1               {
6224   2                      currentOsdWidth = _HOTKEY_FRAME_WIDTH;
6225   2                      currentOsdHeight = (HeightAmount * 2 + 3);
6226   2               }       
6227   1               else if(currentOsdState == _OSD_HOTKEY_LANGUAGE_SELECT || currentOsdState == _OSD_HOTKEY_DISTRICT_SELECT
             -)
6228   1               {
6229   2                      currentOsdWidth = _HOTKEY_FRAME_WIDTH;
6230   2                      currentOsdHeight = (HeightAmount * 2 + 2 + 2);
6231   2               }
6232   1               else
6233   1               {
6234   2                      currentOsdWidth = _HOTKEY_FRAME_WIDTH;
6235   2                      currentOsdHeight = ((HeightAmount) * 2 + 2 + 6);
6236   2               }
6237   1      
6238   1               if(PercentDirectSlect == _POS_PERCENT)
