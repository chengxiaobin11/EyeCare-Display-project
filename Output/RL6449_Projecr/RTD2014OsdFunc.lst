2465   1              {
2466   2                      if((abs(GET_INPUT_TIMING_VFREQ() - tOverScanDOSDisableTable[ucTemp][0]) < 10) && \
2467   2                              (abs(GET_INPUT_TIMING_HWIDTH() - tOverScanDOSDisableTable[ucTemp][1]) < 2) && \
2468   2                              (GET_INPUT_TIMING_VHEIGHT() == tOverScanDOSDisableTable[ucTemp][2]))
2469   2                      {
2470   3                              return _TRUE;
2471   3                      }
2472   2      
2473   2                      ucTemp++;
2474   2              }
2475   1      
2476   1              return _FALSE;
2477   1      }
