 556          //--------------------------------------------------
 557          // Description  : Dp Tx SSC Set
 558          // Input Value  :
 559          // Output Value :
 560          //--------------------------------------------------
 561          void ScalerDisplayDPTxSSCSet(bit bSscEn)
 562          {
 563   1          if(bSscEn == _ENABLE)
 564   1          {
 565   2              PDATA_WORD(0) = (WORD)((ScalerGetBit(P38_DC_DPTX_CMU12, 0x1F) << 4) | (ScalerGetByte(P38_DD_DPTX_C
             -MU13) >> 4));
 566   2              PDATA_WORD(1) = (WORD)((ScalerGetBit(P38_DD_DPTX_CMU13, 0x0F) << 8) | ScalerGetByte(P38_DE_DPTX_CM
             -U14));
 567   2      
 568   2              // Calculate SSC Frequency = 30~33k
 569   2              PDATA_WORD(3) = (((_EXT_XTAL / _DISPLAY_DP_TX_SSC_FREQ) + 2) & 0xFFFC);
 570   2      
 571   2              // Calculate SSC downspread
 572   2              PDATA_WORD(2) = ((((DWORD)PDATA_WORD(0) + 4) * 4096 + PDATA_WORD(1))) * 16 / 200 / PDATA_WORD(3) /
             - 15 * _PANEL_DPTX_SPREAD_RANGE;
 573   2      
 574   2              // Set SSC Frequency = 30~33k
 575   2              ScalerSetByte(P38_E0_DPTX_CMU16, (BYTE)(PDATA_WORD(3) >> 8));
 576   2              ScalerSetByte(P38_E1_DPTX_CMU17, (BYTE)PDATA_WORD(3));
 577   2      
 578   2              // Set SSC downspread
 579   2              ScalerSetByte(P38_E2_DPTX_CMU18, (BYTE)(PDATA_WORD(2) >> 8));
 580   2              ScalerSetByte(P38_E3_DPTX_CMU19, (BYTE)PDATA_WORD(2));
 581   2      
 582   2              // [5] 1: Enable SSC, 0: disable
 583   2              // [4] 0: 1st Order SDM, 1:2nd Order SDM
 584   2              // [3] 0: Triangular wave, 1: Square wave
 585   2              ScalerSetBit(P38_D5_DPTX_CMU5, ~(_BIT5 | _BIT4 | _BIT3), _BIT5);
 586   2          }
 587   1          else
 588   1          {
 589   2              // Disable SSC
C51 COMPILER V8.12   RL6449_SERIES_DISPLAYDPTX                                             01/02/2025 16:31:32 PAGE 11  

 590   2              ScalerSetBit(P38_D5_DPTX_CMU5, ~_BIT5, 0x00);
 591   2          }
 592   1      }
