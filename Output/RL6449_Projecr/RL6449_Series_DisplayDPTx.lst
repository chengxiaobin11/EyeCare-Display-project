             -_TX_SKEW_LANE0 << 3) | _DISPLAY_DP_TX_SKEW_LANE1));
 548   1          ScalerSetByte(P38_86_PHY0_TXBIST_00_H1, ((_DISPLAY_DP_TX_SKEW_LANE2 << 5) | (_DISPLAY_DP_TX_SKEW_LANE3
             - << 2) | (_DISPLAY_DP_TX_SKEW_LANE0 >> 1)));
 549   1          ScalerSetByte(P38_87_PHY0_TXBIST_00_L2, ((_DISPLAY_DP_TX_SKEW_LANE0 << 7) | (_DISPLAY_DP_TX_SKEW_LANE1
             - << 4) | (_DISPLAY_DP_TX_SKEW_LANE2 << 1) | (_DISPLAY_DP_TX_SKEW_LANE3 >> 2)));
