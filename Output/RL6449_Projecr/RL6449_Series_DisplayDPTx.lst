              void ScalerDisplayDPTx2SetSignalLevel(EnumDisplayDPTxLane enumLaneX, BYTE ucVoltageSwing, BYTE ucPreEmphas
             -is)
              {
                  BYTE ucIndex = 0x00;
                  BYTE *pucTable = 0x00;
              
