 304          WORD ScalerOsdWindowRegisterMapping(EnumOsdWindowsType enumOsdWindowsType)
 305          {
 306   1          WORD usWin = 0;
 307   1      
 308   1          usWin = enumOsdWindowsType / 10 * 16;
 309   1          usWin += (enumOsdWindowsType % 10);
 310   1          return (usWin << 8);
 311   1      }
