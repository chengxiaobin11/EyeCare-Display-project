C51 COMPILER V8.12   RL6449_SERIES_COLORRGB3DGAMMAENABLE                                   03/11/2025 19:56:09 PAGE 2   

  52          // Description  : Enable/Disable 3D Gamma
  53          // Input Value  : _FUNCTION_ON / _FUNCTION_OFF/_FUNCTION_CLOCK_GATED
  54          // Output Value : None
  55          //--------------------------------------------------
  56          void ScalerColorRGB3DGammaEnable(EnumFunctionOnOFF enumOn)
  57          {
  58   1          if(enumOn == _FUNCTION_ON)
  59   1          {
  60   2              ScalerSetBit(P1_DB_DCLK_GATED_CTRL1, ~_BIT3, _BIT3);
  61   2              ScalerSetBit(P9_B0_RGB_3D_GAMMA_CTRL, ~_BIT7, _BIT7);
  62   2          }
  63   1          else if(enumOn == _FUNCTION_OFF)
  64   1          {
  65   2              ScalerSetBit(P9_B0_RGB_3D_GAMMA_CTRL, ~_BIT7, 0x00);
  66   2          }
  67   1          else // _FUNCTION_CLOCK_GATED
  68   1          {
  69   2              ScalerSetBit(P9_B0_RGB_3D_GAMMA_CTRL, ~_BIT7, 0x00);
  70   2              ScalerSetBit(P1_DB_DCLK_GATED_CTRL1, ~_BIT3, 0x00);
  71   2          }
  72   1      }
  73          


