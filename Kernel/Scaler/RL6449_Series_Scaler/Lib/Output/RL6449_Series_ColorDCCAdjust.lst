C51 COMPILER V8.12   RL6449_SERIES_COLORDCCADJUST                                          03/11/2025 19:56:02 PAGE 2   

  52          //****************************************************************************
  53          void ScalerColorDCCAdjust(BYTE code *pucDccTable, BYTE ucBankAddress);
  54          
  55          
  56          //****************************************************************************
  57          // FUNCTION DEFINITIONS
  58          //****************************************************************************
  59          
  60          //--------------------------------------------------
  61          // Description  : Adjust DCC Parameter
  62          // Input Value  : pDccTable -> DCC control&user_curve register table
  63          //                ucBankAddress -> Bank address
  64          //                ucAdjustOption ->
  65          //                        _BIT7: _BURSTWRITE_FROM_FLASH / _BURSTWRITE_FROM_XRAM
  66          //                        _BIT6: Y_FORMULA -> 0: Y = (2R+5G+B)/8, 1: Y = (5R+8G+3B)/16
  67          //                        _BIT5: SOFT_CLAMP -> 0: Disable, 1: Enable
  68          //                        _BIT4: DCC_MODE -> 0:Auto Mode, 1: Manual Mode
  69          //                        _BIT3: SCENE_CHANGE -> 0: Disable, 1: Enable
  70          //                        _BIT1: Saturation Compensation -> 0: Disable, 1: Enable
  71          //                        _BIT0: BLD_MODE -> 0: old mode, 1: new mode
  72          // Output Value : None
  73          //--------------------------------------------------
  74          void ScalerColorDCCAdjust(BYTE code *pucDccTable, BYTE ucBankAddress)
  75          {
  76   1          BYTE ucAdjustOption = 0;
  77   1      
  78   1          if(pucDccTable != NULL)
  79   1          {
  80   2              ScalerFlashRead(ucBankAddress, (WORD)(&pucDccTable[_DCC_ADJOPTION_TABLE_OFFSET]), 1, &ucAdjustOpti
             -on);
  81   2              // Load DCC table after DCC Flag Done
  82   2              ScalerTimerPollingFlagProc(20, P7_C8_DCC_CTRL_1, _BIT6, 1);
  83   2      
  84   2              ScalerSetBit(P7_C7_DCC_CTRL_0, ~(_BIT1 | _BIT0), _PAGE0);
  85   2              ScalerSetByte(P7_C9_DCC_ADDRESS_PORT, _P7_CA_PT_03_PORT_PAGE0_BBE_CTRL);
  86   2              ScalerBurstWrite(&pucDccTable[_DCC_CONTORL_TABLE_OFFSET], _DCC_TABLE_SIZE_CTRL, ucBankAddress, P7_
             -CA_DCC_DATA_PORT, _BURSTWRITE_DATA_COMMON, (bit)(ucAdjustOption & _BIT7));
  87   2              ScalerSetByte(P7_C9_DCC_ADDRESS_PORT, _P7_CA_PT_17_PORT_PAGE0_YHL_THD);
  88   2              ScalerBurstWrite(&pucDccTable[_DCC_CONTORL_LSB_TABLE_OFFSET], _DCC_TABLE_SIZE_CTRL_LSB, ucBankAddr
             -ess, P7_CA_DCC_DATA_PORT, _BURSTWRITE_DATA_COMMON, (bit)(ucAdjustOption & _BIT7));
  89   2      
  90   2              // Fill DCC user curve table
  91   2              // Select page1
  92   2              ScalerSetBit(P7_C7_DCC_CTRL_0, ~(_BIT1 | _BIT0), _PAGE1);
  93   2              ScalerSetByte(P7_C9_DCC_ADDRESS_PORT, _P7_CA_PT_00_PORT_PAGE1_DEF_CRV01_H);
  94   2              ScalerBurstWrite(&pucDccTable[_DCC_CURVE_TABLE_OFFSET], _DCC_TABLE_SIZE_CRV, ucBankAddress, P7_CA_
             -DCC_DATA_PORT, _BURSTWRITE_DATA_COMMON, (bit)(ucAdjustOption & _BIT7));
  95   2              ScalerSetByte(P7_C9_DCC_ADDRESS_PORT, _P7_CA_PT_1B_PORT_PAGE1_DEF_CRV00_HALF_H);
  96   2              ScalerBurstWrite(&pucDccTable[_DCC_CURVE_LSB_TABLE_OFFSET], _DCC_TABLE_SIZE_CRV_LSB, ucBankAddress
             -, P7_CA_DCC_DATA_PORT, _BURSTWRITE_DATA_COMMON, (bit)(ucAdjustOption & _BIT7));
  97   2      
  98   2              ScalerSetBit(P7_C8_DCC_CTRL_1, ~(_BIT5 | _BIT4), ((ucAdjustOption & (_BIT1 | _BIT0)) << 4));
  99   2              ScalerSetBit(P7_C7_DCC_CTRL_0, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2), ((ucAdjustOption 
             -& (_BIT6 | _BIT5 | _BIT4 | _BIT3)) | _BIT7));
 100   2          }
 101   1      }


