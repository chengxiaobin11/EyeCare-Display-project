 105          //--------------------------------------------------
 106          void ScalerOsdScaleUpVerSize(WORD usVStart, WORD usVHeight)
 107          {
 108   1          WORD usBGVStart = 0;
 109   1      
 110   1          ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_0E_DISPLAY_VER_BG_STA_H, 2, &pData[0],
             - _AUTOINC);
 111   1          usBGVStart = ((pData[0] & 0x1F) << 8) | (pData[1]);
 112   1      
C51 COMPILER V8.12   RL6449_SERIES_OSDSCALEUP                                              03/11/2025 19:56:19 PAGE 3   

 113   1          usVStart = usVStart + (((usBGVStart % 2) == 0) ? (usBGVStart - 1) : (usBGVStart - 2));
 114   1          ScalerSetBit(P3A_C4_OSD_SU_VER_ST_H, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), HIBYTE(usVStart) & 0x0F);
 115   1          ScalerSetByte(P3A_C5_OSD_SU_VER_ST_L, LOBYTE(usVStart));
 116   1      
 117   1          ScalerSetBit(P3A_C8_OSD_SU_VER_SIZE_H, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), HIBYTE(usVHeight) & 0x0F);
 118   1          ScalerSetByte(P3A_C9_OSD_SU_VER_SIZE_L, LOBYTE(usVHeight));
 119   1      }
