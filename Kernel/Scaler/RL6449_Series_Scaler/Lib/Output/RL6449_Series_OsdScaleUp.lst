 121          //--------------------------------------------------
 122          // Description  : OSD Scale Up H Start/Height
 123          // Input Value  : usHStart
 124          // Input Value  : usHWidth
 125          // Output Value :
 126          //--------------------------------------------------
 127          void ScalerOsdScaleUpHorSize(WORD usHStart, WORD usHWidth)
 128          {
 129   1          WORD usBGHStart = 0;
 130   1      
 131   1          ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_03_DISPLAY_HOR_BG_STA_H, 2, &pData[0],
             - _AUTOINC);
 132   1          usBGHStart = ((pData[0] & 0x1F) << 8) | (pData[1]);
 133   1      
 134   1          ScalerSetByte(0x06, usBGHStart);
 135   1          usHStart = usHStart + (usBGHStart / 2 - 7);
 136   1          ScalerSetBit(P3A_C6_OSD_SU_HOR_ST_H, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), HIBYTE(usHStart) & 0x0F);
 137   1          ScalerSetByte(P3A_C7_OSD_SU_HOR_ST_L, LOBYTE(usHStart));
 138   1      
 139   1          ScalerSetBit(P3A_CA_OSD_SU_HOR_SIZE_H, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), HIBYTE(usHWidth) & 0x0F);
 140   1          ScalerSetByte(P3A_CB_OSD_SU_HOR_SIZE_L, LOBYTE(usHWidth));
 141   1      }
