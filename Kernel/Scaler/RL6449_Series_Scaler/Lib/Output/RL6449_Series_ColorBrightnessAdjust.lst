  46          //--------------------------------------------------
  47          // Description  : Adjust Brightness
  48          // Input Value  : EnumBriConCoefTypem, Coefficient
  49          //                10 bit input, old 8 bit brightness input value must left shift 2 bit
  50          //                -2048(00h) ~ 0(200h) ~  +2044(3FFh)
  51          // Output Value : void
C51 COMPILER V8.12   RL6449_SERIES_COLORBRIGHTNESSADJUST                                   03/11/2025 19:56:02 PAGE 2   

  52          //--------------------------------------------------
  53          void ScalerColorBrightnessAdjust(EnumBriConCoefType enumBriConCoefType, WORD *pusData)
  54          {
  55   1          switch(enumBriConCoefType)
  56   1          {
  57   2              case _BRIGHTNESS_COEF_A:
  58   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_00_BRI_RED_COE_SETA_H, (pusData[0] & 0
             -x03FC) >> 2);
  59   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_01_BRI_GRN_COE_SETA_H, (pusData[1] & 0
             -x03FC) >> 2);
  60   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_02_BRI_BLU_COE_SETA_H, (pusData[2] & 0
             -x03FC) >> 2);
  61   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_20_BRI_COE_SETA_L, ((pusData[0] & 0x00
             -03) << 6) | ((pusData[1] & 0x0003) << 4) | ((pusData[2] & 0x0003) << 2));
  62   2                  break;
  63   2      
  64   2              case _BRIGHTNESS_COEF_B:
  65   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_06_BRI_RED_COE_SETB_H, (pusData[0] & 0
             -x03FC) >> 2);
  66   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_07_BRI_GRN_COE_SETB_H, (pusData[1] & 0
             -x03FC) >> 2);
  67   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_08_BRI_BLU_COE_SETB_H, (pusData[2] & 0
             -x03FC) >> 2);
  68   2                  ScalerSetDataPortByte(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_23_BRI_COE_SETB_L, ((pusData[0] & 0x00
             -03) << 6) | ((pusData[1] & 0x0003) << 4) | ((pusData[2] & 0x0003) << 2));
  69   2                  break;
  70   2      
  71   2              default:
  72   2                  break;
  73   2          }
  74   1      }
