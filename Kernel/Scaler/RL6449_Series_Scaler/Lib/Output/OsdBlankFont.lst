  50          //                ucPixelLength                     -> BLANK_FONT : 4 ~ 255 other 0 ~ 255
C51 COMPILER V8.12   OSDBLANKFONT                                                          03/11/2025 19:55:54 PAGE 2   

  51          //                ucBackgroundColor                 -> Color number
  52          //                enumOsdBlinkingType               -> _OSD_BLANK_FONT or _OSD_BLANK_ALIGN
  53          // Output Value :
  54          //--------------------------------------------------
  55          void ScalerOsdBlankFont(BYTE ucRow, BYTE ucCol, BYTE ucLength, BYTE ucHeight, BYTE ucPixelLength, BYTE ucB
             -ackgroundColor, EnumOsdBlankType enumOsdBlankingType)
  56          {
  57   1          BYTE ucTemp = 0;
  58   1      
  59   1          enumOsdBlankingType = (enumOsdBlankingType & 0x03);
  60   1      
  61   1          for(ucTemp = 0; ucTemp < ucHeight; ucTemp++)
  62   1          {
  63   2              ScalerOsdSramDataValue(ucRow + ucTemp, ucCol, ucLength, enumOsdBlankingType, _OSD_BYTE0);
  64   2              ScalerOsdSramDataValue(ucRow + ucTemp, ucCol, ucLength, (ucPixelLength & 0xFF), _OSD_BYTE1);
  65   2              ScalerOsdSramDataValue(ucRow + ucTemp, ucCol, ucLength, (ucBackgroundColor & 0x3F), _OSD_BYTE2);
  66   2          }
  67   1      }
