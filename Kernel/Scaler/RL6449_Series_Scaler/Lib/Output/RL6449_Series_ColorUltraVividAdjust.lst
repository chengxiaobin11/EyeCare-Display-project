  52          // Description  : UltraVivid Adjust
  53          // Input Value  : UltraVivid Table and ucBankNum
  54          // Output Value : None
  55          //--------------------------------------------------
  56          void ScalerColorUltraVividAdjust(BYTE code *pucUltraVividSetting, BYTE ucBankNum)
  57          {
  58   1          if(GET_V_SCALE_UP() == _TRUE)
  59   1          {
  60   2              ScalerGetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_03_VER_SCALE_FACTOR_H, 2, pData, _AUTOINC);
  61   2              pData[0] = ((pData[0] << 4) | (pData[1] >> 4));
  62   2      
  63   2              if(pData[0] < 85)  // IVHeight/DVHeight <= 1/4
  64   2              {
  65   3                  ScalerBurstWrite(pucUltraVividSetting, _ULTRAVIVID_TABLE_SIZE, ucBankNum, P11_B9_SCALER_LSR_HL
             -W, _BURSTWRITE_COMMAND, _BURSTWRITE_FROM_FLASH);
  66   3              }
  67   2              else if(pData[0] < 170)  // IVHeight/DVHeight < 2/3
  68   2              {
  69   3                  ScalerBurstWrite(pucUltraVividSetting + _ULTRAVIVID_TABLE_SIZE, _ULTRAVIVID_TABLE_SIZE, ucBank
             -Num, P11_B9_SCALER_LSR_HLW, _BURSTWRITE_COMMAND, _BURSTWRITE_FROM_FLASH);
  70   3              }
  71   2              else  // IVHeight/DVHeight <= 1
  72   2              {
  73   3                  ScalerBurstWrite(pucUltraVividSetting + _ULTRAVIVID_TABLE_SIZE * 2, _ULTRAVIVID_TABLE_SIZE, uc
             -BankNum, P11_B9_SCALER_LSR_HLW, _BURSTWRITE_COMMAND, _BURSTWRITE_FROM_FLASH);
  74   3              }
  75   2      
  76   2              // Bypass DSHP
  77   2              ScalerSetBit(P12_A0_SR_SHP_CTRL_0, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), _BIT7);
  78   2              ScalerSetBit(P12_A1_SR_SHP_CTRL_1, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
  79   2          }
  80   1          else if(GET_V_SCALE_DOWN() == _TRUE)
  81   1          {
  82   2              ScalerBurstWrite(pucUltraVividSetting + _ULTRAVIVID_TABLE_SIZE * 3, _ULTRAVIVID_TABLE_SIZE, ucBank
             -Num, P11_B9_SCALER_LSR_HLW, _BURSTWRITE_COMMAND, _BURSTWRITE_FROM_FLASH);
  83   2      
  84   2              // if VSD is on, then LSR shold be off.
  85   2              ScalerSetBit(P14_C0_LSR_CTRL, ~_BIT7, 0x00);
  86   2          }
  87   1          else // by pass
  88   1          {
  89   2              ScalerBurstWrite(pucUltraVividSetting + _ULTRAVIVID_TABLE_SIZE * 4, _ULTRAVIVID_TABLE_SIZE, ucBank
             -Num, P11_B9_SCALER_LSR_HLW, _BURSTWRITE_COMMAND, _BURSTWRITE_FROM_FLASH);
  90   2      
  91   2              // Bypass DSHP
  92   2              ScalerSetBit(P12_A0_SR_SHP_CTRL_0, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), _BIT7);
  93   2              ScalerSetBit(P12_A1_SR_SHP_CTRL_1, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
  94   2          }
  95   1      
  96   1          ScalerBurstWrite(pucUltraVividSetting + _ULTRAVIVID_TABLE_SIZE * 5, _ULTRAVIVID_TABLE_SIZE_CDS, ucBank
             -Num, P13_A0_SR_CDS_CTRL_0, _BURSTWRITE_COMMAND, _BURSTWRITE_FROM_FLASH);
  97   1      
  98   1          // Disable IDLTI
  99   1          ScalerSetBit(P11_A1_I_DLTI_CTRL_M1, ~_BIT0, 0x00);
 100   1      
 101   1          // Wait for Event
 102   1          ScalerGlobalIDDomainDBApply(_DB_APPLY_NONE);
 103   1      }


