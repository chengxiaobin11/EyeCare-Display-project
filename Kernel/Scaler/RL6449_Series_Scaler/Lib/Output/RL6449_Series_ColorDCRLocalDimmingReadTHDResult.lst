  44          // FUNCTION DEFINITIONS
  45          //****************************************************************************
  46          //--------------------------------------------------
  47          // Description  : Read Local Dimming DCR Above THD1/2 Value and Number Result
  48          // Input Value  : DCR Histogram Information Option
  49          // Output Value : DCR Histogram Information
  50          // Note         : When get _DCR_ABOVE_TH_VAL(8bit or 10bit), should get _DCR_ABOVE_TH_VAL_HIGH first
C51 COMPILER V8.12   RL6449_SERIES_COLORDCRLOCALDIMMINGREADTHD                             03/11/2025 19:56:15 PAGE 2   

  51          //              : then get _DCR_ABOVE_TH_VAL
  52          //--------------------------------------------------
  53          DWORD ScalerColorDCRLocalDimmingReadTHDResult(EnumDCRLDAdjOption enumDCRLDReadOption)
  54          {
  55   1          DWORD ulResult = 0;
  56   1      
  57   1          if((GET_DCR_READY_STATUS() == _FALSE) || (ScalerGetDataPortBit(P0_64_CTS_BRI_PORT_ADD, _P0_65_PT_27_CT
             -S_BRI_SET, _BIT0) == 0x00))
  58   1          {
  59   2              return 0;
  60   2          }
  61   1      
  62   1          switch(enumDCRLDReadOption)
  63   1          {
  64   2              case _DCR_LD_ABOVE_TH1_NUM:
  65   2                  ulResult = g_stDCRStoreInfo.ulDCR_LD_ABOVE_TH1_NUM;
  66   2                  break;
  67   2      
  68   2              case _DCR_LD_ABOVE_TH2_NUM:
  69   2                  ulResult = g_stDCRStoreInfo.ulDCR_LD_ABOVE_TH2_NUM;
  70   2                  break;
  71   2      
  72   2              default:
  73   2                  break;
  74   2          }
  75   1      
  76   1          return ulResult;
  77   1      }


