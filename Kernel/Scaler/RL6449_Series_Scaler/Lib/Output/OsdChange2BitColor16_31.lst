C51 COMPILER V8.12   OSDCHANGE2BITCOLOR16_31                                               03/11/2025 19:55:55 PAGE 2   

  51          // Output Value :
  52          //--------------------------------------------------
  53          void ScalerOsdChange2BitColor16_31(BYTE ucRow, BYTE ucCol, BYTE ucLength, BYTE ucHeight, BYTE ucColor0, BY
             -TE ucColor1, BYTE ucColor2, BYTE ucColor3)
  54          {
  55   1          BYTE ucRowCmdByte0 = _BIT7;
  56   1          bit bOSDOn = _OFF;
  57   1          BYTE ucTemp = 0;
  58   1      
  59   1          // Get OSD Status
  60   1          bOSDOn = ScalerGetBit(P3A_02_FRAME_CTRL_02, _BIT0);
  61   1      
  62   1          // Set OSD Circuit Enable for Write-Protection Function effective in OSD enable.
  63   1          ScalerSetBit(P3A_02_FRAME_CTRL_02, ~(_BIT0), _ON);
  64   1      
  65   1          // Check Global Double Buffer
  66   1          if(bOSDOn == _OFF)
  67   1          {
  68   2              ScalerTimerWaitForEvent(_EVENT_DVS);
  69   2          }
  70   1      
  71   1          if(((ucColor0 >= 16) && (ucColor1 >= 16) && (ucColor2 >= 16) && (ucColor3 >= 16)))
  72   1          {
  73   2              ucRowCmdByte0 |= _BIT6;
  74   2              ucColor0 -= 16;
  75   2              ucColor1 -= 16;
  76   2              ucColor2 -= 16;
  77   2              ucColor3 -= 16;
  78   2          }
  79   1      
  80   1      
  81   1          if(ScalerGetBit(P3A_18_FRAME_CTRL_18, _BIT3) == _BIT3) // OSD 2 font function
  82   1          {
  83   2              if(ucRow >= _OSD_MAP_B_ROW_OFFSET)
  84   2              {
  85   3                  ScalerOsdSramAddressSet((ScalerGetByte(P3A_1A_FRAME_CTRL_1A) + (ucRow - _OSD_MAP_B_ROW_OFFSET)
             -), _OSD_BYTE0);
  86   3              }
  87   2              else
  88   2              {
  89   3                  ScalerOsdSramAddressSet((ScalerGetByte(P3A_19_FRAME_CTRL_19) + ucRow), _OSD_BYTE0);
  90   3              }
  91   2          }
  92   1          else
  93   1          {
  94   2              ScalerOsdSramAddressSet((0 + ucRow), _OSD_BYTE0);
  95   2          }
  96   1      
  97   1          for(ucTemp = 0; ucTemp < ucHeight; ucTemp++)
  98   1          {
  99   2              ScalerOsdDataPort(ucRowCmdByte0);
 100   2          }
 101   1      
 102   1          ScalerOsdChange2BitColor(ucRow, ucCol, ucLength, ucHeight, ucColor0, ucColor1, ucColor2, ucColor3);
 103   1      
 104   1          // Recovery OSD Status
 105   1          if(bOSDOn == _OFF)
 106   1          {
 107   2              ScalerOsdCircuitActivated(bOSDOn);
 108   2          }
 109   1      }
