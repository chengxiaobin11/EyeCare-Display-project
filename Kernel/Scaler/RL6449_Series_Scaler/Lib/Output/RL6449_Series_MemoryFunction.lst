  41          DWORD ScalerMemoryCalculateNumberAndRemain(DWORD ulTotalSize, WORD usLength, bit bDummy);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          
  48          //--------------------------------------------------
  49          // Description  : Calculate the number and remain
  50          // Input Value  : ulTotalSize --> Image total size
  51          //                ucLength --> Length of SDRAM access
C51 COMPILER V8.12   RL6449_SERIES_MEMORYFUNCTION                                          03/11/2025 19:56:17 PAGE 2   

  52          // Output Value : Number and Remain
  53          //--------------------------------------------------
  54          DWORD ScalerMemoryCalculateNumberAndRemain(DWORD ulTotalSize, WORD usLength, bit bDummy)
  55          {
  56   1          if(bDummy == _TRUE)
  57   1          {
  58   2              /// In 6193, System Bridge data bus is 128 bits,
  59   2              ///   but its burst length and address unit is still 64 bits.
  60   2              ///   So NUM, LEN, and REM must be a multiple of 2.
  61   2              ulTotalSize += (ulTotalSize % 2);
  62   2          }
  63   1      
  64   1          if((ulTotalSize % usLength) != 0)
  65   1          {
  66   2              PDATA_WORD(0) = ulTotalSize / usLength; // Number
  67   2              PDATA_WORD(1) = ulTotalSize % usLength; // Remain
  68   2          }
  69   1          else
  70   1          {
  71   2              ulTotalSize = ulTotalSize - usLength;
  72   2              PDATA_WORD(0) = ulTotalSize / usLength; // Number
  73   2              PDATA_WORD(1) = usLength;               // Remain
  74   2          }
  75   1      
  76   1          return (((DWORD)PDATA_WORD(1) << 16) | PDATA_WORD(0));
  77   1      }
  78          


