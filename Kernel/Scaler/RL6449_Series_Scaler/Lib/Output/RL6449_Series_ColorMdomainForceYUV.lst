  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Force YUV Color Format to M-domain
  49          // Input Value  : Input Color Space, EnumDBApply
  50          // Output Value : None
  51          //--------------------------------------------------
C51 COMPILER V8.12   RL6449_SERIES_COLORMDOMAINFORCEYUV                                    03/11/2025 19:56:16 PAGE 2   

  52          void ScalerColorMdomainForceYUV(EnumColorSpace enumColorSpace, EnumDBApply enumDBApply)
  53          {
  54   1          //////////////////////////////
  55   1          // I-Domain Color Conversion//
  56   1          //////////////////////////////
  57   1          if(GET_COLOR_SPACE_RGB(enumColorSpace) == _TRUE)
  58   1          {
  59   2              // Enable I-Domain RGB2YUV
  60   2              ScalerSetBit(P0_9C_RGB2YCC_CTRL, ~(_BIT4 | _BIT0), (_BIT4 | _BIT0));
  61   2          }
  62   1          else
  63   1          {
  64   2              // Disable I-Domain RGB2YUV
  65   2              ScalerSetBit(P0_9C_RGB2YCC_CTRL, ~(_BIT4 | _BIT0), 0x00);
  66   2          }
  67   1      
  68   1          //////////////////////////////
  69   1          // D-Domain Color Conversion//
  70   1          //////////////////////////////
  71   1      
  72   1          // Load D-Domain YUV2RGB Table
  73   1          ScalerColorSpaceLoadYuv2RgbTable(enumColorSpace, _OFF);
  74   1      
  75   1          // Enable D-Domain YUV2RGB
  76   1          ScalerSetBit(P14_A1_SR_YCC2RGB_CTRL, ~(_BIT5 | _BIT4 | _BIT0), _BIT0);
  77   1      
  78   1          if(GET_INTERLACED_MODE() == _TRUE)
  79   1          {
  80   2              ScalerGlobalIDomainDBApply(enumDBApply);
  81   2              ScalerGlobalDDomainDBApply(enumDBApply);
  82   2          }
  83   1          else
  84   1          {
  85   2              if(enumDBApply == _DB_APPLY_NO_POLLING)
  86   2              {
  87   3                  enumDBApply = _DB_APPLY_POLLING;
  88   3              }
  89   2      
  90   2              ScalerGlobalIDDomainDBApply(enumDBApply);
  91   2          }
  92   1      }
  93          


