C51 COMPILER V8.12   RL6449_SERIES_COLORCOLORCONVERSION                                    03/11/2025 19:56:02 PAGE 2   

  52          void ScalerColorSpaceConvert(EnumColorSpace enumColorSpace, EnumDBApply enumDBApply)
  53          {
  54   1          //////////////////////////////
  55   1          // I-Domain Color Conversion//
  56   1          //////////////////////////////
  57   1          if(GET_COLOR_SPACE_RGB(enumColorSpace) == _TRUE)
  58   1          {
  59   2              if(GET_INTERLACED_MODE() == _TRUE)
  60   2              {
  61   3                  // Enable I-Domain RGB2YUV
  62   3                  ScalerSetBit(P0_9C_RGB2YCC_CTRL, ~(_BIT4 | _BIT0), (_BIT4 | _BIT0));
  63   3              }
  64   2              else
  65   2              {
  66   3                  // Disable I-Domain RGB2YUV
  67   3                  ScalerSetBit(P0_9C_RGB2YCC_CTRL, ~(_BIT4 | _BIT0), 0x00);
  68   3              }
  69   2          }
  70   1          else
  71   1          {
  72   2              // Disable I-Domain RGB2YUV
  73   2              ScalerSetBit(P0_9C_RGB2YCC_CTRL, ~(_BIT4 | _BIT0), 0x00);
  74   2          }
  75   1      
  76   1          //////////////////////////////
  77   1          // D-Domain Color Conversion//
  78   1          //////////////////////////////
  79   1      
  80   1          // Load D-Domain YUV2RGB Table
  81   1          ScalerColorSpaceLoadYuv2RgbTable(enumColorSpace, _OFF);
  82   1      
  83   1          if(GET_COLOR_SPACE_RGB(enumColorSpace) == _TRUE)
  84   1          {
  85   2              if(GET_INTERLACED_MODE() == _TRUE)
  86   2              {
  87   3                  // Enable D-Domain YUV2RGB
  88   3                  ScalerSetBit(P14_A1_SR_YCC2RGB_CTRL, ~(_BIT5 | _BIT4 | _BIT0), _BIT0);
  89   3              }
  90   2              else
  91   2              {
  92   3                  if(GET_COLOR_RGB_LIMIT_RANGE_USER() == _TRUE)
  93   3                  {
  94   4                      // Enable D-Domain YUV2RGB & Identity_Matrix
  95   4                      ScalerSetBit(P14_A1_SR_YCC2RGB_CTRL, ~(_BIT5 | _BIT4 | _BIT0), (_BIT4 | _BIT0));
  96   4                  }
  97   3                  else
  98   3                  {
  99   4                      // Disable D-Domain YUV2RGB Identity_Matrix
 100   4                      ScalerSetBit(P14_A1_SR_YCC2RGB_CTRL, ~(_BIT5 | _BIT4 | _BIT0), 0x00);
 101   4                  }
 102   3              }
 103   2          }
 104   1          else
 105   1          {
 106   2              ScalerSetBit(P14_A1_SR_YCC2RGB_CTRL, ~(_BIT5 | _BIT4 | _BIT0), _BIT0);
 107   2          }
 108   1      
 109   1          if(GET_INTERLACED_MODE() == _TRUE)
 110   1          {
 111   2              ScalerGlobalIDomainDBApply(enumDBApply);
 112   2              ScalerGlobalDDomainDBApply(enumDBApply);
 113   2          }
C51 COMPILER V8.12   RL6449_SERIES_COLORCOLORCONVERSION                                    03/11/2025 19:56:02 PAGE 3   

 114   1          else
 115   1          {
 116   2              if(enumDBApply == _DB_APPLY_NO_POLLING)
 117   2              {
 118   3                  enumDBApply = _DB_APPLY_POLLING;
 119   3              }
 120   2      
 121   2              ScalerGlobalIDDomainDBApply(enumDBApply);
 122   2          }
 123   1      }
