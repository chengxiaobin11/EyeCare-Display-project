 133          void ScalerODCompressionSetting(void);
 134          
 135          //****************************************************************************
 136          // FUNCTION DEFINITIONS
 137          //****************************************************************************
 138          
 139          //--------------------------------------------------
 140          // Description  : OD compression, level estimation, noise reduction setting
 141          // Input Value  : None
 142          // Output Value : None
 143          //--------------------------------------------------
 144          void ScalerODCompressionSetting(void)
 145          {
 146   1          StructOdParam stOdParam;
 147   1          stOdParam = tOdCmpParamList[ScalerODGetCmpParamMode()][GET_OD_USE_PARAM()];
 148   1      
 149   1          // Enable level estimation, delta gain. Set previous frame source pixel resolution
 150   1          ScalerSetByte(P3_A1_LS_CTRL0, (_BIT5 | _BIT3 | stOdParam.enumPreSrcRes));
 151   1      
 152   1          // Current path: enable compression, set compression mode/method
 153   1          ScalerSetByte(P3_B0_LS_FRAME0, (stOdParam.enumCmpMode | _BIT4 | stOdParam.enumCmpMethod));
 154   1      
 155   1          // Enable previous/current frame decompression, set decompression mode
 156   1          ScalerSetByte(P3_B1_LS_FRAME1, (_BIT7 | _BIT3 | stOdParam.enumDecmpMode));
 157   1      
 158   1          // Set current frame source pixel resolution
 159   1          ScalerSetByte(P3_B2_LS_FRAME2, (stOdParam.enumCurSrcRes));
 160   1      
 161   1          // Set level estimation range, level estimation gain
 162   1          ScalerSetByte(P3_B3_LS_FRAME4, (_OD_EST_RANGE_BYPASS | 0x00));
 163   1      
C51 COMPILER V8.12   SCALERODFUNCTION                                                      03/11/2025 19:55:49 PAGE 4   

 164   1          // Set level estimation value
 165   1          ScalerSetByte(P3_B4_LS_FRAME5, (stOdParam.ucLvlEstValue & 0x3F));
 166   1      
 167   1          // Set OD apply on full window
 168   1          ScalerODHLWinSetting(_HLW_FULL_WINDOW, _DB_APPLY_NO_POLLING);
 169   1      
 170   1          // Set noise reduction threshold
 171   1          {
 172   2              BYTE ucNrEn = (stOdParam.ucNRThreshold > 1) ? _ENABLE : _DISABLE;
 173   2              BYTE ucNrThd_B_3 = 0;
 174   2              BYTE ucNrThd_B_2_0 = 0;
 175   2      
 176   2              if(ucNrEn == _ENABLE)
 177   2              {
 178   3                  ucNrThd_B_3 = ((stOdParam.ucNRThreshold - 1) & 0x08) >> 3;
 179   3                  ucNrThd_B_2_0 = (stOdParam.ucNRThreshold - 1) & 0x07;
 180   3              }
 181   2              ScalerSetByte(P3_A2_LS_CTRL1, ((ucNrThd_B_3 << 5) | (ucNrEn << 4) | _BIT3 | ucNrThd_B_2_0));
 182   2          }
 183   1      
 184   1          // Clear flag
 185   1          ScalerSetByte(P3_A4_LS_STATUS0, _BIT0);
 186   1      }
