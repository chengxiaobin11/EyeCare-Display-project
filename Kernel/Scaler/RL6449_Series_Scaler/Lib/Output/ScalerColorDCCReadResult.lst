  48          // Description  : Read DCC Statistic Result
  49          // Input Value  : pucReadArray, DCCReadOption
  50          // Output Value : Read Result
  51          // Notice : Under _DCC_GEN_0, all result are one byte. Under _DCC_GEN_0, S0~S6 are one byte, but Y_MAX and
C51 COMPILER V8.12   SCALERCOLORDCCREADRESULT                                              03/11/2025 19:55:49 PAGE 2   

             - Y_MIN are one word.
  52          //--------------------------------------------------
  53          WORD ScalerColorDCCReadResult(BYTE *pucReadArray, EnumDCCReadOption enumDCCReadOption)
  54          {
  55   1          WORD usResult = 0;
  56   1      
  57   1          if(pucReadArray == _NULL_POINTER)
  58   1          {
  59   2              return 0;
  60   2          }
  61   1      
  62   1          switch(enumDCCReadOption)
  63   1          {
  64   2              case _DCC_S0:
  65   2                  usResult = pucReadArray[2];
  66   2                  break;
  67   2      
  68   2              case _DCC_S1:
  69   2                  usResult = pucReadArray[3];
  70   2                  break;
  71   2      
  72   2              case _DCC_S2:
  73   2                  usResult = pucReadArray[4];
  74   2                  break;
  75   2      
  76   2              case _DCC_S3:
  77   2                  usResult = pucReadArray[5];
  78   2                  break;
  79   2      
  80   2              case _DCC_S4:
  81   2                  usResult = pucReadArray[6];
  82   2                  break;
  83   2      
  84   2              case _DCC_S5:
  85   2                  usResult = pucReadArray[7];
  86   2                  break;
  87   2      
  88   2              case _DCC_S6:
  89   2                  usResult = pucReadArray[8];
  90   2                  break;
  91   2      
  92   2              case _DCC_Y_MAX:
  93   2      #if(_DCC_Y_BIT_MODE == _DCC_Y_8BIT)
                          usResult = pucReadArray[0];
              #elif(_DCC_Y_BIT_MODE == _DCC_Y_10BIT)
  96   2                  usResult = (((WORD)pucReadArray[0]) << 2) + (pucReadArray[9] >> 6);
  97   2      #endif
  98   2                  break;
  99   2      
 100   2              case _DCC_Y_MIN:
 101   2      #if(_DCC_Y_BIT_MODE == _DCC_Y_8BIT)
                          usResult = pucReadArray[1];
              #elif(_DCC_Y_BIT_MODE == _DCC_Y_10BIT)
 104   2                  usResult = (((WORD)pucReadArray[1]) << 2) + (pucReadArray[10] >> 6);
 105   2      #endif
 106   2                  break;
 107   2      
 108   2              default:
 109   2                  break;
 110   2          }
 111   1      
 112   1          return usResult;
