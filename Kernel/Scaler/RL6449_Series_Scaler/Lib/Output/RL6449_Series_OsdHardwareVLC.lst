  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Osd Load Hardware VLC
  49          // Input Value  : *pArray          -> VLC table
  50          //                usVLCTableSize   -> Use VLC_TABLE_SIZE(VLC table)
C51 COMPILER V8.12   RL6449_SERIES_OSDHARDWAREVLC                                          03/11/2025 19:56:19 PAGE 2   

  51          //                ucBankNum        -> Bank number (GET_CURRENT_BANK_NUMBER())
  52          //                usOffset         -> Font address
  53          //                usFontTableStart -> Font base address
  54          //                ucOsdRotateType  -> _OSD_ROTATE_DEGREE_0 or _OSD_ROTATE_DEGREE_90 or _OSD_ROTATE_DEGREE_
             -270 or _OSD_ROTATE_DEGREE_180
  55          // Output Value :
  56          //--------------------------------------------------
  57          void ScalerOsdHardwareVLC(BYTE *pucArray, WORD usVLCTableSize, BYTE ucBankNum, WORD usOffset, WORD usFontT
             -ableStart, EnumOsdRotateType enumOsdRotateType)
  58          {
  59   1          BYTE ucVlcType = 0;
  60   1      
  61   1          if(enumOsdRotateType == _OSD_ROTATE_DEGREE_90)
  62   1          {
  63   2              ucVlcType = _OSD_ROTATE_CW | _OSD_ROTATE_HARDWARE_ROTATION_ENABLE | _OSD_ROTATE_ROTATION;
  64   2          }
  65   1          else if(enumOsdRotateType == _OSD_ROTATE_DEGREE_270)
  66   1          {
  67   2              ucVlcType = _OSD_ROTATE_CCW | _OSD_ROTATE_HARDWARE_ROTATION_ENABLE | _OSD_ROTATE_ROTATION;
  68   2          }
  69   1          else if(enumOsdRotateType == _OSD_ROTATE_DEGREE_180)
  70   1          {
  71   2              ucVlcType = _OSD_ROTATE_CW180 | _OSD_ROTATE_HARDWARE_ROTATION_ENABLE | _OSD_ROTATE_NORMAL;
  72   2          }
  73   1          else
  74   1          {
  75   2              ucVlcType = _OSD_ROTATE_NO_SWAP;
  76   2          }
  77   1      
  78   1          // rotation
  79   1          ScalerSetBit(P3A_0B_FRAME_CTRL_0B, ~(_BIT7 | _BIT6 | _BIT2 | _BIT0), ucVlcType);
  80   1      
  81   1          ScalerBurstWrite(pucArray, 8, ucBankNum, P3A_0F_FRAME_CTRL_0F, _BURSTWRITE_DATA_COMMON_AUTO_INC, _BURS
             -TWRITE_FROM_FLASH);
  82   1      
  83   1          usOffset = usOffset * 9;
  84   1          usOffset += usFontTableStart;
  85   1      
  86   1          // osd compression enable
  87   1          ScalerSetBit(P3A_17_FRAME_CTRL_17, ~(_BIT1 | _BIT0), (_OSD_DECODE_COMPRESSED | _OSD_COMPRESSION_ENABLE
             -));
  88   1      
  89   1          pucArray += 10;
  90   1      
  91   1          ScalerOsdSramAddressSet(usOffset, _OSD_BYTEALL);
  92   1          ScalerOsdBurstWriteDataPort(pucArray, usVLCTableSize, ucBankNum, _BURSTWRITE_DATA_OSD, _BURSTWRITE_FRO
             -M_FLASH);
  93   1      
  94   1          // OSD HW needs time to process it and then write decompressed data into SRAM.
  95   1          // The value 1ms is enough at all.
  96   1          ScalerTimerDelayXms(2);
  97   1      
  98   1          // osd compression disable
  99   1          ScalerSetBit(P3A_17_FRAME_CTRL_17, ~(_BIT1 | _BIT0), (_OSD_DECODE_COMPRESSED | _OSD_COMPRESSION_DISABL
             -E));
 100   1      
 101   1          switch(enumOsdRotateType)
 102   1          {
 103   2              case _OSD_ROTATE_DEGREE_90:
 104   2              case _OSD_ROTATE_DEGREE_270:
 105   2                  ucVlcType = _OSD_ROTATE_ROTATION;
 106   2                  break;
C51 COMPILER V8.12   RL6449_SERIES_OSDHARDWAREVLC                                          03/11/2025 19:56:19 PAGE 3   

 107   2      
 108   2              default:
 109   2              case _OSD_ROTATE_DEGREE_180:
 110   2                  ucVlcType = _OSD_ROTATE_NORMAL;
 111   2                  break;
 112   2          }
 113   1      
 114   1          ScalerSetBit(P3A_0B_FRAME_CTRL_0B, ~(_BIT7 | _BIT6 | _BIT2 | _BIT0), ucVlcType);
 115   1      }
