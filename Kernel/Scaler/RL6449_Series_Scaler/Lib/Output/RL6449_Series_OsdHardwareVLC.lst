  41          void ScalerOsdHardwareVLC(BYTE *pucArray, WORD usVLCTableSize, BYTE ucBankNum, WORD usOffset, WORD usFontT
             -ableStart, EnumOsdRotateType enumOsdRotateType);
  42          
