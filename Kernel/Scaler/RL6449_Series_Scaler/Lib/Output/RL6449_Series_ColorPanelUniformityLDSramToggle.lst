  52          void ScalerColorPanelUniformityLDSramToggle(EnumDBApply enumDBApply)
  53          {
  54   1          if(ScalerGetBit(P34_17_UN_LOCAL_DIMMING, _BIT1) == _BIT1)
  55   1          {
  56   2              ScalerSetBit(P34_17_UN_LOCAL_DIMMING, ~_BIT1, 0x00);
  57   2          }
  58   1          else
  59   1          {
  60   2              ScalerSetBit(P34_17_UN_LOCAL_DIMMING, ~_BIT1, _BIT1);
  61   2          }
  62   1          ScalerColorDDomainDBApply(enumDBApply);
  63   1      }
