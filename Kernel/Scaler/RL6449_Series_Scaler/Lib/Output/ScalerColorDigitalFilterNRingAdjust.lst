  41          //****************************************************************************
  42          //-------------------------------------------------
  43          // Description  : Set NRing
  44          // Input Value  : THD,Div
  45          // Output Value : None
  46          //-------------------------------------------------
  47          void ScalerColorDigitalFilterNRingAdjust(BYTE ucTHD, BYTE ucDIV)
  48          {
  49   1          // Set negative ring  parameter
  50   1          ScalerSetBit(P0_98_DIGITAL_FILTER_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT0), _BIT6);
  51   1          ScalerSetByte(P0_99_DIGITAL_FILTER_PORT, ((ucTHD << 4) | (ucDIV << 2) | _BIT7));
