  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  :
  49          // Input Value  : ucRow -> ROW_MAPA(x), ROW_MAPB(x)
  50          //                ucHeight -> 1 ~ 64
  51          //                ucLength -> number of row to be changed
C51 COMPILER V8.12   OSDROWHEIGHT                                                          03/11/2025 19:55:57 PAGE 2   

  52          // Output Value :
  53          //--------------------------------------------------
  54          void ScalerOsdRowHeight(BYTE ucRow, BYTE ucHeight, BYTE ucLength)
  55          {
  56   1          BYTE ucIdx = 0;
  57   1      
  58   1          if(ucHeight > 64)
  59   1          {
  60   2              ucHeight = 64;
  61   2          }
  62   1      
  63   1          ucHeight--;
  64   1      
  65   1          if(ScalerGetBit(P3A_18_FRAME_CTRL_18, _BIT3) == _BIT3) // OSD 2 font function
  66   1          {
  67   2              if(ucRow >= _OSD_MAP_B_ROW_OFFSET)
  68   2              {
  69   3                  ScalerOsdSramAddressSet((ScalerGetByte(P3A_1A_FRAME_CTRL_1A) + (ucRow - _OSD_MAP_B_ROW_OFFSET)
             -), _OSD_BYTE1);
  70   3              }
  71   2              else
  72   2              {
  73   3                  ScalerOsdSramAddressSet((ScalerGetByte(P3A_19_FRAME_CTRL_19) + ucRow), _OSD_BYTE1);
  74   3              }
  75   2          }
  76   1          else
  77   1          {
  78   2              ScalerOsdSramAddressSet((0 + ucRow), _OSD_BYTE1);
  79   2          }
  80   1      
  81   1          for(ucIdx = 0; ucIdx < ucLength; ucIdx++)
  82   1          {
  83   2              ScalerOsdDataPort(ucHeight);
  84   2          }
  85   1      }
  86          
  87          /*
  88          //--------------------------------------------------
  89          // example
  90          //--------------------------------------------------
  91              ScalerOsdRowHeight(ROW_MAPA(0), HEIGHT(31), LENGTH(3));
  92          */
