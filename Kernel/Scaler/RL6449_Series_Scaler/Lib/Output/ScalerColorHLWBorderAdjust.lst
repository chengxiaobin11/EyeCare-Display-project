C51 COMPILER V8.12   SCALERCOLORHLWBORDERADJUST                                            03/11/2025 19:55:44 PAGE 2   

  52          void ScalerColorHLWBorderAdjust(BYTE ucBorderWidth, BYTE ucRed, BYTE ucGreen, BYTE ucBlue)
  53          {
  54   1          // set HLW's Border
  55   1          ScalerSetDataPortByte(P0_60_HLW_ADDR_PORT, _P0_61_PT_08_HLW_BORDER_WIDTH, (ucBorderWidth & 0x1F));
  56   1      
  57   1          // border color is 10bits,  here still use 8bits
  58   1          ScalerSetDataPortByte(P0_60_HLW_ADDR_PORT, _P0_61_PT_09_HLW_BORDER_RED, (ucRed & 0xFF));
  59   1          ScalerSetDataPortByte(P0_60_HLW_ADDR_PORT, _P0_61_PT_0A_HLW_BORDER_GRN, (ucGreen & 0xFF));
  60   1          ScalerSetDataPortByte(P0_60_HLW_ADDR_PORT, _P0_61_PT_0B_HLW_BORDER_BLU, (ucBlue & 0xFF));
  61   1      
  62   1          ScalerGlobalDDomainDBApply(_DB_APPLY_NO_POLLING);
  63   1      }


