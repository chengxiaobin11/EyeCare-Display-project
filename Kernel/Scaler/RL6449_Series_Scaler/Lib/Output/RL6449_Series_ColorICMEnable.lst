  51          // Description  : Enable/Disable ICM Function
C51 COMPILER V8.12   RL6449_SERIES_COLORICMENABLE                                          03/11/2025 19:56:06 PAGE 2   

  52          // Input Value  : EnumFunctionOnOFF
  53          // Output Value : None
  54          //--------------------------------------------------
  55          void ScalerColorICMEnable(EnumFunctionOnOFF enumOn)
  56          {
  57   1          if(enumOn == _FUNCTION_ON)
  58   1          {
  59   2              ScalerSetBit(P1_DB_DCLK_GATED_CTRL1, ~(_BIT4), _BIT4);
  60   2              ScalerSetBit(P7_D0_ICM_CONTROL, ~_BIT7, _BIT7);
  61   2          }
  62   1          else if(enumOn == _FUNCTION_OFF)
  63   1          {
  64   2              ScalerSetBit(P7_D0_ICM_CONTROL, ~(_BIT7), 0x00);
  65   2          }
  66   1          else
  67   1          {
  68   2              // gated on
  69   2              ScalerSetBit(P7_D0_ICM_CONTROL, ~(_BIT7), 0x00);
  70   2              ScalerTimerWaitForEvent(_EVENT_DVS);
  71   2              ScalerTimerDelayXms(2);
  72   2              ScalerSetBit(P1_DB_DCLK_GATED_CTRL1, ~(_BIT4), 0x00);
  73   2          }
  74   1      }


