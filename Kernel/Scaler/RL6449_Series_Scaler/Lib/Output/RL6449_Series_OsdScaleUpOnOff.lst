C51 COMPILER V8.12   RL6449_SERIES_OSDSCALEUPONOFF                                         03/11/2025 19:56:19 PAGE 2   

  52          void ScalerOsdScaleUpOnOff(bit bOnOff)
  53          {
  54   1          BYTE ucOSDOffsetCorrect = _DISABLE;
  55   1      
  56   1          if(((bit)ScalerGetBit(P3A_C0_OSD_SU_CRTL, _BIT7) != bOnOff) && (ScalerOsdPositionCorrectSupport() == _
             -ON))
  57   1          {
  58   2              ucOSDOffsetCorrect = _ENABLE;
  59   2          }
  60   1      
  61   1          ScalerSetBit(P3A_C0_OSD_SU_CRTL, ~(_BIT7), ((BYTE)bOnOff << 7));
  62   1      
  63   1          if(ucOSDOffsetCorrect == _ENABLE)
  64   1          {
  65   2              ScalerOsdPositionOffsetCorrection();
  66   2          }
  67   1      
  68   1          if(ScalerGlobalGetIDCode() == _RL6449_VER_A_ID_CODE)
  69   1          {
  70   2              // Read value effective not immediately
  71   2              ScalerTimerWaitForEvent(_EVENT_DVS);
  72   2          }
  73   1      }
