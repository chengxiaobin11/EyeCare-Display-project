 215          //****************************************************************************
 216          // FUNCTION DEFINITIONS
 217          //****************************************************************************
 218          //--------------------------------------------------
 219          // Description  : 6 Color ICM adjust
 220          // Input Value  : ucColorIndex --> Color Adjusted Now
 221          //                ucHuePosition --> Hue position after mapping
 222          //                ucSatPosition --> Sat position after mapping
 223          // Output Value : None
 224          //--------------------------------------------------
 225          void ScalerColorSixColorAdjustNormal(BYTE ucColorIndex, BYTE ucHuePosition, BYTE ucSatPosition)
 226          {
 227   1          BYTE pucCentDeltaUV[16];
 228   1          BYTE ucLastIndex = 0;
 229   1          BYTE ucAxis = 0;
 230   1          BYTE ucPointIndex = 0;
 231   1          SWORD shDeltaSat = 0;
 232   1          SWORD shDeltaUmax1 = 0;
 233   1          SWORD shDeltaVmax1 = 0;
 234   1          SWORD shDeltaUmax = 0;
 235   1          SWORD shDeltaVmax = 0;
 236   1          SWORD shDeltaU = 0;
 237   1          SWORD shDeltaV = 0;
C51 COMPILER V8.12   RL6449_SERIES_COLORSIXCOLORADJUST                                     03/11/2025 19:56:11 PAGE 5   

 238   1          BYTE ucTurningPositiongUp = 0;
 239   1          BYTE ucTurningPositiongDown = 0;
 240   1          BYTE ucLSBDataIndex = 0;
 241   1          memset(pucCentDeltaUV, 0, sizeof(pucCentDeltaUV));
 242   1      
 243   1          ucLastIndex = (ucColorIndex == 0) ? 5 : (ucColorIndex - 1);
 244   1      
 245   1          // Not Use SCM
 246   1          ScalerSetBit(P7_CD_SCM_BLOCK_SELECT, ~_BIT4, 0x00);
 247   1      
 248   1          if(ucSatPosition != 0)
 249   1          {
 250   2              ucTurningPositiongUp = tL_TURNING_POSITION_UP[ucColorIndex];
 251   2              ucTurningPositiongDown = tR_TURNING_POSITION_DOWN[ucColorIndex];
 252   2      
 253   2              // Delta Saturation = (-512 * 200 + ((512 - (-512)) * ucSatPosition)) / 200
 254   2              shDeltaSat = ((SDWORD)-102400 + ((SDWORD)ucSatPosition << 10)) / 200;
 255   2      
 256   2              for(ucAxis = 1; ucAxis < 4; ucAxis++)
 257   2              {
 258   3                  // Calculate Delta Hue of one Axis
 259   3      
 260   3                  if(ucAxis == _SIX_COLOR_RIGHTWIDTH)
 261   3                  {
 262   4                      if((ucHuePosition > 50) && (ucHuePosition <= ucTurningPositiongDown))
 263   4                      {
 264   5                          shDeltaUmax = (SDWORD)tSIX_COLOR_RTOR_DELTA_UV_DOWN[ucColorIndex][0] * (ucHuePosition 
             -- 50) / (ucTurningPositiongDown - 50);
 265   5                          shDeltaVmax = (SDWORD)tSIX_COLOR_RTOR_DELTA_UV_DOWN[ucColorIndex][1] * (ucHuePosition 
             -- 50) / (ucTurningPositiongDown - 50);
 266   5                      }
 267   4                      else if(ucHuePosition > ucTurningPositiongDown)
 268   4                      {
 269   5                          shDeltaUmax = tSIX_COLOR_RTOR_DELTA_UV_DOWN[ucColorIndex][0] + (SDWORD)tSIX_COLOR_RTOR
             -_DELTA_UV_DOWN[ucColorIndex][2] * (ucHuePosition - ucTurningPositiongDown) / (100 - ucTurningPositiongDown);
 270   5                          shDeltaVmax = tSIX_COLOR_RTOR_DELTA_UV_DOWN[ucColorIndex][1] + (SDWORD)tSIX_COLOR_RTOR
             -_DELTA_UV_DOWN[ucColorIndex][3] * (ucHuePosition - ucTurningPositiongDown) / (100 - ucTurningPositiongDown);
 271   5                      }
 272   4                      else if(ucHuePosition < 50)
 273   4                      {
 274   5                          shDeltaUmax = (SDWORD)tSIX_COLOR_RTOR_DELTA_UV_UP[ucColorIndex][0] * (50 - ucHuePositi
             -on) / 50;
 275   5                          shDeltaVmax = (SDWORD)tSIX_COLOR_RTOR_DELTA_UV_UP[ucColorIndex][1] * (50 - ucHuePositi
             -on) / 50;
 276   5                      }
 277   4                      else
 278   4                      {
 279   5                          shDeltaUmax = 0;
 280   5                          shDeltaVmax = 0;
 281   5                      }
 282   4                  }
 283   3                  else if(ucAxis == _SIX_COLOR_CENTER)
 284   3                  {
 285   4                      if(ucHuePosition > 50)
 286   4                      {
 287   5                          shDeltaUmax = (SDWORD)tSIX_COLOR_CTOC_DELTA_UV_DOWN[ucColorIndex][0] * (ucHuePosition 
             -- 50) / 50;
 288   5                          shDeltaVmax = (SDWORD)tSIX_COLOR_CTOC_DELTA_UV_DOWN[ucColorIndex][1] * (ucHuePosition 
             -- 50) / 50;
 289   5                      }
 290   4                      else if(ucHuePosition < 50)
 291   4                      {
C51 COMPILER V8.12   RL6449_SERIES_COLORSIXCOLORADJUST                                     03/11/2025 19:56:11 PAGE 6   

 292   5                          shDeltaUmax = (SDWORD)tSIX_COLOR_CTOC_DELTA_UV_UP[ucColorIndex][0] * (50 - ucHuePositi
             -on) / 50;
 293   5                          shDeltaVmax = (SDWORD)tSIX_COLOR_CTOC_DELTA_UV_UP[ucColorIndex][1] * (50 - ucHuePositi
             -on) / 50;
 294   5                      }
 295   4                      else
 296   4                      {
 297   5                          shDeltaUmax = 0;
 298   5                          shDeltaVmax = 0;
 299   5                      }
 300   4                  }
 301   3                  else
 302   3                  {
 303   4                      if(ucHuePosition > 50)
 304   4                      {
 305   5                          shDeltaUmax = (SDWORD)tSIX_COLOR_LTOL_DELTA_UV_DOWN[ucColorIndex][0] * (ucHuePosition 
             -- 50) / 50;
 306   5                          shDeltaVmax = (SDWORD)tSIX_COLOR_LTOL_DELTA_UV_DOWN[ucColorIndex][1] * (ucHuePosition 
             -- 50) / 50;
 307   5                      }
 308   4                      else if((ucHuePosition < 50) && (ucHuePosition >= ucTurningPositiongUp))
 309   4                      {
 310   5                          shDeltaUmax = (SDWORD)tSIX_COLOR_LTOL_DELTA_UV_UP[ucColorIndex][0] * (50 - ucHuePositi
             -on) / (50 - ucTurningPositiongUp);
 311   5                          shDeltaVmax = (SDWORD)tSIX_COLOR_LTOL_DELTA_UV_UP[ucColorIndex][1] * (50 - ucHuePositi
             -on) / (50 - ucTurningPositiongUp);
 312   5                      }
 313   4                      else if(ucHuePosition < ucTurningPositiongUp)
 314   4                      {
 315   5                          shDeltaUmax = tSIX_COLOR_LTOL_DELTA_UV_UP[ucColorIndex][0] + (SDWORD)tSIX_COLOR_LTOL_D
             -ELTA_UV_UP[ucColorIndex][2] * (ucTurningPositiongUp - ucHuePosition) / ucTurningPositiongUp;
 316   5                          shDeltaVmax = tSIX_COLOR_LTOL_DELTA_UV_UP[ucColorIndex][1] + (SDWORD)tSIX_COLOR_LTOL_D
             -ELTA_UV_UP[ucColorIndex][3] * (ucTurningPositiongUp - ucHuePosition) / ucTurningPositiongUp;
 317   5                      }
 318   4                      else
 319   4                      {
 320   5                          shDeltaUmax = 0;
 321   5                          shDeltaVmax = 0;
 322   5                      }
 323   4                  }
 324   3      
 325   3                  shDeltaUmax1 = tSIX_COLOR_U_MAX_8[ucColorIndex][ucAxis - 1] + shDeltaUmax;
 326   3                  shDeltaVmax1 = tSIX_COLOR_V_MAX_8[ucColorIndex][ucAxis - 1] + shDeltaVmax;
 327   3      
 328   3                  shDeltaUmax1 = ((SDWORD)shDeltaSat * shDeltaUmax1) >> 9;
 329   3                  shDeltaVmax1 = ((SDWORD)shDeltaSat * shDeltaVmax1) >> 9;
 330   3      
 331   3                  shDeltaUmax = (shDeltaUmax1 + shDeltaUmax) >> 3;
 332   3                  shDeltaVmax = (shDeltaVmax1 + shDeltaVmax) >> 3;
 333   3      
 334   3                  for(ucPointIndex = 0; ucPointIndex < 8; ucPointIndex++)
 335   3                  {
 336   4                      shDeltaU = (shDeltaUmax * (ucPointIndex + 1)) >> 3;
 337   4                      shDeltaV = (shDeltaVmax * (ucPointIndex + 1)) >> 3;
 338   4      
 339   4                      shDeltaU = MAXOF(-128, MINOF(127, shDeltaU));
 340   4                      shDeltaV = MAXOF(-128, MINOF(127, shDeltaV));
 341   4      
 342   4                      pucCentDeltaUV[ucPointIndex << 1] = shDeltaU & 0xFF;
 343   4                      pucCentDeltaUV[(ucPointIndex << 1) + 1] = shDeltaV & 0xFF;
 344   4                  }
 345   3      
C51 COMPILER V8.12   RL6449_SERIES_COLORSIXCOLORADJUST                                     03/11/2025 19:56:11 PAGE 7   

 346   3                  ScalerColorSixColorICMLoad(pucCentDeltaUV, ucColorIndex, ucAxis);
 347   3      
 348   3                  if(ucAxis == _SIX_COLOR_RIGHTWIDTH)
 349   3                  {
 350   4                      ScalerColorSixColorICMLoad(pucCentDeltaUV, ucColorIndex, _SIX_COLOR_RIGHTBUFFER);
 351   4                      ScalerColorSixColorICMLoad(pucCentDeltaUV, ucLastIndex, _SIX_COLOR_LEFTBUFFER);
 352   4                  }
