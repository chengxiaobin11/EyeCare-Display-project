 365   2              ScalerSetByte(P7_D2_ICM_ADDR, _P7_D3_PT_7F_PORT_CMN_LBUF_00_01_UV_OFFSET_L);
 366   2      
 367   2              for(ucLSBDataIndex = 0; ucLSBDataIndex < 4; ucLSBDataIndex++)
 368   2              {
