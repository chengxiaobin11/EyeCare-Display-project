  41          BYTE ScalerOsdPositionOffsetVerticalAlignByDVBGStart(BYTE ucVOffset);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Align vertical offset by DVBGStart
  49          // Input Value  : ucVOffset           -> Vertical offset base on DVBGStart 6
  50          // Output Value : Vertical offset compensation depend on DVBGStart
C51 COMPILER V8.12   OSDPOSITIONOFFSETVERTICALALIGNBYDVBGSTART                             03/11/2025 19:55:52 PAGE 2   

  51          //--------------------------------------------------
  52          BYTE ScalerOsdPositionOffsetVerticalAlignByDVBGStart(BYTE ucVOffset)
  53          {
  54   1          WORD usDVBGStart = 0;
  55   1      
  56   1          ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_0E_DISPLAY_VER_BG_STA_H, 2, &pData[0],
             - _AUTOINC);
  57   1          usDVBGStart = ((pData[0] & 0x1F) << 8) | (pData[1]);
  58   1      
  59   1          if((ScalerOsdGetDoubleFunctionH() == _TRUE) && (ScalerOsdGetDoubleFunctionV() == _TRUE))
  60   1          {
  61   2              if(usDVBGStart > 6)
  62   2              {
  63   3                  ucVOffset = ucVOffset + ((usDVBGStart - 6) / 2);
  64   3              }
  65   2              else
  66   2              {
  67   3                  if(ucVOffset >= ((6 - usDVBGStart + 1) / 2))
  68   3                  {
  69   4                      ucVOffset = ucVOffset - ((6 - usDVBGStart + 1) / 2);
  70   4                  }
  71   3                  else
  72   3                  {
  73   4                      ucVOffset = 0;
  74   4                  }
  75   3              }
  76   2          }
  77   1          else
  78   1          {
  79   2              if(usDVBGStart > 6)
  80   2              {
  81   3                  ucVOffset = ucVOffset + usDVBGStart - 6;
  82   3              }
  83   2              else
  84   2              {
  85   3                  if(ucVOffset >= (6 - usDVBGStart))
  86   3                  {
  87   4                      ucVOffset = ucVOffset - (6 - usDVBGStart);
  88   4                  }
  89   3                  else
  90   3                  {
  91   4                      ucVOffset = 0;
  92   4                  }
  93   3              }
  94   2          }
  95   1      
  96   1          // Check OSD V offset minimum
  97   1          if(ucVOffset < _OSD_V_OFFSET_MIN)
  98   1          {
  99   2              return _OSD_V_OFFSET_MIN;
 100   2          }
 101   1          else
 102   1          {
 103   2              return ucVOffset;
 104   2          }
 105   1      }
