  54          void ScalerSetDataPortDword(WORD usAddr, BYTE ucValue1, DWORD ulValue2)
  55          {
  56   1          ScalerSetDataPortByte(usAddr, ucValue1, (BYTE)(ulValue2 >> 24));
  57   1          ScalerSetDataPortByte(usAddr, ucValue1 + 1, (BYTE)(ulValue2 >> 16));
  58   1          ScalerSetDataPortByte(usAddr, ucValue1 + 2, (BYTE)(ulValue2 >> 8));
  59   1          ScalerSetDataPortByte(usAddr, ucValue1 + 3, (BYTE)(ulValue2 >> 0));
