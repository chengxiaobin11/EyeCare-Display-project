  43          void ScalerColorOutputGammaAdjust(BYTE *pucGammaTableArray, BYTE ucBankNum);
  44          
  45          //****************************************************************************
  46          // FUNCTION DEFINITIONS
  47          //****************************************************************************
  48          //--------------------------------------------------
  49          // Description  : Adjust output gamma
  50          // Input Value  : SelRegion ans Gamma Table and Gamma Table Banks and Table Length
  51          // Output Value : None
C51 COMPILER V8.12   RL6449_SERIES_COLOROUTPUTGAMMAADJUST                                  03/11/2025 19:56:07 PAGE 2   

  52          //--------------------------------------------------
  53          void ScalerColorOutputGammaAdjust(BYTE *pucGammaTableArray, BYTE ucBankNum)
  54          {
  55   1          if(ScalerGetBit(P0_67_GAMMA_CTRL_SETA, _BIT6) == _BIT6) // Gamma On
  56   1          {
  57   2              ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  58   2              ScalerColorOutputGammaEnable(_FUNCTION_OFF);
  59   2      
  60   2              // Load gamma table of R Channel
  61   2              ScalerColorOutputGammaChannelCtrl(_GAMMA_RED_CHANNEL, 0x0000, _GAMMA_WRITE_TO_SRAM);
  62   2              ScalerBurstWrite(pucGammaTableArray, _GAMMA_TABLE_SIZE, ucBankNum, P0_66_GAMMA_PORT_SETA, _BURSTWR
             -ITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  63   2      
  64   2              // Load gamma table of G Channel
  65   2              ScalerColorOutputGammaChannelCtrl(_GAMMA_GREEN_CHANNEL, 0x0000, _GAMMA_WRITE_TO_SRAM);
  66   2              ScalerBurstWrite(pucGammaTableArray + _GAMMA_TABLE_SIZE, _GAMMA_TABLE_SIZE, ucBankNum, P0_66_GAMMA
             -_PORT_SETA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  67   2      
  68   2              // Load gamma table of B Channel
  69   2              ScalerColorOutputGammaChannelCtrl(_GAMMA_BLUE_CHANNEL, 0x0000, _GAMMA_WRITE_TO_SRAM);
  70   2              ScalerBurstWrite(pucGammaTableArray + (_GAMMA_TABLE_SIZE * 2), _GAMMA_TABLE_SIZE, ucBankNum, P0_66
             -_GAMMA_PORT_SETA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  71   2      
  72   2              // Disable Port Access
  73   2              ScalerSetBit(P0_67_GAMMA_CTRL_SETA, ~_BIT7, 0x00);
  74   2      
  75   2              ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  76   2              ScalerColorOutputGammaEnable(_FUNCTION_ON);
  77   2          }
  78   1          else
  79   1          {
  80   2              // Load gamma table of R Channel
  81   2              ScalerColorOutputGammaChannelCtrl(_GAMMA_RED_CHANNEL, 0x0000, _GAMMA_WRITE_TO_SRAM);
  82   2              ScalerBurstWrite(pucGammaTableArray, _GAMMA_TABLE_SIZE, ucBankNum, P0_66_GAMMA_PORT_SETA, _BURSTWR
             -ITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  83   2      
  84   2              // Load gamma table of G Channel
  85   2              ScalerColorOutputGammaChannelCtrl(_GAMMA_GREEN_CHANNEL, 0x0000, _GAMMA_WRITE_TO_SRAM);
  86   2              ScalerBurstWrite(pucGammaTableArray + _GAMMA_TABLE_SIZE, _GAMMA_TABLE_SIZE, ucBankNum, P0_66_GAMMA
             -_PORT_SETA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  87   2      
  88   2              // Load gamma table of B Channel
  89   2              ScalerColorOutputGammaChannelCtrl(_GAMMA_BLUE_CHANNEL, 0x0000, _GAMMA_WRITE_TO_SRAM);
  90   2              ScalerBurstWrite(pucGammaTableArray + (_GAMMA_TABLE_SIZE * 2), _GAMMA_TABLE_SIZE, ucBankNum, P0_66
             -_GAMMA_PORT_SETA, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  91   2      
  92   2              // Disable Port Access
  93   2              ScalerSetBit(P0_67_GAMMA_CTRL_SETA, ~_BIT7, 0x00);
  94   2          }
  95   1      }


