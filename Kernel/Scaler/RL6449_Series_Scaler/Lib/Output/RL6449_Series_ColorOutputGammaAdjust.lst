  22          #define _GAMMA_WRITE_TO_SRAM                    0
  23          #define _GAMMA_WRITE_TO_LATCH                   1
  24          
  25          //****************************************************************************
  26          // STRUCT / TYPE / ENUM DEFINITTIONS
  27          //****************************************************************************
  28          
