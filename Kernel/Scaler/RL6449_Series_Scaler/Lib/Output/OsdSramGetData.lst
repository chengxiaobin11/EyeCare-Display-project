C51 COMPILER V8.12   OSDSRAMGETDATA                                                        03/11/2025 19:55:58 PAGE 2   

  51          // Output Value : pucData -> Data
  52          //--------------------------------------------------
  53          void ScalerOsdSramGetData(EnumOsdWriteType enumOsdWriteType, WORD usSramAddress, BYTE ucLength, BYTE *pucD
             -ata)
  54          {
  55   1          BYTE ucLenIdx = 0;
  56   1          BYTE ucRdIdx = 0;
  57   1          BYTE ucByteSel = 0;
  58   1          bit bOSDEnableBackup = 0;
  59   1      
  60   1          bOSDEnableBackup = ScalerGetBit(P3A_02_FRAME_CTRL_02, _BIT0);
  61   1      
  62   1          ScalerOsdCircuitActivated(_DISABLE);
  63   1          ScalerTimerWaitForEvent(_EVENT_DVS);
  64   1      
  65   1          ScalerSetBit(P3A_33_FRAME_CTRL_33, ~_BIT4, _BIT4);
  66   1      
  67   1          ucByteSel = ((enumOsdWriteType == _OSD_BYTEALL) ? (3) : ((enumOsdWriteType == _OSD_BYTE0_BYTE1) ? 2 : 
             -((enumOsdWriteType == _OSD_BYTE0_BYTE2) ? 2 : ((enumOsdWriteType == _OSD_BYTE1_BYTE2) ? 2 : 1))));
  68   1      
  69   1          for(ucLenIdx = 0; ucLenIdx < ucLength; ucLenIdx++)
  70   1          {
  71   2              ScalerOsdSramAddressSet(usSramAddress + ucLenIdx, enumOsdWriteType);
  72   2      
  73   2              for(ucRdIdx = 0; ucRdIdx < ucByteSel; ucRdIdx++)
  74   2              {
  75   3                  pucData[(ucLenIdx * ucByteSel) + ucRdIdx] = ScalerGetByte(P0_92_OSD_DATA_PORT);
  76   3              }
  77   2      
  78   2              for(ucRdIdx = 0; ucRdIdx < ucByteSel; ucRdIdx++)
  79   2              {
  80   3                  pucData[(ucLenIdx * ucByteSel) + ucRdIdx] = ScalerGetByte(P0_92_OSD_DATA_PORT);
  81   3              }
  82   2          }
  83   1      
  84   1          ScalerSetBit(P3A_33_FRAME_CTRL_33, ~_BIT4, 0x00);
  85   1          ScalerOsdCircuitActivated(bOSDEnableBackup);
  86   1      }
