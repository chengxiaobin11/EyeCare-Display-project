  46          //--------------------------------------------------
  47          // Description  : Get DCC Histogram Information
  48          // Input Value  : pucReadArray
  49          // Output Value : None
  50          //--------------------------------------------------
  51          void ScalerColorDCCGetHistoInfo(BYTE *pucReadArray)
C51 COMPILER V8.12   RL6449_SERIES_COLORDCCGETHISTOINFO                                    03/11/2025 19:56:03 PAGE 2   

  52          {
  53   1          BYTE ucI = 0;
  54   1      
  55   1          if(GET_DCC_READY_STATUS() == _FALSE)
  56   1          {
  57   2              memset(pucReadArray, 0, 11);
  58   2              return;
  59   2          }
  60   1      
  61   1          ScalerSetBit(P7_C7_DCC_CTRL_0, ~(_BIT1 | _BIT0), _PAGE0);
  62   1      
  63   1          // Pop out result
  64   1          ScalerSetByte(P7_C9_DCC_ADDRESS_PORT, _P7_CA_PT_0C_PORT_PAGE0_POPUP_CTRL);
  65   1          // Read 0x07C9_0C to freeze DCC infomation
  66   1          ScalerGetByte(P7_CA_DCC_DATA_PORT);
  67   1      
  68   1          // Get Histogram Info
  69   1          ScalerSetByte(P7_C9_DCC_ADDRESS_PORT, _P7_CA_PT_0E_PORT_PAGE0_Y_MAX_VAL_H);
  70   1      
  71   1          for(ucI = 0; ucI < 9; ucI++)
  72   1          {
  73   2              pucReadArray[ucI] = ScalerGetByte(P7_CA_DCC_DATA_PORT);
  74   2          }
  75   1      
  76   1          ScalerSetByte(P7_C9_DCC_ADDRESS_PORT, _P7_CA_PT_1C_PORT_PAGE0_Y_MAX_VAL_L);
  77   1          pucReadArray[9] = ScalerGetByte(P7_CA_DCC_DATA_PORT);
  78   1          pucReadArray[10] = ScalerGetByte(P7_CA_DCC_DATA_PORT);
  79   1      }


