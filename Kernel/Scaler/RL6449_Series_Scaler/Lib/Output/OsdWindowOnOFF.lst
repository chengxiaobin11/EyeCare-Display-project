  46          //--------------------------------------------------
  47          // Description  : Enable/Disable window
  48          // Input Value  : enumOsdWindowsType -> _OSD_WINDOW_0,   _OSD_WINDOW_1,   _OSD_WINDOW_2,   _OSD_WINDOW_3, 
             -  _OSD_WINDOW_4,   _OSD_WINDOW_5,
  49          //                                      _OSD_WINDOW_6,   _OSD_WINDOW_7,   _OSD_WINDOW_8,   _OSD_WINDOW_9, 
             -  _OSD_WINDOW_4_1, _OSD_WINDOW_4_2,
C51 COMPILER V8.12   OSDWINDOWONOFF                                                        03/11/2025 19:56:01 PAGE 2   

  50          //                                      _OSD_WINDOW_4_3, _OSD_WINDOW_4_4, _OSD_WINDOW_4_5, _OSD_WINDOW_4_6
             -, _OSD_WINDOW_4_7, _OSD_WINDOW_4_8
  51          //                                      _OSD_WINDOW_5_1, _OSD_WINDOW_5_2, _OSD_WINDOW_5_3, _OSD_WINDOW_5_4
             -, _OSD_WINDOW_5_5, _OSD_WINDOW_5_6,
  52          //                                      _OSD_WINDOW_5_7, _OSD_WINDOW_5_8
  53          //                                      _OSD_WINDOW_ALL,
  54          // Output Value :
  55          //--------------------------------------------------
  56          void ScalerOsdWindowOnOFF(EnumOsdWindowsType enumOsdWindowsType, bit bWinOnOff)
  57          {
  58   1          if(enumOsdWindowsType <= _OSD_WINDOW_7)
  59   1          {
  60   2              // _OSD_WINDOW_0 ~ _OSD_WINDOW_7
  61   2              ScalerSetBit(P3A_57_FRAME_CTRL_57, ~(_BIT0 << enumOsdWindowsType), ((BYTE)bWinOnOff << enumOsdWind
             -owsType));
  62   2          }
  63   1          else if((enumOsdWindowsType == _OSD_WINDOW_8) || (enumOsdWindowsType == _OSD_WINDOW_9))
  64   1          {
  65   2              // _OSD_WINDOW_8 ~ _OSD_WINDOW_9
  66   2              ScalerSetBit(P3A_58_FRAME_CTRL_58, ~(_BIT0 << (enumOsdWindowsType - _OSD_WINDOW_8)), ((BYTE)bWinOn
             -Off << (enumOsdWindowsType - _OSD_WINDOW_8)));
  67   2          }
  68   1          else if((enumOsdWindowsType >= _OSD_WINDOW_4_1) && (enumOsdWindowsType <= _OSD_WINDOW_4_8))
  69   1          {
  70   2              // _OSD_WINDOW_4_1 ~ _OSD_WINDOW_4_8
  71   2              ScalerSetBit(P3A_59_FRAME_CTRL_59, ~(_BIT0 << (enumOsdWindowsType - _OSD_WINDOW_4_1)), ((BYTE)bWin
             -OnOff << (enumOsdWindowsType - _OSD_WINDOW_4_1)));
  72   2          }
  73   1      #if(_OSD_WINDOW_5_1_5_8_SUPPORT == _ON)
  74   1          else if((enumOsdWindowsType >= _OSD_WINDOW_5_1) && (enumOsdWindowsType <= _OSD_WINDOW_5_8))
  75   1          {
  76   2              // _OSD_WINDOW_5_1 ~ _OSD_WINDOW_5_8
  77   2              ScalerSetBit(P3A_5A_FRAME_CTRL_5A, ~(_BIT0 << (enumOsdWindowsType - _OSD_WINDOW_5_1)), ((BYTE)bWin
             -OnOff << (enumOsdWindowsType - _OSD_WINDOW_5_1)));
  78   2          }
  79   1      #endif
  80   1      }


