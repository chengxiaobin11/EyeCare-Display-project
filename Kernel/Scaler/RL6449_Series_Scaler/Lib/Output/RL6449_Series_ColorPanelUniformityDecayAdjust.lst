  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Load Panel Uniformity LUT
  49          // Input Value  : LUT, Bank number, EnumUniformityModeSelect
C51 COMPILER V8.12   RL6449_SERIES_COLORPANELUNIFORMITYDECAYAD                             03/11/2025 19:56:12 PAGE 2   

  50          // Output Value : None
  51          //--------------------------------------------------
  52          void ScalerColorPanelUniformityDecayAdjust(BYTE *pucUNILUT, WORD usUNILUTSize, BYTE ucBankNum, EnumUniform
             -ityModeSelect enumUniformityMode, BYTE ucDecayDegree)
  53          {
  54   1          // Set degree of decay
  55   1          if(enumUniformityMode == _UNIFORMITY_PCM_MODE)
  56   1          {
  57   2              ScalerSetBit(P34_01_UN_MULTI_LUT_CTRL, ~(_BIT5 | _BIT4), ((ucDecayDegree / 2) << 4));
  58   2          }
  59   1          else
  60   1          {
  61   2              // Enable uniformity access
  62   2              ScalerSetBit(P34_00_UN_GLOBAL_CTRL, ~_BIT2, _BIT2);
  63   2      
  64   2              // Load uniformity gain LUT
  65   2              ScalerBurstWrite(pucUNILUT, usUNILUTSize, ucBankNum, P34_14_UN_DECAY_LUT_ACCESS_PORT, _BURSTWRITE_
             -DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  66   2      
  67   2              // Disable uniformity access
  68   2              ScalerSetBit(P34_00_UN_GLOBAL_CTRL, ~_BIT2, 0x00);
  69   2          }
  70   1      }
  71          


