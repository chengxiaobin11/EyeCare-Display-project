  41          void ScalerColorPanelUniformityDecayAdjust(BYTE *pucUNILUT, WORD usUNILUTSize, BYTE ucBankNum, EnumUniform
             -ityModeSelect enumUniformityMode, BYTE ucDecayDegree);
  42          
