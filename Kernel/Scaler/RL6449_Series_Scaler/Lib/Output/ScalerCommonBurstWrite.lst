  51          // Output Value : Value after & operation
  52          //--------------------------------------------------
  53          void ScalerBurstWrite(BYTE *pucAddress, WORD usWriteLength, BYTE ucBankNum, WORD usHostAddr, BYTE ucTableT
             -ype, bit bTableLocation)
  54          {
  55   1          BYTE ucTimeOut = 100;
  56   1      
  57   1          ScalerSetByte(P0_9F_PAGE_SEL, HIBYTE(usHostAddr));
  58   1      
  59   1          // Disable burst write data and burst write command function.
  60   1          MCU_FFF3_SCA_INF_CONTROL &= 0xE7;
  61   1      
  62   1          // Disable Burst write Auto Inc
  63   1          MCU_FFF3_SCA_INF_CONTROL |= _BIT5;
  64   1      
  65   1          if((ucTableType == _BURSTWRITE_DATA_COMMON) || (ucTableType == _BURSTWRITE_DATA_COMMON_AUTO_INC) || (u
             -cTableType == _BURSTWRITE_DATA_OSD))
  66   1          {
  67   2              MCU_FFF4_SCA_INF_ADDR = usHostAddr;
  68   2          }
  69   1      
  70   1          MCU_FFF6_SCA_INF_BWR_ADRH = ucBankNum;
  71   1      
  72   1          MCU_FFF7_SCA_INF_BWR_ADRM = (BYTE)((((WORD)pucAddress) & 0xFF00) >> 8);
  73   1          MCU_FFF8_SCA_INF_BWR_ADRL = (BYTE)((((WORD)pucAddress) & 0x00FF));
  74   1      
  75   1          MCU_FFF9_SCA_INF_BWR_COUNT_H = (BYTE)(((usWriteLength) & 0xFF00) >> 8);
  76   1          MCU_FFFA_SCA_INF_BWR_COUNT_L = (BYTE)(((usWriteLength) & 0x00FF));
  77   1      
  78   1          if(ucTableType == _BURSTWRITE_DATA_OSD)
  79   1          {
  80   2              BYTE ucData = 0;
  81   2      
  82   2              ucData = ScalerBurstWriteTimeoutCal();
  83   2      
  84   2              if(ucData >= 2)
  85   2              {
  86   3                  // Set the interval between two command for OSD Load Font data.
  87   3                  MCU_FFFB_SCA_INF_PERIOD = ucData;
  88   3              }
  89   2              else
  90   2              {
  91   3                  MCU_FFFB_SCA_INF_PERIOD = 0x02;
  92   3              }
  93   2          }
  94   1          else
  95   1          {
  96   2              MCU_FFFB_SCA_INF_PERIOD = 0x03;
  97   2          }
  98   1      
  99   1          MCU_FFFC_BANK_SWICH_CONTROL |= (_BIT5 & (((BYTE)bTableLocation) << 5));
 100   1      
 101   1          if(ucTableType == _BURSTWRITE_COMMAND)
 102   1          {
 103   2              // Enable burst write command function, enable the function of releasing mcu by interrupt.
 104   2              MCU_FFF3_SCA_INF_CONTROL = 0x10;
 105   2      
 106   2              while(((MCU_FFF3_SCA_INF_CONTROL & _BIT4) == _BIT4) && (--ucTimeOut > 0))
 107   2              {
 108   3                  // Restart Burst Write When Interrupted
 109   3                  MCU_FFF3_SCA_INF_CONTROL |= _BIT4;
 110   3              }
C51 COMPILER V8.12   SCALERCOMMONBURSTWRITE                                                03/11/2025 19:55:38 PAGE 3   

 111   2          }
 112   1          else  // _BURSTWRITE_DATA_COMMON/OSD
 113   1          {
 114   2              if(ucTableType == _BURSTWRITE_DATA_COMMON_AUTO_INC)
 115   2              {
 116   3                  // Enable burst write data function, disable auto address increase, enable the function of rel
             -easing mcu by interrupt.
 117   3                  MCU_FFF3_SCA_INF_CONTROL = 0x08;
 118   3              }
 119   2              else
 120   2              {
 121   3                  // Enable burst write data function, disable auto address increase, enable the function of rel
             -easing mcu by interrupt.
 122   3                  MCU_FFF3_SCA_INF_CONTROL = 0x28;
 123   3              }
 124   2      
 125   2              while(((MCU_FFF3_SCA_INF_CONTROL & _BIT3) == _BIT3) && (--ucTimeOut > 0))
 126   2              {
 127   3                  // Restart Burst Write When Interrupted
 128   3                  MCU_FFF3_SCA_INF_CONTROL |= _BIT3;
 129   3              }
 130   2          }
 131   1      
 132   1          // disable burst data from int xram.
 133   1          MCU_FFFC_BANK_SWICH_CONTROL &= ~_BIT5;
 134   1      }


