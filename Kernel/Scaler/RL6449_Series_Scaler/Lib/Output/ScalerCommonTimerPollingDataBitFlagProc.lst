  43          //----------------------------------------------------------------------
  44          // Description  : Polling Scaler Flag Process
  45          // Input Value  : ucTimeout --> Timeout number (Max: 255 ms)
  46          //                ucRegister--> Current Register
  47          //                ucBit     --> Polling Bit
  48          //                bSuccess  --> 1 or 0 when finished for Polling Bit
  49          // Output Value : Return _TRUE while polling success, _FALSE for timeout
C51 COMPILER V8.12   SCALERCOMMONTIMERPOLLINGDATABITFLAGPROC                               03/11/2025 19:55:37 PAGE 2   

  50          //----------------------------------------------------------------------
  51          bit ScalerTimerPollingDataBitFlagProc(WORD usTimeout, WORD usRegister, BYTE ucValue, BYTE ucBit, bit bSucc
             -ess)
  52          {
  53   1          WORD usTimeElapsed = 0;
  54   1          WORD usPreviousTime = 0;
  55   1      
  56   1          usPreviousTime = g_usTimerCounter;
  57   1      
  58   1          do
  59   1          {
  60   2              if(((bit)ScalerGetDataPortBit(usRegister, ucValue, ucBit) ^ bSuccess) == _FALSE)
  61   2              {
  62   3                  return _TRUE;
  63   3              }
  64   2      
  65   2              if(usPreviousTime != g_usTimerCounter)
  66   2              {
  67   3                  usTimeElapsed++;
  68   3                  usPreviousTime = g_usTimerCounter;
  69   3              }
  70   2          }
  71   1          while(usTimeElapsed <= usTimeout);
  72   1      
  73   1          return _FALSE;
  74   1      }
