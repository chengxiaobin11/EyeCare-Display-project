  53          void ScalerMDomainDisplayTimingGenDBEnable(bit bEnable)
  54          {
  55   1          // Set Display Timing Gen Double Buffer
  56   1          if(bEnable == _ENABLE)
  57   1          {
  58   2              ScalerSetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, ~(_BIT7 | _BIT6), _BIT7);
  59   2          }
  60   1          else
  61   1          {
  62   2              ScalerSetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, ~(_BIT7 | _BIT6), 0x00);
  63   2          }
  64   1      }
