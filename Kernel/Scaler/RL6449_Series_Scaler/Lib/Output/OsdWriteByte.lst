  41          void ScalerOsdWriteByte(BYTE ucIndicateAndWriteByte, EnumOsdDBufType enumDBuf, WORD usAddr, BYTE ucData);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Set OSD Write Byte
  49          // Input Value  : ucIndicateAndWriteByte -> (_OSD_WIN_CONTROL or _OSD_SRAM)  |
  50          //                                          (_OSD_BYTE0       or _OSD_BYTE1       or _OSD_BYTE2       or
  51          //                                           _OSD_BYTE0_BYTE1 or _OSD_BYTE0_BYTE2 or _OSD_BYTE1_BYTE2 or _
C51 COMPILER V8.12   OSDWRITEBYTE                                                          03/11/2025 19:55:50 PAGE 2   

             -OSD_BYTEALL)
  52          //                usAddr                 -> SRAM address
  53          //                ucData                 -> ucIndicate's Data
  54          // Output Value :
  55          //--------------------------------------------------
  56          void ScalerOsdWriteByte(BYTE ucIndicateAndWriteByte, EnumOsdDBufType enumDBuf, WORD usAddr, BYTE ucData)
  57          {
  58   1          enumDBuf = enumDBuf;
  59   1      
  60   1          // Set Address Indicator: 00: Window control registers, 10: Font Select and font map SRAM
  61   1          ScalerSetBit(P0_94_OSD_WRITE_OPTION, ~(_BIT3 | _BIT2), (ucIndicateAndWriteByte & (_BIT3 | _BIT2)));
  62   1      
  63   1          // Select Which Byte to Write:  001: Byte0, 010: Byte1, 100: Byte2, 011: Byte0 & Byte1, 101: Byte0 & B
             -yte2, 110: Byte1 & Byte2,111: All
  64   1          ScalerSetBit(P0_94_OSD_WRITE_OPTION, ~(_BIT7 | _BIT6 | _BIT5), (ucIndicateAndWriteByte & (_BIT7 | _BIT
             -6 | _BIT5)));
  65   1      
  66   1          // Set Address
  67   1          ScalerSetBit(P0_90_OSD_ADR_PORT_MSB, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (HIBYTE
             -(usAddr) & 0x7F));
  68   1          ScalerSetByte(P0_91_OSD_ADR_PORT_LSB, LOBYTE(usAddr));
  69   1      
  70   1          // Set Data
  71   1          ScalerSetByte(P0_92_OSD_DATA_PORT, ucData);
  72   1      }


