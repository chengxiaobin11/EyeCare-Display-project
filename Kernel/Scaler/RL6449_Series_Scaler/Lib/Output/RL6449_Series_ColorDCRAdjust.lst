C51 COMPILER V8.12   RL6449_SERIES_COLORDCRADJUST                                          03/11/2025 19:56:03 PAGE 2   

  52          void ScalerColorDCRAdjust(WORD usThreshold1, WORD usThreshold2, EnumDCRMeasureSel enumDCRMeasureSel)
  53          {
  54   1          ScalerSetByte(P7_D8_DCR_ADDRESS_PORT, (_P7_D9_PT_00_DCR_THESHOLD1_1 << 2) | _BIT0);
  55   1          ScalerSetByte(P7_D9_DCR_DATA_PORT, usThreshold1 >> 2);
  56   1          ScalerSetByte(P7_D8_DCR_ADDRESS_PORT, (_P7_D9_PT_01_DCR_THESHOLD2_1 << 2) | _BIT0);
  57   1          ScalerSetByte(P7_D9_DCR_DATA_PORT, usThreshold2 >> 2);
  58   1      
  59   1          ScalerSetByte(P7_D8_DCR_ADDRESS_PORT, (_P7_D9_PT_38_DCR_THESHOLD1_0 << 2) | _BIT0);
  60   1          ScalerSetByte(P7_D9_DCR_DATA_PORT, (usThreshold1 & (_BIT1 | _BIT0)) << 6);
  61   1          ScalerSetByte(P7_D8_DCR_ADDRESS_PORT, (_P7_D9_PT_39_DCR_THESHOLD2_0 << 2) | _BIT0);
  62   1          ScalerSetByte(P7_D9_DCR_DATA_PORT, (usThreshold2 & (_BIT1 | _BIT0)) << 6);
  63   1      
  64   1          ScalerSetBit(P7_DA_DCR_CTRL, ~(_BIT3 | _BIT2 | _BIT1), (enumDCRMeasureSel << 1));
  65   1      }
