  48          // Description  : Set OSD Char Command All Byte Series
  49          // Input Value  : usCharAddr -> SRAM address
  50          //                ucByte0      -> Byte0 data
C51 COMPILER V8.12   OSDCHARCOMMANDALLBYTESERIES                                           03/11/2025 19:55:55 PAGE 2   

  51          //                ucByte1      -> Byte1 data
  52          //                ucByte2      -> Byte2 data
  53          //                usLength     -> Length
  54          // Output Value :
  55          //--------------------------------------------------
  56          void ScalerOsdCharCommandAllByteSeries(WORD usCharAddr, BYTE ucByte0, BYTE ucByte1, BYTE ucByte2, WORD usL
             -ength)
  57          {
  58   1          ScalerOsdSramAddressSet(usCharAddr, _OSD_BYTEALL);
  59   1      
  60   1          do
  61   1          {
  62   2              ScalerSetByte(P0_92_OSD_DATA_PORT, ucByte0);
  63   2              ScalerSetByte(P0_92_OSD_DATA_PORT, ucByte1);
  64   2              ScalerSetByte(P0_92_OSD_DATA_PORT, ucByte2);
  65   2          }
  66   1          while(--usLength);
  67   1      }


