C51 COMPILER V8.12   SCALERCOMMONDATAPORTACCESS_EXINT0                                     03/11/2025 19:55:40 PAGE 2   

  52          //                ucValue   --> Data Port Value we want to set
  53          // Output Value : Return Access Port Value
  54          //--------------------------------------------------
  55          BYTE ScalerEnableAccessPort_EXINT0(WORD usAddr, BYTE ucValue) using 1
  56          {
  57   1          usAddr = usAddr;
  58   1          return ucValue;
  59   1      }
  60          
  61          //--------------------------------------------------
  62          // Description  : Disable Access Port
  63          // Input Value  : usAddr   --> Start address of register
  64          // Output Value : None
  65          //--------------------------------------------------
  66          void ScalerDisableAccessPort_EXINT0(WORD usAddr) using 1
  67          {
  68   1          usAddr = usAddr;
  69   1      }
  70          
  71          //--------------------------------------------------
  72          // Description  : Set the value into selected register in data port
  73          // Input Value  : usAddr    --> Access Port Address of register
  74          //                ucValue1  --> Data Port Value we want to set
  75          //                ucValue2  --> Data Value we want to set
  76          // Output Value : None
  77          //--------------------------------------------------
  78          void ScalerSetDataPortByte_EXINT0(WORD usAddr, BYTE ucValue1, BYTE ucValue2) using 1
  79          {
  80   1          ScalerSetByte_EXINT(usAddr, ScalerEnableAccessPort_EXINT0(usAddr, ucValue1));
  81   1          ScalerSetByte_EXINT(usAddr + 1, ucValue2);
  82   1      
  83   1          ScalerDisableAccessPort_EXINT0(usAddr);
  84   1      }
  85          
  86          //--------------------------------------------------
  87          // Description  : Set some bits of selected register in data port
  88          // Input Value  : usAddr    --> Access Port Address of register
  89          //                ucValue   --> Data Port Value we want to set
  90          //                ucAnd     --> & operation
  91          //                ucOr      --> | operation
  92          // Output Value : None
  93          //--------------------------------------------------
  94          void ScalerSetDataPortBit_EXINT0(WORD usAddr, BYTE ucValue, BYTE ucAnd, BYTE ucOr) using 1
  95          {
  96   1          BYTE ucValueTemp = 0;
  97   1      
  98   1          // backup port addr
  99   1          BYTE ucBackupPortAddr = ScalerGetByte_EXINT(usAddr);
 100   1      
 101   1          ScalerSetByte_EXINT(usAddr, ScalerEnableAccessPort_EXINT0(usAddr, ucValue));
 102   1          ucValueTemp = ScalerGetByte_EXINT(usAddr + 1);
 103   1      
 104   1          ucValueTemp = (ucValueTemp & ucAnd) | ucOr;
 105   1      
 106   1          ScalerSetByte_EXINT(usAddr, ScalerEnableAccessPort_EXINT0(usAddr, ucValue));
 107   1          ScalerSetByte_EXINT(usAddr + 1, ucValueTemp);
 108   1      
 109   1          ScalerDisableAccessPort_EXINT0(usAddr);
 110   1      
 111   1          // return backup port addr
 112   1          ScalerSetByte_EXINT(usAddr, ucBackupPortAddr);
 113   1      }
