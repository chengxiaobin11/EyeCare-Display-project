C51 COMPILER V8.12   RL6449_SERIES_COLORRINGINGFILTERADJUST                                03/11/2025 19:56:10 PAGE 2   

  52          //--------------------------------------------------
  53          // Description  : Adjust Ringing Filter
  54          // Input Value  : Offset Coef
  55          // Output Value : None
  56          //--------------------------------------------------
  57          void ScalerColorRingingFilterAdjust(BYTE *pucOffsetCoef)
  58          {
  59   1          BYTE ucTHD = 0;
  60   1          BYTE ucRFEn = 0;
  61   1      
  62   1          if(*pucOffsetCoef > 0)
  63   1          {
  64   2              ucTHD = (WORD)_RINGING_FILTER_DELTA * 128 / (*pucOffsetCoef);
  65   2          }
  66   1          else
  67   1          {
  68   2              ucTHD = 255;
  69   2          }
  70   1      
  71   1          if(ucTHD < _RINGING_FILTER_THRESHOLD)
  72   1          {
  73   2              ucTHD = _RINGING_FILTER_THRESHOLD;
  74   2          }
  75   1          else if(ucTHD > 255 - (1 << _RINGING_FILTER_THD_RANGE))
  76   1          {
  77   2              ucTHD = 255 - (1 << _RINGING_FILTER_THD_RANGE);
  78   2          }
  79   1      
  80   1          ucRFEn = 1;
  81   1      
  82   1          ScalerSetByte(P25_A1_RFILTER_THD, ucTHD);
  83   1          ScalerSetByte(P25_A2_RFILTER_THD_RNG_EXP, _RINGING_FILTER_THD_RANGE);
  84   1          ScalerSetByte(P25_A3_RFILTER_OFS_COEF, (*pucOffsetCoef));
  85   1          ScalerSetByte(P25_A5_RFILTER_DIFF_THD_UB, _RINGING_JUMP_DIFF_THD_UB);
  86   1          ScalerSetByte(P25_A6_RFILTER_DIFF_THD_LB, _RINGING_JUMP_DIFF_THD_LB);
  87   1          ScalerSetBit(P25_A0_RFILTER_CTRL, ~(_BIT7 | _BIT6 | _BIT5), ((ucRFEn << 7) | _BIT6 | (_RINGING_JUMP_JU
             -DGEMENT_EN << 5)));
  88   1      }


