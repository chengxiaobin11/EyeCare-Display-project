  21          #define _RINGING_FILTER_THRESHOLD           30
  22          #define _RINGING_FILTER_THD_RANGE           4
  23          #define _RINGING_JUMP_JUDGEMENT_EN          _DISABLE
  24          #define _RINGING_JUMP_DIFF_THD_UB           1  // reg value
  25          #define _RINGING_JUMP_DIFF_THD_LB           1  // reg value
  26          #define _RINGING_FILTER_DELTA               5
