  52          void ScalerColorHLWDDomainAdjust(WORD usHPos, WORD usHWidth, WORD usVPos, WORD usVHeight)
  53          {
  54   1          if((usHWidth == 0) || (usVHeight == 0))
  55   1          {
  56   2              return;
  57   2          }
  58   1      
  59   1          if(ScalerGlobalGetHLWDBStatus() == _FALSE)
  60   1          {
  61   2              ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  62   2          }
  63   1      
