C51 COMPILER V8.12   RL6449_SERIES_COLORRGB3DGAMMA                                         03/11/2025 19:56:09 PAGE 2   

  52          // Description  : Adjust 3D gamma
  53          // Input Value  : 3D Gamma Table and 3D Gamma Table Banks
  54          // Output Value : None
  55          //--------------------------------------------------
  56          void ScalerColorRGB3DGammaAdjust(BYTE *pucGammaTableArray, BYTE ucBankNum)
  57          {
  58   1          if(ScalerGetBit(P9_B0_RGB_3D_GAMMA_CTRL, _BIT7) == _BIT7) // 3D Gamma On
  59   1          {
  60   2              ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  61   2              ScalerColorRGB3DGammaEnable(_FUNCTION_OFF);
  62   2      
  63   2              // Enable Gamma access
  64   2              ScalerSetBit(P9_B0_RGB_3D_GAMMA_CTRL, ~_BIT6, _BIT6);
  65   2      
  66   2              // Initial Table Address
  67   2              ScalerSetByte(P9_B1_RGB_3D_GAMMA_ADDRESS_H, 0x00);
  68   2              ScalerSetByte(P9_B2_RGB_3D_GAMMA_ADDRESS_L, 0x00);
  69   2      
  70   2              // Load gamma table of 3D Gamma
  71   2              ScalerBurstWrite(pucGammaTableArray, _3DGAMMA_TABLE_SIZE, ucBankNum, P9_B3_RGB_3D_GAMMA_PORT, _BUR
             -STWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  72   2      
  73   2              // Disable Port Access
  74   2              ScalerSetBit(P9_B0_RGB_3D_GAMMA_CTRL, ~_BIT6, 0x00);
  75   2      
  76   2              ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  77   2              ScalerColorRGB3DGammaEnable(_FUNCTION_ON);
  78   2          }
  79   1          else
  80   1          {
  81   2              // Enable Gamma access
  82   2              ScalerSetBit(P9_B0_RGB_3D_GAMMA_CTRL, ~_BIT6, _BIT6);
  83   2      
  84   2              // Initial Table Address
  85   2              ScalerSetByte(P9_B1_RGB_3D_GAMMA_ADDRESS_H, 0x00);
  86   2              ScalerSetByte(P9_B2_RGB_3D_GAMMA_ADDRESS_L, 0x00);
  87   2      
  88   2              // Load gamma table of 3D Gamma
  89   2              ScalerBurstWrite(pucGammaTableArray, _3DGAMMA_TABLE_SIZE, ucBankNum, P9_B3_RGB_3D_GAMMA_PORT, _BUR
             -STWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
  90   2      
  91   2              // Disable Port Access
  92   2              ScalerSetBit(P9_B0_RGB_3D_GAMMA_CTRL, ~_BIT6, 0x00);
  93   2          }
  94   1      }


