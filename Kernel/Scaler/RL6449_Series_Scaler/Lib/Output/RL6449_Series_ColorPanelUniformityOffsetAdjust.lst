  48          // Description  : Load Panel Uniformity LUT
  49          // Input Value  : LUT, Bank number, EnumUniformityModeSelect
  50          // Output Value : None
C51 COMPILER V8.12   RL6449_SERIES_COLORPANELUNIFORMITYOFFSETA                             03/11/2025 19:56:12 PAGE 2   

  51          //--------------------------------------------------
  52          void ScalerColorPanelUniformityOffsetAdjust(BYTE *pucUNILUT, WORD usUNILUTSize, BYTE ucBankNum)
  53          {
  54   1          // Enable uniformity access
  55   1          ScalerSetBit(P34_00_UN_GLOBAL_CTRL, ~_BIT2, _BIT2);
  56   1      
  57   1          // Load uniformity offset LUT
  58   1          ScalerBurstWrite(pucUNILUT, usUNILUTSize, ucBankNum, P34_0F_UN_OFFSET_LUT_ACCESS_PORT, _BURSTWRITE_DAT
             -A_COMMON, _BURSTWRITE_FROM_FLASH);
  59   1      
  60   1          // Disable uniformity access
  61   1          ScalerSetBit(P34_00_UN_GLOBAL_CTRL, ~_BIT2, 0x00);
  62   1      }
  63          


