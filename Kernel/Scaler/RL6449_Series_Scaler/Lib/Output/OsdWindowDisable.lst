  47          //--------------------------------------------------
  48          // Description  : Disable window
  49          // Input Value  : enumOsdWindowsType -> _OSD_WINDOW_0,   _OSD_WINDOW_1,   _OSD_WINDOW_2,   _OSD_WINDOW_3, 
             -  _OSD_WINDOW_4,   _OSD_WINDOW_5,
  50          //                                      _OSD_WINDOW_6,   _OSD_WINDOW_7,   _OSD_WINDOW_8,   _OSD_WINDOW_9, 
C51 COMPILER V8.12   OSDWINDOWDISABLE                                                      03/11/2025 19:56:00 PAGE 2   

             -  _OSD_WINDOW_4_1, _OSD_WINDOW_4_2,
  51          //                                      _OSD_WINDOW_4_3, _OSD_WINDOW_4_4, _OSD_WINDOW_4_5, _OSD_WINDOW_4_6
             -, _OSD_WINDOW_4_7, _OSD_WINDOW_4_8
  52          //                                      _OSD_WINDOW_5_1, _OSD_WINDOW_5_2, _OSD_WINDOW_5_3, _OSD_WINDOW_5_4
             -, _OSD_WINDOW_5_5, _OSD_WINDOW_5_6,
  53          //                                      _OSD_WINDOW_5_7, _OSD_WINDOW_5_8
  54          //                                      _OSD_WINDOW_ALL,
  55          // Output Value :
  56          //--------------------------------------------------
  57          void ScalerOsdWindowDisable(EnumOsdWindowsType enumOsdWindowsType)
  58          {
  59   1      
  60   1          WORD usWinTemp = 0;
  61   1      
  62   1          if(enumOsdWindowsType == _OSD_WINDOW_ALL)
  63   1          {
  64   2              for(usWinTemp = 0; usWinTemp < 10; usWinTemp++)
  65   2              {
  66   3                  // Window 0~9
  67   3                  ScalerOsdWriteByte((_OSD_WIN_CONTROL | _OSD_BYTE2), _OSD_WITHOUT_DB, ((_P0_92_PT_103_WIN0_ADR3
             -_LSB >> 4) + usWinTemp * 4), 0x00);
  68   3      
  69   3                  if(usWinTemp < 8)
  70   3                  {
  71   4                      // Window 4-1~4-8
  72   4                      ScalerOsdWriteByte((_OSD_WIN_CONTROL | _OSD_BYTE2), _OSD_WITHOUT_DB, ((_P0_92_PT_203_WIN4_
             -1_ADR3_LSB >> 4) + usWinTemp * 4), 0x00);  // _OSD_WINDOW_4_1 ~ _OSD_WINDOW_4_8
  73   4      
  74   4      #if(_OSD_WINDOW_5_1_5_8_SUPPORT == _ON)
  75   4                      // Window 5-1~5-8
  76   4                      ScalerOsdWriteByte((_OSD_WIN_CONTROL | _OSD_BYTE2), _OSD_WITHOUT_DB, ((_P0_92_PT_223_WIN5_
             -1_ADR3_LSB >> 4) + usWinTemp * 4), 0x00);  // _OSD_WINDOW_5_1 ~ _OSD_WINDOW_5_8
  77   4      #endif
  78   4                  }
  79   3              }
  80   2          }
  81   1          else
  82   1          {
  83   2      #if(_OSD_WINDOW_5_1_5_8_SUPPORT == _ON)
  84   2              if((enumOsdWindowsType >= _OSD_WINDOW_5_1) && (enumOsdWindowsType <= _OSD_WINDOW_5_8))
  85   2              {
  86   3                  usWinTemp = (_P0_92_PT_223_WIN5_1_ADR3_LSB >> 4) + ((enumOsdWindowsType - _OSD_WINDOW_5_1) * 4
             -);
  87   3              }
  88   2              else
  89   2      #endif
  90   2              {
  91   3                  if((enumOsdWindowsType >= _OSD_WINDOW_4_1) && (enumOsdWindowsType <= _OSD_WINDOW_4_8))
  92   3                  {
  93   4                      usWinTemp = (_P0_92_PT_203_WIN4_1_ADR3_LSB >> 4) + ((enumOsdWindowsType - _OSD_WINDOW_4_1)
             - * 4);
  94   4                  }
  95   3                  else if(enumOsdWindowsType <= _OSD_WINDOW_9)
  96   3                  {
  97   4                      usWinTemp = (_P0_92_PT_103_WIN0_ADR3_LSB >> 4) + (enumOsdWindowsType * 4);
  98   4                  }
  99   3              }
 100   2      
 101   2              ScalerOsdWriteByte((_OSD_WIN_CONTROL | _OSD_BYTE2), _OSD_WITHOUT_DB, usWinTemp, 0x00);
 102   2          }
 103   1      }
