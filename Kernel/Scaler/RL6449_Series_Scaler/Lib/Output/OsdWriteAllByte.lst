  56          void ScalerOsdWriteAllByte(BYTE ucIndicateAndDbuf, WORD usAddr, BYTE ucByte0, BYTE ucByte1, BYTE ucByte2)
  57          {
  58   1          ScalerOsdWriteByte((ucIndicateAndDbuf | _OSD_BYTEALL), _OSD_WITHOUT_DB, usAddr, ucByte0);
  59   1          ScalerSetByte(P0_92_OSD_DATA_PORT, ucByte1);
  60   1          ScalerSetByte(P0_92_OSD_DATA_PORT, ucByte2);
  61   1      }


