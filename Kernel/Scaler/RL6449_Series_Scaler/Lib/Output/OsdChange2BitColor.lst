  48          // Description  : SRAM address value and which byte
  49          // Input Value  : ucRow. ucCol. ucLength. ucHeight.       -> Just that !!
  50          //                ucColor0. ucColor1. ucColor2. ucColor3  -> Color number
C51 COMPILER V8.12   OSDCHANGE2BITCOLOR                                                    03/11/2025 19:55:54 PAGE 2   

  51          // Output Value :
  52          //--------------------------------------------------
  53          void ScalerOsdChange2BitColor(BYTE ucRow, BYTE ucCol, BYTE ucLength, BYTE ucHeight, BYTE ucColor0, BYTE uc
             -Color1, BYTE ucColor2, BYTE ucColor3)
  54          {
  55   1          BYTE ucTemp = 0;
  56   1          BYTE ucByte0 = _BIT7;
  57   1          BYTE ucByte2 = 0;
  58   1      
  59   1          if((ucColor0 > 7) && (ucColor3 > 7))
  60   1          {
  61   2              ucByte0 |= _BIT5;
  62   2              ucColor0 -= 8;
  63   2              ucColor3 -= 8;
  64   2          }
  65   1      
  66   1          if((ucColor1 > 7) && (ucColor2 > 7))
  67   1          {
  68   2              ucByte0 |= _BIT4;
  69   2              ucColor1 -= 8;
  70   2              ucColor2 -= 8;
  71   2          }
  72   1      
  73   1          ucByte0 = ucByte0 | ((ucColor3 & 0x07) << 1) | ((ucColor0 & _BIT2) >> 2);
  74   1          ucByte2 = ((ucColor0 & 0x03) << 6) | ((ucColor2 & 0x07) << 3) | (ucColor1 & 0x07);
  75   1      
  76   1          for(ucTemp = 0; ucTemp < ucHeight; ucTemp++)
  77   1          {
  78   2              ScalerOsdSramDataValue2Byte(ucRow + ucTemp, ucCol, ucLength, ucByte0, ucByte2, _OSD_BYTE0_BYTE2);
  79   2          }
  80   1      }
