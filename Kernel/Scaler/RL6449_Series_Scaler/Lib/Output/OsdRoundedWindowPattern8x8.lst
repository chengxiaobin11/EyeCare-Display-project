  41          
  42          //****************************************************************************
  43          // FUNCTION DEFINITIONS
  44          //****************************************************************************
  45          //--------------------------------------------------
  46          // Description  : Set Window Rounded Pattern 8x8
  47          // Input Value  : ucIdx -> Pattern Index 0~7
  48          // Input Value  : ucType -> Pattern Type
  49          // Output Value :
  50          //--------------------------------------------------
  51          void ScalerOsdRoundedWindowPattern8x8(BYTE ucIdx, BYTE ucType)
C51 COMPILER V8.12   OSDROUNDEDWINDOWPATTERN8X8                                            03/11/2025 19:55:59 PAGE 2   

  52          {
  53   1          WORD usAddr = P3A_60_FRAME_CTRL_60;
  54   1      
  55   1          usAddr += (ucIdx / 2);
  56   1      
  57   1          if((ucIdx % 2) == 0)
  58   1          {
  59   2              ScalerSetBit(usAddr, ~(_BIT2 | _BIT1 | _BIT0), (ucType & 0x07));
  60   2          }
  61   1          else
  62   1          {
  63   2              ScalerSetBit(usAddr, ~(_BIT6 | _BIT5 | _BIT4), ((ucType & 0x07) << 4));
  64   2          }
  65   1      }


