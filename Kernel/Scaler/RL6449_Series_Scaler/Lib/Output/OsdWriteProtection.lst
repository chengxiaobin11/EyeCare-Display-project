  41          void ScalerOsdWriteProtection(bit bEnable, EnumOsdWriteType enumOsdWriteType, BYTE ucBitSelect);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Set write protection for SRAM when OSD is on
  49          // Input Value  : bEnable          -> _ENABLE or _DISABLE
  50          //                enumOsdWriteType -> _OSD_BYTE0 or _OSD_BYTE1 or _OSD_BYTE2
  51          //                ucBitSelect      -> (_BIT7 | _BIT6 | _BIT5 |_BIT4 | _BIT3 |_BIT2 | _BIT1 | _BIT0)
C51 COMPILER V8.12   OSDWRITEPROTECTION                                                    03/11/2025 19:55:50 PAGE 2   

  52          // Output Value :
  53          //--------------------------------------------------
  54          void ScalerOsdWriteProtection(bit bEnable, EnumOsdWriteType enumOsdWriteType, BYTE ucBitSelect)
  55          {
  56   1          BYTE ucTemp = 0;
  57   1      
  58   1          // Set OSD Circuit Enable for Write-Protection Function effective in OSD enable.
  59   1          if((bEnable == _ENABLE) && (ScalerGetBit(P3A_02_FRAME_CTRL_02, _BIT0) == 0x00))
  60   1          {
  61   2              if(ScalerOsdGetOsdEnable() == _TRUE)
  62   2              {
  63   3                  ScalerOsdDisableOsd();
  64   3              }
  65   2      
  66   2              ScalerOsdCircuitActivated(_ENABLE);
  67   2          }
  68   1      
  69   1          ScalerTimerWaitForEvent(_EVENT_DVS);
  70   1      
  71   1          if(enumOsdWriteType == _OSD_BYTE1)
  72   1          {
  73   2              ucTemp |= _BIT1;
  74   2          }
  75   1          else if(enumOsdWriteType == _OSD_BYTE2)
  76   1          {
  77   2              ucTemp |= _BIT2;
  78   2          }
  79   1      
  80   1          ScalerSetBit(P3A_33_FRAME_CTRL_33, ~(_BIT2 | _BIT1 | _BIT0), (ucTemp | (BYTE)bEnable));
  81   1          ScalerSetByte(P3A_34_FRAME_CTRL_34, ucBitSelect);
  82   1      }


