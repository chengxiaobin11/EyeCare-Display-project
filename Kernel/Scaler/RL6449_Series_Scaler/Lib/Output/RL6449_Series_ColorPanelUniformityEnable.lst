C51 COMPILER V8.12   RL6449_SERIES_COLORPANELUNIFORMITYENABLE                              03/11/2025 19:56:07 PAGE 2   

  52          void ScalerColorPanelUniformityEnable(EnumFunctionOnOFF enumOn)
  53          {
  54   1          if(enumOn == _FUNCTION_ON)
  55   1          {
  56   2              ScalerSetBit(P1_DB_DCLK_GATED_CTRL1, ~_BIT0, _BIT0);
  57   2              ScalerSetBit(P34_00_UN_GLOBAL_CTRL, ~_BIT7, _BIT7);
  58   2          }
  59   1          else if(enumOn == _FUNCTION_OFF)
  60   1          {
  61   2              ScalerSetBit(P1_DB_DCLK_GATED_CTRL1, ~_BIT0, _BIT0);
  62   2              ScalerSetBit(P34_00_UN_GLOBAL_CTRL, ~_BIT7, 0x00);
  63   2          }
  64   1          else
  65   1          {
  66   2              ScalerSetBit(P34_00_UN_GLOBAL_CTRL, ~_BIT7, 0x00);
  67   2              ScalerTimerWaitForEvent(_EVENT_DVS);
  68   2              ScalerTimerDelayXms(2);
  69   2              ScalerSetBit(P1_DB_DCLK_GATED_CTRL1, ~_BIT0, 0x00);
  70   2          }
  71   1      }


