  46          //--------------------------------------------------
  47          // Description  : Activate OSD circuit enable disable
  48          // Input Value  : bEnable      -> _ENABLE or _DISABLE
  49          // Output Value :
  50          //--------------------------------------------------
  51          void ScalerOsdCircuitActivated(bit bEnable)
C51 COMPILER V8.12   OSDCIRCUITACTIVATED                                                   03/11/2025 19:55:51 PAGE 2   

  52          {
  53   1          bit bBackup = _DISABLE;
  54   1      
  55   1          if(ScalerGetBit(P3A_02_FRAME_CTRL_02, _BIT0) == _BIT0)
  56   1          {
  57   2              if(bEnable == _ENABLE)
  58   2              {
  59   3                  return;
  60   3              }
  61   2              bBackup = _ENABLE;
  62   2          }
  63   1      
  64   1          if(bEnable == _DISABLE)
  65   1          {
  66   2              // must be reset before disable osd circuit
  67   2              // [7:5] --> Set write byte : ALL
  68   2              // [3:2] --> Set address indicator : Window control register
  69   2              ScalerSetBit(P0_94_OSD_WRITE_OPTION, ~(_BIT7 | _BIT6 | _BIT5 | _BIT3 | _BIT2), 0x00);
  70   2          }
  71   1      
  72   1          ScalerSetBit(P3A_02_FRAME_CTRL_02, ~(_BIT0), bEnable);
  73   1      
  74   1          if((bBackup == _DISABLE) && (bEnable == _ENABLE))
  75   1          {
  76   2              ScalerTimerWaitForEvent(_EVENT_DVS);
