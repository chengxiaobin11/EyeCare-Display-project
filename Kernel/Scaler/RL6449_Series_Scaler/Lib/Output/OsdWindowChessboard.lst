  41          void ScalerOsdWindowChessboard(bit bEnable, EnumOsdWindowsType enumOsdWindowsType, BYTE ucChessBoardColor1
             -, BYTE ucChessBoardColor2);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Set window 6 Special function
  49          // Input Value  : bEnable            -> _ENABLE or _DISABLE
  50          //                enumOsdWindowsType -> _OSD_WINDOW_8   or _OSD_WINDOW_9   or _OSD_WINDOW_4_1 or _OSD_WIND
C51 COMPILER V8.12   OSDWINDOWCHESSBOARD                                                   03/11/2025 19:56:00 PAGE 2   

             -OW_4_2 or _OSD_WINDOW_4_3 or
  51          //                                      _OSD_WINDOW_4_4 or _OSD_WINDOW_4_5 or _OSD_WINDOW_4_6 or _OSD_WIND
             -OW_4_7 or _OSD_WINDOW_4_8
  52          //                ChessBoardColor1   -> Color (0 ~ 63)
  53          //                ChessBoardColor2   -> Color (0 ~ 63)
  54          // Output Value :
  55          //--------------------------------------------------
  56          void ScalerOsdWindowChessboard(bit bEnable, EnumOsdWindowsType enumOsdWindowsType, BYTE ucChessBoardColor1
             -, BYTE ucChessBoardColor2)
  57          {
  58   1          WORD usTemp = 0;
  59   1      
  60   1          if((enumOsdWindowsType >= _OSD_WINDOW_4_1) && (enumOsdWindowsType <= _OSD_WINDOW_4_8))
  61   1          {
  62   2              // _OSD_WINDOW_4_1 ~ _OSD_WINDOW_4_8
  63   2              usTemp = 0x164 + (enumOsdWindowsType - _OSD_WINDOW_4_1) * 2;
  64   2          }
  65   1      #if(_OSD_WINDOW_CHESSBORAD_WIN8_WIND9_SUPPORT == _ON)
  66   1          else if((enumOsdWindowsType == _OSD_WINDOW_8) || (enumOsdWindowsType == _OSD_WINDOW_9))
  67   1          {
  68   2              usTemp = 0x161 + (enumOsdWindowsType - _OSD_WINDOW_8) * 2;
  69   2          }
  70   1      #endif
  71   1      #if(_OSD_WINDOW_5_1_5_8_SUPPORT == _ON)
  72   1          else if((enumOsdWindowsType >= _OSD_WINDOW_5_1) && (enumOsdWindowsType <= _OSD_WINDOW_5_8))
  73   1          {
  74   2              // _OSD_WINDOW_5_1 ~ _OSD_WINDOW_5_8
  75   2              usTemp = 0x2A0 + (enumOsdWindowsType - _OSD_WINDOW_5_1) * 10;
  76   2          }
  77   1      #endif
  78   1      
  79   1          ScalerOsdWriteAllByte((_OSD_WIN_CONTROL), usTemp, (BYTE)bEnable << 7, (ucChessBoardColor1 & 0x3F), (uc
             -ChessBoardColor2 & 0x3F));
  80   1      }
  81          
