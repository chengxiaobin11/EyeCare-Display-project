  47          //--------------------------------------------------
  48          // Description  : Set window Priority
  49          // Input Value  : enumOsdWindowsType        -> _OSD_WINDOW_2 or _OSD_WINDOW_3 or _OSD_WINDOW_4 or _OSD_WIN
             -DOW_8 or _OSD_WINDOW_9
C51 COMPILER V8.12   OSDWINDOWPRIORITY                                                     03/11/2025 19:56:01 PAGE 2   

  50          //                enumOsdWindowPriorityType -> _OSD_WINDOW_PRIORITY_LOWER_THAN_FONT or _OSD_WINDOW_PRIORIT
             -Y_HIGHTER_THAN_FONT
  51          // Output Value :
  52          //--------------------------------------------------
  53          void ScalerOsdWindowPriority(EnumOsdWindowsType enumOsdWindowsType, EnumOsdWindowPriorityType enumOsdWindo
             -wPriorityType)
  54          {
  55   1          if(enumOsdWindowsType == _OSD_WINDOW_2)
  56   1          {
  57   2              ScalerSetBit(P3A_08_FRAME_CTRL_08, ~_BIT7, (enumOsdWindowPriorityType << 7));
  58   2          }
  59   1          else if(enumOsdWindowsType == _OSD_WINDOW_3)
  60   1          {
  61   2              ScalerSetBit(P3A_07_FRAME_CTRL_07, ~_BIT0, enumOsdWindowPriorityType);
  62   2          }
  63   1          else if(enumOsdWindowsType == _OSD_WINDOW_4)
  64   1          {
  65   2              ScalerSetBit(P3A_07_FRAME_CTRL_07, ~_BIT1, (enumOsdWindowPriorityType << 1));
  66   2          }
  67   1          else if(enumOsdWindowsType == _OSD_WINDOW_8)
  68   1          {
  69   2              ScalerSetBit(P3A_08_FRAME_CTRL_08, ~_BIT5, (enumOsdWindowPriorityType << 5));
  70   2          }
  71   1          else if(enumOsdWindowsType == _OSD_WINDOW_9)
  72   1          {
  73   2              ScalerSetBit(P3A_08_FRAME_CTRL_08, ~_BIT6, (enumOsdWindowPriorityType << 6));
  74   2          }
  75   1      }
  76          
