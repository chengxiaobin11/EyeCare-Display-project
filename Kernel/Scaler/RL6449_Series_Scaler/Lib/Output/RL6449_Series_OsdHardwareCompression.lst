  41          void ScalerOsdHardwareCompression(BYTE *pucArray, WORD usVLCTableSize, BYTE ucBankNum, WORD usOffset, WORD
             - usFontTableStart, EnumOsdRotateType enumOsdRotateType, bit bTableLocation);
  42          
