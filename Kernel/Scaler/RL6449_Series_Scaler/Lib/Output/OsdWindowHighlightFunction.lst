  56          void ScalerOsdWindowHighlightFunction(bit bEnable, EnumOsdWindowsType enumOsdWindowsType, BYTE ucForegroun
             -dColor, BYTE ucBackgroundColor, BYTE ucCharactorBorderColor)
  57          {
