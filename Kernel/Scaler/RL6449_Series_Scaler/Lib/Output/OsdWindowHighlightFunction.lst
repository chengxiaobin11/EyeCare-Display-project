  89   2                  ScalerSetBit(P3A_50_FRAME_CTRL_50, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), ucBackgro
             -undColor);
  90   2                  break;
  91   2      
