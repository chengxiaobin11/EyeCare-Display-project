  48          // Description  : MASK Specific Region of Font A/B
  49          // Input Value  : ucRowStart
  50          // Input Value  : ucRowEnd
C51 COMPILER V8.12   OSDFONTMASKREGIONSET                                                  03/11/2025 19:55:57 PAGE 2   

  51          // Input Value  : ucColumnStart
  52          // Input Value  : ucColumnEnd
  53          // Output Value :
  54          //--------------------------------------------------
  55          void ScalerOsdFontMaskRegionSet(EnumOsdMapType enumOsdMapType, BYTE ucRowStart, BYTE ucRowEnd, BYTE ucColu
             -mnStart, BYTE ucColumnEnd)
  56          {
  57   1          if(enumOsdMapType == _OSD_A)
  58   1          {
  59   2              // MASK Row Start/End of Font A
  60   2              ScalerSetBit(P3A_45_FRAME_CTRL_45, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (ucRo
             -wStart & 0x7F));
  61   2              ScalerSetBit(P3A_46_FRAME_CTRL_46, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (ucRo
             -wEnd & 0x7F));
  62   2      
  63   2              // MASK Column Start/End of Font A
  64   2              ScalerSetByte(P3A_49_FRAME_CTRL_49, ucColumnStart);
  65   2              ScalerSetByte(P3A_4A_FRAME_CTRL_4A, ucColumnEnd);
  66   2          }
  67   1          else
  68   1          {
  69   2              // MASK Row Start/End of Font B
  70   2              ScalerSetBit(P3A_47_FRAME_CTRL_47, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (ucRo
             -wStart & 0x7F));
  71   2              ScalerSetBit(P3A_48_FRAME_CTRL_48, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (ucRo
             -wEnd & 0x7F));
  72   2      
  73   2              // MASK Column Start/End of Font B
  74   2              ScalerSetByte(P3A_4B_FRAME_CTRL_4B, ucColumnStart);
  75   2              ScalerSetByte(P3A_4C_FRAME_CTRL_4C, ucColumnEnd);
  76   2          }
  77   1      }
