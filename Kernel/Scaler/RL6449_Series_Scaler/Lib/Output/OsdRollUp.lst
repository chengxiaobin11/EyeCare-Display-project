  41          void ScalerOsdRollUp(bit bEnable, BYTE ucRowStart, BYTE ucRowBack);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Set OSD RollUp function
  49          // Input Value  :  bEnable    -> _ENABLE or _DISABLE
  50          //                 ucRowStart -> Set RollUp start (end) row
  51          //                 ucRowBack  -> Set RollUp reposition row
C51 COMPILER V8.12   OSDROLLUP                                                             03/11/2025 19:55:53 PAGE 2   

  52          // Output Value :
  53          //--------------------------------------------------
  54          void ScalerOsdRollUp(bit bEnable, BYTE ucRowStart, BYTE ucRowBack)
  55          {
  56   1          BYTE pucTemp[2];
  57   1          WORD usCharCommandAddress = 0;
  58   1          memset(pucTemp, 0, sizeof(pucTemp));
  59   1      
  60   1          // Set OSD Special Function Enable/Disable
  61   1          ScalerSetBit(P3A_18_FRAME_CTRL_18, ~(_BIT7 | _BIT6), ((BYTE)bEnable << 7));
  62   1      
  63   1          // Get Font Select Base Address
  64   1          pucTemp[0] = ScalerGetByte(P3A_0C_FRAME_CTRL_0C);
  65   1          pucTemp[1] = ScalerGetByte(P3A_0D_FRAME_CTRL_0D);
  66   1          usCharCommandAddress = (WORD)((pucTemp[1] & 0xF0) << 4) | pucTemp[0];
  67   1          usCharCommandAddress = usCharCommandAddress + (ucRowStart * GET_OSD_MAPA_COL_MAX());
  68   1      
  69   1          // Set Row Command Base 0
  70   1          ScalerSetByte(P3A_19_FRAME_CTRL_19, ucRowStart);
  71   1          // Set Row Command Base 1
  72   1          ScalerSetByte(P3A_1A_FRAME_CTRL_1A, ucRowBack);
  73   1      
  74   1          // Set Font Select Base 0
  75   1          ScalerSetBit(P3A_1B_FRAME_CTRL_1B, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), ((usCharCommandAddress & 0xF00) >
             -> 4));
  76   1          ScalerSetByte(P3A_1C_FRAME_CTRL_1C, (usCharCommandAddress & 0x0FF));
  77   1      }


