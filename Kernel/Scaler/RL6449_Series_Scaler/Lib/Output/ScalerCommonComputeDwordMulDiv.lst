  46          //--------------------------------------------------
  47          // Description  : Division for (A * 2^pow) / ulB
  48          // Input Value  : A, ucPow, ulB
  49          // Output Value : (A * 2^pow) / B ratio in 32-bit precision
  50          //--------------------------------------------------
C51 COMPILER V8.12   SCALERCOMMONCOMPUTEDWORDMULDIV                                        03/11/2025 19:55:37 PAGE 2   

  51          DWORD ScalerComputeDwordPowDiv(DWORD ulA, BYTE ucPow, DWORD ulB)
  52          {
  53   1          DWORD ulResult = 0;
  54   1      
  55   1          do
  56   1          {
  57   2              ulResult <<= 1;
  58   2      
  59   2              if(ulA >= ulB)
  60   2              {
  61   3                  ulResult += (ulA / ulB);
  62   3                  ulA %= ulB;
  63   3              }
  64   2      
  65   2              ulA <<= 1;
  66   2          }
  67   1          while(ucPow-- != 0);
  68   1      
  69   1          return (ulA >= ulB) ? (ulResult + 1) : ulResult;
  70   1      }
  71          
  72          //--------------------------------------------------
  73          // Description  : Multiplication and Division for DWORD
  74          // Input Value  : A, B, C
  75          // Output Value : A * B / C in 32-bit precision
  76          //--------------------------------------------------
  77          DWORD ScalerComputeDwordMulDiv(DWORD ulA, DWORD ulB, DWORD ulC)
  78          {
  79   1          if(MULTIPLY_OVERFLOW32_CHECK(ulA, ulB) == _TRUE)
  80   1          {
  81   2              return ulA * ulB / ulC;
  82   2          }
  83   1          else
  84   1          {
  85   2              /// Let A = x1 * 2^16 + x2, B = x3 * 2^16 + x4
  86   2              /// --> A * B = (x1 * x3) * 2^32 + ((x1 * x4) + (x2 * x3)) * 2^16 + (x2 * x4)
  87   2              ///           = factor_32 * 2^32 + factor_00
  88   2              DWORD ulBase16_0 = (DWORD)HIWORD(ulA) * LOWORD(ulB);
  89   2              DWORD ulBase16_1 = (DWORD)LOWORD(ulA) * HIWORD(ulB);
  90   2      
  91   2              DWORD ulBase00 = (DWORD)LOWORD(ulA) * LOWORD(ulB);
  92   2              DWORD ulBase32 = (DWORD)HIWORD(ulA) * HIWORD(ulB);
  93   2      
  94   2              DWORD ulBuffer = ((DWORD)LOWORD(ulBase16_0) + LOWORD(ulBase16_1) + HIWORD(ulBase00));
  95   2      
  96   2              ulBase00 = ((((DWORD)LOWORD(ulBuffer)) << 16) | LOWORD(ulBase00));
  97   2              ulBase32 += ((DWORD)HIWORD(ulBase16_0) + HIWORD(ulBase16_1) + HIWORD(ulBuffer));
  98   2      
  99   2              return ScalerComputeDwordPowDiv(ulBase32, 32, ulC) +
 100   2                     ScalerComputeDwordPowDiv(ulBase00, 0, ulC);
 101   2          }
 102   1      
