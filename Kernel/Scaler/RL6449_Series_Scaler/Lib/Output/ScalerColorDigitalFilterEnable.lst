C51 COMPILER V8.12   SCALERCOLORDIGITALFILTERENABLE                                        03/11/2025 19:55:42 PAGE 2   

  52          void ScalerColorDigitalFilterEnable(EnumFunctionOnOFF enumOn)
  53          {
  54   1          BYTE ucCtrlReg = 0;
  55   1      
  56   1          if(enumOn == _FUNCTION_ON)
  57   1          {
  58   2              ScalerSetBit(P0_98_DIGITAL_FILTER_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT0), (_BIT6 | _BIT5 |
             - _BIT4));
  59   2              ucCtrlReg = ScalerGetByte(P0_99_DIGITAL_FILTER_PORT);
  60   2      
  61   2              // write extension data separately to avoid autoinc
  62   2              ScalerSetBit(P0_98_DIGITAL_FILTER_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT0), (_BIT6 | _BIT5 |
             - _BIT4));
  63   2              ScalerSetByte(P0_99_DIGITAL_FILTER_PORT, (ucCtrlReg | (_BIT7 | _BIT6 | _BIT5)));
  64   2          }
  65   1          else
  66   1          {
  67   2              ScalerSetBit(P0_98_DIGITAL_FILTER_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT0), (_BIT6 | _BIT5 |
             - _BIT4));
  68   2              ucCtrlReg = ScalerGetByte(P0_99_DIGITAL_FILTER_PORT);
  69   2      
  70   2              // write extension data separately to avoid autoinc
  71   2              ScalerSetBit(P0_98_DIGITAL_FILTER_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT0), (_BIT6 | _BIT5 |
             - _BIT4));
  72   2              ScalerSetByte(P0_99_DIGITAL_FILTER_PORT, (ucCtrlReg & (~(_BIT7 | _BIT6 | _BIT5))));
  73   2          }
  74   1      }


