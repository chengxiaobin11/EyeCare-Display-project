  41          void ScalerOsdSetColorPalette(BYTE ucIndex, BYTE ucColorR, BYTE ucColorG, BYTE ucColorB);
  42          
  43          
  44          //****************************************************************************
  45          // FUNCTION DEFINITIONS
  46          //****************************************************************************
  47          //--------------------------------------------------
  48          // Description  : Set OSD Color Palette
  49          // Input Value  : ucIndex  -> Which palette
  50          //                ucColorR -> Palette red data   (0 ~ 255)
  51          //                ucColorG -> Palette green data (0 ~ 255)
C51 COMPILER V8.12   OSDSETCOLORPALETTE                                                    03/11/2025 19:55:53 PAGE 2   

  52          //                ucColorB -> Palette blue data  (0 ~ 255)
  53          // Output Value :
  54          //--------------------------------------------------
  55          void ScalerOsdSetColorPalette(BYTE ucIndex, BYTE ucColorR, BYTE ucColorG, BYTE ucColorB)
  56          {
  57   1          ScalerSetByte(P0_6E_OVERLAY_LUT_ADDR, (_BIT7 | ucIndex));
  58   1          ScalerSetByte(P0_6F_COLOR_LUT_PORT, ucColorR);
  59   1          ScalerSetByte(P0_6F_COLOR_LUT_PORT, ucColorG);
  60   1          ScalerSetByte(P0_6F_COLOR_LUT_PORT, ucColorB);
  61   1          ScalerSetByte(P0_6E_OVERLAY_LUT_ADDR, 0x00);
  62   1      }


